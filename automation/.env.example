# Crama 자동화 환경변수 — 복사해서 .env 로 사용하세요
# ⚠️ 이 파일(.env.example)에는 실제 키를 넣지 마세요! 실제 키는 .env 에만.

# 필수: Claude API (글 생성/리서치)
ANTHROPIC_API_KEY=sk-ant-...

# 모델 선택 (선택) — 비용 절감: 본문은 sonnet, 리서치는 opus 권장
WRITE_MODEL=claude-sonnet-4-6
RESEARCH_MODEL=claude-opus-4-8

# 이미지 생성: provider = openai | stability | placeholder
# placeholder 는 키 없이 SVG 더미를 만들어 파이프라인 테스트용
IMAGE_PROVIDER=openai
OPENAI_API_KEY=sk-...
STABILITY_API_KEY=sk-...

# (선택) Cloudflare R2 — 설정 시 이미지를 R2에 업로드하고 URL을 사용
# 비우면 site/public/img/generated 에 로컬 저장(깃 커밋)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=crama-images
R2_PUBLIC_BASE=https://img.crama.app

# (선택) 오디오 TTS — Azure Neural TTS (무료 F0: 매달 50만 자) → R2 호스팅(무료 송신)
#   생성: node gen-audio.js <slug>   (자세한 셋업은 automation/AUDIO_SETUP.md)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=koreacentral
AZURE_TTS_VOICE=ko-KR-SunHiNeural
# 오디오 전용 R2 버킷/공개 URL (이미지와 분리 권장). 비우면 위 R2_BUCKET/R2_PUBLIC_BASE 사용.
R2_AUDIO_BUCKET=crama-audio
R2_AUDIO_PUBLIC_BASE=https://audio.crama.app
