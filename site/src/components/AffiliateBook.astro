---
// 제휴 도서 추천 카드(쿠팡 파트너스) — rel=sponsored + 필수 고지문. 세련된 앱 카드 UI.
interface Props {
  href: string;   // 쿠팡 파트너스 링크
  img: string;    // 표지/배너 이미지 URL
  title: string;  // 책 제목
  blurb?: string; // 한 줄 추천 이유
}
const { href, img, title, blurb } = Astro.props;
---
<aside class="bookpick">
  <div class="bookpick__main">
    <a class="bookpick__cover" href={href} target="_blank" rel="sponsored nofollow" referrerpolicy="unsafe-url" aria-label={title} tabindex="-1">
      <img src={img} alt={title} width="120" height="240" loading="lazy" />
    </a>
    <div class="bookpick__body">
      <span class="bookpick__tag">추천 도서</span>
      <strong class="bookpick__title">{title}</strong>
      {blurb && <p class="bookpick__blurb">{blurb}</p>}
      <a class="bookpick__btn" href={href} target="_blank" rel="sponsored nofollow" referrerpolicy="unsafe-url">
        <svg class="ic" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 5.5A1.5 1.5 0 0 1 5.5 4H19a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H6a2 2 0 0 0-2 2z"/><path d="M8 4v13"/></svg>
        <span>쿠팡에서 보기</span>
        <svg class="arr" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
  <p class="bookpick__disc">제휴 · 이 포스팅은 쿠팡 파트너스 활동의 일환으로, 이에 따른 일정액의 수수료를 제공받습니다.</p>
</aside>

<style>
  .bookpick {
    max-width: var(--measure); margin: 2.4rem auto; overflow: hidden;
    border: 1px solid var(--line); border-radius: 18px; background: var(--paper);
    box-shadow: 0 14px 36px -22px rgba(0,0,0,0.32);
    transition: box-shadow .2s ease, transform .2s ease;
  }
  .bookpick:hover { box-shadow: 0 18px 44px -22px rgba(0,0,0,0.4); }
  .bookpick__main { display: flex; gap: 1.25rem; align-items: center; padding: 1.4rem 1.5rem; }
  .bookpick__cover {
    flex: none; width: 92px; aspect-ratio: 1 / 1.5; border-radius: 12px; overflow: hidden;
    box-shadow: 0 14px 28px -12px rgba(0,0,0,0.45); transition: transform .2s ease; display: block;
  }
  .bookpick:hover .bookpick__cover { transform: translateY(-3px) rotate(-1deg); }
  .bookpick__cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .bookpick__body { min-width: 0; display: flex; flex-direction: column; }
  .bookpick__tag {
    align-self: flex-start; font-size: 0.66rem; font-weight: 800; letter-spacing: 0.06em;
    color: var(--accent); background: color-mix(in srgb, var(--accent) 13%, transparent);
    padding: 0.2rem 0.6rem; border-radius: 999px; text-transform: uppercase;
  }
  .bookpick__title { font-family: var(--font-serif); font-size: 1.16rem; line-height: 1.32; color: var(--ink); margin: 0.45rem 0 0.3rem; }
  .bookpick__blurb {
    font-size: 0.9rem; color: var(--ink-soft); line-height: 1.55; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .bookpick__btn {
    align-self: flex-start; display: inline-flex; align-items: center; gap: 0.45rem; margin-top: 0.75rem;
    background: var(--ink); color: var(--paper) !important; padding: 0.55rem 1.05rem; border-radius: 12px;
    font-size: 0.86rem; font-weight: 700; text-decoration: none;
    transition: background .15s ease, transform .12s ease, box-shadow .15s ease;
  }
  .bookpick__btn:hover { background: var(--accent); transform: translateY(-1px); box-shadow: 0 8px 18px -8px color-mix(in srgb, var(--accent) 70%, transparent); }
  .bookpick__btn .ic, .bookpick__btn .arr { display: block; }
  .bookpick__btn .arr { transition: transform .15s ease; }
  .bookpick__btn:hover .arr { transform: translateX(3px); }
  .bookpick__disc {
    font-size: 0.72rem; color: var(--muted); line-height: 1.5; margin: 0;
    padding: 0.7rem 1.5rem; border-top: 1px solid var(--line);
    background: color-mix(in srgb, var(--ink) 3%, var(--paper));
  }
  @media (max-width: 640px) {
    .bookpick { margin: 2rem auto; border-radius: 16px; }
    .bookpick__main { padding: 1.1rem; gap: 1rem; }
    .bookpick__cover { width: 76px; }
    .bookpick__title { font-size: 1.06rem; }
    .bookpick__disc { padding: 0.65rem 1.1rem; }
  }
</style>
