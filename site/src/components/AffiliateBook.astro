---
// 제휴 도서 추천 박스(쿠팡 파트너스) — rel=sponsored + 필수 고지문 포함. 글 하단/문맥에 삽입.
interface Props {
  href: string;       // 쿠팡 파트너스 링크
  img: string;        // 표지/배너 이미지 URL
  title: string;      // 책 제목
  blurb?: string;     // 한 줄 추천 이유
}
const { href, img, title, blurb } = Astro.props;
---
<aside class="bookpick">
  <a class="bookpick__cover" href={href} target="_blank" rel="sponsored nofollow" referrerpolicy="unsafe-url" aria-label={title}>
    <img src={img} alt={title} width="120" height="240" loading="lazy" />
  </a>
  <div class="bookpick__body">
    <span class="bookpick__label">📚 함께 읽으면 좋은 책</span>
    <strong class="bookpick__title">{title}</strong>
    {blurb && <p class="bookpick__blurb">{blurb}</p>}
    <a class="bookpick__btn" href={href} target="_blank" rel="sponsored nofollow" referrerpolicy="unsafe-url">쿠팡에서 보기 →</a>
    <p class="bookpick__disc">이 포스팅은 쿠팡 파트너스 활동의 일환으로, 이에 따른 일정액의 수수료를 제공받습니다.</p>
  </div>
</aside>

<style>
  .bookpick {
    display: flex; gap: 1.1rem; align-items: flex-start;
    margin: 2rem auto; padding: 1.1rem 1.2rem; max-width: var(--measure);
    border: 1px solid var(--line); border-left: 3px solid var(--accent);
    border-radius: var(--radius); background: var(--paper-2, var(--paper));
  }
  .bookpick__cover { flex: none; width: 96px; border-radius: 8px; overflow: hidden; box-shadow: 0 6px 18px -8px rgba(0,0,0,0.35); }
  .bookpick__cover img { width: 100%; height: auto; display: block; }
  .bookpick__body { min-width: 0; display: flex; flex-direction: column; }
  .bookpick__label { font-size: 0.74rem; font-weight: 800; color: var(--accent); letter-spacing: 0.02em; }
  .bookpick__title { font-family: var(--font-serif); font-size: 1.1rem; line-height: 1.3; margin: 0.2rem 0 0.3rem; color: var(--ink); }
  .bookpick__blurb { font-size: 0.92rem; color: var(--ink-soft); line-height: 1.55; margin: 0 0 0.6rem; }
  .bookpick__btn {
    align-self: flex-start; display: inline-block; background: var(--accent); color: #fff !important;
    padding: 0.5rem 1rem; border-radius: 999px; font-size: 0.88rem; font-weight: 700; text-decoration: none;
  }
  .bookpick__btn:hover { filter: brightness(0.94); }
  .bookpick__disc { font-size: 0.74rem; color: var(--muted); line-height: 1.5; margin: 0.7rem 0 0; }
  @media (max-width: 640px) {
    .bookpick { gap: 0.9rem; padding: 1rem; }
    .bookpick__cover { width: 80px; }
    .bookpick__title { font-size: 1.02rem; }
  }
</style>
