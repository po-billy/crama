---
// 제휴 마케팅 박스 — rel="sponsored" + 광고 고지(필수)
interface Props { href: string; label?: string; cta?: string; }
const { href, label = '추천', cta = '자세히 보기' } = Astro.props;
---
<aside class="affiliate">
  <div class="affiliate__label">{label}</div>
  <slot />
  <a class="affiliate__cta" href={href} rel="sponsored nofollow noopener" target="_blank">{cta} →</a>
  <p class="affiliate__disclosure">이 글에는 제휴 링크가 포함될 수 있으며, 구매 시 일정 수수료를 받을 수 있습니다.</p>
</aside>
