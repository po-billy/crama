---
// 오디오 플레이리스트 — 테마별 카드(가로 스크롤). 누르면 해당 글로 이동해 자동 재생.
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../consts';

// 테마별 큐레이션(시간대/무드 + 글 묶음). audio 있는 글만 노출.
const PLAYLISTS = [
  { vibe: '출근길', title: '월급쟁이를 위한 돈 칼럼', slugs: ['time-over-money', 'scarcity-mindset', 'lifestyle-inflation-trap'] },
  { vibe: '지금 꼭', title: '내가 받을 수 있는 정부 지원', slugs: ['livelihood-coupon-2026', 'youth-future-savings-2026', 'median-income-2026'] },
  { vibe: '일하며', title: '지금 알아야 할 AI 트렌드', slugs: ['latest-ai-models-2026', 'ai-trends-2026', 'chatgpt-free-vs-paid'] },
  { vibe: '마음 챙김', title: '조급할 때 듣는 돈 이야기', slugs: ['latte-factor-myth', 'chasing-returns-fomo', 'compound-interest-power'] },
  { vibe: '퇴근길', title: '월급 밖에서 버는 법', slugs: ['side-hustle-for-office-workers', 'ai-side-hustle-guide', 'seed-money-guide'] },
];

const all = await getCollection('blog');
const byId = new Map(all.map((p) => [p.id, p]));
// 48px 썸네일엔 풀사이즈 hero 대신 160px 썸네일 사용(용량 절감)
const thumb = (h) => (h && /-hero\.webp$/.test(h) ? h.replace(/-hero\.webp$/, '-hero-thumb.webp') : h);
const estMin = (p) => Math.max(1, Math.round((p.body || '').length / 600));
const lists = PLAYLISTS.map((pl) => ({
  ...pl,
  items: pl.slugs.map((s) => byId.get(s)).filter((p) => p && p.data.audio && !p.data.draft).slice(0, 3),
})).filter((pl) => pl.items.length > 0);
---
{lists.length > 0 && (
  <section class="apl" aria-label="오디오로 듣는 콘텐츠">
    <div class="apl__head">
      <h2 class="apl__title"><span aria-hidden="true">🎧</span> 오디오로 듣는 콘텐츠</h2>
      <p class="apl__sub">이동하며 · 일하며 · 스마트폰 보며. 누르면 바로 재생돼요.</p>
    </div>
    <div class="apl__scroll">
      {lists.map((pl) => (
        <div class="apl__card">
          <div class="apl__card-head">
            <span class="apl__vibe">{pl.vibe}</span>
            <strong class="apl__card-title">{pl.title}</strong>
          </div>
          <ul class="apl__items">
            {pl.items.map((p) => (
              <li>
                <a class="apl__item" href={`/blog/${p.id}/`} data-audio-play data-src={p.data.audio} data-title={p.data.title}>
                  <span class="apl__thumb">
                    {p.data.heroImage && <img src={thumb(p.data.heroImage)} alt={p.data.title} loading="lazy" width="48" height="48" />}
                  </span>
                  <span class="apl__body">
                    <span class="apl__tag">오디오 · {CATEGORIES[p.data.category]?.name ?? ''}</span>
                    <strong class="apl__name">{p.data.title}</strong>
                    <span class="apl__meta">{p.data.author} · 약 {estMin(p)}분</span>
                  </span>
                  <span class="apl__play" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M7 4.5v15l12-7.5z" /></svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
)}

<script is:inline>
  if (!window.__apickBound) {
    window.__apickBound = true;
    // 캡처 단계로 등록 → ClientRouter(버블)보다 먼저 가로채 우리가 제어
    document.addEventListener('click', (e) => {
      const a = e.target && e.target.closest ? e.target.closest('[data-audio-play]') : null;
      if (!a) return;
      const src = a.getAttribute('data-src');
      const href = a.getAttribute('href') || '';
      if (src && window.__cramaCtl) {
        // 모바일 핵심: 탭 제스처 안에서 play() 호출 → '실제 재생 시작'을 확인한 뒤 소프트 내비로 이동
        // (즉시 이동하면 모바일에서 재생 시작 전에 페이지가 넘어가 무음이 됨)
        e.preventDefault();
        e.stopPropagation();
        const C = window.__cramaCtl();
        try {
          if (C.audio.src !== src) { C.audio.src = src; try { C.audio.currentTime = 0; } catch (e2) {} }
          const m = href.match(/\/blog\/([^/]+)/); C.slug = m ? m[1] : null;
        } catch (err) {}
        let navd = false;
        const go = () => {
          if (navd) return; navd = true;
          C.audio.removeEventListener('playing', go);
          // ClientRouter 가 가로채도록 합성 링크 클릭(소프트 내비)
          try { const lnk = document.createElement('a'); lnk.href = href; lnk.style.display = 'none'; document.body.appendChild(lnk); lnk.click(); setTimeout(() => lnk.remove(), 0); }
          catch (e3) { location.href = href; }
        };
        C.audio.addEventListener('playing', go);
        const p = C.audio.play();
        if (p && p.catch) p.catch(() => { go(); }); // 재생 실패 시에도 이동(폴백)
        setTimeout(go, 700); // 안전망: 0.7초 내 이동
      }
    }, true);
  }
  // 자동 스크롤(한 칸씩, 끝에서 루프). 손대면 잠시 멈췄다 재개. SPA 전환마다 재바인딩(이전 타이머 정리).
  function __aplAuto() {
    if (window.__aplStop) { window.__aplStop(); window.__aplStop = null; }
    const el = document.querySelector('.apl__scroll');
    if (!el) return;
    const gap = () => { const g = parseFloat(getComputedStyle(el).columnGap || getComputedStyle(el).gap || '14'); return isNaN(g) ? 14 : g; };
    const step = () => { const c = el.firstElementChild; return c ? c.getBoundingClientRect().width + gap() : el.clientWidth; };
    let t, idle;
    const tick = () => {
      if (el.scrollWidth <= el.clientWidth + 8) return;
      if (el.scrollLeft + el.clientWidth >= el.scrollWidth - 8) el.scrollTo({ left: 0, behavior: 'smooth' });
      else el.scrollBy({ left: step(), behavior: 'smooth' });
    };
    const start = () => { clearInterval(t); t = setInterval(tick, 4000); };
    const stop = () => { clearInterval(t); clearTimeout(idle); };
    const pause = () => { clearInterval(t); clearTimeout(idle); idle = setTimeout(start, 4500); };
    el.addEventListener('mouseenter', stop);
    el.addEventListener('mouseleave', start);
    ['pointerdown', 'touchstart', 'wheel'].forEach((e) => el.addEventListener(e, pause, { passive: true }));
    window.__aplStop = stop;
    start();
  }
  if (!window.__aplBound) { window.__aplBound = true; document.addEventListener('astro:page-load', __aplAuto); }
  if (document.readyState !== 'loading') __aplAuto(); else document.addEventListener('DOMContentLoaded', __aplAuto, { once: true });
</script>

<style>
  .apl { margin: 2.2rem 0; }
  .apl__head { padding: 0 0.2rem; }
  .apl__title { font-family: var(--font-serif); font-size: 1.4rem; margin: 0; display: flex; align-items: center; gap: 0.4rem; }
  .apl__sub { color: var(--muted); font-size: 0.9rem; margin: 0.25rem 0 0; }

  .apl__scroll {
    display: flex; gap: 0.9rem; margin-top: 1rem; padding: 0.2rem 0.2rem 0.8rem;
    overflow-x: auto; scroll-snap-type: x proximity; -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }
  .apl__card {
    flex: 0 0 min(320px, 84vw); scroll-snap-align: start;
    border-radius: 16px; padding: 1rem 0.9rem 0.7rem;
    background: var(--paper);
  }
  /* 파스텔 톤 로테이션 */
  .apl__card:nth-child(5n+1) { background: color-mix(in srgb, #8b7ff0 12%, var(--paper)); }
  .apl__card:nth-child(5n+2) { background: color-mix(in srgb, #f0a27f 13%, var(--paper)); }
  .apl__card:nth-child(5n+3) { background: color-mix(in srgb, #6fc3a3 13%, var(--paper)); }
  .apl__card:nth-child(5n+4) { background: color-mix(in srgb, #6fa8f0 12%, var(--paper)); }
  .apl__card:nth-child(5n+5) { background: color-mix(in srgb, #e6c45f 16%, var(--paper)); }

  .apl__card-head { margin: 0 0.15rem 0.7rem; }
  .apl__vibe { font-size: 0.72rem; font-weight: 700; color: var(--accent); }
  .apl__card-title { display: block; font-size: 1.05rem; font-weight: 700; line-height: 1.25; margin-top: 0.1rem; color: var(--ink); }

  .apl__items { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.4rem; }
  .apl__item {
    display: flex; align-items: center; gap: 0.65rem; padding: 0.5rem; border-radius: 12px;
    text-decoration: none; color: var(--ink); background: color-mix(in srgb, var(--paper) 72%, transparent);
    transition: background .15s ease, transform .12s ease;
  }
  .apl__item:hover { background: var(--paper); transform: translateY(-1px); }
  .apl__thumb {
    flex: none; width: 3rem; height: 3rem; border-radius: 9px; overflow: hidden;
    background: var(--paper-2, var(--line)); display: block;
  }
  .apl__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .apl__body { display: flex; flex-direction: column; min-width: 0; flex: 1; }
  .apl__tag { font-size: 0.66rem; font-weight: 700; color: var(--accent); letter-spacing: 0.01em; }
  .apl__name {
    font-size: 0.86rem; font-weight: 700; line-height: 1.3; color: var(--ink); margin: 0.05rem 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .apl__meta { font-size: 0.72rem; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .apl__play {
    flex: none; width: 2.1rem; height: 2.1rem; border-radius: 999px;
    background: var(--accent); color: #fff; display: grid; place-items: center;
    box-shadow: 0 3px 9px -4px var(--accent);
  }
  .apl__play svg { margin-left: 1px; }

  @media (max-width: 640px) {
    .apl__title { font-size: 1.25rem; }
  }
</style>
