---
import { SITE } from '../consts';
import '../styles/global.css';
import '../styles/components.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  image = '/og-home.png',
  type = 'website',
  publishedTime,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
const ogImage = new URL(image, Astro.site ?? SITE.url).href;
const fullTitle = title === SITE.title ? title : `${title} · ${SITE.name}`;

// 사이트 레벨 구조화 데이터(브랜드 인식 + 사이트링크 검색창)
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE.url}/#organization`,
      name: SITE.name,
      alternateName: ['크라마', 'CRAMA'],
      slogan: 'Curate · Read · Ahead — 돈과 AI를 먼저 읽다',
      url: SITE.url,
      logo: new URL('/icon-512.png', SITE.url).href,
      description: SITE.description,
      // 브랜드 엔티티 강화(동음이의 분리 + 지식패널 신호). 소셜 핸들 확정 시 인스타·스레드·유튜브 추가.
      sameAs: [
        'https://open.spotify.com/show/033DHRPU1sMJr3RdugoqTG',
        'https://podcasts.apple.com/podcast/id6783594375',
        'https://jocohunt.com/p/tu87yztf',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}/#website`,
      name: SITE.name,
      url: SITE.url,
      inLanguage: 'ko-KR',
      publisher: { '@id': `${SITE.url}/#organization` },
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: `${SITE.url}/search?q={search_term_string}` },
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- 폰트: 동적 서브셋(Pretendard) + Google Fonts를 비차단(render-blocking 방지)으로 로드.
     media="print" → onload 시 all 로 전환하는 표준 비동기 로드 패턴. JS 없으면 noscript로 보강. -->
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-dynamic-subset.min.css"
  media="print"
  onload="this.media='all'"
/>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Noto+Serif+KR:wght@500;600;700&display=swap"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard-dynamic-subset.min.css" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Noto+Serif+KR:wght@500;600;700&display=swap" />
</noscript>
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon-48.png" sizes="48x48" type="image/png" />
<link rel="icon" href="/favicon-96.png" sizes="96x96" type="image/png" />
<link rel="icon" href="/icon-192.png" sizes="192x192" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#6c5ce7" />
<!-- PWA: iOS '홈 화면에 추가' 시 독립 앱처럼 실행 -->
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="Crama" />
<script is:inline>
  if ('serviceWorker' in navigator && location.hostname !== 'localhost') {
    window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));
  }
  // 친구 초대 링크(?ref=CODE) 저장 — 로그인 후 /me에서 보상 청구
  try { const r = new URLSearchParams(location.search).get('ref'); if (r) localStorage.setItem('crama:ref', r); } catch (e) {}
</script>
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
<link rel="alternate" type="application/rss+xml" title="크라마 오디오 (팟캐스트)" href="/podcast.xml" />
<link rel="canonical" href={canonical} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />

<!-- 색인/리치결과: 큰 이미지 미리보기(Google Discover) + 스니펫·동영상 제한 해제 -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- 사이트 소유 확인 -->
<meta name="naver-site-verification" content="c69b0220b12e6057b3e2906976c33f3a2ea703e4" />

<!-- Google AdSense + GA4 — 모바일 TBT 절감을 위해 무거운 외부 스크립트를
     '첫 사용자 상호작용(스크롤·터치·클릭·마우스이동) 시점'에만 지연 로드.
     실제 사용자는 대부분 즉시 상호작용하므로 광고/측정은 정상 동작하고,
     초기 렌더 단계의 메인스레드 차단(TBT)만 제거된다. -->
<meta name="google-adsense-account" content="ca-pub-8780643027232358" />
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-4NSBZ832J7');
  (() => {
    let done = false;
    const EVTS = ['pointerdown', 'mousemove', 'touchstart', 'keydown', 'scroll', 'wheel'];
    function add(src, cross) {
      const s = document.createElement('script');
      s.async = true; s.src = src;
      if (cross) s.crossOrigin = 'anonymous';
      document.head.appendChild(s);
    }
    function loadThirdParty() {
      if (done) return; done = true;
      EVTS.forEach((e) => window.removeEventListener(e, loadThirdParty));
      add('https://www.googletagmanager.com/gtag/js?id=G-4NSBZ832J7');
      add('https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8780643027232358', true);
    }
    EVTS.forEach((e) => window.addEventListener(e, loadThirdParty, { passive: true, once: true }));
  })();
</script>

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1536" />
<meta property="og:image:height" content="864" />
<meta property="og:locale" content={SITE.locale} />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- 다크모드 깜빡임 방지: 렌더 전 테마 적용 -->
<script is:inline>
  (() => {
    const saved = localStorage.getItem('theme');
    const dark = saved ? saved === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
    if (dark) document.documentElement.dataset.theme = 'dark';
  })();
</script>

<script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
