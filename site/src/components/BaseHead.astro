---
import { SITE } from '../consts';
import '../styles/global.css';
import '../styles/components.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  image = '/og-default.svg',
  type = 'website',
  publishedTime,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
const ogImage = new URL(image, Astro.site ?? SITE.url).href;
const fullTitle = title === SITE.title ? title : `${title} · ${SITE.name}`;

// 사이트 레벨 구조화 데이터(브랜드 인식 + 사이트링크 검색창)
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${SITE.url}/#organization`,
      name: SITE.name,
      alternateName: ['크라마', 'CRAMA'],
      url: SITE.url,
      logo: new URL('/icon-512.png', SITE.url).href,
      description: SITE.description,
    },
    {
      '@type': 'WebSite',
      '@id': `${SITE.url}/#website`,
      name: SITE.name,
      url: SITE.url,
      inLanguage: 'ko-KR',
      publisher: { '@id': `${SITE.url}/#organization` },
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: `${SITE.url}/search?q={search_term_string}` },
        'query-input': 'required name=search_term_string',
      },
    },
  ],
};
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon-48.png" sizes="48x48" type="image/png" />
<link rel="icon" href="/favicon-96.png" sizes="96x96" type="image/png" />
<link rel="icon" href="/icon-192.png" sizes="192x192" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#b04a2f" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />
<link rel="canonical" href={canonical} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />

<!-- 색인/리치결과: 큰 이미지 미리보기(Google Discover) + 스니펫·동영상 제한 해제 -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<!-- 사이트 소유 확인 -->
<meta name="naver-site-verification" content="c69b0220b12e6057b3e2906976c33f3a2ea703e4" />

<!-- Google AdSense -->
<meta name="google-adsense-account" content="ca-pub-8780643027232358" />
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8780643027232358" crossorigin="anonymous"></script>

<!-- Google Analytics (GA4) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-4NSBZ832J7"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-4NSBZ832J7');
</script>

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={SITE.locale} />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- 다크모드 깜빡임 방지: 렌더 전 테마 적용 -->
<script is:inline>
  (() => {
    const saved = localStorage.getItem('theme');
    const dark = saved ? saved === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
    if (dark) document.documentElement.dataset.theme = 'dark';
  })();
</script>

<script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
