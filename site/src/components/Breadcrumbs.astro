---
import { SITE } from '../consts';
interface Crumb { label: string; href?: string; }
interface Props { items: Crumb[]; }
const { items } = Astro.props;

// 현재 페이지 URL — 마지막 항목(링크 없는 현재 페이지)의 item 으로 사용해
// Search Console "Missing field 'item'" 경고를 없앤다(모든 ListItem 에 item 부여).
const here = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;

// BreadcrumbList 구조화 데이터(리치 결과)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [{ label: '홈', href: '/' }, ...items].map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    item: c.href ? new URL(c.href, SITE.url).href : here,
  })),
};
---
<nav class="breadcrumbs measure" aria-label="현재 위치">
  <a href="/">홈</a>
  {items.map((c) => (
    <>
      <span class="sep" aria-hidden="true">/</span>
      {c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
    </>
  ))}
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
