---
// 쿠키 동의 배너 (하단) — 전역. 동의 여부를 localStorage에 기록.
---
<div class="cookie-consent" id="cookie-consent" hidden>
  <p class="cookie-consent__text">
    이 사이트는 분석과 광고를 위해 쿠키를 사용합니다. 계속 이용하시면 동의로 간주됩니다.
    <a href="/privacy/">자세히 보기</a>
  </p>
  <div class="cookie-consent__actions">
    <button id="cookie-accept" class="btn">동의</button>
  </div>
</div>
<script is:inline>
  (() => {
    const el = document.getElementById('cookie-consent');
    if (!el) return;
    if (localStorage.getItem('crama:cookie') === 'ok') return;
    el.hidden = false;
    document.getElementById('cookie-accept')?.addEventListener('click', () => {
      localStorage.setItem('crama:cookie', 'ok');
      el.hidden = true;
    });
  })();
</script>
