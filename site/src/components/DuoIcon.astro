---
/**
 * DuoIcon — 듀오톤 그라데이션 아이콘 세트(홈 카테고리/CTA 공용).
 * 그라데이션은 '아이콘 내부'에만 사용(레이아웃은 플랫 유지).
 *   <DuoIcon name="calc" class="hcircle__svg" />
 */
interface Props { name: string; class?: string }
const { name, class: cls = '' } = Astro.props;

// 아이콘별 2색 그라데이션 — 카테고리가 멀티컬러로 보이도록 hue를 분산
const G: Record<string, [string, string]> = {
  quiz:     ['#a855f7', '#ec4899'],
  diagnose: ['#14b8a6', '#3b82f6'],
  column:   ['#f59e0b', '#ef4444'],
  guide:    ['#22c55e', '#16a34a'],
  calc:     ['#3b82f6', '#6366f1'],
  glossary: ['#ec4899', '#f43f5e'],
  money:    ['#10b981', '#059669'],
  ai:       ['#6366f1', '#8b5cf6'],
  income:   ['#f97316', '#fb923c'],
  shorts:   ['#f43f5e', '#fb7185'],
  start:    ['#6c5ce7', '#a855f7'],
};
const [c1, c2] = G[name] ?? G.start;
const gid = `di-${name}`;
const u = `url(#${gid})`;
---
<svg class={`duoicon ${cls}`} viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true">
  <defs>
    <linearGradient id={gid} x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color={c1} />
      <stop offset="1" stop-color={c2} />
    </linearGradient>
  </defs>

  {name === 'quiz' && (<>
    <rect x="3" y="3" width="18" height="18" rx="6" fill={u} />
    <circle cx="9.2" cy="10.4" r="1.4" fill="#fff" />
    <circle cx="14.8" cy="10.4" r="1.4" fill="#fff" />
    <path d="M9 14.6c1.1 1.3 4 1.3 6 0" stroke="#fff" stroke-width="1.7" stroke-linecap="round" />
  </>)}

  {name === 'diagnose' && (<>
    <rect x="4" y="11" width="3.6" height="8" rx="1.5" fill={u} opacity=".55" />
    <rect x="10.2" y="6" width="3.6" height="13" rx="1.5" fill={u} />
    <rect x="16.4" y="9" width="3.6" height="10" rx="1.5" fill={u} opacity=".8" />
  </>)}

  {name === 'column' && (<>
    <rect x="5" y="3" width="14" height="18" rx="3.5" fill={u} />
    <path d="M8.5 8h7M8.5 11.5h7M8.5 15h4.5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" />
  </>)}

  {name === 'guide' && (<>
    <path d="M5 5.5A1.5 1.5 0 016.5 4H18a1 1 0 011 1v13a1 1 0 01-1 1H6.5A1.5 1.5 0 015 17.5V5.5Z" fill={u} />
    <path d="M9 4.2v14.6" stroke="#fff" stroke-width="1.3" opacity=".75" />
  </>)}

  {name === 'calc' && (<>
    <rect x="5" y="3" width="14" height="18" rx="3.5" fill={u} />
    <rect x="8" y="6" width="8" height="3" rx="1" fill="#fff" opacity=".9" />
    <g fill="#fff"><circle cx="9" cy="13" r="1.1" /><circle cx="12" cy="13" r="1.1" /><circle cx="15" cy="13" r="1.1" /><circle cx="9" cy="16.4" r="1.1" /><circle cx="12" cy="16.4" r="1.1" /><circle cx="15" cy="16.4" r="1.1" /></g>
  </>)}

  {name === 'glossary' && (<>
    <rect x="5" y="4" width="14" height="16" rx="3.5" fill={u} />
    <path d="M12 8l2.5 7h-1.6l-.45-1.5h-2.9L9.1 15H7.5L10 8h2Zm-.2 4.2-.8-2.5-.8 2.5h1.6Z" fill="#fff" />
  </>)}

  {name === 'money' && (<>
    <path d="M4 16l4.5-4.5 3 3L20 7" stroke={u} stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M15 7h5v5" stroke={u} stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
  </>)}

  {name === 'ai' && (<>
    <rect x="6" y="6" width="12" height="12" rx="3.2" fill={u} />
    <rect x="9.5" y="9.5" width="5" height="5" rx="1.5" fill="#fff" opacity=".92" />
    <g stroke={u} stroke-width="1.7" stroke-linecap="round"><path d="M9 3v2.6M15 3v2.6M9 18.4V21M15 18.4V21M3 9h2.6M3 15h2.6M18.4 9H21M18.4 15H21" /></g>
  </>)}

  {name === 'income' && (<>
    <rect x="3.5" y="7.5" width="17" height="11" rx="3.2" fill={u} />
    <path d="M9 7.5v-1A1.5 1.5 0 0110.5 5h3A1.5 1.5 0 0115 6.5v1" stroke={u} stroke-width="1.8" stroke-linecap="round" />
    <rect x="3.5" y="11.4" width="17" height="2.4" fill="#fff" opacity=".5" />
  </>)}

  {name === 'shorts' && (<>
    <rect x="5" y="3" width="14" height="18" rx="4.5" fill={u} />
    <path d="M10.4 8.4l5 3.6-5 3.6V8.4Z" fill="#fff" />
  </>)}

  {(name === 'start' || !G[name]) && (<>
    <circle cx="12" cy="12" r="8" fill={u} />
    <path d="M12 8.1l1.15 2.35 2.6.32-1.9 1.78.5 2.55L12 15.85l-2.35 1.25.5-2.55-1.9-1.78 2.6-.32L12 8.1Z" fill="#fff" />
  </>)}
</svg>
