---
import { SITE, NAV } from '../consts';
import DuoIcon from './DuoIcon.astro';
---
<header class="site-header">
  <div class="wrap site-header__inner">
    <button class="nav-toggle" id="nav-toggle" type="button" aria-label="메뉴" aria-expanded="false" aria-controls="nav">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
    </button>
    <a href="/" class="brand" aria-label={`${SITE.name} 홈`}>
      Cr<span>a</span>ma
      <small>{SITE.tagline}</small>
    </a>
    <div class="header-actions">
      <button class="theme-toggle" id="theme-toggle" aria-label="다크 모드 전환" title="다크 모드 전환">◐</button>
      <a href="/search/" class="search-link" aria-label="검색" title="검색">⌕</a>
      <a href="/me/" class="search-link" aria-label="내 계정" title="내 계정" style="display:inline-flex;align-items:center">
        <span id="me-ava"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.6 3.2-5.5 7-5.5s7 1.9 7 5.5"/></svg></span>
      </a>
    </div>
    <nav class="nav" id="nav" aria-label="주요 메뉴">
      {NAV.map((item) =>
        item.children ? (
          <div class="nav-group">
            <button type="button" class="nav-group__trigger" aria-expanded="false">
              {item.label}
              <svg class="nav-group__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="nav-group__dropdown">
              {item.children.map((child) => (
                <a href={child.href}>
                  {child.icon && <DuoIcon name={child.icon} class="nav-drop__icon" />}
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href}>{item.label}</a>
        )
      )}
    </nav>
  </div>
</header>
<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const el = document.documentElement;
    const dark = el.dataset.theme === 'dark';
    el.dataset.theme = dark ? '' : 'dark';
    localStorage.setItem('theme', dark ? 'light' : 'dark');
  });

  // 햄버거 메뉴 토글
  (() => {
    const t = document.getElementById('nav-toggle');
    const nav = document.getElementById('nav');
    if (!t || !nav) return;
    const focusables = nav.querySelectorAll('a, button');
    const set = (o) => {
      nav.classList.toggle('is-open', o);
      t.setAttribute('aria-expanded', String(o));
      if (o && focusables.length) focusables[0].focus();
      else if (!o) t.focus();
    };
    t.addEventListener('click', (e) => { e.stopPropagation(); set(!nav.classList.contains('is-open')); });
    nav.addEventListener('click', (e) => { if (e.target.closest('a')) set(false); });
    document.addEventListener('click', (e) => { if (!nav.contains(e.target) && !t.contains(e.target)) set(false); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.classList.contains('is-open')) { set(false); return; }
      if (!nav.classList.contains('is-open') || !focusables.length) return;
      if (e.key === 'Tab') {
        if (e.shiftKey && document.activeElement === focusables[0]) { e.preventDefault(); focusables[focusables.length - 1].focus(); }
        else if (!e.shiftKey && document.activeElement === focusables[focusables.length - 1]) { e.preventDefault(); focusables[0].focus(); }
      }
    });
  })();

  // 드롭다운 그룹 — PC: hover로 열기 / 모바일: CSS로 항상 펼침
  (() => {
    var isMobile = function () { return window.matchMedia('(max-width: 768px)').matches; };

    document.querySelectorAll('.nav-group').forEach(function (group) {
      var btn = group.querySelector('.nav-group__trigger');
      var openTimer, closeTimer;
      function open() {
        clearTimeout(closeTimer);
        document.querySelectorAll('.nav-group.is-open').forEach(function (g) { if (g !== group) { g.classList.remove('is-open'); g.querySelector('.nav-group__trigger').setAttribute('aria-expanded', 'false'); } });
        group.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
      function close() {
        clearTimeout(openTimer);
        closeTimer = setTimeout(function () {
          group.classList.remove('is-open');
          btn.setAttribute('aria-expanded', 'false');
        }, 150);
      }
      // PC: hover
      group.addEventListener('mouseenter', function () { if (!isMobile()) { clearTimeout(closeTimer); openTimer = setTimeout(open, 80); } });
      group.addEventListener('mouseleave', function () { if (!isMobile()) close(); });
      // PC: click도 지원 (접근성)
      btn.addEventListener('click', function (e) {
        if (isMobile()) return;
        e.stopPropagation();
        if (group.classList.contains('is-open')) close();
        else open();
      });
    });
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.nav-group')) {
        document.querySelectorAll('.nav-group.is-open').forEach(function (g) { g.classList.remove('is-open'); g.querySelector('.nav-group__trigger').setAttribute('aria-expanded', 'false'); });
      }
    });
  })();

  // 스크롤 내리면 브랜드 줄을 숨기고 메뉴·검색·테마 바만 남기기.
  (() => {
    const header = document.querySelector('.site-header');
    if (!header) return;
    let compact = false, ticking = false;
    const update = () => {
      ticking = false;
      const y = window.scrollY || window.pageYOffset || 0;
      if (!compact && y > 140) { compact = true; header.classList.add('is-compact'); }
      else if (compact && y < 70) { compact = false; header.classList.remove('is-compact'); }
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    }, { passive: true });
    update();
  })();
</script>

<script>
  // 로그인 시 프로필 아이콘에 내 크라미(착장)를 동그라미로 — 로그인된 경우에만 supabase 동적 로드
  (async () => {
    const el = document.getElementById('me-ava');
    if (!el) return;
    let hasSession = false;
    try { hasSession = Object.keys(localStorage).some((k) => k.includes('-auth-token')); } catch {}
    if (!hasSession) return;
    const { getUser, equippedMap } = await import('../lib/api');
    if (!(await getUser())) return;
    const eq = await equippedMap();
    const IMG = (id: string) => `/img/wardrobe/${id}.webp`;
    let html = '<img class="base base-body" src="/img/generated/meerkat-body.webp" alt="">';
    if (eq.outfit) html += `<img class="layer gear" src="${IMG(eq.outfit)}" alt="">`;
    if (eq.scarf) html += `<img class="layer gear-scarf" src="${IMG(eq.scarf)}" alt="">`;
    html += '<img class="base base-head" src="/img/generated/meerkat-head.webp" alt="">';
    if (eq.glasses) html += `<img class="layer acc-glasses" src="${IMG(eq.glasses)}" alt="">`;
    if (eq.hat) html += `<img class="layer acc-hat" src="${IMG(eq.hat)}" alt="">`;
    el.classList.add('me-ava');
    el.innerHTML = `<div class="char">${html}</div>`;
  })();
</script>
