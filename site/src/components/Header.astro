---
import { SITE, NAV } from '../consts';
---
<header class="site-header">
  <div class="wrap site-header__inner">
    <a href="/" class="brand" aria-label={`${SITE.name} 홈`}>
      Cr<span>a</span>ma
      <small>{SITE.tagline}</small>
    </a>
    <div class="header-actions">
      <a href="/search/" class="search-link" aria-label="검색" title="검색">⌕</a>
      <button class="theme-toggle" id="theme-toggle" aria-label="다크 모드 전환" title="다크 모드 전환">◐</button>
    </div>
    <nav class="nav" aria-label="주요 메뉴">
      {NAV.map((item) => (
        <a href={item.href} class="is-cat">{item.label}</a>
      ))}
    </nav>
  </div>
</header>
<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const el = document.documentElement;
    const dark = el.dataset.theme === 'dark';
    el.dataset.theme = dark ? '' : 'dark';
    localStorage.setItem('theme', dark ? 'light' : 'dark');
  });

  // 스크롤 내리면 브랜드 줄을 숨기고 메뉴·검색·테마 바만 남기기
  (() => {
    const header = document.querySelector('.site-header');
    if (!header) return;
    const onScroll = () => header.classList.toggle('is-compact', window.scrollY > 80);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
