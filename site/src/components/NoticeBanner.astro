---
// 상단 공지/추천 배너 (닫기 가능, localStorage 기억) — 전역
import { NOTICE } from '../consts';
---
{NOTICE.enabled && (
  <div class="notice-banner" id="notice-banner" data-key={NOTICE.key} hidden>
    <div class="notice-banner__viewport">
      <a class="notice-banner__text" href={NOTICE.href}>{NOTICE.text}</a>
    </div>
    <button class="notice-banner__close" id="notice-close" aria-label="공지 닫기">×</button>
  </div>
)}
<script is:inline>
  (() => {
    const keyOf = (el) => 'crama:notice:' + (el.dataset.key || '');
    function apply() {
      const el = document.getElementById('notice-banner');
      if (!el) return;
      let closed = false;
      try { closed = localStorage.getItem(keyOf(el)) === 'closed'; } catch (e) {}
      el.hidden = closed;
    }
    if (!window.__noticeBound) {
      window.__noticeBound = true;
      // 닫기: 문서 위임 → SPA 전환으로 요소가 교체돼도 동작
      document.addEventListener('click', (e) => {
        const btn = e.target && e.target.closest ? e.target.closest('#notice-close') : null;
        if (!btn) return;
        const el = document.getElementById('notice-banner');
        if (!el) return;
        el.hidden = true;
        try { localStorage.setItem(keyOf(el), 'closed'); } catch (e2) {}
      });
      document.addEventListener('astro:page-load', apply);
    }
    apply();
  })();
</script>
