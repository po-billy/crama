---
import FormattedDate from './FormattedDate.astro';
import { CATEGORIES, type CategorySlug } from '../consts';

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  category: CategorySlug;
  heroImage?: string;
  thumb?: string;
  audio?: boolean;
  feature?: boolean;
  format?: 'guide' | 'column';
  readingTime?: number;
}
const { href, title, description, pubDate, category, heroImage, thumb, audio = false, feature = false, format = 'guide', readingTime } = Astro.props;
const cat = CATEGORIES[category];
const isColumn = format === 'column';
const cardImg = thumb || heroImage; // 카드용 유튜브식 썸네일 우선, 없으면 히어로
const cardSlug = href.replace(/^\/blog\//, '').replace(/\/$/, '');
---
{feature ? (
  <a href={href} class="feature card" data-format={format} data-cat={category} data-slug={cardSlug}>
    <div class="feature__media card__media">
      {isColumn && <span class="card__badge">칼럼</span>}
      {cardImg && <img src={cardImg} alt={title} loading="eager" width="640" height="360" style="aspect-ratio:16/9;object-fit:cover;" />}
    </div>
    <div>
      <span class="eyebrow">{cat.name}</span>
      <h2 class="feature__title card__title">{title}</h2>
      <p class="feature__excerpt">{description}</p>
      <div class="card__meta"><FormattedDate date={pubDate} />{readingTime && <span class="card__time">{readingTime}분</span>}{audio && <span class="card__audio">🎧 들어보기</span>}</div>
    </div>
  </a>
) : (
  <a href={href} class="card" data-format={format} data-cat={category} data-slug={cardSlug}>
    <div class="card__media">
      {isColumn && <span class="card__badge">칼럼</span>}
      {cardImg && <img src={cardImg} alt={title} loading="lazy" width="640" height="360" style="aspect-ratio:16/9;object-fit:cover;" />}
    </div>
    <span class="eyebrow">{cat.name}</span>
    <h3 class="card__title">{title}</h3>
    <p class="card__excerpt">{description}</p>
    <div class="card__meta"><FormattedDate date={pubDate} />{readingTime && <span class="card__time">{readingTime}분</span>}{audio && <span class="card__audio">🎧 들어보기</span>}</div>
  </a>
)}
