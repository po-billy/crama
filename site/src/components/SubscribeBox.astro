---
// 이메일 뉴스레터 구독 폼 — Supabase email_subscriptions RPC 직접 호출
const SU = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const AK = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---
<form class="subscribe" id="subscribe-form">
  <div class="subscribe__head">
    <p class="subscribe__title">📬 새 글을 메일로 받아보세요</p>
    <p class="subscribe__sub">매일 아침, 돈·AI·생활 인사이트를 3분으로 요약해 보내드립니다.</p>
  </div>
  <div class="subscribe__row">
    <input type="email" name="email" required placeholder="이메일 주소" aria-label="이메일 주소" />
    <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
    <button type="submit" class="btn">구독</button>
  </div>
  <p class="subscribe__status" id="subscribe-status" role="status" aria-live="polite"></p>
</form>
<script is:inline define:vars={{ SU, AK }}>
  (() => {
    const f = document.getElementById('subscribe-form');
    const s = document.getElementById('subscribe-status');
    if (!f || !SU || !AK) return;
    f.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = f.querySelector('button');
      const data = Object.fromEntries(new FormData(f).entries());
      if (data.website) return; // 허니팟 봇 차단
      const email = (data.email || '').trim();
      if (!email) return;
      btn.disabled = true;
      s.textContent = '신청 중…';
      s.className = 'subscribe__status';
      try {
        const r = await fetch(`${SU}/rest/v1/rpc/subscribe_email`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': AK,
            'Authorization': `Bearer ${AK}`,
          },
          body: JSON.stringify({ p_email: email }),
        });
        if (r.ok || r.status === 204) {
          f.reset();
          s.textContent = '구독 완료! 매일 아침 브리핑을 보내드릴게요.';
          s.className = 'subscribe__status is-ok';
        } else {
          const t = await r.text().catch(() => '');
          s.textContent = t.includes('duplicate') ? '이미 구독 중입니다.' : '구독에 실패했습니다. 잠시 후 다시 시도해 주세요.';
          s.className = 'subscribe__status is-err';
        }
      } catch {
        s.textContent = '구독에 실패했습니다. 잠시 후 다시 시도해 주세요.';
        s.className = 'subscribe__status is-err';
      }
      btn.disabled = false;
    });
  })();
</script>
