---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NoticeBanner from '../components/NoticeBanner.astro';
import BackToTop from '../components/BackToTop.astro';
import CookieConsent from '../components/CookieConsent.astro';
import CalcEnhance from '../components/CalcEnhance.astro';
import QuickListen from '../components/QuickListen.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  jsonLd?: Record<string, unknown>;
  spa?: boolean; // 글 페이지에서 SPA(View Transitions) — 오디오 끊김 없는 글↔글 이동
}
const { spa, ...props } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <BaseHead {...props} />
    {spa && <ClientRouter />}
  </head>
  <body>
    {spa && (
      <script is:inline>
        if (!window.__cramaGA) {
          window.__cramaGA = true;
          document.addEventListener('astro:page-load', () => {
            try { if (window.gtag) gtag('event', 'page_view', { page_path: location.pathname + location.search, page_location: location.href, page_title: document.title }); } catch (e) {}
            try { (adsbygoogle = window.adsbygoogle || []).forEach(function(){}); } catch (e) {}
          });
        }
      </script>
    )}
    <a href="#main" class="skip-link">본문으로 건너뛰기</a>
    <NoticeBanner />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <BackToTop />
    <CookieConsent />
    <CalcEnhance />
    <QuickListen />
  </body>
</html>
