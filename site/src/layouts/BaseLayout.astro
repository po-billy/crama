---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NoticeBanner from '../components/NoticeBanner.astro';
import BackToTop from '../components/BackToTop.astro';
import CookieConsent from '../components/CookieConsent.astro';
import CalcEnhance from '../components/CalcEnhance.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  jsonLd?: Record<string, unknown>;
  spa?: boolean; // 글 페이지에서 SPA(View Transitions) — 오디오 끊김 없는 글↔글 이동
}
const { spa, ...props } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <BaseHead {...props} />
    {spa && <ClientRouter />}
  </head>
  <body>
    <script is:inline>
      // 전역 지속 오디오 컨트롤러 — 목록(홈)·본문 공용. 1회 생성, SPA 소프트 내비를 넘어 유지(이벤트는 페이지 훅으로 위임).
      if (!window.__cramaCtl) {
        window.__cramaCtl = function () {
          if (window.__cramaPlayer) return window.__cramaPlayer;
          var audio = new Audio(); audio.preload = 'none';
          var C = { audio: audio, slug: null, href: '', rate: 1, autoNext: false, follow: true, hooks: {} };
          try { C.rate = parseFloat(localStorage.getItem('crama:tts:rate')) || 1; } catch (e) {}
          try { C.autoNext = localStorage.getItem('crama:tts:auto') === '1'; } catch (e) {}
          audio.playbackRate = C.rate;
          ['timeupdate', 'play', 'pause', 'ended', 'loadedmetadata'].forEach(function (n) { audio.addEventListener(n, function (e) { if (C.hooks[n]) C.hooks[n](e); }); });
          window.__cramaPlayer = C; return C;
        };
      }
    </script>
    {spa && (
      <script is:inline>
        if (!window.__cramaGA) {
          window.__cramaGA = true;
          document.addEventListener('astro:page-load', () => {
            try { if (window.gtag) gtag('event', 'page_view', { page_path: location.pathname + location.search, page_location: location.href, page_title: document.title }); } catch (e) {}
            try { (adsbygoogle = window.adsbygoogle || []).forEach(function(){}); } catch (e) {}
          });
        }
      </script>
    )}
    <a href="#main" class="skip-link">본문으로 건너뛰기</a>
    <NoticeBanner />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <BackToTop />
    <CookieConsent />
    <CalcEnhance />
  </body>
</html>
