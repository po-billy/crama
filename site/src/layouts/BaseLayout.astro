---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import BackToTop from '../components/BackToTop.astro';
import CookieConsent from '../components/CookieConsent.astro';
import CalcEnhance from '../components/CalcEnhance.astro';
import { ClientRouter } from 'astro:transitions';
import { VAPID_PUBLIC_KEY } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  jsonLd?: Record<string, unknown>;
  spa?: boolean; // 글 페이지에서 SPA(View Transitions) — 오디오 끊김 없는 글↔글 이동
  footer?: 'full' | 'slim' | 'none'; // 앱/코어서비스는 slim(법적 링크만)·none 으로 마케팅 푸터 축소·제거
}
const { spa, footer = 'full', ...props } = Astro.props;
// 통합 관심 저장(CramaSaved) 서버 동기화용 — 익명 키만 사용(공개 가능)
const SAVED_SU = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SAVED_AK = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---
<!doctype html>
<html lang="ko">
  <head>
    <BaseHead {...props} />
    {spa && <ClientRouter />}
  </head>
  <body data-footer={footer}>
    <script is:inline define:vars={{ SAVED_SU, SAVED_AK }}>
      // 통합 관심 저장 스토어 — 청년·복지·혜택 공용. 로그인 전용(비로그인 토글 시 로그인 유도),
      // 저장은 Supabase saved_items(RLS: 본인 행만) + localStorage 캐시(동기 API 유지·기기 간은 서버가 원본).
      // 페이지 스크립트보다 먼저 정의되어야 함.
      window.CramaSaved = window.CramaSaved || (function () {
        var K = 'crama:saved';
        var SU = SAVED_SU, AK = SAVED_AK;
        function readTok() {
          try {
            for (var i = 0; i < localStorage.length; i++) {
              var k = localStorage.key(i);
              if (k && k.indexOf('sb-') === 0 && k.indexOf('-auth-token') !== -1) {
                var o = JSON.parse(localStorage.getItem(k));
                return (o && (o.access_token || (o.currentSession && o.currentSession.access_token))) || null;
              }
            }
          } catch (e) {}
          return null;
        }
        var tok = readTok();
        function get() { try { var a = JSON.parse(localStorage.getItem(K) || '[]'); return Array.isArray(a) ? a : []; } catch (e) { return []; } }
        function put(a) { try { localStorage.setItem(K, JSON.stringify(a.slice(0, 300))); } catch (e) {} }
        function idx(a, type, id) { for (var i = 0; i < a.length; i++) if (a[i].type === type && a[i].id === id) return i; return -1; }
        function hdrs(extra) { var h = { 'Content-Type': 'application/json', apikey: AK, Authorization: 'Bearer ' + tok }; if (extra) for (var k in extra) h[k] = extra[k]; return h; }
        function rowToRec(r) { return { type: r.item_type, id: r.item_id, name: r.name, url: r.url || '', sub: r.sub || '', deadline: r.deadline || '' }; }
        function pushRow(rec) {
          if (!tok || !SU) return;
          fetch(SU + '/rest/v1/saved_items', {
            method: 'POST',
            headers: hdrs({ Prefer: 'resolution=merge-duplicates' }),
            body: JSON.stringify({ item_type: rec.type, item_id: rec.id, name: rec.name, url: rec.url || null, sub: rec.sub || null, deadline: rec.deadline || null }),
          }).catch(function () {});
        }
        function dropRow(type, id) {
          if (!tok || !SU) return;
          fetch(SU + '/rest/v1/saved_items?item_type=eq.' + encodeURIComponent(type) + '&item_id=eq.' + encodeURIComponent(id), { method: 'DELETE', headers: hdrs() }).catch(function () {});
        }
        var api = {
          authed: !!tok,
          promptLogin: function () {
            if (confirm('관심 저장은 로그인하고 쓸 수 있어요.\n저장한 항목은 어느 기기에서나 보이고, 곧 마감 알림도 받게 돼요.\n\n무료 로그인하러 갈까요? (30초)')) {
              try { localStorage.setItem('crama:login-return', location.pathname + location.search); } catch (e) {}
              location.href = '/login/';
            }
          },
          has: function (type, id) { return idx(get(), type, id) !== -1; },
          toggle: function (rec) {
            if (!tok) { api.promptLogin(); return false; }
            var a = get(); var i = idx(a, rec.type, rec.id);
            if (i === -1) { a.unshift(rec); put(a); pushRow(rec); return true; }
            a.splice(i, 1); put(a); dropRow(rec.type, rec.id); return false;
          },
          add: function (rec) { if (!tok) return; var a = get(); if (idx(a, rec.type, rec.id) === -1) { a.unshift(rec); put(a); pushRow(rec); } },
          remove: function (type, id) { var a = get(); var i = idx(a, type, id); if (i !== -1) { a.splice(i, 1); put(a); } dropRow(type, id); },
          list: function (type) { var a = get(); return type ? a.filter(function (x) { return x.type === type; }) : a; },
          count: function (type) { return this.list(type).length; }
        };
        if (tok && SU) {
          // 서버가 원본: pull → 로컬 전용분은 1회 업로드(병합) → 캐시 갱신 → 페이지에 알림
          fetch(SU + '/rest/v1/saved_items?select=item_type,item_id,name,url,sub,deadline&order=created_at.desc', { headers: hdrs() })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (rows) {
              if (!rows) return;
              var server = rows.map(rowToRec);
              var local = get();
              var missing = local.filter(function (l) { return server.every(function (s) { return !(s.type === l.type && s.id === l.id); }); });
              missing.forEach(pushRow);
              put(missing.concat(server));
              document.dispatchEvent(new CustomEvent('crama:saved-sync'));
            }).catch(function () {});
        } else {
          put([]); // 로그인 전용 전환 — 비로그인 캐시는 비움(재로그인 시 서버에서 복원)
        }
        return api;
      })();

      // 내 정보(프로필) 스토어 — 나이·지역·연봉·차량(jsonb). 서버 user_profile + localStorage 캐시.
      // 기능 페이지가 프리필로 읽고, 계산 후 '내 정보로 등록'으로 쓴다(양방향 사이클).
      window.CramaProfile = window.CramaProfile || (function () {
        var K = 'crama:profile';
        var SU = SAVED_SU, AK = SAVED_AK;
        function readTok() {
          try {
            for (var i = 0; i < localStorage.length; i++) {
              var k = localStorage.key(i);
              if (k && k.indexOf('sb-') === 0 && k.indexOf('-auth-token') !== -1) {
                var o = JSON.parse(localStorage.getItem(k));
                return (o && (o.access_token || (o.currentSession && o.currentSession.access_token))) || null;
              }
            }
          } catch (e) {}
          return null;
        }
        var tok = readTok();
        function cache() { try { var o = JSON.parse(localStorage.getItem(K) || '{}'); return o && typeof o === 'object' ? o : {}; } catch (e) { return {}; } }
        function putCache(o) { try { localStorage.setItem(K, JSON.stringify(o)); } catch (e) {} }
        function hdrs(extra) { var h = { 'Content-Type': 'application/json', apikey: AK, Authorization: 'Bearer ' + tok }; if (extra) for (var k in extra) h[k] = extra[k]; return h; }
        var api = {
          authed: !!tok,
          get: function () { return cache(); },
          set: function (patch) {
            if (!tok) { if (window.CramaSaved) window.CramaSaved.promptLogin(); return false; }
            var merged = Object.assign({}, cache(), patch);
            putCache(merged);
            fetch(SU + '/rest/v1/user_profile', {
              method: 'POST',
              headers: hdrs({ Prefer: 'resolution=merge-duplicates' }),
              body: JSON.stringify({ data: merged, updated_at: new Date().toISOString() }),
            }).catch(function () {});
            document.dispatchEvent(new CustomEvent('crama:profile-sync'));
            return true;
          },
        };
        if (tok && SU) {
          fetch(SU + '/rest/v1/user_profile?select=data', { headers: hdrs() })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (rows) {
              if (rows && rows[0] && rows[0].data) { putCache(rows[0].data); document.dispatchEvent(new CustomEvent('crama:profile-sync')); }
            }).catch(function () {});
        } else {
          putCache({});
        }
        return api;
      })();
    </script>
    <script is:inline>
      // 전역 지속 오디오 컨트롤러 — 목록(홈)·본문 공용. 1회 생성, SPA 소프트 내비를 넘어 유지(이벤트는 페이지 훅으로 위임).
      if (!window.__cramaCtl) {
        window.__cramaCtl = function () {
          if (window.__cramaPlayer) return window.__cramaPlayer;
          var audio = new Audio(); audio.preload = 'none';
          var C = { audio: audio, slug: null, href: '', rate: 1.25, autoNext: false, follow: true, hooks: {} };
          try { C.rate = parseFloat(localStorage.getItem('crama:tts:rate')) || 1.25; } catch (e) {}
          try { C.autoNext = localStorage.getItem('crama:tts:auto') === '1'; } catch (e) {}
          // defaultPlaybackRate 도 함께 설정 — 새 src 로드 시 playbackRate 가 1.0 으로 리셋되는 것 방지
          audio.defaultPlaybackRate = C.rate; audio.playbackRate = C.rate;
          ['timeupdate', 'play', 'pause', 'ended', 'loadedmetadata'].forEach(function (n) { audio.addEventListener(n, function (e) { if (C.hooks[n]) C.hooks[n](e); }); });
          window.__cramaPlayer = C; return C;
        };
      }
    </script>

    <!-- 마감 알림 넛지 — 하트(dday 등) 저장 직후 푸시 미허용이면 '알림 켜기' 유도(7일 스누즈) -->
    <div class="push-nudge" id="push-nudge" hidden>
      <span id="push-nudge-msg">저장 완료! 마감 <b>D-3·D-1 알림</b>으로 챙겨드릴까요?</span>
      <button type="button" id="push-nudge-on">알림 켜기</button>
      <button type="button" id="push-nudge-x" aria-label="닫기">×</button>
    </div>
    <script is:inline define:vars={{ NUDGE_VAPID: VAPID_PUBLIC_KEY, NUDGE_SU: SAVED_SU, NUDGE_AK: SAVED_AK }}>
      (() => {
        if (window.__pushNudge) return; window.__pushNudge = true;
        var box = document.getElementById('push-nudge');
        if (!box || !('Notification' in window) || !('PushManager' in window)) return;
        var K = 'crama:push-nudge-snooze';
        function snoozed() { try { return Number(localStorage.getItem(K) || 0) > Date.now(); } catch (e) { return false; } }
        function show() { if (Notification.permission === 'granted' || snoozed()) return; box.hidden = false; }
        // CramaSaved.toggle 래핑 — 항목 '추가' 시에만 넛지 (레퍼런스는 페이지가 들고 있어도 메서드 조회는 호출 시점)
        var S = window.CramaSaved;
        if (S && S.toggle && !S.__nudgeWrapped) {
          S.__nudgeWrapped = true;
          var orig = S.toggle.bind(S);
          S.toggle = function (rec) { var on = orig(rec); if (on) setTimeout(show, 500); return on; };
        }
        document.getElementById('push-nudge-x').addEventListener('click', function () {
          box.hidden = true;
          try { localStorage.setItem(K, String(Date.now() + 7 * 864e5)); } catch (e) {}
        });
        document.getElementById('push-nudge-on').addEventListener('click', async function () {
          var btn = this;
          btn.disabled = true;
          try {
            var reg = await navigator.serviceWorker.ready;
            var perm = await Notification.requestPermission();
            if (perm !== 'granted') { btn.disabled = false; return; }
            var s = await reg.pushManager.getSubscription();
            if (!s) {
              var pad = '='.repeat((4 - (NUDGE_VAPID.length % 4)) % 4);
              var raw = atob((NUDGE_VAPID + pad).replace(/-/g, '+').replace(/_/g, '/'));
              var key = new Uint8Array(raw.length);
              for (var i = 0; i < raw.length; i++) key[i] = raw.charCodeAt(i);
              s = await reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: key });
            }
            var j = s.toJSON();
            var tok = null;
            try {
              for (var i2 = 0; i2 < localStorage.length; i2++) {
                var k2 = localStorage.key(i2);
                if (k2 && k2.indexOf('sb-') === 0 && k2.indexOf('-auth-token') !== -1) {
                  var o = JSON.parse(localStorage.getItem(k2));
                  tok = o && (o.access_token || (o.currentSession && o.currentSession.access_token));
                  break;
                }
              }
            } catch (e) {}
            await fetch(NUDGE_SU + '/rest/v1/rpc/subscribe_push', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', apikey: NUDGE_AK, Authorization: 'Bearer ' + (tok || NUDGE_AK) },
              body: JSON.stringify({ p_endpoint: j.endpoint, p_p256dh: j.keys.p256dh, p_auth: j.keys.auth }),
            });
            document.getElementById('push-nudge-msg').textContent = '알림을 켰어요 — 마감 전에 챙겨드릴게요';
            btn.remove();
            setTimeout(function () { box.hidden = true; }, 2500);
          } catch (e) { btn.disabled = false; }
        });
      })();
    </script>

    <!-- 누적 청취 시간 집계 — 전역 플레이어 재생 중 1초씩 누적, 60초마다/이탈 시 flush(REST, supabase-js 미로드) -->
    <script is:inline define:vars={{ SU: import.meta.env.PUBLIC_SUPABASE_URL ?? '', AK: import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '' }}>
      (() => {
        if (window.__listenBound) return; window.__listenBound = true;
        const KEY = 'crama:listen:pending';
        const getP = () => { try { return parseInt(localStorage.getItem(KEY) || '0', 10) || 0; } catch (e) { return 0; } };
        const setP = (v) => { try { localStorage.setItem(KEY, String(v)); } catch (e) {} };
        const token = () => {
          try {
            for (const k of Object.keys(localStorage)) {
              if (k.includes('-auth-token')) {
                const v = JSON.parse(localStorage.getItem(k) || 'null');
                return v && (v.access_token || (v.currentSession && v.currentSession.access_token));
              }
            }
          } catch (e) {}
          return null;
        };
        let flushing = false;
        async function flush() {
          const pend = getP();
          if (flushing || pend <= 0 || !SU || !AK) return;
          const tk = token(); if (!tk) return; // 비로그인: 보류했다가 로그인 시 합산
          flushing = true;
          try {
            const res = await fetch(SU + '/rest/v1/rpc/add_listen_seconds', {
              method: 'POST', keepalive: true,
              headers: { apikey: AK, Authorization: 'Bearer ' + tk, 'Content-Type': 'application/json' },
              body: JSON.stringify({ secs: pend }),
            });
            if (res.ok) setP(0);
          } catch (e) {} finally { flushing = false; }
        }
        function bind() {
          const C = window.__cramaCtl ? window.__cramaCtl() : window.__cramaPlayer;
          if (!C || !C.audio) return false;
          const a = C.audio; let ticker = null, n = 0;
          const startTick = () => { if (ticker || a.paused) return; ticker = setInterval(() => {
            setP(getP() + 1);
            if (++n >= 60) { n = 0; flush(); }
          }, 1000); };
          const stopTick = () => { if (ticker) { clearInterval(ticker); ticker = null; } n = 0; flush(); };
          a.addEventListener('play', startTick);
          a.addEventListener('playing', startTick);
          a.addEventListener('pause', stopTick);
          a.addEventListener('ended', stopTick);
          if (!a.paused) startTick();
          return true;
        }
        if (!bind()) { const t = setInterval(() => { if (bind()) clearInterval(t); }, 1000); setTimeout(() => clearInterval(t), 30000); }
        document.addEventListener('visibilitychange', () => { if (document.hidden) flush(); });
        window.addEventListener('pagehide', flush);
        setTimeout(flush, 2500); // 로그인 페이지 진입 시 보류분 합산
      })();
    </script>
    {spa && (
      <script is:inline>
        if (!window.__cramaGA) {
          window.__cramaGA = true;
          document.addEventListener('astro:page-load', () => {
            try { if (window.gtag) gtag('event', 'page_view', { page_path: location.pathname + location.search, page_location: location.href, page_title: document.title }); } catch (e) {}
            try { (adsbygoogle = window.adsbygoogle || []).forEach(function(){}); } catch (e) {}
          });
        }
      </script>
    )}
    <a href="#main" class="skip-link">본문으로 건너뛰기</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    {footer === 'full' && <Footer />}
    {footer === 'slim' && <Footer variant="slim" />}
    <BottomNav />
    <BackToTop />
    <CookieConsent />
    <CalcEnhance />
    <style is:global>
      /* 앱/코어서비스(slim·none): main 이 화면을 채우고 푸터는 바닥에 — 마케팅 푸터 제거 후 빈 공백 방지 */
      body[data-footer='slim'], body[data-footer='none'] {
        min-height: 100vh; min-height: 100dvh; display: flex; flex-direction: column;
      }
      body[data-footer='slim'] > main, body[data-footer='none'] > main { flex: 1 0 auto; }
    </style>
    <script is:inline>
      // 읽은 글 카드에 '읽음' 뱃지 표시
      (() => {
        function markRead() {
          try {
            const list = JSON.parse(localStorage.getItem('crama:read') || '[]');
            if (!list.length) return;
            const set = new Set(list);
            document.querySelectorAll('.card[data-slug]').forEach(function (el) {
              if (set.has(el.dataset.slug) && !el.querySelector('.card__read')) {
                var b = document.createElement('span');
                b.className = 'card__read';
                b.textContent = '읽음';
                el.querySelector('.card__meta')?.appendChild(b);
              }
            });
          } catch (e) {}
        }
        if (!window.__readBound) { window.__readBound = true; document.addEventListener('astro:page-load', markRead); }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', markRead); else markRead();
      })();
    </script>
  </body>
</html>
