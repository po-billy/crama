---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import CookieConsent from '../components/CookieConsent.astro';
import CalcEnhance from '../components/CalcEnhance.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  jsonLd?: Record<string, unknown>;
  spa?: boolean; // 글 페이지에서 SPA(View Transitions) — 오디오 끊김 없는 글↔글 이동
}
const { spa, ...props } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <BaseHead {...props} />
    {spa && <ClientRouter />}
  </head>
  <body>
    <script is:inline>
      // 전역 지속 오디오 컨트롤러 — 목록(홈)·본문 공용. 1회 생성, SPA 소프트 내비를 넘어 유지(이벤트는 페이지 훅으로 위임).
      if (!window.__cramaCtl) {
        window.__cramaCtl = function () {
          if (window.__cramaPlayer) return window.__cramaPlayer;
          var audio = new Audio(); audio.preload = 'none';
          var C = { audio: audio, slug: null, href: '', rate: 1, autoNext: false, follow: true, hooks: {} };
          try { C.rate = parseFloat(localStorage.getItem('crama:tts:rate')) || 1; } catch (e) {}
          try { C.autoNext = localStorage.getItem('crama:tts:auto') === '1'; } catch (e) {}
          audio.playbackRate = C.rate;
          ['timeupdate', 'play', 'pause', 'ended', 'loadedmetadata'].forEach(function (n) { audio.addEventListener(n, function (e) { if (C.hooks[n]) C.hooks[n](e); }); });
          window.__cramaPlayer = C; return C;
        };
      }
    </script>

    <!-- 누적 청취 시간 집계 — 전역 플레이어 재생 중 1초씩 누적, 60초마다/이탈 시 flush(REST, supabase-js 미로드) -->
    <script is:inline define:vars={{ SU: import.meta.env.PUBLIC_SUPABASE_URL ?? '', AK: import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '' }}>
      (() => {
        if (window.__listenBound) return; window.__listenBound = true;
        const KEY = 'crama:listen:pending';
        const getP = () => { try { return parseInt(localStorage.getItem(KEY) || '0', 10) || 0; } catch (e) { return 0; } };
        const setP = (v) => { try { localStorage.setItem(KEY, String(v)); } catch (e) {} };
        const token = () => {
          try {
            for (const k of Object.keys(localStorage)) {
              if (k.includes('-auth-token')) {
                const v = JSON.parse(localStorage.getItem(k) || 'null');
                return v && (v.access_token || (v.currentSession && v.currentSession.access_token));
              }
            }
          } catch (e) {}
          return null;
        };
        let flushing = false;
        async function flush() {
          const pend = getP();
          if (flushing || pend <= 0 || !SU || !AK) return;
          const tk = token(); if (!tk) return; // 비로그인: 보류했다가 로그인 시 합산
          flushing = true;
          try {
            const res = await fetch(SU + '/rest/v1/rpc/add_listen_seconds', {
              method: 'POST', keepalive: true,
              headers: { apikey: AK, Authorization: 'Bearer ' + tk, 'Content-Type': 'application/json' },
              body: JSON.stringify({ secs: pend }),
            });
            if (res.ok) setP(0);
          } catch (e) {} finally { flushing = false; }
        }
        function bind() {
          const C = window.__cramaCtl ? window.__cramaCtl() : window.__cramaPlayer;
          if (!C || !C.audio) return false;
          const a = C.audio; let ticker = null, n = 0;
          const startTick = () => { if (ticker || a.paused) return; ticker = setInterval(() => {
            setP(getP() + 1);
            if (++n >= 60) { n = 0; flush(); }
          }, 1000); };
          const stopTick = () => { if (ticker) { clearInterval(ticker); ticker = null; } n = 0; flush(); };
          a.addEventListener('play', startTick);
          a.addEventListener('playing', startTick);
          a.addEventListener('pause', stopTick);
          a.addEventListener('ended', stopTick);
          if (!a.paused) startTick();
          return true;
        }
        if (!bind()) { const t = setInterval(() => { if (bind()) clearInterval(t); }, 1000); setTimeout(() => clearInterval(t), 30000); }
        document.addEventListener('visibilitychange', () => { if (document.hidden) flush(); });
        window.addEventListener('pagehide', flush);
        setTimeout(flush, 2500); // 로그인 페이지 진입 시 보류분 합산
      })();
    </script>
    {spa && (
      <script is:inline>
        if (!window.__cramaGA) {
          window.__cramaGA = true;
          document.addEventListener('astro:page-load', () => {
            try { if (window.gtag) gtag('event', 'page_view', { page_path: location.pathname + location.search, page_location: location.href, page_title: document.title }); } catch (e) {}
            try { (adsbygoogle = window.adsbygoogle || []).forEach(function(){}); } catch (e) {}
          });
        }
      </script>
    )}
    <a href="#main" class="skip-link">본문으로 건너뛰기</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <div class="vfab" id="vfab" hidden data-su={import.meta.env.PUBLIC_SUPABASE_URL ?? ''} data-ak={import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? ''}>
      <a class="vfab__bubble" id="vfab-bubble" href="/vote/" hidden>
        <button class="vfab__x" id="vfab-x" aria-label="닫기">×</button>
        <b id="vfab-q"></b>
        <span class="vfab__cta">지금 빼꼼 투표 →</span>
      </a>
      <a class="vfab__btn" href="/vote/" id="vfab-btn" aria-label="오늘의 투표">
        <img src="/img/generated/crami-vote.webp" alt="" />
      </a>
    </div>
    <script is:inline>
      // ClientRouter(spa)에서도 매 페이지마다 표시를 재평가 — 첫 로드 페이지에 따라 vfab/버블이 고정되던 문제 방지
      (() => {
        function initVfab() {
          const w = document.getElementById('vfab');
          if (!w) return;
          const excluded = /^\/(vote|login|me|saved|wardrobe|calendar|membership)\b/.test(location.pathname);
          if (excluded) { w.hidden = true; return; }
          w.hidden = false; // 제외 페이지가 아니면 항상 노출(홈 포함)
          const su = w.dataset.su, ak = w.dataset.ak;
          if (!su || !ak) return;
          const apply = (rows) => {
            const p = rows && rows[0]; if (!p) return; // 활성 투표가 있을 때만 말풍선
            const b = document.getElementById('vfab-bubble'); if (!b) return;
            document.getElementById('vfab-q').textContent = p.question + (p.emoji ? ' ' + p.emoji : '');
            let dismissed = false; try { dismissed = localStorage.getItem('crama:vfab-x') === String(p.id); } catch (e) {}
            if (!dismissed) b.hidden = false;
            const x = document.getElementById('vfab-x');
            if (x) x.onclick = (e) => { e.preventDefault(); e.stopPropagation(); b.hidden = true; try { localStorage.setItem('crama:vfab-x', String(p.id)); } catch (e2) {} };
          };
          if (window.__cramaPoll) { apply(window.__cramaPoll); return; } // 1회 fetch 후 캐시
          fetch(su + '/rest/v1/polls?active=eq.true&order=created_at.desc&limit=1&select=id,question,emoji,image', { headers: { apikey: ak } })
            .then((r) => (r.ok ? r.json() : [])).then((rows) => { window.__cramaPoll = rows; apply(rows); }).catch(() => {});
        }
        if (!window.__vfabBound) { window.__vfabBound = true; document.addEventListener('astro:page-load', initVfab); }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initVfab); else initVfab();
      })();
    </script>
    <BackToTop />
    <CookieConsent />
    <CalcEnhance />
  </body>
</html>
