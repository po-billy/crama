---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import AdSlot from '../components/AdSlot.astro';
import PostCard from '../components/PostCard.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import ShareButtons from '../components/ShareButtons.astro';
import FloatingShare from '../components/FloatingShare.astro';
import ListenButton from '../components/ListenButton.astro';
import GlossaryTooltips from '../components/GlossaryTooltips.astro';
import TagList from '../components/TagList.astro';
import AuthorBox from '../components/AuthorBox.astro';
import ContentRail from '../components/ContentRail.astro';
import { SITE, CATEGORIES, type CategorySlug } from '../consts';
import { bylineLabel, resolveAuthorName, getPersona, REAL_AUTHOR } from '../data/personas';

interface RelatedPost {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  category: CategorySlug;
  heroImage?: string;
  format?: 'guide' | 'column';
}
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: CategorySlug;
  author: string;
  format?: 'guide' | 'column';
  heroImage?: string;
  readingTime?: number;
  premium?: boolean;
  audioSrc?: string;
  tags?: string[];
  headings?: MarkdownHeading[];
  related?: RelatedPost[];
  nextHref?: string;    // 오디오 '이어 듣기' 다음 글(전역 시간순) — 기본
  nextHrefCat?: string; // 같은 카테고리 내 시간순 — '범위: 카테고리' 옵션용
  guide?: { title: string; href: string };
}
const {
  title, description, pubDate, updatedDate, category, author, format = 'guide', heroImage,
  readingTime, premium = false, audioSrc, tags = [], headings = [], related = [], nextHref = '', nextHrefCat = '', guide,
} = Astro.props;

const cat = CATEGORIES[category];
const slug = (Astro.url.pathname.match(/\/blog\/([^/]+)/) || [])[1];
// 칼럼이면 작성자를 페르소나로 안전 해석(미지정·미등록 시 카테고리 기본 칼럼니스트로 대체)
const resolvedAuthor = resolveAuthorName(author, category, format === 'column');
const byline = bylineLabel(resolvedAuthor);
// 저자 구조화데이터: 가이드(정보성)=실명 Person(엄희송, E-E-A-T) / 칼럼=가상 페르소나는 사람으로 위장하지 않고 Organization
const authorLd = getPersona(resolvedAuthor)
  ? { '@type': 'Organization', name: byline }
  : {
      '@type': 'Person',
      name: REAL_AUTHOR.name,
      url: new URL(`/authors/${REAL_AUTHOR.id}/`, SITE.url).href,
      ...(REAL_AUTHOR.sameAs.length ? { sameAs: REAL_AUTHOR.sameAs } : {}),
    };
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: authorLd,
  publisher: { '@type': 'Organization', name: SITE.name },
  articleSection: cat.name,
  ...(heroImage ? { image: new URL(heroImage, SITE.url).href } : {}),
  isAccessibleForFree: !premium,
};
---
<BaseLayout
  spa
  title={title}
  description={description}
  image={heroImage}
  type="article"
  publishedTime={pubDate}
  jsonLd={jsonLd}
>
  <ReadingProgress />
  <FloatingShare />
  <div class="detail-layout">
  <article class="wrap" data-next-article={nextHref} data-next-cat={nextHrefCat}>
    <Breadcrumbs items={[{ label: cat.name, href: `/category/${cat.slug}/` }, { label: title }]} />

    <header class="article-head measure">
      <a href={`/category/${cat.slug}/`} class="eyebrow">{cat.name}</a>
      <h1>{title}{premium && <span class="premium-tag">멤버십</span>}</h1>
      <p class="dek">{description}</p>
      <div class="article-meta">
        <span>{byline}</span>
        <span aria-hidden="true">·</span>
        <FormattedDate date={pubDate} />
        {readingTime && (<><span aria-hidden="true">·</span><span>{readingTime}분 읽기</span></>)}
        <button id="bm-btn" class="bm-btn" hidden>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 3h12a1 1 0 0 1 1 1v17l-7-4-7 4V4a1 1 0 0 1 1-1z"/></svg>
          <span id="bm-label">저장</span>
        </button>
      </div>
    </header>

    {heroImage && (
      <figure class="article-hero measure">
        <img src={heroImage} alt={title} fetchpriority="high" />
      </figure>
    )}

    <ListenButton audioSrc={audioSrc} />

    {guide && (
      <a class="guide-link measure" href={guide.href}>
        <span class="guide-link__badge">가이드</span>
        <span class="guide-link__text">이 글은 <strong>{guide.title}</strong>의 일부입니다</span>
        <span class="guide-link__cta">전체 보기 →</span>
      </a>
    )}

    <TableOfContents headings={headings} />

    <div class:list={['prose', 'measure', { 'is-premium': premium }]}>
      <slot />
    </div>

    {!premium && <GlossaryTooltips />}

    {!premium && (
      <div class="measure article-footer">
        <TagList tags={tags} />
        <ShareButtons title={title} />
        <AuthorBox author={resolvedAuthor} />
      </div>
    )}

    {premium ? (
      <aside class="paywall">
        <span class="paywall__badge">멤버십 전용</span>
        <h2>이어지는 내용은 멤버 전용입니다</h2>
        <p>광고 없이 더 깊은 분석을 보시려면 멤버십에 가입하세요.</p>
        <a class="paywall__cta" href="/membership/">멤버십 알아보기</a>
      </aside>
    ) : (
      <AdSlot slot="article-bottom" />
    )}

    <aside id="signup-cta" class="signup-cta measure" hidden>
      <img src="/img/generated/meerkat-baby-wave.webp" alt="크라미" />
      <div class="signup-cta__body">
        <b>읽은 만큼 쌓이는 재미, 크라미</b>
        <p>로그인하면 글 읽을 때마다 <strong>밀웜</strong>을 모아 나만의 <strong>크라미</strong>를 꾸밀 수 있어요. 콘텐츠는 계속 무료예요.</p>
        <a class="signup-cta__btn" href="/login/">크라미 시작하기 →</a>
      </div>
    </aside>

    {related.length > 0 && (
      <section class="wrap" style="padding-inline:0;">
        <div class="section-head"><h2>이어 읽기</h2></div>
        <div class="card-grid">
          {related.map((p) => <PostCard {...p} />)}
        </div>
      </section>
    )}
  </article>
  <ContentRail excludeSlug={slug} />
  </div>
</BaseLayout>

<script>
  // 밀웜 적립 — 글당 1회(서버 캡). 어뷰징 방지: 단순 스크롤이 아니라
  //  · 완독: 스크롤 90% 도달 + 체류 20초 (둘 다)
  //  · 오디오: 이 글 오디오를 60초(또는 길이의 50%) 이상 재생
  import { getUser, earnWorms, getBookmarks, toggleBookmark } from '../lib/api';
  (async () => {
    const m = location.pathname.match(/\/blog\/([^/]+)/);
    if (!m) return;
    const slug = m[1];
    if (!(await getUser())) {
      const cta = document.getElementById('signup-cta'); // 로그아웃: 가입 유도 CTA 노출(콘텐츠는 그대로)
      if (cta) (cta as HTMLElement).hidden = false;
      return;
    }

    // ── 스크랩(북마크) 버튼 ──
    const bm = document.getElementById('bm-btn');
    if (bm) {
      bm.hidden = false;
      const lbl = document.getElementById('bm-label')!;
      let saved = (await getBookmarks()).includes(slug);
      const paint = () => { bm.classList.toggle('on', saved); lbl.textContent = saved ? '저장됨' : '저장'; };
      paint();
      bm.addEventListener('click', async () => {
        const r = await toggleBookmark(slug);
        saved = r.bookmarked; paint();
      });
    }

    // ── 완독 ──
    let readEarned = false;
    const startedAt = Date.now();
    let timer: any;
    const tryRead = () => {
      if (readEarned) return;
      const scrolled = (window.scrollY + window.innerHeight) / document.body.scrollHeight;
      const dwell = (Date.now() - startedAt) / 1000;
      if (scrolled >= 0.9 && dwell >= 20) {
        readEarned = true;
        window.removeEventListener('scroll', tryRead);
        clearInterval(timer);
        earnWorms('read', slug);
      }
    };
    window.addEventListener('scroll', tryRead, { passive: true });
    timer = setInterval(tryRead, 5000); // 스크롤 멈춰도 체류시간 충족 체크

    // ── 오디오 듣기 ──
    let audioEarned = false;
    const hookAudio = () => {
      const C = (window as any).__cramaPlayer;
      if (!C || !C.audio) return false;
      C.audio.addEventListener('timeupdate', () => {
        if (audioEarned || C.slug !== slug) return;
        const need = Math.min(60, (C.audio.duration || 120) * 0.5);
        if (C.audio.currentTime >= need) { audioEarned = true; earnWorms('audio', slug); }
      });
      return true;
    };
    if (!hookAudio()) {
      const t = setInterval(() => { if (hookAudio()) clearInterval(t); }, 1000);
      setTimeout(() => clearInterval(t), 30000);
    }
  })();
</script>
