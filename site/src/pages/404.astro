---
import BaseLayout from '../layouts/BaseLayout.astro';
import DuoIcon from '../components/DuoIcon.astro';
import { CATEGORIES } from '../consts';
---
<BaseLayout title="페이지를 찾을 수 없어요 (404)" description="요청하신 페이지를 찾을 수 없습니다.">
  <div class="wrap measure" style="text-align:center; padding: 4rem 0 3rem;">
    <p class="eyebrow">404</p>
    <h1 style="font-size:clamp(2rem,6vw,3rem);">페이지를 찾을 수 없어요</h1>
    <p style="color:var(--muted); font-size:1.1rem; margin-top:0.6rem;">
      주소가 바뀌었거나 삭제된 글일 수 있습니다.
    </p>
    <form action="/search/" method="get" style="max-width:400px;margin:1.5rem auto;display:flex;gap:.5rem;">
      <input type="search" name="q" placeholder="찾고 싶은 주제를 검색해 보세요" style="flex:1;padding:.6rem 1rem;border:1px solid var(--border,#e2e8f0);border-radius:8px;font-size:.95rem;background:var(--paper,#fff);color:var(--ink);" />
      <button type="submit" class="btn" style="white-space:nowrap;">검색</button>
    </form>
    <div style="display:flex; gap:0.8rem; justify-content:center; flex-wrap:wrap; margin-top:1rem;">
      <a class="btn" href="/">홈으로</a>
      {Object.values(CATEGORIES).map((c) => (
        <a class="btn" href={`/category/${c.slug}/`} style="background:var(--paper-2); color:var(--ink);">{c.name}</a>
      ))}
    </div>

    <!-- 서비스 추천으로 이탈 방지 -->
    <div style="margin-top:2.5rem; padding-top:2rem; border-top:1px solid var(--line);">
      <p style="font-weight:600; margin-bottom:1rem; font-size:0.95rem;">혹시 이런 서비스를 찾으셨나요?</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:0.6rem; max-width:480px; margin:0 auto;">
        <a href="/benefits/" style="display:flex;flex-direction:column;align-items:center;gap:0.4rem;padding:1rem;border:1px solid var(--line);border-radius:12px;text-decoration:none;color:var(--ink);background:var(--paper);transition:border-color .12s;">
          <DuoIcon name="benefits" class="svc-ico" />
          <strong style="font-size:0.85rem;">내 혜택 찾기</strong>
        </a>
        <a href="/checkup/" style="display:flex;flex-direction:column;align-items:center;gap:0.4rem;padding:1rem;border:1px solid var(--line);border-radius:12px;text-decoration:none;color:var(--ink);background:var(--paper);transition:border-color .12s;">
          <DuoIcon name="checkup" class="svc-ico" />
          <strong style="font-size:0.85rem;">재무 체크업</strong>
        </a>
        <a href="/policy-calendar/" style="display:flex;flex-direction:column;align-items:center;gap:0.4rem;padding:1rem;border:1px solid var(--line);border-radius:12px;text-decoration:none;color:var(--ink);background:var(--paper);transition:border-color .12s;">
          <DuoIcon name="calendar" class="svc-ico" />
          <strong style="font-size:0.85rem;">정책 캘린더</strong>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
