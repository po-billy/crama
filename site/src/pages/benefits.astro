      // ── 네비게이션 ──
      function showSection(id) {
        ['bf-hero', 'bf-flow', 'bf-result'].forEach(function (s) {
          $(s).hidden = s !== id;
        });
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      $('bf-start').addEventListener('click', function () {
        showSection('bf-flow');
        step = 0; renderStep();
      });

      $('bf-back').addEventListener('click', function () {
        if (step > 0) { step--; renderStep(); }
        else showSection('bf-hero');
      });

      $('bf-next').addEventListener('click', function () {
        if (step < STEPS.length - 1) { step++; renderStep(); }
        else { showSection('bf-result'); showResults(); }
      });

      $('bf-retry').addEventListener('click', function () {
        showSection('bf-flow');
        step = 0; renderStep();
      });

      $('bf-save').addEventListener('click', function () {
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(profile)); } catch (e) {}
        $('bf-save-done').hidden = false;
        this.textContent = '✓ 저장 완료';
        this.disabled = true;
      });

      $('bf-share-result').addEventListener('click', async function () {
        var results = match(profile);
        var total = results.reduce(function (s, b) { return s + b.amountValue; }, 0);
        var text = '방금 확인해봤는데 나한테 해당되는 지원금이 ' + results.length + '건, 약 ' + total.toLocaleString() + '만원이래.\n너도 몰라서 못 받는 거 있을 수 있어. 3분이면 확인됨 →';
        var url = location.origin + '/benefits/';
        try {
          if (navigator.share) await navigator.share({ title: '내 혜택 찾기 결과', text: text, url: url });
          else { await navigator.clipboard.writeText(text + '\n' + url); alert('결과를 복사했어요! 친구에게 공유해 보세요.'); }
