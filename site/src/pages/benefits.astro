---
import BaseLayout from '../layouts/BaseLayout.astro';
import DuoIcon from '../components/DuoIcon.astro';
import { BENEFITS, BENEFIT_CATEGORIES, REGIONS } from '../data/benefits';

// 빌드 시점에 데이터를 인라인(JSON) — 클라이언트 JS에서 매칭
const benefitsJson = JSON.stringify(BENEFITS);
const categoriesJson = JSON.stringify(BENEFIT_CATEGORIES);
const regionsJson = JSON.stringify(REGIONS);

// FAQ 구조화 데이터 (검색 노출 강화)
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '내가 받을 수 있는 정부 지원금을 어떻게 확인하나요?', acceptedAnswer: { '@type': 'Answer', text: '크라마 "내 혜택 찾기"에서 나이, 소득, 주거, 가족 상황을 입력하면 3분 만에 해당되는 지원금·대출·공제를 자동으로 매칭해 드립니다.' } },
    { '@type': 'Question', name: '2026년 청년도약계좌 신청 자격은?', acceptedAnswer: { '@type': 'Answer', text: '만 19~34세, 개인소득 연 7,500만원 이하, 가구소득 중위 250% 이하인 근로·사업소득자가 신청할 수 있습니다. 매월 최대 70만원 납입, 5년 만기 시 약 5,000만원을 모을 수 있습니다.' } },
    { '@type': 'Question', name: '지원금 자격 확인에 비용이 드나요?', acceptedAnswer: { '@type': 'Answer', text: '아니요. 크라마의 내 혜택 찾기는 완전 무료이며, 입력한 개인정보는 서버로 전송되지 않고 기기에만 저장됩니다.' } },
  ],
};
---
<BaseLayout
  title="내 혜택 찾기 — 나에게 해당되는 지원금을 3분 만에"
  description="나이·소득·상황만 입력하면, 지금 당장 신청할 수 있는 정부 지원금·혜택을 찾아드립니다. 계산기가 아니라 진짜로 찾아주는 서비스."
  image="/og-home.png"
  jsonLd={faqLd}
>
  <div class="bf">
    <!-- ━━ 1. 인트로 ━━ -->
    <section class="bf-hero" id="bf-hero">
      <div class="bf-hero__inner">
        <span class="bf-hero__badge">서비스</span>
        <h1 class="bf-hero__title">나에게 해당되는<br/>혜택, <em>진짜로</em> 찾아드려요</h1>
        <p class="bf-hero__lead">
          5가지 질문이면 충분합니다.<br/>
          지금 신청할 수 있는 지원금·대출·공제를<br/>
          <strong>놓치지 않게</strong> 한눈에 보여드릴게요.
        </p>
        <div class="bf-hero__stats">
          <div class="bf-stat"><span class="bf-stat__num">{BENEFITS.length}</span><span class="bf-stat__label">혜택 수록</span></div>
          <div class="bf-stat"><span class="bf-stat__num">3분</span><span class="bf-stat__label">소요 시간</span></div>
          <div class="bf-stat"><span class="bf-stat__num">0원</span><span class="bf-stat__label">완전 무료</span></div>
        </div>
        <p class="bf-hero__proof">평균 <strong>7~12건</strong>, 연 <strong>300~800만원</strong>의 혜택이 발견됩니다</p>
        <p class="bf-hero__social" id="bf-social" hidden></p>
        <button class="bf-cta" type="button" id="bf-start">내 혜택 찾기 시작 →</button>
        <p class="bf-hero__note">입력하신 정보는 기기에만 저장되며 서버로 전송되지 않습니다.</p>
        <div class="bf-hero__cases">
          <div class="bf-case">
            <span class="bf-case__q">28세 직장인, 연 3,500만원</span>
            <span class="bf-case__a">→ 12건, 약 820만원/년 발견</span>
          </div>
          <div class="bf-case">
            <span class="bf-case__q">32세 프리랜서, 1인 가구</span>
            <span class="bf-case__a">→ 8건, 약 450만원/년 발견</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ━━ 2. 프로필 입력 (단계별) ━━ -->
    <section class="bf-flow" id="bf-flow" hidden>
      <div class="bf-flow__top">
        <button class="bf-flow__back" type="button" id="bf-back" aria-label="이전">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5m7-7-7 7 7 7"/></svg>
        </button>
        <div class="bf-progress"><span class="bf-progress__bar" id="bf-bar"></span></div>
        <span class="bf-flow__step" id="bf-step-label"></span>
      </div>

      <div class="bf-step" id="bf-step">
        <!-- JS가 단계별 콘텐츠를 렌더 -->
      </div>

      <div class="bf-flow__footer">
        <button class="bf-cta bf-cta--next" type="button" id="bf-next" disabled>다음 →</button>
      </div>
    </section>

    <!-- ━━ 3. 결과 대시보드 ━━ -->
    <section class="bf-result" id="bf-result" hidden>
      <div class="bf-result__hero">
        <p class="bf-result__eyebrow">분석 완료</p>
        <h2 class="bf-result__title" id="bf-result-title"></h2>
        <p class="bf-result__amount" id="bf-result-amount"></p>
        <p class="bf-result__sub">예상 연간 혜택 총액 (최대 기준)</p>
        <p class="bf-result__missed" id="bf-missed" hidden></p>
      </div>

      <div class="bf-filters" id="bf-filters"></div>

      <div class="bf-cards" id="bf-cards">
        <!-- JS가 매칭 결과 카드를 렌더 -->
      </div>

      <div class="bf-result__actions">
        <button class="bf-cta" type="button" id="bf-share-result">결과 공유하기</button>
        <button class="bf-cta bf-cta--ghost" type="button" id="bf-save">프로필 저장</button>
        <button class="bf-cta bf-cta--ghost" type="button" id="bf-retry">다시 입력</button>
      </div>

      <div class="bf-result__cta-box" id="bf-save-done" hidden>
        <p>프로필이 저장됐어요. 다음에 방문하면 바로 결과를 보여드릴게요.</p>
      </div>

      <!-- 서비스 크로스 연결 -->
      <div class="bf-cross">
        <a href="/checkup/" class="bf-cross__card">
          <span class="bf-cross__icon"><DuoIcon name="checkup" /></span>
          <div>
            <strong>재무 건강 체크업</strong>
            <p>내 돈 관리가 건강한지 5분 만에 진단해 보세요</p>
          </div>
          <span class="bf-cross__arrow">→</span>
        </a>
        <a href="/policy-calendar/" class="bf-cross__card">
          <span class="bf-cross__icon"><DuoIcon name="calendar" /></span>
          <div>
            <strong>정책 캘린더 2026</strong>
            <p>놓치면 손해인 신청 마감일을 한눈에</p>
          </div>
          <span class="bf-cross__arrow">→</span>
        </a>
      </div>

      <div class="bf-result__note">
        <p>※ 이 결과는 공개된 자격 요건을 기반으로 한 <strong>예상 결과</strong>입니다. 실제 수급 여부는 각 기관에서 최종 확인하세요.</p>
        <p>데이터 기준: 2026년 6월 · 정책 변경 시 업데이트됩니다.</p>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ benefitsJson, categoriesJson, regionsJson }}>
    (() => {
      const BENEFITS = JSON.parse(benefitsJson);
      const CATS = JSON.parse(categoriesJson);
      const REGIONS = JSON.parse(regionsJson);
      const STORAGE_KEY = 'crama:benefits:profile';
      const $ = (id) => document.getElementById(id);

      // ── 중위소득 계산 ──
      const MEDIAN = { 1: 2392, 2: 3932, 3: 5025, 4: 6097, 5: 7108, 6: 8064 };
      function medianIncome(fam, pct) {
        return Math.round((MEDIAN[Math.min(fam, 6)] || MEDIAN[4]) * 12 * (pct / 100));
      }

      // ── 매칭 엔진 ──
      function match(p) {
        return BENEFITS.filter(function (b) {
          var e = b.eligibility;
          if (e.ageMin != null && p.age < e.ageMin) return false;
          if (e.ageMax != null && p.age > e.ageMax) return false;
          if (e.incomeMax != null && p.income > e.incomeMax) return false;
          if (e.incomePercentile != null && p.income > medianIncome(p.familySize, e.incomePercentile)) return false;
          if (e.employment && e.employment.indexOf(p.employment) === -1) return false;
          if (e.housing && e.housing.indexOf(p.housing) === -1) return false;
          if (e.region && e.region.indexOf(p.region) === -1) return false;
          if (e.familySizeMin != null && p.familySize < e.familySizeMin) return false;
          if (e.hasChildren === true && !p.hasChildren) return false;
          if (e.childAgeMax != null && (!p.hasChildren || (p.childAge == null ? 99 : p.childAge) > e.childAgeMax)) return false;
          if (e.isNewlywed === true && !p.isNewlywed) return false;
          if (e.isPregnant === true && !p.isPregnant) return false;
          return true;
        }).sort(function (a, b) { return b.amountValue - a.amountValue; });
      }

      // ── 상태 ──
      var profile = { age: 28, income: 3000, employment: 'employed', housing: 'rent', region: 'seoul', familySize: 1, hasChildren: false, childAge: null, isNewlywed: false, isPregnant: false };
      var step = 0;
      var STEPS = [
        { key: 'basic', title: '기본 정보', question: '나이와 거주 지역을 알려주세요' },
        { key: 'work', title: '일과 소득', question: '현재 상황을 알려주세요' },
        { key: 'housing', title: '주거', question: '주거 형태를 알려주세요' },
        { key: 'family', title: '가족', question: '가구 구성을 알려주세요' },
        { key: 'extra', title: '추가 정보', question: '해당되는 항목이 있다면 체크해 주세요' },
      ];

      // ── 프로필 입력 UI ──
      function renderStep() {
        var s = STEPS[step];
        $('bf-bar').style.width = ((step + 1) / STEPS.length * 100) + '%';
        $('bf-step-label').textContent = (step + 1) + ' / ' + STEPS.length;
        $('bf-back').style.visibility = step === 0 ? 'hidden' : '';
        var wrap = $('bf-step');

        var html = '<p class="bf-step__q">' + s.question + '</p>';

        if (s.key === 'basic') {
          html += '<div class="bf-field">' +
            '<label class="bf-label">나이<input type="number" id="inp-age" class="bf-input" min="15" max="80" value="' + profile.age + '" inputmode="numeric" /></label>' +
            '</div>' +
            '<div class="bf-field"><label class="bf-label">거주 지역</label>' +
            '<div class="bf-chips" id="chips-region">' +
            Object.keys(REGIONS).map(function (k) {
              return '<button type="button" class="bf-chip' + (profile.region === k ? ' is-on' : '') + '" data-val="' + k + '">' + REGIONS[k] + '</button>';
            }).join('') + '</div></div>';
        } else if (s.key === 'work') {
          var empOpts = [
            { val: 'employed', label: '직장인', icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#ecebfc"/><rect x="3.5" y="7.5" width="17" height="11" rx="3" fill="#6c5ce7"/><path d="M9 7.5v-1A1.5 1.5 0 0110.5 5h3A1.5 1.5 0 0115 6.5v1" stroke="#6c5ce7" stroke-width="1.5"/><rect x="3.5" y="11" width="17" height="2" fill="#fff" opacity=".4"/></svg>' },
            { val: 'self-employed', label: '자영업·프리랜서', icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#fef3c7"/><rect x="5" y="6" width="14" height="12" rx="3" fill="#f59e0b"/><path d="M5 10h14" stroke="#fff" stroke-width="1.2"/><rect x="9" y="8" width="6" height="4" rx="1" fill="#fff" opacity=".8"/></svg>' },
            { val: 'unemployed', label: '구직 중', icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#e0f2fe"/><circle cx="11" cy="11" r="5" stroke="#3b82f6" stroke-width="2"/><path d="M15 15l3.5 3.5" stroke="#3b82f6" stroke-width="2" stroke-linecap="round"/></svg>' },
            { val: 'student', label: '학생', icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#ede9fe"/><path d="M5 9.5L12 6l7 3.5-7 3.5L5 9.5z" fill="#8b5cf6"/><path d="M8 11v4c0 1.5 1.8 2.5 4 2.5s4-1 4-2.5v-4" stroke="#8b5cf6" stroke-width="1.3"/></svg>' },
          ];
          html += '<div class="bf-field"><label class="bf-label">고용 상태</label>' +
            '<div class="bf-opts" id="opts-emp">' +
            empOpts.map(function (o) {
              return '<button type="button" class="bf-opt' + (profile.employment === o.val ? ' is-on' : '') + '" data-val="' + o.val + '">' +
                '<span class="bf-opt__icon">' + o.icon + '</span><span>' + o.label + '</span></button>';
            }).join('') + '</div></div>' +
            '<div class="bf-field">' +
            '<label class="bf-label">연소득 (만원)<input type="number" id="inp-income" class="bf-input" min="0" max="30000" step="100" value="' + profile.income + '" inputmode="numeric" /></label>' +
            '<input type="range" id="rng-income" class="bf-range" min="0" max="15000" step="100" value="' + Math.min(profile.income, 15000) + '" />' +
            '<div class="bf-range-labels"><span>0</span><span>3,000</span><span>6,000</span><span>9,000</span><span>1.5억</span></div>' +
            '</div>';
        } else if (s.key === 'housing') {
          var housingOpts = [
            { val: 'own', label: '자가', icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#dcfce7"/><path d="M4 12l8-7 8 7" stroke="#22c55e" stroke-width="2" stroke-linecap="round"/><rect x="7" y="12" width="10" height="7" rx="1" fill="#22c55e"/><rect x="10" y="14" width="4" height="5" rx=".5" fill="#fff"/></svg>' },
            { val: 'jeonse', label: '전세', icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#e0f2fe"/><rect x="6" y="7" width="12" height="12" rx="2" fill="#3b82f6"/><rect x="8" y="9" width="3" height="2.5" rx=".5" fill="#fff" opacity=".8"/><rect x="13" y="9" width="3" height="2.5" rx=".5" fill="#fff" opacity=".8"/><rect x="8" y="13" width="3" height="2.5" rx=".5" fill="#fff" opacity=".8"/><rect x="13" y="13" width="3" height="2.5" rx=".5" fill="#fff" opacity=".8"/></svg>' },
            { val: 'rent', label: '월세', icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#fef3c7"/><circle cx="12" cy="10" r="4" stroke="#f59e0b" stroke-width="2"/><circle cx="12" cy="10" r="1.5" fill="#f59e0b"/><path d="M12 14v4" stroke="#f59e0b" stroke-width="2" stroke-linecap="round"/></svg>' },
            { val: 'parents', label: '부모님 집', icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="#fce7f3"/><path d="M4 13l8-8 8 8" stroke="#ec4899" stroke-width="2" stroke-linecap="round"/><rect x="7" y="13" width="10" height="6" rx="1" fill="#ec4899"/><circle cx="10" cy="16" r="1.2" fill="#fff"/><circle cx="14" cy="16" r="1.2" fill="#fff"/></svg>' },
          ];
          html += '<div class="bf-opts" id="opts-housing">' +
            housingOpts.map(function (o) {
              return '<button type="button" class="bf-opt' + (profile.housing === o.val ? ' is-on' : '') + '" data-val="' + o.val + '">' +
                '<span class="bf-opt__icon">' + o.icon + '</span><span>' + o.label + '</span></button>';
            }).join('') + '</div>';
        } else if (s.key === 'family') {
          html += '<div class="bf-field">' +
            '<label class="bf-label">가구원 수 (본인 포함)<input type="number" id="inp-fam" class="bf-input" min="1" max="10" value="' + profile.familySize + '" inputmode="numeric" /></label></div>' +
            '<div class="bf-field"><label class="bf-label">자녀 여부</label>' +
            '<div class="bf-opts" id="opts-children">' +
            '<button type="button" class="bf-opt' + (!profile.hasChildren ? ' is-on' : '') + '" data-val="no"><span>없음</span></button>' +
            '<button type="button" class="bf-opt' + (profile.hasChildren ? ' is-on' : '') + '" data-val="yes"><span>있음</span></button>' +
            '</div></div>' +
            '<div class="bf-field" id="child-age-wrap"' + (!profile.hasChildren ? ' hidden' : '') + '>' +
            '<label class="bf-label">막내 자녀 나이<input type="number" id="inp-child-age" class="bf-input" min="0" max="18" value="' + (profile.childAge ?? 0) + '" inputmode="numeric" /></label></div>';
        } else if (s.key === 'extra') {
          html += '<div class="bf-checks">' +
            '<label class="bf-check"><input type="checkbox" id="chk-newlywed" ' + (profile.isNewlywed ? 'checked' : '') + ' /><span>신혼부부 (혼인 7년 이내)</span></label>' +
            '<label class="bf-check"><input type="checkbox" id="chk-pregnant" ' + (profile.isPregnant ? 'checked' : '') + ' /><span>임신 중이거나 2년 이내 출산</span></label>' +
            '</div>';
        }

        wrap.innerHTML = html;
        bindStepEvents();
        checkNext();
      }

      function bindStepEvents() {
        var s = STEPS[step];
        if (s.key === 'basic') {
          var ageInp = $('inp-age');
          ageInp.addEventListener('input', function () { profile.age = parseInt(this.value) || 0; checkNext(); });
          $('chips-region').addEventListener('click', function (ev) {
            var btn = ev.target.closest('.bf-chip'); if (!btn) return;
            profile.region = btn.dataset.val;
            this.querySelectorAll('.bf-chip').forEach(function (c) { c.classList.toggle('is-on', c.dataset.val === profile.region); });
            checkNext();
          });
        } else if (s.key === 'work') {
          $('opts-emp').addEventListener('click', function (ev) {
            var btn = ev.target.closest('.bf-opt'); if (!btn) return;
            profile.employment = btn.dataset.val;
            this.querySelectorAll('.bf-opt').forEach(function (c) { c.classList.toggle('is-on', c.dataset.val === profile.employment); });
            checkNext();
          });
          var incInp = $('inp-income'), rng = $('rng-income');
          incInp.addEventListener('input', function () { profile.income = parseInt(this.value) || 0; rng.value = Math.min(profile.income, 15000); checkNext(); });
          rng.addEventListener('input', function () { profile.income = parseInt(this.value) || 0; incInp.value = profile.income; checkNext(); });
        } else if (s.key === 'housing') {
          $('opts-housing').addEventListener('click', function (ev) {
            var btn = ev.target.closest('.bf-opt'); if (!btn) return;
            profile.housing = btn.dataset.val;
            this.querySelectorAll('.bf-opt').forEach(function (c) { c.classList.toggle('is-on', c.dataset.val === profile.housing); });
            checkNext();
          });
        } else if (s.key === 'family') {
          $('inp-fam').addEventListener('input', function () { profile.familySize = parseInt(this.value) || 1; checkNext(); });
          $('opts-children').addEventListener('click', function (ev) {
            var btn = ev.target.closest('.bf-opt'); if (!btn) return;
            profile.hasChildren = btn.dataset.val === 'yes';
            this.querySelectorAll('.bf-opt').forEach(function (c) { c.classList.toggle('is-on', (c.dataset.val === 'yes') === profile.hasChildren); });
            var caw = $('child-age-wrap'); if (caw) caw.hidden = !profile.hasChildren;
            checkNext();
          });
          var caInp = $('inp-child-age');
          if (caInp) caInp.addEventListener('input', function () { profile.childAge = parseInt(this.value) || 0; });
        } else if (s.key === 'extra') {
          $('chk-newlywed').addEventListener('change', function () { profile.isNewlywed = this.checked; });
          $('chk-pregnant').addEventListener('change', function () { profile.isPregnant = this.checked; });
        }
      }

      function checkNext() {
        var s = STEPS[step];
        var valid = true;
        if (s.key === 'basic') valid = profile.age >= 15 && profile.age <= 80 && profile.region;
        else if (s.key === 'work') valid = profile.employment && profile.income >= 0;
        else if (s.key === 'housing') valid = !!profile.housing;
        else if (s.key === 'family') valid = profile.familySize >= 1;
        $('bf-next').disabled = !valid;
      }

      // ── 결과 대시보드 ──
      // 로그인 여부 확인
      function isLoggedIn() {
        try { return Object.keys(localStorage).some(function (k) { return k.includes('-auth-token'); }); } catch (e) { return false; }
      }
      var FREE_LIMIT = 3; // 비회원에게 보여줄 카드 수

      function showResults() {
        var results = match(profile);
        var total = results.reduce(function (s, b) { return s + b.amountValue; }, 0);
        var loggedIn = isLoggedIn();

        $('bf-result-title').textContent = '받을 수 있는 혜택 ' + results.length + '건';
        $('bf-result-amount').innerHTML = '예상 총 <strong>' + total.toLocaleString() + '만원</strong>/년';

        // "놓쳤을 수 있는 금액" — 나이 기반으로 신청 가능했던 기간 추정
        var missedEl = $('bf-missed');
        if (total > 0 && profile.age > 20) {
          var yearsCouldHave = Math.min(profile.age - 19, 5); // 최대 5년 추정
          var missedTotal = total * yearsCouldHave;
          missedEl.innerHTML = '지금까지 놓쳤을 수 있는 금액: 약 <strong>' + missedTotal.toLocaleString() + '만원</strong>';
          missedEl.hidden = false;
        }

        // 카테고리 필터
        var cats = {};
        results.forEach(function (b) { cats[b.category] = (cats[b.category] || 0) + 1; });
        var filterHtml = '<button type="button" class="bf-filter is-on" data-cat="all">전체 ' + results.length + '</button>';
        Object.keys(cats).forEach(function (c) {
          var ci = CATS[c];
          filterHtml += '<button type="button" class="bf-filter" data-cat="' + c + '">' + ci.icon + ' ' + ci.name + ' ' + cats[c] + '</button>';
        });
        $('bf-filters').innerHTML = filterHtml;

        // 카테고리별 금액 분포 인포그래픽
        var catAmounts = {};
        results.forEach(function (b) { catAmounts[b.category] = (catAmounts[b.category] || 0) + b.amountValue; });
        var maxCatAmount = Math.max.apply(null, Object.values(catAmounts).concat([1]));
        var chartHtml = '<div class="bf-chart">';
        Object.keys(catAmounts).forEach(function (c) {
          var ci = CATS[c]; if (!ci) return;
          var pct = Math.round(catAmounts[c] / maxCatAmount * 100);
          chartHtml += '<div class="bf-chart__row">' +
            '<span class="bf-chart__label">' + ci.name + '</span>' +
            '<div class="bf-chart__track"><div class="bf-chart__bar" style="width:' + pct + '%;background:' + ci.color + '"></div></div>' +
            '<span class="bf-chart__val">' + catAmounts[c].toLocaleString() + '만</span></div>';
        });
        chartHtml += '</div>';
        $('bf-filters').insertAdjacentHTML('afterend', chartHtml);

        // 필터 이벤트
        $('bf-filters').addEventListener('click', function (ev) {
          var btn = ev.target.closest('.bf-filter'); if (!btn) return;
          var cat = btn.dataset.cat;
          this.querySelectorAll('.bf-filter').forEach(function (f) { f.classList.toggle('is-on', f.dataset.cat === cat); });
          document.querySelectorAll('.bf-card').forEach(function (card) {
            card.hidden = cat !== 'all' && card.dataset.cat !== cat;
