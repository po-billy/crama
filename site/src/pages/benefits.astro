              return '<div class="bf-card bf-card--blur" aria-hidden="true">' +
                '<h3 class="bf-card__title">' + b.name.replace(/./g, '●') + '</h3>' +
                '<p class="bf-card__summary">이 혜택의 상세 조건과 신청 방법은 로그인 후 확인할 수 있습니다.</p>' +
