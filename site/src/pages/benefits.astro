    .bf-result { padding: 0 0 3rem; }
    .bf-result__hero {
      text-align: center; padding: 2.5rem 1rem;
      background: linear-gradient(135deg, var(--accent) 0%, #8b5cf6 100%);
      border-radius: 16px; color: #fff; margin-bottom: 1.5rem;
    }
    .bf-result__eyebrow { font-size: 0.8rem; font-weight: 600; opacity: 0.8; margin: 0 0 0.5rem; letter-spacing: 0.08em; }
    .bf-result__title { font-family: var(--font-serif); font-size: 1.6rem; margin: 0 0 0.6rem; }
    .bf-result__amount { font-size: 2rem; font-weight: 800; margin: 0; }
    .bf-result__amount strong { font-size: 2.4rem; }
    .bf-result__sub { font-size: 0.78rem; opacity: 0.7; margin: 0.3rem 0 0; }
    .bf-result__missed {
      font-size: 0.85rem; margin: 0.8rem 0 0; padding: 0.5rem 1rem;
      background: rgba(255,255,255,0.15); border-radius: 8px; opacity: 0.9;
