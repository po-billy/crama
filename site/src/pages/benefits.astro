        // 이용 횟수 카운터 (localStorage)
        try {
          var useCount = parseInt(localStorage.getItem('crama:bf:uses') || '0') + 1;
          localStorage.setItem('crama:bf:uses', String(useCount));
        } catch (e) {}
        try { if (window.gtag) gtag('event', 'benefits_result', { count: results.length, total: total, loggedIn: loggedIn }); } catch (e) {}
