    .bf-gate__inner {
      text-align: center; padding: 2rem 1.5rem;
      border: 2px solid var(--accent); border-radius: 16px;
      background: var(--paper);
    }
    .bf-gate__icon { display: flex; justify-content: center; margin-bottom: 0.6rem; }
    .bf-gate__title { font-family: var(--font-serif); font-size: 1.2rem; margin: 0 0 0.5rem; }
    .bf-gate__desc { font-size: 0.92rem; color: var(--ink-soft); margin: 0 0 1.2rem; line-height: 1.6; }
    .bf-gate__btn {
      display: inline-block; padding: 0.85rem 2rem;
      background: var(--accent); color: #fff; font-weight: 700; font-size: 1rem;
      border-radius: 12px; text-decoration: none; transition: all 0.15s;
    }
    .bf-gate__btn:hover { filter: brightness(1.1); transform: translateY(-1px); color: #fff; }
    .bf-gate__note { font-size: 0.75rem; color: var(--muted); margin: 0.8rem 0 0; }

    /* ── 빈 상태 ── */
    .bf-empty { text-align: center; padding: 3rem 1rem; color: var(--muted); }
    .bf-empty__icon { font-size: 2.5rem; margin-bottom: 0.5rem; }

    /* ── 하단 액션 ── */
    .bf-result__actions { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 2rem; }
    .bf-result__actions .bf-cta { flex: 1; min-width: 8rem; }
    .bf-result__cta-box {
      text-align: center; padding: 1rem; margin-top: 1rem;
      background: var(--accent-soft); border-radius: 10px;
      font-size: 0.9rem; color: var(--accent); font-weight: 500;
    }
    .bf-result__note {
      margin-top: 2rem; padding: 1rem 1.2rem;
      background: var(--paper-2); border-radius: 10px;
      font-size: 0.8rem; color: var(--muted); line-height: 1.7;
    }
    .bf-result__note p { margin: 0.3rem 0; }

    /* ── 크로스 연결 ── */
    .bf-cross { display: flex; flex-direction: column; gap: 0.6rem; margin: 1.5rem 0; }
    .bf-cross__card {
      display: flex; align-items: center; gap: 0.8rem; padding: 1rem 1.2rem;
      border: 1px solid var(--line); border-radius: 12px; background: var(--paper);
      text-decoration: none; color: var(--ink); transition: border-color 0.12s, box-shadow 0.12s;
    }
    .bf-cross__card:hover { border-color: var(--accent); box-shadow: 0 2px 8px rgba(0,0,0,.05); }
    .bf-cross__icon { flex: none; display: flex; align-items: center; }
    .bf-cross__icon .duoicon { width: 24px; height: 24px; }
    .bf-cross__card div { flex: 1; }
    .bf-cross__card strong { font-size: 0.95rem; display: block; }
    .bf-cross__card p { font-size: 0.82rem; color: var(--muted); margin: 0.2rem 0 0; }
    .bf-cross__arrow { font-size: 1.2rem; color: var(--accent); flex: none; font-weight: 700; }

    /* ── 반응형 ── */
    @media (max-width: 640px) {
      .bf { padding: 0 0.5rem; }
      .bf-hero__title { font-size: 1.6rem; }
      .bf-hero__stats { gap: 0.8rem; padding: 0.8rem 0.5rem; }
      .bf-hero__stats .bf-stat__num { font-size: 1.2rem; }
      .bf-result__hero { padding: 1.5rem 0.8rem; border-radius: 12px; }
      .bf-result__amount { font-size: 1.5rem; }
      .bf-result__amount strong { font-size: 1.8rem; }
      .bf-card { padding: 1rem; }
      .bf-card__title { font-size: 1rem; }
      .bf-filters { gap: 0.3rem; }
      .bf-filter { padding: 0.35rem 0.7rem; font-size: 0.78rem; }
      .bf-chips { gap: 0.3rem; }
      .bf-chip { padding: 0.4rem 0.7rem; font-size: 0.82rem; }
      .bf-cross__card { padding: 0.8rem 1rem; }
      .bf-gate__inner { padding: 1.5rem 1rem; }
      .bf-gate__title { font-size: 1.05rem; }
    }
    @media (max-width: 480px) {
      .bf-opts { grid-template-columns: 1fr 1fr; }
      .bf-result__actions { flex-direction: column; }
      .bf-cta { font-size: 0.95rem; padding: 0.85rem; }
    }
  </style>
</BaseLayout>
