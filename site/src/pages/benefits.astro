                  '<h3 class="bf-gate__title">나머지 ' + lockedCount + '건의 혜택이 더 있어요</h3>' +
                  '<p class="bf-gate__desc">무료 로그인하면 전체 결과 + 신청 링크 + 프로필 저장까지 모두 이용할 수 있어요.</p>' +
                  '<a class="bf-gate__btn" href="/login/">무료 로그인하고 전체 보기 →</a>' +
                  '<p class="bf-gate__note">가입 30초 · 완전 무료 · 광고 없음</p>' +
                '</div>' +
              '</div>' +
            '</div>';
          }
          cardsHtml = visible + gateHtml;
        }

        $('bf-cards').innerHTML = cardsHtml;

        // 캘린더 추가 버튼
        $('bf-cards').addEventListener('click', function (ev) {
          var btn = ev.target.closest('.bf-card__ical'); if (!btn) return;
          var title = btn.dataset.title, date = btn.dataset.date;
          if (!date) return;
          var d = new Date(date);
          var pad = function (n) { return String(n).padStart(2, '0'); };
          var dtStart = d.getFullYear() + pad(d.getMonth() + 1) + pad(d.getDate());
          var nd = new Date(d); nd.setDate(nd.getDate() + 1);
          var dtEnd = nd.getFullYear() + pad(nd.getMonth() + 1) + pad(nd.getDate());
          var ics = ['BEGIN:VCALENDAR','VERSION:2.0','BEGIN:VEVENT',
            'DTSTART;VALUE=DATE:' + dtStart, 'DTEND;VALUE=DATE:' + dtEnd,
            'SUMMARY:' + title + ' 마감', 'DESCRIPTION:크라마 내 혜택 찾기에서 확인: https://crama.app/benefits/',
            'BEGIN:VALARM','TRIGGER:-P1D','ACTION:DISPLAY','DESCRIPTION:내일: ' + title,'END:VALARM',
            'END:VEVENT','END:VCALENDAR'].join('\r\n');
