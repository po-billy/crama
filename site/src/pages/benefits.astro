    .bf-result__missed strong { font-weight: 800; }
    .bf-result__saved-note { text-align: center; font-size: 0.88rem; color: var(--muted); margin: -0.5rem 0 1.5rem; }

    /* ── 카테고리 필터 ── */
    .bf-filters { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.2rem; overflow-x: auto; padding-bottom: 0.3rem; }
    .bf-filter {
      padding: 0.4rem 0.9rem; border: 1px solid var(--line); border-radius: 20px;
      background: var(--paper); font: inherit; font-size: 0.82rem; font-weight: 500;
      color: var(--ink-soft); cursor: pointer; white-space: nowrap; transition: all 0.12s;
    }
    .bf-filter:hover { border-color: var(--accent); }
    .bf-filter.is-on { background: var(--ink); color: var(--paper); border-color: var(--ink); }

    /* ── 혜택 카드 ── */
    .bf-cards { display: flex; flex-direction: column; gap: 1rem; }
    .bf-card {
      border: 1px solid var(--line); border-radius: 14px; padding: 1.3rem 1.4rem;
      background: var(--paper); transition: box-shadow 0.15s;
    }
    .bf-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.06); }
    .bf-card__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.6rem; }
    .bf-card__cat { font-size: 0.78rem; font-weight: 600; color: var(--cat-color, var(--accent)); }
    .bf-card__dday {
      font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.6rem;
      border-radius: 6px; background: var(--paper-2); color: var(--ink-soft);
    }
    .bf-card__dday--urgent { background: #fee2e2; color: #dc2626; }
    .bf-card__dday--expired { background: var(--paper-2); color: var(--muted); text-decoration: line-through; }
    .bf-card__title { font-size: 1.1rem; font-weight: 700; margin: 0 0 0.5rem; line-height: 1.35; }
    .bf-card__summary { font-size: 0.9rem; color: var(--ink-soft); line-height: 1.6; margin: 0 0 0.8rem; }
    .bf-card__amount {
      font-size: 1rem; font-weight: 800; color: var(--accent);
      padding: 0.6rem 0.8rem; background: var(--accent-soft); border-radius: 8px;
      margin-bottom: 0.6rem; display: inline-block;
    }
    .bf-card__deadline { font-size: 0.82rem; color: var(--muted); margin: 0 0 0.6rem; }
    .bf-card__foot { display: flex; justify-content: space-between; align-items: center; margin-top: 0.8rem; padding-top: 0.8rem; border-top: 1px solid var(--line); }
    .bf-card__method { font-size: 0.8rem; color: var(--muted); flex: 1; }
    .bf-card__ease { font-size: 0.7rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 4px; white-space: nowrap; }
    .bf-card__ease--easy { background: #dcfce7; color: #16a34a; }
    .bf-card__ease--visit { background: #fef9c3; color: #a16207; }
    .bf-card__ical {
      background: none; border: 1px solid var(--line); border-radius: 6px;
      padding: 0.2rem 0.5rem; font-size: 0.8rem; cursor: pointer; transition: border-color 0.12s;
    }
    .bf-card__ical:hover { border-color: var(--accent); }

    /* 카테고리 분포 차트 */
    .bf-chart { margin-bottom: 1.2rem; padding: 0.8rem 1rem; background: var(--paper-2); border-radius: 10px; }
    .bf-chart__row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
    .bf-chart__row:last-child { margin-bottom: 0; }
    .bf-chart__label { font-size: 0.75rem; font-weight: 600; color: var(--ink-soft); min-width: 4rem; }
    .bf-chart__track { flex: 1; height: 8px; background: var(--line); border-radius: 4px; overflow: hidden; }
    .bf-chart__bar { height: 100%; border-radius: 4px; transition: width 0.6s ease; }
    .bf-chart__val { font-size: 0.72rem; font-weight: 700; color: var(--muted); min-width: 3.5rem; text-align: right; }
    .bf-card__apply {
      font-size: 0.88rem; font-weight: 700; color: var(--accent);
      text-decoration: none; padding: 0.4rem 0.9rem; border: 1px solid var(--accent);
      border-radius: 8px; transition: all 0.12s;
    }
    .bf-card__apply:hover { background: var(--accent); color: #fff; }
    .bf-card__related {
      display: block; margin-top: 0.6rem; font-size: 0.84rem; color: var(--ink-soft);
      text-decoration: none; padding: 0.5rem 0.8rem; background: var(--paper-2);
      border-radius: 8px; transition: color 0.12s;
    }
    .bf-card__related:hover { color: var(--accent); }

    /* ── 블러 카드 (비회원) ── */
    .bf-card--blur {
      filter: blur(6px); pointer-events: none; user-select: none; opacity: 0.5;
    }

    /* ── 프리미엄 게이트 ── */
    .bf-gate { position: relative; margin-top: -1rem; }
    .bf-gate__blur { pointer-events: none; }
    .bf-gate__cta {
      position: relative; z-index: 2; margin-top: -3rem;
      background: linear-gradient(to bottom, transparent, var(--paper) 2rem);
      padding-top: 4rem;
