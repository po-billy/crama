      });

      // 소셜 프루프 — 이용 횟수 기반
      try {
        var uses = parseInt(localStorage.getItem('crama:bf:uses') || '0');
        var socialEl = $('bf-social');
        if (socialEl && uses > 0) {
          socialEl.innerHTML = '지금까지 <strong>' + uses + '번</strong> 혜택을 찾아봤어요';
          socialEl.hidden = false;
        }
      } catch (e) {}

      // ── 저장된 프로필 복원 ──
      try {
        var saved = localStorage.getItem(STORAGE_KEY);
        if (saved) {
          var p = JSON.parse(saved);
          Object.assign(profile, p);
          // 바로 결과 표시
          showSection('bf-result');
          showResults();
          // "프로필 수정" 안내
          $('bf-result-title').insertAdjacentHTML('afterend', '<p class="bf-result__saved-note">저장된 프로필로 결과를 보여드리고 있어요. <button type="button" id="bf-edit" class="bf-link">수정하기</button></p>');
          $('bf-edit').addEventListener('click', function () { showSection('bf-flow'); step = 0; renderStep(); });
        }
      } catch (e) {}
    })();
  </script>

  <style is:global>
    /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
