            var diff = Math.ceil((dl - now) / 86400000);
            if (diff < 0) ddayHtml = '<span class="bf-card__dday bf-card__dday--expired">마감됨</span>';
            else if (diff === 0) ddayHtml = '<span class="bf-card__dday bf-card__dday--urgent">D-Day</span>';
            else if (diff <= 60) ddayHtml = '<span class="bf-card__dday bf-card__dday--urgent">D-' + diff + '</span>';
            else ddayHtml = '<span class="bf-card__dday">D-' + diff + '</span>';
          }
          return '<div class="bf-card" data-cat="' + b.category + '">' +
            '<div class="bf-card__head"><span class="bf-card__cat" style="--cat-color:' + ci.color + '">' + ci.icon + ' ' + ci.name + '</span>' + ddayHtml + '</div>' +
            '<h3 class="bf-card__title">' + b.name + '</h3>' +
            '<p class="bf-card__summary">' + b.summary + '</p>' +
            '<div class="bf-card__amount">' + b.amount + '</div>' +
            (b.deadlineLabel ? '<p class="bf-card__deadline">' + b.deadlineLabel + '</p>' : '') +
            '<div class="bf-card__foot">' +
            '<span class="bf-card__method">' + b.applyMethod + '</span>' +
            (b.applyMethod.indexOf('온라인') !== -1 || b.applyMethod.indexOf('앱') !== -1
              ? '<span class="bf-card__ease bf-card__ease--easy">간편 신청</span>'
              : b.applyMethod.indexOf('방문') !== -1
              ? '<span class="bf-card__ease bf-card__ease--visit">방문 필요</span>'
              : '') +
            (b.deadline && b.deadline !== '상시' ? '<button class="bf-card__ical" type="button" data-title="' + b.name + '" data-date="' + b.deadline + '" title="캘린더에 추가">📅</button>' : '') +
            '<a class="bf-card__apply" href="' + b.applyUrl + '" target="_blank" rel="noopener">신청하기 →</a></div>' +
            (b.relatedSlug ? '<a class="bf-card__related" href="/blog/' + b.relatedSlug + '/">자세한 가이드 읽기 →</a>' : '') +
          '</div>';
        }

        var cardsHtml = '';
        if (results.length === 0) {
          cardsHtml = '<div class="bf-empty"><p class="bf-empty__icon" style="opacity:.4;"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg></p><p>입력하신 조건에 맞는 혜택을 찾지 못했어요.</p></div>';
