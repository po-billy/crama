---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { PILLARS, type CategorySlug } from '../../consts';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, all: posts },
  }));
}

const { post, all } = Astro.props;
const { Content, headings } = await render(post);

// 읽는 시간 추정(한글 기준 분당 ~500자)
const words = post.body?.length ?? 0;
const readingTime = Math.max(1, Math.round(words / 500));

// 오디오 '이어 듣기' 다음 글 — 두 모드 모두 '시간 역순 바로 다음(더 이전) 글'이라 항상
// 더 오래된 글로만 이동 → 한 방향으로 흘러 루프가 없다(끝에 닿으면 종료). 날짜 동점은 slug로 안정 정렬.
//   nextHrefAll : 전체 글 시간 역순(카테고리 무관) — 기본값(data-next-article)
//   nextHrefCat : 같은 카테고리 내 시간 역순 — 옵션(data-next-cat)
const byTime = (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf() || (a.id < b.id ? -1 : 1);
const nextIn = (list) => {
  const i = list.findIndex((p) => p.id === post.id);
  return i >= 0 && i + 1 < list.length ? `/blog/${list[i + 1].id}/` : '';
};
const nextHrefAll = nextIn([...all].sort(byTime));
const nextHrefCat = nextIn(all.filter((p) => p.data.category === post.data.category).sort(byTime));

// 관련글 — 태그 겹침 점수 + 같은 카테고리 우선(단순 최신순보다 정확한 추천)
const postTags = new Set(post.data.tags ?? []);
const related = all
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const sameCat = p.data.category === post.data.category ? 2 : 0;
    const tagOverlap = (p.data.tags ?? []).filter((t: string) => postTags.has(t)).length;
    return { post: p, score: sameCat + tagOverlap };
  })
  .filter((r) => r.score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 4)
  .map((r) => ({
    href: `/blog/${r.post.id}/`,
    title: r.post.data.title,
    description: r.post.data.description,
    pubDate: r.post.data.pubDate,
    category: r.post.data.category as CategorySlug,
    heroImage: r.post.data.heroImage,
    format: r.post.data.format,
  }));

// 이전/다음 글 네비게이션 (시간순 기준, 같은 카테고리 내)
const catPosts = all.filter((p) => p.data.category === post.data.category).sort(byTime);
const catIdx = catPosts.findIndex((p) => p.id === post.id);
const prevPost = catIdx > 0 ? catPosts[catIdx - 1] : null;       // 더 새로운 글
const nextPost = catIdx >= 0 && catIdx < catPosts.length - 1 ? catPosts[catIdx + 1] : null; // 더 오래된 글
const prevNav = prevPost ? { href: `/blog/${prevPost.id}/`, title: prevPost.data.title } : undefined;
const nextNav = nextPost ? { href: `/blog/${nextPost.id}/`, title: nextPost.data.title } : undefined;

// 이 글이 속한 필러(허브) 가이드 — 자기 자신이 아니면 백링크 제공(양방향 링크)
const pillarSlug = PILLARS[post.data.category];
const pillarPost = pillarSlug && pillarSlug !== post.id ? all.find((p) => p.id === pillarSlug) : null;
const guide = pillarPost ? { title: pillarPost.data.title, href: `/blog/${pillarPost.id}/` } : undefined;
---
<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  author={post.data.author}
  format={post.data.format}
  heroImage={post.data.heroImage}
  readingTime={readingTime}
  premium={post.data.premium}
  audioSrc={post.data.audio}
  tags={post.data.tags}
  headings={headings}
  related={related}
  nextHref={nextHrefAll}
  nextHrefCat={nextHrefCat}
  guide={guide}
  prevNav={prevNav}
  nextNav={nextNav}
>
  <Content />
</PostLayout>
