---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import BriefSubscribe from '../../components/BriefSubscribe.astro';
import DuoIcon from '../../components/DuoIcon.astro';
import { CATEGORIES, type CategorySlug } from '../../consts';
const SU = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const AK = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const today = posts[0];
const recent = posts.slice(1, 13);
const todayAudio = today ? !!today.data.audio : false;
---
<BaseLayout
  title="오늘의 브리핑 — 매일 아침 3분 | 크라마"
  description="매일 아침, 오늘 꼭 알아야 할 돈·AI·생활경제를 3분 브리핑으로. 먼저 읽는 사람들의 데일리 브리핑, 크라마(Crama)."
>
  <div class="wrap">
    <header class="page-hero brief-hero">
      <span class="eyebrow">Daily Briefing</span>
      <h1>매일 아침, <strong>3분 브리핑</strong></h1>
      <p>오늘 꼭 알아야 할 <b>돈·AI·생활경제</b>를 딱 3분에. <br class="brief-hero__br" />읽거나, 출근길에 들으세요. 정보의 시차를 0으로.</p>
    </header>

    <!-- 브리핑 받는 방법 — 1줄 컴팩트 -->
    <section class="brief-subscribe-row">
      <div class="brief-subscribe-row__push">
        <BriefSubscribe />
      </div>
      <span class="brief-subscribe-row__or">또는</span>
      <form class="brief-email" id="brief-email-form">
        <input type="email" name="email" required placeholder="이메일로 받기" aria-label="이메일 주소" />
        <input type="text" name="hp" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <button type="submit">신청</button>
      </form>
      <p class="brief-email-status" id="brief-email-status" role="status" aria-live="polite"></p>
    </section>

    {today && (
      <section class="brief-section">
        <div class="section-head"><h2>오늘의 브리핑</h2></div>
        <a class="brief-today" href={`/blog/${today.id}/`}>
          {today.data.heroImage && (
            <div class="brief-today__media"><img src={today.data.heroImage} alt="" loading="eager" /></div>
          )}
          <div class="brief-today__body">
            <span class="brief-today__tag">
              {CATEGORIES[today.data.category as CategorySlug]?.name}<span aria-hidden="true"> · </span><FormattedDate date={today.data.pubDate} />
            </span>
            <h3>{today.data.title}</h3>
            <p>{today.data.description}</p>
            <span class="brief-today__cta">{todayAudio ? '▶ 3분 듣기' : '읽어보기'} →</span>
          </div>
        </a>
      </section>
    )}

    <!-- 왜 매일 브리핑 -->
    <section class="brief-why">
      <div class="brief-why__item"><b>먼저</b><span>남보다 한발 빠르게</span></div>
      <div class="brief-why__item"><b>3분</b><span>핵심만, 짧게</span></div>
      <div class="brief-why__item"><b>매일 아침</b><span>출근길 루틴으로</span></div>
    </section>

    {recent.length > 0 && (
      <section class="brief-section">
        <div class="section-head"><h2>지난 브리핑</h2></div>
        <div class="card-grid">
          {recent.map((p) => (
            <PostCard
              href={`/blog/${p.id}/`}
              title={p.data.title}
              description={p.data.description}
              pubDate={p.data.pubDate}
              category={p.data.category as CategorySlug}
              heroImage={p.data.heroImage}
              thumb={p.data.thumb}
              audio={!!p.data.audio}
              format={p.data.format}
            />
          ))}
        </div>
      </section>
    )}

    <!-- 서비스 소개 -->
    <section class="brief-section">
      <div class="section-head"><h2>브리핑 너머, 더 챙기세요</h2></div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.7rem;margin-top:1rem;">
        <a href="/benefits/" style="display:flex;flex-direction:column;align-items:center;gap:.4rem;padding:1.2rem;border:1px solid var(--line);border-radius:14px;text-decoration:none;color:var(--ink);background:var(--paper);transition:border-color .12s,box-shadow .12s;">
          <DuoIcon name="benefits" class="svc-ico" />
          <strong style="font-size:.92rem;">내 혜택 찾기</strong>
          <span style="font-size:.78rem;color:var(--muted);text-align:center;">나에게 해당되는 지원금을 3분 만에</span>
        </a>
        <a href="/checkup/" style="display:flex;flex-direction:column;align-items:center;gap:.4rem;padding:1.2rem;border:1px solid var(--line);border-radius:14px;text-decoration:none;color:var(--ink);background:var(--paper);transition:border-color .12s,box-shadow .12s;">
          <DuoIcon name="checkup" class="svc-ico" />
          <strong style="font-size:.92rem;">재무 건강 체크업</strong>
          <span style="font-size:.78rem;color:var(--muted);text-align:center;">내 돈 상태를 5분 만에 진단</span>
        </a>
        <a href="/policy-calendar/" style="display:flex;flex-direction:column;align-items:center;gap:.4rem;padding:1.2rem;border:1px solid var(--line);border-radius:14px;text-decoration:none;color:var(--ink);background:var(--paper);transition:border-color .12s,box-shadow .12s;">
          <DuoIcon name="calendar" class="svc-ico" />
          <strong style="font-size:.92rem;">정책 캘린더</strong>
          <span style="font-size:.78rem;color:var(--muted);text-align:center;">놓치면 손해인 일정 한눈에</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .brief-hero strong { color: var(--accent); }
  .brief-section { margin-bottom: 2.6rem; }

  /* 브리핑 받기 — 푸시 | 또는 | 이메일 1줄 */
  .brief-subscribe-row {
    display: flex; align-items: center; gap: .6rem; flex-wrap: wrap;
    margin: 0 0 2rem; padding: .8rem 1rem;
    border: 1px solid var(--line); border-radius: 12px; background: var(--paper-2);
  }
  .brief-subscribe-row__push { flex: 0 0 auto; }
  .brief-subscribe-row__push .cta-card--brief { border: 0; padding: .3rem .6rem; }
  .brief-subscribe-row__or {
    flex: 0 0 auto; font-size: .8rem; color: var(--muted); font-weight: 500;
  }
  .brief-email {
    display: flex; flex: 1; min-width: 180px; gap: .4rem; align-items: center;
  }
  .brief-email input[type="email"] {
    flex: 1; padding: .45rem .65rem; border: 1px solid var(--line); border-radius: 8px;
    font-size: .85rem; background: var(--paper); color: var(--ink); min-width: 0;
  }
  .brief-email .hp { display: none; }
  .brief-email button {
    flex-shrink: 0; padding: .45rem .8rem; border: 1px solid var(--accent); background: var(--accent);
    color: #fff; font-size: .85rem; font-weight: 600; cursor: pointer;
    border-radius: 8px; transition: opacity .15s;
  }
  .brief-email button:hover { opacity: .85; }
  .brief-email-status { width: 100%; margin: .3rem 0 0; font-size: .8rem; color: var(--muted); }
  .brief-email-status:empty { display: none; }
  .brief-email-status.is-ok { color: #22c55e; }
  .brief-email-status.is-err { color: #ef4444; }
  @media (max-width: 520px) {
    .brief-subscribe-row { flex-direction: column; align-items: stretch; gap: .5rem; }
    .brief-subscribe-row__or { text-align: center; }
    .brief-email { width: 100%; }
  }

  /* 오늘의 브리핑 — 가로 피처 카드 */
  .brief-today {
    display: grid; grid-template-columns: 300px 1fr; gap: 1.4rem; align-items: stretch;
    border: 1px solid var(--line); border-radius: 14px; overflow: hidden; background: var(--paper-2);
    text-decoration: none; color: inherit; transition: border-color .15s, box-shadow .15s, transform .15s;
  }
  .brief-today:hover { border-color: var(--accent); box-shadow: 0 14px 34px -22px rgba(20,18,30,.4); transform: translateY(-2px); color: inherit; }
  .brief-today__media { background: var(--paper); }
  .brief-today__media img { width: 100%; height: 100%; object-fit: cover; display: block; min-height: 180px; }
  .brief-today__body { padding: 1.3rem 1.4rem; display: flex; flex-direction: column; gap: .5rem; justify-content: center; }
  .brief-today__tag { font-size: .78rem; font-weight: 700; color: var(--accent); letter-spacing: .01em; }
  .brief-today__body h3 { margin: 0; font-family: var(--font-serif); font-size: 1.5rem; line-height: 1.3; }
  .brief-today__body p { margin: 0; color: var(--muted); font-size: .95rem; line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .brief-today__cta { margin-top: .3rem; font-weight: 700; color: var(--accent); font-size: .95rem; }

  /* 왜 브리핑 — 3칸 가치 스트립 */
  .brief-why {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 0 0 2.8rem;
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 1.4rem 0;
  }
  .brief-why__item { text-align: center; }
  .brief-why__item b { display: block; font-family: var(--font-serif); font-size: 1.4rem; color: var(--ink); }
  .brief-why__item span { font-size: .85rem; color: var(--muted); }

  @media (max-width: 640px) {
    .brief-today { grid-template-columns: 1fr; }
    .brief-today__media img { min-height: 0; aspect-ratio: 16/9; }
    .brief-today__body { padding: 1.1rem 1.2rem; }
    .brief-today__body h3 { font-size: 1.25rem; }
    .brief-hero__br { display: none; }
  }
</style>

<script is:inline define:vars={{ SU, AK }}>
  (() => {
    const f = document.getElementById('brief-email-form');
    const s = document.getElementById('brief-email-status');
    if (!f || !SU || !AK) return;
    f.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(f).entries());
      if (data.hp) return;
      const email = (data.email || '').trim();
      if (!email) return;
      const btn = f.querySelector('button');
      btn.disabled = true;
      s.textContent = '신청 중…';
      s.className = 'brief-email-status';
      try {
        const r = await fetch(`${SU}/rest/v1/rpc/subscribe_email`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', apikey: AK, Authorization: `Bearer ${AK}` },
          body: JSON.stringify({ p_email: email }),
        });
        if (r.ok || r.status === 204) {
          f.reset();
          s.textContent = '완료! 매일 아침 메일로 보내드릴게요.';
          s.className = 'brief-email-status is-ok';
        } else {
          const t = await r.text().catch(() => '');
          s.textContent = t.includes('duplicate') ? '이미 신청되어 있어요.' : '실패했습니다. 다시 시도해 주세요.';
          s.className = 'brief-email-status is-err';
        }
      } catch {
        s.textContent = '실패했습니다. 다시 시도해 주세요.';
        s.className = 'brief-email-status is-err';
      }
      btn.disabled = false;
    });
  })();
</script>
