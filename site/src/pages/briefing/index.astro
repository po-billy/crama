---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import BriefSubscribe from '../../components/BriefSubscribe.astro';
import DuoIcon from '../../components/DuoIcon.astro';
import { CATEGORIES, type CategorySlug } from '../../consts';
const SU = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const AK = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const today = posts[0];
const recent = posts.slice(1, 13);
const todayAudio = today ? !!today.data.audio : false;
---
<BaseLayout
  title="오늘의 브리핑 — 매일 아침 3분 | 크라마"
  description="매일 아침, 오늘 꼭 알아야 할 돈·AI·생활경제를 3분 브리핑으로. 먼저 읽는 사람들의 데일리 브리핑, 크라마(Crama)."
>
  <div class="wrap">
    <header class="brief-hero">
      <span class="brief-hero__badge">Daily Briefing · 매일 아침</span>
      <h1 class="brief-hero__title">먼저 읽는 사람들의<br/><em>3분 브리핑</em></h1>
      <p class="brief-hero__lead">오늘 꼭 알아야 할 <b>돈·AI·생활경제</b>를 딱 3분에.<br class="brief-hero__br" />읽거나, 출근길에 들으세요.</p>
      <div class="brief-hero__stats">
        <div class="brief-hero__stat"><b>매일</b><span>아침 업데이트</span></div>
        <div class="brief-hero__stat"><b>3분</b><span>핵심만 요약</span></div>
        <div class="brief-hero__stat"><b>0원</b><span>완전 무료</span></div>
      </div>
    </header>

    <!-- 구독 (받아보기) -->
    <section class="brief-sub">
      <div class="brief-sub__head">
        <h2 class="brief-sub__title">매일 아침, 놓치지 않게</h2>
        <p class="brief-sub__sub">푸시 또는 이메일로 — 광고 없이 핵심만 보내드려요.</p>
      </div>
      <div class="brief-sub__grid">
        <div class="brief-sub__card">
          <div class="brief-sub__cardhead">
            <span class="brief-sub__ic brief-sub__ic--push">🔔</span>
            <div><h3>푸시 알림</h3><p>올라오면 바로 알림</p></div>
          </div>
          <div class="brief-sub__action"><BriefSubscribe /></div>
        </div>
        <div class="brief-sub__card">
          <div class="brief-sub__cardhead">
            <span class="brief-sub__ic brief-sub__ic--mail">📧</span>
            <div><h3>이메일</h3><p>메일함에서 확인</p></div>
          </div>
          <form class="brief-sub__email" id="brief-email-form">
            <input type="email" name="email" required placeholder="이메일 주소" aria-label="이메일 주소" />
            <input type="text" name="hp" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
            <button type="submit">신청</button>
          </form>
        </div>
      </div>
      <p class="brief-email-status" id="brief-email-status" role="status" aria-live="polite"></p>
    </section>

    {today && (
      <section class="brief-section">
        <p class="brief-eyebrow"><span class="brief-eyebrow__live" aria-hidden="true"></span>오늘의 브리핑<span class="brief-eyebrow__date"> · <FormattedDate date={today.data.pubDate} /></span></p>
        <a class="brief-today" href={`/blog/${today.id}/`}>
          {today.data.heroImage && (
            <div class="brief-today__media">
              <img src={today.data.heroImage} alt="" loading="eager" />
              {todayAudio && <span class="brief-today__play" aria-hidden="true">▶</span>}
            </div>
          )}
          <div class="brief-today__body">
            <span class="brief-today__tag">{CATEGORIES[today.data.category as CategorySlug]?.name}</span>
            <h2 class="brief-today__title">{today.data.title}</h2>
            <p class="brief-today__desc">{today.data.description}</p>
            <span class="brief-today__cta">{todayAudio ? '▶ 3분 듣기' : '읽어보기'} →</span>
          </div>
        </a>
      </section>
    )}

    <!-- 왜 매일 브리핑 -->
    <section class="brief-why">
      <div class="brief-why__item"><b>먼저</b><span>남보다 한발 빠르게</span></div>
      <div class="brief-why__item"><b>3분</b><span>핵심만, 짧게</span></div>
      <div class="brief-why__item"><b>매일 아침</b><span>출근길 루틴으로</span></div>
    </section>

    <!-- 브리핑 다음 행동: 내 돈 챙기기 여정 (홈과 동일 컴포넌트) -->
    <section class="brief-section">
      <div class="svc-start">
        <div class="svc-start__head">
          <span class="svc-start__badge">브리핑 너머</span>
          <p class="svc-start__title">읽었으면, 내 돈도 챙기기</p>
        </div>
        <div class="svc-start__steps">
          <a href="/benefits/" class="svc-step">
            <span class="svc-step__no">1</span>
            <span class="svc-step__ic"><DuoIcon name="benefits" /></span>
            <span class="svc-step__body"><strong>받을 돈부터 찾기</strong><small>숨은 지원금·환급 · 3분</small></span>
            <span class="svc-step__arrow">→</span>
          </a>
          <a href="/checkup/" class="svc-step">
            <span class="svc-step__no">2</span>
            <span class="svc-step__ic"><DuoIcon name="checkup" /></span>
            <span class="svc-step__body"><strong>재무 건강 진단</strong><small>저축·부채·투자 · 5분</small></span>
            <span class="svc-step__arrow">→</span>
          </a>
          <a href="/policy-calendar/" class="svc-step">
            <span class="svc-step__no">3</span>
            <span class="svc-step__ic"><DuoIcon name="calendar" /></span>
            <span class="svc-step__body"><strong>마감 일정 챙기기</strong><small>신청·세금 마감일 · 1분</small></span>
            <span class="svc-step__arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    {recent.length > 0 && (
      <section class="brief-section">
        <div class="section-head"><h2>지난 브리핑</h2></div>
        <div class="card-grid">
          {recent.map((p) => (
            <PostCard
              href={`/blog/${p.id}/`}
              title={p.data.title}
              description={p.data.description}
              pubDate={p.data.pubDate}
              category={p.data.category as CategorySlug}
              heroImage={p.data.heroImage}
              thumb={p.data.thumb}
              audio={!!p.data.audio}
              format={p.data.format}
            />
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  /* ── 히어로 (서비스 페이지 톤) ── */
  .brief-hero { text-align: center; padding: 1.4rem 0 1.7rem; }
  .brief-hero__badge {
    display: inline-block; padding: 0.32rem 0.9rem; background: var(--accent-soft); color: var(--accent);
    font-size: 0.72rem; font-weight: 800; letter-spacing: 0.05em; border-radius: 20px; margin-bottom: 1.1rem;
  }
  .brief-hero__title {
    font-family: var(--font-serif); font-size: clamp(1.95rem, 6vw, 2.8rem);
    line-height: 1.24; letter-spacing: -0.02em; margin: 0 0 1.1rem;
  }
  .brief-hero__title em { font-style: normal; color: var(--accent); }
  .brief-hero__lead { color: var(--muted); font-size: 1.05rem; line-height: 1.65; margin: 0 auto 1.9rem; max-width: 34rem; }
  .brief-hero__lead b { color: var(--ink); font-weight: 700; }
  .brief-hero__stats { display: flex; justify-content: center; gap: 0.7rem; max-width: 30rem; margin: 0 auto; }
  .brief-hero__stat { flex: 1; padding: 0.95rem 0.4rem; background: var(--paper-2); border-radius: 12px; }
  .brief-hero__stat b { display: block; font-family: var(--font-serif); font-size: 1.45rem; color: var(--ink); line-height: 1.15; }
  .brief-hero__stat span { font-size: 0.74rem; color: var(--muted); }

  .brief-section { margin-bottom: 2.8rem; }

  /* ── 에디토리얼 아이브로 (라이브 점) ── */
  .brief-eyebrow { display: flex; align-items: center; gap: 0.45rem; font-size: 0.95rem; font-weight: 800; color: var(--ink); margin: 0 0 0.9rem; }
  .brief-eyebrow__live { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,.16); animation: briefPulse 1.9s ease-in-out infinite; flex: none; }
  .brief-eyebrow__date { color: var(--muted); font-weight: 600; }
  @keyframes briefPulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: .45; transform: scale(.82); } }

  /* ── 오늘의 브리핑 (대형 피처) ── */
  .brief-today {
    display: grid; grid-template-columns: 340px 1fr; align-items: stretch;
    border: 1px solid var(--line); border-radius: 18px; overflow: hidden; background: var(--paper);
    text-decoration: none; color: inherit; transition: border-color .15s, box-shadow .18s, transform .18s;
  }
  .brief-today:hover { border-color: var(--accent); box-shadow: 0 22px 48px -28px rgba(20,18,30,.45); transform: translateY(-3px); color: inherit; }
  .brief-today__media { position: relative; background: var(--paper-2); }
  .brief-today__media img { width: 100%; height: 100%; object-fit: cover; display: block; min-height: 215px; }
  .brief-today__play {
    position: absolute; left: 0.9rem; bottom: 0.9rem; width: 2.5rem; height: 2.5rem; border-radius: 50%;
    background: rgba(0,0,0,.55); color: #fff; display: grid; place-items: center; font-size: 0.8rem;
    -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px);
  }
  .brief-today__body { padding: 1.6rem 1.7rem; display: flex; flex-direction: column; gap: .5rem; justify-content: center; }
  .brief-today__tag { align-self: flex-start; padding: 0.22rem 0.72rem; background: var(--accent-soft); color: var(--accent); font-size: .72rem; font-weight: 800; border-radius: 20px; }
  .brief-today__title { margin: 0.25rem 0 0; font-family: var(--font-serif); font-size: clamp(1.35rem, 3vw, 1.85rem); line-height: 1.3; letter-spacing: -0.01em; }
  .brief-today__desc { margin: 0; color: var(--muted); font-size: .96rem; line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .brief-today__cta { margin-top: .45rem; font-weight: 800; color: var(--accent); font-size: .96rem; }

  /* ── 구독 (받아보기) ── */
  .brief-sub { margin-bottom: 2.8rem; }
  .brief-sub__head { text-align: center; margin-bottom: 1.1rem; }
  .brief-sub__title { font-size: 1.35rem; font-weight: 800; margin: 0 0 0.3rem; letter-spacing: -0.01em; }
  .brief-sub__sub { font-size: 0.9rem; color: var(--muted); margin: 0; }
  .brief-sub__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
  .brief-sub__card { display: flex; flex-direction: column; gap: 1rem; padding: 1.3rem; border: 1px solid var(--line); border-radius: 14px; background: var(--paper); }
  .brief-sub__cardhead { display: flex; align-items: center; gap: 0.7rem; }
  .brief-sub__ic { width: 2.6rem; height: 2.6rem; border-radius: 50%; display: grid; place-items: center; font-size: 1.2rem; flex: none; }
  .brief-sub__ic--push { background: var(--accent-soft); }
  .brief-sub__ic--mail { background: var(--paper-2); }
  .brief-sub__cardhead h3 { font-size: 0.98rem; font-weight: 800; margin: 0; }
  .brief-sub__cardhead p { font-size: 0.8rem; color: var(--muted); margin: 0.1rem 0 0; }
  .brief-sub__action { margin-top: auto; }
  .brief-sub__action .cta-card--brief { border: 0; padding: 0; }
  .brief-sub__email { display: flex; gap: 0.4rem; margin-top: auto; }
  .brief-sub__email input[type="email"] { flex: 1; padding: 0.7rem 0.8rem; border: 1px solid var(--line); border-radius: 10px; font-size: 16px; background: var(--paper-2); color: var(--ink); min-width: 0; }
  .brief-sub__email input[type="email"]:focus { outline: none; border-color: var(--accent); }
  .brief-sub__email .hp { display: none; }
  .brief-sub__email button { flex-shrink: 0; padding: 0.7rem 1.1rem; border: none; background: var(--accent); color: #fff; font-size: 0.9rem; font-weight: 700; cursor: pointer; border-radius: 10px; transition: filter 0.15s; }
  .brief-sub__email button:hover { filter: brightness(1.1); }
  .brief-email-status { text-align: center; margin: 0.7rem 0 0; font-size: 0.82rem; color: var(--muted); }
  .brief-email-status:empty { display: none; }
  .brief-email-status.is-ok { color: #22c55e; }
  .brief-email-status.is-err { color: #ef4444; }

  /* ── 왜 3분 브리핑 ── */
  .brief-why {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 0 0 2.8rem;
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 1.5rem 0;
  }
  .brief-why__item { text-align: center; }
  .brief-why__item b { display: block; font-family: var(--font-serif); font-size: 1.4rem; color: var(--ink); }
  .brief-why__item span { font-size: .84rem; color: var(--muted); }

  @media (max-width: 640px) {
    .brief-today { grid-template-columns: 1fr; }
    .brief-today__media img { min-height: 0; aspect-ratio: 16/9; }
    .brief-today__body { padding: 1.2rem 1.3rem; }
    .brief-hero__br { display: none; }
  }
  @media (max-width: 520px) {
    .brief-sub__grid { grid-template-columns: 1fr; }
    .brief-hero__stat b { font-size: 1.25rem; }
  }
</style>

<script is:inline define:vars={{ SU, AK }}>
  (() => {
    const f = document.getElementById('brief-email-form');
    const s = document.getElementById('brief-email-status');
    if (!f || !SU || !AK) return;
    f.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(f).entries());
      if (data.hp) return;
      const email = (data.email || '').trim();
      if (!email) return;
      const btn = f.querySelector('button');
      btn.disabled = true;
      s.textContent = '신청 중…';
      s.className = 'brief-email-status';
      try {
        const r = await fetch(`${SU}/rest/v1/rpc/subscribe_email`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', apikey: AK, Authorization: `Bearer ${AK}` },
          body: JSON.stringify({ p_email: email }),
        });
        if (r.ok || r.status === 204) {
          f.reset();
          s.textContent = '완료! 매일 아침 메일로 보내드릴게요.';
          s.className = 'brief-email-status is-ok';
        } else {
          const t = await r.text().catch(() => '');
          s.textContent = t.includes('duplicate') ? '이미 신청되어 있어요.' : '실패했습니다. 다시 시도해 주세요.';
          s.className = 'brief-email-status is-err';
        }
      } catch {
        s.textContent = '실패했습니다. 다시 시도해 주세요.';
        s.className = 'brief-email-status is-err';
      }
      btn.disabled = false;
    });
  })();
</script>
