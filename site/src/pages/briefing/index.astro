---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import DuoIcon from '../../components/DuoIcon.astro';
import ratesData from '../../data/rates.json';
import { CATEGORIES, type CategorySlug, VAPID_PUBLIC_KEY } from '../../consts';

// 오늘의 숫자 — 12개월 최고금리(rates.json 일일 갱신)
function bestRate(list: any[]) {
  let best: number | null = null;
  for (const p of list || []) for (const o of p.options || [])
    if (o.trm === 12 && o.rate2 != null && (best == null || o.rate2 > best)) best = o.rate2;
  return best;
}
const numDep = bestRate((ratesData as any).deposits);
const numSav = bestRate((ratesData as any).savings);
const SU = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const AK = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const today = posts[0];
const recent = posts.slice(1, 13);
const todayAudio = today ? !!today.data.audio : false;
---
<BaseLayout
  title="오늘의 브리핑 — 매일 아침 3분 | 크라마"
  description="매일 아침, 오늘 꼭 알아야 할 돈·AI·생활경제를 3분 브리핑으로. 먼저 읽는 사람들의 데일리 브리핑, 크라마(Crama)."
>
  <div class="wrap">
    <header class="brief-hero">
      <span class="brief-hero__badge">Daily Briefing · 매일 아침</span>
      <h1 class="brief-hero__title">먼저 읽는 사람들의<br/><em>3분 브리핑</em></h1>
      <p class="brief-hero__lead">오늘 꼭 알아야 할 <b>돈·AI·생활경제</b>를 딱 3분에.<br class="brief-hero__br" />읽거나, 출근길에 들으세요.</p>
      <div class="brief-hero__stats">
        <div class="brief-hero__stat"><b>매일</b><span>아침 업데이트</span></div>
        <div class="brief-hero__stat"><b>3분</b><span>핵심만 요약</span></div>
        <div class="brief-hero__stat"><b>0원</b><span>완전 무료</span></div>
      </div>
    </header>

    {numDep && numSav && (
      <a class="brief-nums" href="/rates/">
        <span class="brief-nums__label">오늘의 숫자</span>
        <span>예금 최고 <b>연 {numDep}%</b></span>
        <span>적금 최고 <b>연 {numSav}%</b></span>
        <span class="brief-nums__cta">금리 비교 →</span>
      </a>
    )}

    <!-- 구독 — 컴팩트 토글 바 (한 줄, 스크롤 최소) -->
    <section class="brief-sub">
      <div class="brief-subbar">
        <span class="brief-subbar__title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="1.6"/><path d="M8 9h8M8 13h8M8 17h5"/></svg>
          매일 아침 브리핑 받기
        </span>
        <div class="brief-subbar__toggles">
          <button type="button" class="brief-tog" id="brief-push-switch" role="switch" aria-checked="false" aria-label="푸시 알림 받기">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
            <span>푸시</span>
          </button>
          <button type="button" class="brief-tog" id="brief-email-switch" aria-haspopup="dialog" aria-label="이메일로 받기">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            <span>이메일</span>
          </button>
        </div>
      </div>
    </section>

    <!-- 이메일 신청 바텀시트 -->
    <div class="brief-sheet" id="brief-email-sheet" hidden>
      <div class="brief-sheet__backdrop" data-close></div>
      <div class="brief-sheet__panel" role="dialog" aria-modal="true" aria-labelledby="brief-email-h">
        <button class="brief-sheet__x" type="button" data-close aria-label="닫기">×</button>
        <span class="brief-sheet__ic" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        </span>
        <h3 id="brief-email-h">이메일로 브리핑 받기</h3>
        <p class="brief-sheet__desc">매일 아침, 핵심만 담아 메일로 보내드려요. 광고 없이 무료예요.</p>
        <form class="brief-sub__email" id="brief-email-form">
          <input type="email" name="email" required placeholder="이메일 주소" aria-label="이메일 주소" />
          <input type="text" name="hp" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <button type="submit">신청하기</button>
        </form>
        <p class="brief-email-status" id="brief-email-status" role="status" aria-live="polite"></p>
      </div>
    </div>

    <!-- 푸시: iOS 설치 안내 + 토스트 -->
    <div class="ios-guide" id="brief-ios-guide" hidden>
      <div class="ios-guide__panel">
        <button class="ios-guide__x" type="button" id="brief-ios-x" aria-label="닫기">×</button>
        <h3>iPhone은 먼저 홈 화면에 추가</h3>
        <ol>
          <li><b>Safari</b>로 이 페이지를 열어주세요</li>
          <li>하단 <b>공유</b> 버튼을 눌러주세요</li>
          <li><b>홈 화면에 추가</b>를 선택해주세요</li>
          <li>추가된 앱에서 다시 <b>푸시</b>를 누르면 알림이 켜져요</li>
        </ol>
        <p class="ios-guide__tip">iOS는 홈 화면에 추가한 앱에서만 알림을 받을 수 있어요(16.4 이상).</p>
      </div>
    </div>
    <div class="brief-toast" id="brief-toast" role="status" aria-live="polite"></div>

    {today && (
      <section class="brief-section">
        <p class="brief-eyebrow"><span class="brief-eyebrow__live" aria-hidden="true"></span>오늘의 브리핑<span class="brief-eyebrow__date"> · <FormattedDate date={today.data.pubDate} /></span></p>
        <a class="brief-today" href={`/blog/${today.id}/`}>
          {today.data.heroImage && (
            <div class="brief-today__media">
              <img src={today.data.heroImage} alt={today.data.title} loading="eager" />
              {todayAudio && <span class="brief-today__play" aria-hidden="true">▶</span>}
            </div>
          )}
          <div class="brief-today__body">
            <span class="brief-today__tag">{CATEGORIES[today.data.category as CategorySlug]?.name}</span>
            <h2 class="brief-today__title">{today.data.title}</h2>
            <p class="brief-today__desc">{today.data.description}</p>
            <span class="brief-today__cta">{todayAudio ? '▶ 3분 듣기' : '읽어보기'} →</span>
          </div>
        </a>
      </section>
    )}

    <!-- 왜 매일 브리핑 -->
    <section class="brief-why">
      <div class="brief-why__item"><b>먼저</b><span>남보다 한발 빠르게</span></div>
      <div class="brief-why__item"><b>3분</b><span>핵심만, 짧게</span></div>
      <div class="brief-why__item"><b>매일 아침</b><span>출근길 루틴으로</span></div>
    </section>

    <!-- 브리핑 다음 행동: 내 돈 챙기기 여정 (홈과 동일 컴포넌트) -->
    <section class="brief-section">
      <div class="svc-start">
        <div class="svc-start__head">
          <span class="svc-start__badge">브리핑 너머</span>
          <p class="svc-start__title">읽었으면, 내 돈도 챙기기</p>
        </div>
        <div class="svc-start__steps">
          <a href="/benefits/" class="svc-step">
            <span class="svc-step__no">1</span>
            <span class="svc-step__ic"><DuoIcon name="benefits" /></span>
            <span class="svc-step__body"><strong>받을 돈부터 찾기</strong><small>숨은 지원금·환급 · 3분</small></span>
            <span class="svc-step__arrow">→</span>
          </a>
          <a href="/checkup/" class="svc-step">
            <span class="svc-step__no">2</span>
            <span class="svc-step__ic"><DuoIcon name="checkup" /></span>
            <span class="svc-step__body"><strong>재무 건강 진단</strong><small>저축·부채·투자 · 5분</small></span>
            <span class="svc-step__arrow">→</span>
          </a>
          <a href="/policy-calendar/" class="svc-step">
            <span class="svc-step__no">3</span>
            <span class="svc-step__ic"><DuoIcon name="calendar" /></span>
            <span class="svc-step__body"><strong>마감 일정 챙기기</strong><small>신청·세금 마감일 · 1분</small></span>
            <span class="svc-step__arrow">→</span>
          </a>
        </div>
      </div>
    </section>

    {recent.length > 0 && (
      <section class="brief-section">
        <div class="section-head"><h2>지난 브리핑</h2></div>
        <div class="card-grid">
          {recent.map((p) => (
            <PostCard
              href={`/blog/${p.id}/`}
              title={p.data.title}
              description={p.data.description}
              pubDate={p.data.pubDate}
              category={p.data.category as CategorySlug}
              heroImage={p.data.heroImage}
              thumb={p.data.thumb}
              audio={!!p.data.audio}
              format={p.data.format}
            />
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>

<style>
  /* ── 히어로 (서비스 페이지 톤) ── */
  .brief-hero { text-align: center; padding: 1.4rem 0 1.7rem; }
  .brief-hero__badge {
    display: inline-block; padding: 0.32rem 0.9rem; background: var(--accent-soft); color: var(--accent);
    font-size: 0.72rem; font-weight: 800; letter-spacing: 0.05em; border-radius: 20px; margin-bottom: 1.1rem;
  }
  .brief-hero__title {
    font-family: var(--font-serif); font-size: clamp(1.95rem, 6vw, 2.8rem);
    line-height: 1.24; letter-spacing: -0.02em; margin: 0 0 1.1rem;
  }
  .brief-hero__title em { font-style: normal; color: var(--accent); }
  .brief-hero__lead { color: var(--muted); font-size: 1.05rem; line-height: 1.65; margin: 0 auto 1.9rem; max-width: 34rem; }
  .brief-hero__lead b { color: var(--ink); font-weight: 700; }
  .brief-hero__stats { display: flex; justify-content: center; gap: 0.7rem; max-width: 30rem; margin: 0 auto; }
  .brief-hero__stat { flex: 1; padding: 0.95rem 0.4rem; background: var(--paper-2); border-radius: 12px; }
  .brief-hero__stat b { display: block; font-family: var(--font-serif); font-size: 1.45rem; color: var(--ink); line-height: 1.15; }
  .brief-hero__stat span { font-size: 0.74rem; color: var(--muted); }

  .brief-section { margin-bottom: 2.8rem; }

  /* ── 에디토리얼 아이브로 (라이브 점) ── */
  .brief-eyebrow { display: flex; align-items: center; gap: 0.45rem; font-size: 0.95rem; font-weight: 800; color: var(--ink); margin: 0 0 0.9rem; }
  .brief-eyebrow__live { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,.16); animation: briefPulse 1.9s ease-in-out infinite; flex: none; }
  .brief-eyebrow__date { color: var(--muted); font-weight: 600; }
  @keyframes briefPulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: .45; transform: scale(.82); } }

  /* ── 오늘의 브리핑 (대형 피처) ── */
  .brief-today {
    display: grid; grid-template-columns: 340px 1fr; align-items: stretch;
    border: 1px solid var(--line); border-radius: 18px; overflow: hidden; background: var(--paper);
    text-decoration: none; color: inherit; transition: border-color .15s, box-shadow .18s, transform .18s;
  }
  .brief-today:hover { border-color: var(--accent); box-shadow: 0 22px 48px -28px rgba(20,18,30,.45); transform: translateY(-3px); color: inherit; }
  .brief-today__media { position: relative; background: var(--paper-2); }
  .brief-today__media img { width: 100%; height: 100%; object-fit: cover; display: block; min-height: 215px; }
  .brief-today__play {
    position: absolute; left: 0.9rem; bottom: 0.9rem; width: 2.5rem; height: 2.5rem; border-radius: 50%;
    background: rgba(0,0,0,.55); color: #fff; display: grid; place-items: center; font-size: 0.8rem;
    -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px);
  }
  .brief-today__body { padding: 1.6rem 1.7rem; display: flex; flex-direction: column; gap: .5rem; justify-content: center; }
  .brief-today__tag { align-self: flex-start; padding: 0.22rem 0.72rem; background: var(--accent-soft); color: var(--accent); font-size: .72rem; font-weight: 800; border-radius: 20px; }
  .brief-today__title { margin: 0.25rem 0 0; font-family: var(--font-serif); font-size: clamp(1.35rem, 3vw, 1.85rem); line-height: 1.3; letter-spacing: -0.01em; }
  .brief-today__desc { margin: 0; color: var(--muted); font-size: .96rem; line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .brief-today__cta { margin-top: .45rem; font-weight: 800; color: var(--accent); font-size: .96rem; }

  /* ── 구독 — 컴팩트 토글 바 ── */
  /* 오늘의 숫자 — 매일 갱신되는 금리 훅 */
  .brief-nums { display: flex; align-items: center; gap: 0.8rem; flex-wrap: wrap; margin: 0 0 0.8rem; padding: 0.65rem 1.05rem; border: 1px solid var(--line); border-radius: 12px; background: var(--paper-2); text-decoration: none; color: var(--ink-soft); font-size: 0.86rem; transition: border-color 0.12s; }
  .brief-nums:hover { border-color: var(--accent); }
  .brief-nums__label { font-size: 0.75rem; font-weight: 800; color: var(--accent); flex: none; }
  .brief-nums b { color: var(--ink); }
  .brief-nums__cta { margin-left: auto; font-size: 0.78rem; font-weight: 700; color: var(--accent); flex: none; }

  .brief-sub { margin-bottom: 2.4rem; }
  .brief-subbar { display: flex; align-items: center; justify-content: space-between; gap: 0.7rem; flex-wrap: wrap; padding: 0.8rem 1.05rem; border: 1px solid var(--line); border-radius: 14px; background: var(--paper); }
  .brief-subbar__title { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.98rem; font-weight: 800; }
  .brief-subbar__title svg { width: 1.2rem; height: 1.2rem; color: var(--accent); flex: none; }
  .brief-subbar__toggles { display: flex; gap: 0.45rem; }
  .brief-tog { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.5rem 0.85rem; border: 1px solid var(--line); border-radius: 999px; background: var(--paper-2); font: inherit; font-size: 0.85rem; font-weight: 700; color: var(--ink-soft); cursor: pointer; transition: all .15s; }
  .brief-tog svg { width: 1.05rem; height: 1.05rem; flex: none; }
  .brief-tog:hover { border-color: var(--accent); }
  .brief-tog[aria-checked="true"] { background: var(--accent-soft); color: var(--accent); border-color: var(--accent); }
  /* 이메일 신청 폼(바텀시트 내부) */
  .brief-sub__email { display: flex; flex-direction: column; gap: 0.6rem; margin-top: 1rem; }
  .brief-sub__email input[type="email"] { padding: 0.85rem 0.95rem; border: 1px solid var(--line); border-radius: 12px; font-size: 16px; background: var(--paper-2); color: var(--ink); min-width: 0; }
  .brief-sub__email input[type="email"]:focus { outline: none; border-color: var(--accent); }
  .brief-sub__email .hp { display: none; }
  .brief-sub__email button { padding: 0.9rem 1.15rem; border: none; background: var(--accent); color: #fff; font-size: 0.95rem; font-weight: 700; cursor: pointer; border-radius: 12px; transition: filter 0.15s; }
  .brief-sub__email button:hover { filter: brightness(1.1); }
  .brief-sub__email button:disabled { opacity: 0.6; cursor: default; }
  .brief-email-status { margin: 0.7rem 0 0; font-size: 0.85rem; color: var(--muted); text-align: center; }
  .brief-email-status:empty { display: none; }
  .brief-email-status.is-ok { color: #22c55e; }
  .brief-email-status.is-err { color: #ef4444; }

  /* 이메일 신청 바텀시트 */
  .brief-sheet { position: fixed; inset: 0; z-index: 400; display: flex; align-items: flex-end; justify-content: center; background: rgba(0,0,0,0.5); }
  .brief-sheet[hidden] { display: none; }
  .brief-sheet__backdrop { position: absolute; inset: 0; }
  .brief-sheet__panel { position: relative; width: 100%; max-width: 27rem; background: var(--paper); color: var(--ink); border-radius: 20px 20px 0 0; padding: 1.7rem 1.4rem calc(1.6rem + env(safe-area-inset-bottom)); box-shadow: 0 -10px 40px rgba(0,0,0,0.16); }
  .brief-sheet__x { position: absolute; top: 0.7rem; right: 0.9rem; background: none; border: 0; font-size: 1.6rem; line-height: 1; color: var(--muted); cursor: pointer; }
  .brief-sheet__ic { display: inline-flex; align-items: center; justify-content: center; width: 2.9rem; height: 2.9rem; border-radius: 50%; background: var(--accent-soft); color: var(--accent); margin-bottom: 0.7rem; }
  .brief-sheet__ic svg { width: 1.4rem; height: 1.4rem; }
  .brief-sheet__panel h3 { font-family: var(--font-serif); font-size: 1.25rem; margin: 0 0 0.4rem; color: var(--ink); }
  .brief-sheet__desc { margin: 0; font-size: 0.92rem; line-height: 1.5; color: var(--ink-soft); }
  @media (min-width: 640px) { .brief-sheet { align-items: center; padding: 1rem; } .brief-sheet__panel { border-radius: 20px; } }

  /* 푸시 iOS 안내 + 토스트 (BriefSubscribe에서 이관) */
  .ios-guide { position: fixed; inset: 0; z-index: 400; display: flex; align-items: flex-end; justify-content: center; background: rgba(0,0,0,0.55); }
  .ios-guide[hidden] { display: none; }
  .ios-guide__panel { position: relative; width: 100%; max-width: 26rem; background: var(--paper); color: var(--ink); border-radius: 18px 18px 0 0; padding: 1.6rem 1.4rem calc(1.6rem + env(safe-area-inset-bottom)); }
  .ios-guide__x { position: absolute; top: 0.7rem; right: 0.9rem; background: none; border: 0; font-size: 1.6rem; line-height: 1; color: var(--muted); cursor: pointer; }
  .ios-guide__panel h3 { font-family: var(--font-serif); font-size: 1.2rem; margin: 0 0 1rem; color: var(--ink); }
  .ios-guide__panel ol { margin: 0; padding-left: 1.2rem; display: grid; gap: 0.55rem; color: var(--ink-soft); font-size: 0.96rem; line-height: 1.5; }
  .ios-guide__panel b { color: var(--accent); }
  .ios-guide__tip { margin: 1rem 0 0; font-size: 0.82rem; color: var(--muted); }
  @media (min-width: 640px) { .ios-guide { align-items: center; padding: 1rem; } .ios-guide__panel { border-radius: 18px; } }

  .brief-toast { position: fixed; left: 50%; bottom: 1.5rem; transform: translateX(-50%); z-index: 410; background: var(--ink); color: var(--paper); padding: 0.7rem 1.1rem; border-radius: 999px; font-size: 0.9rem; opacity: 0; transition: opacity .2s; pointer-events: none; max-width: calc(100vw - 2rem); text-align: center; }
  .brief-toast.show { opacity: 1; }

  /* ── 왜 3분 브리핑 ── */
  .brief-why {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 0 0 2.8rem;
    border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); padding: 1.5rem 0;
  }
  .brief-why__item { text-align: center; }
  .brief-why__item b { display: block; font-family: var(--font-serif); font-size: 1.4rem; color: var(--ink); }
  .brief-why__item span { font-size: .84rem; color: var(--muted); }

  @media (max-width: 640px) {
    .brief-today { grid-template-columns: 1fr; }
    .brief-today__media img { min-height: 0; aspect-ratio: 16/9; }
    .brief-today__body { padding: 1.2rem 1.3rem; }
    .brief-hero__br { display: none; }
  }
  @media (max-width: 520px) {
    .brief-subbar { justify-content: center; }
    .brief-hero__stat b { font-size: 1.25rem; }
  }
</style>

<script is:inline define:vars={{ SU, AK }}>
  (() => {
    const f = document.getElementById('brief-email-form');
    const s = document.getElementById('brief-email-status');
    if (!f || !SU || !AK) return;
    f.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(f).entries());
      if (data.hp) return;
      const email = (data.email || '').trim();
      if (!email) return;
      const btn = f.querySelector('button');
      btn.disabled = true;
      s.textContent = '신청 중…';
      s.className = 'brief-email-status';
      try {
        const r = await fetch(`${SU}/rest/v1/rpc/subscribe_email`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', apikey: AK, Authorization: `Bearer ${AK}` },
          body: JSON.stringify({ p_email: email }),
        });
        if (r.ok || r.status === 204) {
          f.reset();
          s.textContent = '완료! 매일 아침 메일로 보내드릴게요.';
          s.className = 'brief-email-status is-ok';
          setTimeout(() => { const sheet = document.getElementById('brief-email-sheet'); if (sheet) sheet.hidden = true; s.textContent = ''; s.className = 'brief-email-status'; }, 1800);
        } else {
          const t = await r.text().catch(() => '');
          s.textContent = t.includes('duplicate') ? '이미 신청되어 있어요.' : '실패했습니다. 다시 시도해 주세요.';
          s.className = 'brief-email-status is-err';
        }
      } catch {
        s.textContent = '실패했습니다. 다시 시도해 주세요.';
        s.className = 'brief-email-status is-err';
      }
      btn.disabled = false;
    });
  })();
</script>

<script is:inline>
  (() => {
    // 이메일 토글 → 바텀시트 열기/닫기
    var emailSw = document.getElementById('brief-email-switch');
    var sheet = document.getElementById('brief-email-sheet');
    if (!emailSw || !sheet) return;
    var openSheet = function () {
      sheet.hidden = false;
      var inp = sheet.querySelector('input[type=email]');
      if (inp) setTimeout(function () { inp.focus(); }, 60);
    };
    var closeSheet = function () { sheet.hidden = true; };
    emailSw.addEventListener('click', openSheet);
    sheet.querySelectorAll('[data-close]').forEach(function (el) { el.addEventListener('click', closeSheet); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !sheet.hidden) closeSheet(); });
  })();
</script>

<script is:inline define:vars={{ VAPID_PUBLIC_KEY, SU, AK }}>
  (() => {
    // 푸시 토글 → Web Push 구독/해제 (BriefSubscribe 이벤트 프로세스 이관)
    const sw = document.getElementById('brief-push-switch');
    if (!sw || sw.dataset.bound) return;
    sw.dataset.bound = '1';
    const guide = document.getElementById('brief-ios-guide');
    const toastEl = document.getElementById('brief-toast');
    const toast = (m) => { if (!toastEl) return; toastEl.textContent = m; toastEl.classList.add('show'); setTimeout(() => toastEl.classList.remove('show'), 2600); };

    const isIOS = /iPhone|iPad|iPod/.test(navigator.userAgent);
    const standalone = matchMedia('(display-mode: standalone)').matches || navigator.standalone === true;
    const supported = 'serviceWorker' in navigator && 'PushManager' in window && 'Notification' in window;

    const b64ToU8 = (b64) => {
      const pad = '='.repeat((4 - (b64.length % 4)) % 4);
      const s = (b64 + pad).replace(/-/g, '+').replace(/_/g, '/');
      const raw = atob(s);
      return Uint8Array.from([...raw].map((c) => c.charCodeAt(0)));
    };
    // 로그인 상태면 유저 토큰으로 RPC 호출 → 구독에 user_id 기록(저장 항목 마감 알림용)
    const userTok = () => {
      try {
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i);
          if (k && k.indexOf('sb-') === 0 && k.indexOf('-auth-token') !== -1) {
            const o = JSON.parse(localStorage.getItem(k));
            return (o && (o.access_token || (o.currentSession && o.currentSession.access_token))) || null;
          }
        }
      } catch (e) {}
      return null;
    };
    let subscribed = false;
    const setOn = () => { subscribed = true; sw.setAttribute('aria-checked', 'true'); };
    const setOff = () => { subscribed = false; sw.setAttribute('aria-checked', 'false'); };

    (async () => {
      if (!supported) return;
      try { const reg = await navigator.serviceWorker.ready; const s = await reg.pushManager.getSubscription(); if (s && Notification.permission === 'granted') setOn(); else setOff(); } catch (e) {}
    })();

    async function subscribe() {
      let reg; try { reg = await navigator.serviceWorker.ready; } catch (e) { toast('서비스워커 준비 안 됨'); return; }
      const perm = await Notification.requestPermission();
      if (perm !== 'granted') { toast('알림 권한이 필요해요 (' + perm + ')'); return; }
      let s;
      try {
        s = await reg.pushManager.getSubscription();
        if (!s) s = await reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: b64ToU8(VAPID_PUBLIC_KEY) });
      } catch (e) { toast('구독 생성 실패: ' + (e && e.message || e)); console.error('[push] subscribe', e); return; }
      const j = s.toJSON();
      if (!SU || !AK) { toast('구독 설정(env) 누락'); return; }
      let res;
      try {
        res = await fetch(SU + '/rest/v1/rpc/subscribe_push', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', apikey: AK, Authorization: 'Bearer ' + (userTok() || AK) },
          body: JSON.stringify({ p_endpoint: j.endpoint, p_p256dh: j.keys.p256dh, p_auth: j.keys.auth }),
        });
      } catch (e) { toast('네트워크 오류로 저장 실패'); return; }
      if (!res.ok) { toast('구독 저장 실패 (' + res.status + ')'); return; }
      setOn();
      toast('매일 브리핑 알림을 켰어요');
    }

    async function unsubscribe() {
      let reg; try { reg = await navigator.serviceWorker.ready; } catch (e) { setOff(); return; }
      const s = await reg.pushManager.getSubscription();
      if (s) {
        const ep = s.endpoint;
        try { await s.unsubscribe(); } catch (e) {}
        if (SU && AK) {
          try { await fetch(SU + '/rest/v1/rpc/unsubscribe_push', { method: 'POST', headers: { 'Content-Type': 'application/json', apikey: AK, Authorization: 'Bearer ' + AK }, body: JSON.stringify({ p_endpoint: ep }) }); } catch (e) {}
        }
      }
      setOff();
      toast('알림을 껐어요');
    }

    sw.addEventListener('click', async () => {
      if (!supported) { toast('이 브라우저는 알림을 지원하지 않아요'); return; }
      if (subscribed) { await unsubscribe(); return; }
      if (isIOS && !standalone) { guide.hidden = false; return; }
      if (!standalone && window.__deferredInstall) {
        try { window.__deferredInstall.prompt(); await window.__deferredInstall.userChoice; } catch (e) {}
        window.__deferredInstall = null;
      }
      await subscribe();
    });

    if (guide) {
      const x = document.getElementById('brief-ios-x');
      if (x) x.onclick = () => { guide.hidden = true; };
      guide.onclick = (e) => { if (e.target === guide) guide.hidden = true; };
    }
  })();
</script>
