---
import BaseLayout from '../layouts/BaseLayout.astro';
// 비영업 승용 기준: cc당 ≤1000cc 80원 · ≤1600cc 140원 · 초과 200원, +지방교육세 30%
// 차령 경감: 3년차부터 매년 5%p, 최대 50% · 전기/수소차: 자동차세 10만 + 교육세 3만 = 13만원
// 2026 연납 공제 3%(신청월 이후 일수 비례 — 1월 실효 약 2.7%)
const SAMPLES = [
  { name: '모닝·레이 (998cc)', cc: 998 },
  { name: '아반떼 1.6 (1,598cc)', cc: 1598 },
  { name: '쏘나타 2.0 (1,999cc)', cc: 1999 },
  { name: '그랜저 2.5 (2,497cc)', cc: 2497 },
  { name: '카니발 3.5 (3,470cc)', cc: 3470 },
];
const calcNew = (cc: number) => { const unit = cc <= 1000 ? 80 : cc <= 1600 ? 140 : 200; const base = cc * unit; return Math.floor((base * 1.3) / 10) * 10; };
const fmt = (n: number) => Math.round(n).toLocaleString('ko-KR');
---
<BaseLayout
  title="자동차세 계산기 2026 — 배기량·차령별, 연납 할인까지"
  description="배기량과 연식만 넣으면 자동차세(지방교육세 포함)와 차령 경감, 2026년 연납 할인(3%)까지 계산. 12월 2기분·1월 연납 알림도 받아보세요."
>
  <div class="wrap ct">
    <header class="page-hero">
      <span class="eyebrow">Car Tax</span>
      <h1>자동차세 계산기 <span class="ct-y">2026</span></h1>
      <p><b>배기량 × 연식</b>만 넣으세요. 지방교육세 포함 연세액과 6월·12월 분납액, 연납 할인까지 나옵니다.</p>
      <p class="ct-basis">비영업 승용 기준 · 차령 3년차부터 매년 5%p 경감(최대 50%) · 2026 연납 공제 3%</p>
    </header>

    <div class="ct-form">
      <label>배기량(cc)
        <input id="ct-cc" type="number" inputmode="numeric" placeholder="예: 1598" min="0" max="8000" />
      </label>
      <label>최초 등록 연도
        <input id="ct-yr" type="number" inputmode="numeric" placeholder="예: 2021" min="1990" max="2026" />
      </label>
      <label class="ct-ev"><input id="ct-isev" type="checkbox" /> 전기·수소차</label>
      <button type="button" id="ct-go">계산하기</button>
    </div>

    <div class="ct-result" id="ct-result" hidden>
      <div class="ct-hero">
        <div><span>연 자동차세<br/>(교육세 포함)</span><b id="ct-total">-</b></div>
        <div class="ct-hero__main"><span>6월 · 12월 분납</span><b id="ct-half">-</b><em id="ct-disc">-</em></div>
        <div><span>1월 연납 시</span><b id="ct-annual">-</b><em>약 2.7% 절약</em></div>
      </div>
      <p class="ct-explain" id="ct-explain"></p>
      <button type="button" class="ct-reg" id="ct-reg" hidden>이 차를 내 정보로 저장 → 다음부터 자동 계산</button>
    </div>

    <section class="ct-sec">
      <h2>대표 차종별 자동차세 (신차 기준)</h2>
      <table class="ct-table">
        <thead><tr><th>차종(배기량)</th><th>연세액</th><th>분납(회당)</th></tr></thead>
        <tbody>
          {SAMPLES.map((s) => (
            <tr><th>{s.name}</th><td>{fmt(calcNew(s.cc))}원</td><td>{fmt(calcNew(s.cc) / 2)}원</td></tr>
          ))}
          <tr><th>전기·수소차 (공통)</th><td>130,000원</td><td>65,000원</td></tr>
        </tbody>
      </table>
      <p class="ct-note">※ 차령 3년차부터 매년 5%p씩 최대 50%까지 줄어들어요(예: 2019년식은 2026년 기준 40% 경감).</p>
    </section>

    <section class="ct-sec">
      <h2>놓치면 손해인 날짜</h2>
      <ul class="ct-alerts">
        <li data-id="cartax-2nd" data-name="자동차세 2기분 납부" data-deadline="2026-12-31">
          <div><b>12월 2기분 납부</b><span>12/16 ~ 12/31 · 늦으면 3% 가산</span></div>
          <button type="button" class="ct-save" aria-pressed="false"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> 알림</button>
        </li>
        <li data-id="cartax-annual-2027" data-name="자동차세 연납 신청(1월)" data-deadline="2027-01-31">
          <div><b>2027년 1월 연납 신청</b><span>1월에 한 번에 내면 할인 — 위택스/앱에서 신청</span></div>
          <button type="button" class="ct-save" aria-pressed="false"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> 알림</button>
        </li>
      </ul>
    </section>

    <div class="ct-cross">
      <a href="/rate-calendar/">금리 결정 캘린더 →</a>
      <a href="/salary/">연봉 실수령액 →</a>
      <a href="/benefits/">내 지원금 찾기 →</a>
    </div>
    <p class="ct-note">※ 연납 공제율은 지방세법 개정에 따라 변동될 수 있어요(2026년 3% 기준, 신청월 이후 일수 비례 적용).</p>
  </div>

  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const fmt = (n) => Math.round(n).toLocaleString('ko-KR');
      function calc() {
        const cc = Number($('ct-cc').value);
        const yr = Number($('ct-yr').value);
        const ev = $('ct-isev').checked;
        if (!ev && (!cc || !yr)) return;
        let total, explain;
        if (ev) {
          total = 130000;
          explain = '전기·수소차는 배기량과 무관하게 자동차세 10만원 + 지방교육세 3만원 = 연 13만원 정액이에요.';
        } else {
          const unit = cc <= 1000 ? 80 : cc <= 1600 ? 140 : 200;
          const age = 2026 - yr + 1; // 차령(등록해 1년차)
          const cut = Math.min(Math.max(age - 2, 0) * 5, 50) / 100;
          const base = cc * unit * (1 - cut);
          total = Math.floor((base * 1.3) / 10) * 10;
          explain = 'cc당 ' + unit + '원 × ' + cc.toLocaleString() + 'cc' + (cut ? ' × 차령 ' + age + '년차 경감 ' + (cut * 100) + '%' : '') + ' + 지방교육세 30% 기준이에요.';
        }
        $('ct-total').textContent = fmt(total) + '원';
        $('ct-half').textContent = fmt(total / 2) + '원';
        $('ct-disc').textContent = '6/16~30 · 12/16~31 납부';
        $('ct-annual').textContent = fmt(total * (1 - 0.03 * 334 / 365)) + '원';
        // 정기검사 주기 추정(비사업용 승용: 최초 4년, 이후 2년마다) — 연식 입력 시에만
        if (yr) {
          var nowY = new Date().getFullYear();
          var insp = yr + 4;
          while (insp < nowY) insp += 2;
          explain += ' 다음 자동차 정기검사는 ' + insp + '년경(등록월 전후 31일 이내)으로 추정돼요.';
        }
        $('ct-explain').textContent = explain;
        $('ct-result').hidden = false;
      }
      $('ct-go').addEventListener('click', calc);
      ['ct-cc', 'ct-yr'].forEach((id) => $(id).addEventListener('keydown', (e) => { if (e.key === 'Enter') calc(); }));

      // 프로필 사이클: 등록된 차량이면 자동 프리필+계산, 아니면 계산 후 '내 정보로 저장'
      const P = window.CramaProfile;
      function regSync() {
        const btn = $('ct-reg');
        if (!P) { btn.hidden = true; return; }
        const d = P.get();
        const has = d.car && (d.car.cc || d.car.ev);
        btn.hidden = false;
        btn.textContent = has ? '내 차 정보 업데이트' : '이 차를 내 정보로 저장 → 다음부터 자동 계산';
      }
      if (P) {
        const d = P.get();
        if (d.car && (d.car.ev || (d.car.cc && d.car.year))) {
          if (d.car.cc) $('ct-cc').value = d.car.cc;
          if (d.car.year) $('ct-yr').value = d.car.year;
          $('ct-isev').checked = !!d.car.ev;
          calc(); regSync();
        }
        $('ct-reg').addEventListener('click', () => {
          const car = { cc: Number($('ct-cc').value) || undefined, year: Number($('ct-yr').value) || undefined, ev: $('ct-isev').checked || undefined };
          if (P.set({ car })) { $('ct-reg').textContent = '저장됐어요 — /me에서 관리'; setTimeout(regSync, 2500); }
        });
        document.addEventListener('crama:profile-sync', regSync);
      }
      const _calc = calc;
      $('ct-go').addEventListener('click', regSync);

      const S = window.CramaSaved;
      document.querySelectorAll('.ct-alerts li').forEach((li) => {
        const btn = li.querySelector('.ct-save');
        if (!S) { btn.hidden = true; return; }
        const sync = (on) => { btn.classList.toggle('is-on', on); btn.setAttribute('aria-pressed', on ? 'true' : 'false'); };
        sync(S.has('dday', li.dataset.id));
        btn.addEventListener('click', () => sync(S.toggle({ type: 'dday', id: li.dataset.id, name: li.dataset.name, url: '/car-tax/', sub: '자동차세', deadline: li.dataset.deadline })));
      });
    })();
  </script>

  <style>
    .ct { max-width: 42rem; }
    .ct-y { color: var(--accent); }
    .page-hero .ct-basis { font-size: 0.82rem; color: var(--muted); margin-top: 0.5rem; }
    .ct-form { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin: 1.4rem 0 1rem; padding: 1.1rem 1.2rem; border: 1px solid var(--line); border-radius: 14px; background: var(--paper-2); align-items: end; }
    .ct-form label { font-size: 0.84rem; font-weight: 700; color: var(--ink-soft); display: flex; flex-direction: column; gap: 0.35rem; }
    .ct-form input[type=number] { font: inherit; font-size: 1rem; padding: 0.6rem 0.8rem; border: 1px solid var(--line); border-radius: 10px; background: var(--paper); color: var(--ink); }
    .ct-form input:focus { outline: none; border-color: var(--accent); }
    .ct-ev { flex-direction: row !important; align-items: center; gap: 0.4rem !important; }
    .ct-form button { font: inherit; font-weight: 800; font-size: 1rem; padding: 0.75rem; border: 0; border-radius: 12px; background: var(--accent); color: #fff; cursor: pointer; }
    @media (max-width: 560px) { .ct-form { grid-template-columns: 1fr; } }
    .ct-result[hidden] { display: none; }
    .ct-hero { display: grid; grid-template-columns: 1fr 1.2fr 1fr; gap: 0.6rem; }
    .ct-hero > div { border: 1px solid var(--line); border-radius: 14px; padding: 0.9rem 1rem; background: var(--paper); display: flex; flex-direction: column; gap: 0.15rem; }
    .ct-hero span { font-size: 0.74rem; color: var(--muted); font-weight: 600; line-height: 1.3; }
    .ct-hero b { font-size: 1.12rem; }
    .ct-hero em { font-style: normal; font-size: 0.72rem; color: var(--muted); }
    .ct-hero__main { background: var(--accent) !important; border-color: var(--accent) !important; color: #fff; }
    .ct-hero__main span, .ct-hero__main em { color: rgba(255,255,255,0.85); }
    .ct-hero__main b { font-size: 1.3rem; }
    @media (max-width: 560px) { .ct-hero { grid-template-columns: 1fr; } }
    .ct-explain { font-size: 0.82rem; color: var(--muted); margin: 0.6rem 0 0; }
    .ct-reg { display: block; margin-top: 0.7rem; font: inherit; font-size: 0.85rem; font-weight: 700; color: var(--accent); background: var(--accent-soft); border: 1px dashed var(--accent); border-radius: 10px; padding: 0.6rem 1rem; cursor: pointer; width: 100%; }
    .ct-reg[hidden] { display: none; }
    .ct-sec { margin: 1.8rem 0; }
    .ct-sec h2 { font-size: 1.1rem; margin: 0 0 0.7rem; }
    .ct-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
    .ct-table thead th { font-size: 0.76rem; color: var(--muted); text-align: left; padding: 0.45rem 0.7rem; border-bottom: 2px solid var(--line); }
    .ct-table tbody th, .ct-table tbody td { padding: 0.55rem 0.7rem; border-bottom: 1px solid var(--line); text-align: left; font-variant-numeric: tabular-nums; }
    .ct-table tbody td { text-align: right; font-weight: 600; }
    .ct-note { font-size: 0.78rem; color: var(--muted); margin: 0.7rem 0 0; line-height: 1.5; }
    .ct-alerts { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.5rem; }
    .ct-alerts li { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; padding: 0.75rem 0.9rem; border: 1px solid var(--line); border-radius: 12px; }
    .ct-alerts b { font-size: 0.92rem; display: block; }
    .ct-alerts span { font-size: 0.76rem; color: var(--muted); }
    .ct-save { flex: none; display: inline-flex; align-items: center; gap: 0.3rem; font: inherit; font-size: 0.8rem; font-weight: 700; padding: 0.45rem 0.8rem; border: 1px solid var(--line); border-radius: 999px; background: var(--paper); color: var(--ink-soft); cursor: pointer; }
    .ct-save:hover { border-color: #e11d48; color: #e11d48; }
    .ct-save.is-on { color: #e11d48; border-color: #e11d48; }
    .ct-save.is-on svg { fill: #e11d48; }
    .ct-cross { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; margin: 1.8rem 0 0.6rem; padding-top: 1.4rem; border-top: 1px solid var(--line); }
    .ct-cross a { font-size: 0.88rem; font-weight: 700; color: var(--accent); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid var(--line); border-radius: 999px; }
    .ct-cross a:hover { border-color: var(--accent); }
  </style>
</BaseLayout>
