---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
---
<BaseLayout title="문의하기" description={`${SITE.name}에 제휴·광고·제보 문의하기`}>
  <div class="wrap">
    <header class="page-hero">
      <span class="eyebrow">Contact</span>
      <h1>문의하기</h1>
      <p>제휴·광고·제보 문의를 환영합니다.</p>
    </header>
    <div class="measure">
      <p style="color:var(--muted);">아래 폼으로 보내 주시면 담당자에게 바로 전달됩니다. 확인 후 회신드립니다.</p>

      <form id="contact-form" class="contact-form">
        <label>이름 / 회사
          <input name="name" type="text" autocomplete="organization" />
        </label>
        <label>이메일 <span style="color:var(--accent)">*</span>
          <input name="email" type="email" required autocomplete="email" placeholder="회신받을 이메일" />
        </label>
        <label>문의 유형
          <select name="type">
            <option>제휴 문의</option>
            <option>광고 문의</option>
            <option>일반 문의</option>
            <option>오류 제보</option>
          </select>
        </label>
        <label>문의 내용 <span style="color:var(--accent)">*</span>
          <textarea name="message" rows="6" required placeholder="문의 내용을 적어 주세요."></textarea>
        </label>
        <!-- 봇 차단용 허니팟 (사람에겐 안 보임) -->
        <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <button type="submit" class="btn">보내기</button>
        <p id="contact-status" class="contact-status" role="status" aria-live="polite"></p>
      </form>

      <p style="color:var(--muted);font-size:0.9rem;margin-top:1.5rem;">
        또는 이메일로: <a href="mailto:gmlthd94@gmail.com">gmlthd94@gmail.com</a>
      </p>
    </div>
  </div>

  <script is:inline>
    const f = document.getElementById('contact-form');
    const s = document.getElementById('contact-status');
    f?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = f.querySelector('button');
      const data = Object.fromEntries(new FormData(f).entries());
      btn.disabled = true;
      s.textContent = '전송 중…';
      s.className = 'contact-status';
      try {
        const r = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const j = await r.json().catch(() => ({}));
        if (r.ok && j.ok) {
          f.reset();
          s.textContent = '문의가 정상적으로 접수되었습니다. 감사합니다!';
          s.className = 'contact-status is-ok';
        } else {
          s.textContent = j.error || '전송에 실패했습니다. 잠시 후 다시 시도해 주세요.';
          s.className = 'contact-status is-err';
        }
      } catch {
        s.textContent = '전송에 실패했습니다. 잠시 후 다시 시도해 주세요.';
        s.className = 'contact-status is-err';
      }
      btn.disabled = false;
    });
  </script>
</BaseLayout>
