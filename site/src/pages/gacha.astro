---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqBox from '../components/FaqBox.astro';
import { gIcon } from '../lib/game-icons';

const SU = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const AK = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---
<BaseLayout
  title="밀웜 뽑기 — 크라미 아이템 캡슐머신"
  image="/og-gacha.png"
  description="밀웜 15마리로 크라미 아이템 캡슐을 뽑아보세요. 중복 없는 컬렉션 시스템, 레어 12%, 전부 모으면 잭팟. 하루 3번의 두근거림."
  footer="none"
>
  <div class="gc wrap">
    <header class="page-hero">
      <span class="eyebrow">Capsule Machine</span>
      <h1>밀웜 뽑기 <span class="gc-y" set:html={gIcon('capsule', 30)} /></h1>
      <p>밀웜 <b>15마리</b> = 캡슐 1개. 아이템은 <b>중복 없이</b>, 대신 <b>꽝도 있고 비쌀수록 극악</b> — 그게 뽑는 맛.</p>
    </header>

    <!-- 상태 바 -->
    <div class="gc-status" id="gc-status" hidden>
      <span>오늘 남은 뽑기 <b id="gc-spins">●●●</b></span>
      <span class="gc-status__worm">내 밀웜 <b id="gc-bal">-</b><Fragment set:html={gIcon('worm', 15)} /></span>
      <span>컬렉션 <b id="gc-col">-</b></span>
    </div>

    <!-- 캡슐 머신 -->
    <div class="gc-machine" id="gc-machine">
      <div class="gc-dome">
        <i class="gc-cap" style="--x:18%;--y:52%;--c:#f9a8d4;--d:.1s"></i>
        <i class="gc-cap" style="--x:44%;--y:64%;--c:#93c5fd;--d:.25s"></i>
        <i class="gc-cap" style="--x:64%;--y:48%;--c:#fde68a;--d:.4s"></i>
        <i class="gc-cap" style="--x:30%;--y:30%;--c:#86efac;--d:.55s"></i>
        <i class="gc-cap" style="--x:56%;--y:24%;--c:#c4b5fd;--d:.7s"></i>
      </div>
      <div class="gc-body">
        <span class="gc-slot"></span>
        <span class="gc-knob" id="gc-knob"></span>
      </div>
      <i class="gc-drop" id="gc-drop" hidden></i>
    </div>

    <button type="button" class="gc-spin" id="gc-spin"><Fragment set:html={gIcon('capsule', 18)} /> 뽑기 — 밀웜 15</button>
    <p class="gc-msg" id="gc-msg" hidden></p>

    <!-- 꽝 -->
    <div class="gc-dud" id="gc-dud" hidden>
      <span class="gc-dud__emoji" set:html={gIcon('wind', 34)} />
      <b>캡슐이... 비어 있다?!</b>
      <p>바닥에 <b>밀웜 부스러기 +2</b>가 떨어져 있었다 <Fragment set:html={gIcon('worm', 13)} /></p>
      <button type="button" id="gc-dud-again">분하다, 한 번 더!</button>
    </div>

    <!-- 결과 카드 -->
    <div class="gc-result" id="gc-result" hidden>
      <div class="gc-card" id="gc-card">
        <img id="gc-item-img" src="" alt="" />
        <b id="gc-item-name"></b>
        <span id="gc-item-slot"></span>
        <em class="gc-rare" id="gc-item-rare" hidden><Fragment set:html={gIcon('sparkle', 13)} /> RARE <Fragment set:html={gIcon('sparkle', 13)} /></em>
      </div>
      <div class="gc-result__acts">
        <a href="/wardrobe/" class="is-main">입혀보러 가기 →</a>
        <button type="button" id="gc-again">한 번 더!</button>
      </div>
    </div>
    <div class="pl-confetti" id="gc-confetti" aria-hidden="true">
      {Array.from({ length: 18 }).map((_, i) => <i style={`--i:${i}`}></i>)}
    </div>

    <!-- 컬렉션 -->
    <section class="gc-sec">
      <h2>내 컬렉션 <span id="gc-col2"></span></h2>
      <div class="gc-grid" id="gc-grid"></div>
    </section>

    <div class="gc-faq"><FaqBox items={[
      { q: '확률이 어떻게 되나요? (전체 공개)', a: '매 스핀: 꽝 22%(위로 보상 부스러기 +2밀웜). 나머지 78%에서 미보유 아이템 중 가격 반비례(가격의 1.8제곱분의 1) 가중치로 추첨합니다. 예를 들어 20밀웜 아이템과 100밀웜 아이템만 남았다면 각각 약 94.7% : 5.3% — 비쌀수록 극악이지만, 언젠가는 반드시 나옵니다(중복 없음).' },
      { q: '중복이 나올 수 있나요?', a: '없습니다. 아이템은 항상 미보유 중에서만 뽑혀요. 꽝(22%)만 조심하세요. 전부 모으면 스핀 시 잭팟 +30밀웜이 나옵니다.' },
      { q: '하루 몇 번 뽑을 수 있나요?', a: '자정 리셋 기준 하루 3번입니다. 밀웜은 예측 게임·무지출 챌린지·출석·글 읽기로 모을 수 있어요.' },
      { q: '밀웜을 현금으로 살 수 있나요?', a: '아니요. 밀웜은 활동으로만 얻는 무료 포인트이고 현금 구매·환전이 모두 불가능합니다. 그래서 마음 편히 뽑아도 돼요.' },
    ]} /></div>

    <div class="gc-cross">
      <a href="/play/"><Fragment set:html={gIcon('crystal', 14)} /> 밀웜 벌기: 오르까 내리까</a>
      <a href="/challenge/"><Fragment set:html={gIcon('flame', 14)} /> 무지출 챌린지</a>
      <a href="/me/">밀웜 모으기(출석·읽기) →</a>
    </div>
  </div>

  <script is:inline define:vars={{ SU, AK }}>
    (() => {
      const $ = (id) => document.getElementById(id);
      function tok() {
        try {
          for (let i = 0; i < localStorage.length; i++) {
            const k = localStorage.key(i);
            if (k && k.indexOf('sb-') === 0 && k.indexOf('-auth-token') !== -1) {
              const o = JSON.parse(localStorage.getItem(k));
              return (o && (o.access_token || (o.currentSession && o.currentSession.access_token))) || null;
            }
          }
        } catch (e) {}
        return null;
      }
      const T = tok();
      const H = (auth) => ({ 'Content-Type': 'application/json', apikey: AK, Authorization: 'Bearer ' + (auth && T ? T : AK) });
      const rpc = (fn, body, auth) => fetch(SU + '/rest/v1/rpc/' + fn, { method: 'POST', headers: H(auth), body: JSON.stringify(body || {}) }).then((r) => (r.ok ? r.json() : null)).catch(() => null);
      const rest = (path, auth) => fetch(SU + '/rest/v1/' + path, { headers: H(auth) }).then((r) => (r.ok ? r.json() : null)).catch(() => null);

      let items = [], owned = new Set(), spinning = false;

      function paintStatus(st) {
        if (!st) return;
        $('gc-status').hidden = false;
        $('gc-spins').textContent = '●'.repeat(st.spins_left) + '○'.repeat(3 - st.spins_left);
        $('gc-bal').textContent = Number(st.balance).toLocaleString('ko-KR');
        $('gc-col').textContent = st.owned + '/' + st.total;
        $('gc-col2').textContent = st.owned + '/' + st.total;
        if (st.spins_left === 0) { $('gc-spin').disabled = true; $('gc-spin').textContent = '오늘 뽑기 끝 — 내일 자정에 3번 충전!'; }
        else if (st.balance < 15) { $('gc-spin').disabled = true; $('gc-spin').textContent = '밀웜이 부족해요 (' + st.balance + '/15)'; msg('아래에서 밀웜 버는 법을 확인하세요 — 예측 게임이 가장 빨라요 🔮'); }
      }
      function msg(t) { const m = $('gc-msg'); m.textContent = t; m.hidden = !t; }
      function paintGrid() {
        const host = $('gc-grid');
        host.innerHTML = '';
        for (const it of items) {
          const d = document.createElement('div');
          d.className = 'gc-cell' + (owned.has(it.id) ? ' is-owned' : '') + (it.rarity === 'rare' ? ' is-rare' : '');
          d.title = owned.has(it.id) ? it.name : '???';
          d.innerHTML = '<img src="' + it.asset_url + '" alt="' + (owned.has(it.id) ? it.name : '미획득 아이템') + '" loading="lazy" />';
          host.appendChild(d);
        }
      }
      async function load() {
        items = (await rest('wardrobe_items?select=id,name,slot,rarity,asset_url&order=slot,sort')) || [];
        if (T) {
          const inv = (await rest('user_inventory?select=item_id', true)) || [];
          owned = new Set(inv.map((r) => r.item_id));
          paintStatus(await rpc('gacha_status', {}, true));
        } else {
          msg('로그인하면 하루 3번 뽑을 수 있어요 — 가입만 해도 첫 밀웜이 모여요.');
        }
        paintGrid();
      }

      const SLOT_KO = { hat: '모자', glasses: '안경', scarf: '스카프', outfit: '옷', floor: '바닥', wallpaper: '벽지' };
      $('gc-spin').addEventListener('click', async () => {
        if (spinning) return;
        if (!T) { if (window.CramaSaved) window.CramaSaved.promptLogin(); return; }
        spinning = true;
        $('gc-result').hidden = true;
        $('gc-dud').hidden = true;
        $('gc-confetti').classList.remove('is-on');
        msg('');
        const machine = $('gc-machine');
        machine.classList.add('is-shaking');
        $('gc-knob').classList.add('is-turn');
        const res = await rpc('spin_gacha', {}, true);
        setTimeout(() => {
          machine.classList.remove('is-shaking');
          $('gc-knob').classList.remove('is-turn');
          if (!res || !res.ok) {
            spinning = false;
            if (res && res.error === 'cap') paintStatus({ spins_left: 0, balance: '-', owned: owned.size, total: items.length });
            else if (res && res.error === 'insufficient') paintStatus({ spins_left: 3, balance: res.balance, owned: owned.size, total: items.length });
            else msg('잠시 후 다시 시도해 주세요.');
            return;
          }
          // 캡슐 낙하 연출 → 결과
          const drop = $('gc-drop');
          drop.hidden = false;
          drop.classList.remove('is-fall'); void drop.offsetWidth; drop.classList.add('is-fall');
          try { if (window.gtag) window.gtag('event', 'gacha_spin', { rare: !!(res.item && res.item.rarity === 'rare'), jackpot: !!res.jackpot }); } catch (e) {}
          setTimeout(() => {
            drop.hidden = true;
            if (res.dud) {
              const dud = $('gc-dud');
              dud.hidden = false;
              dud.classList.remove('is-shake'); void dud.offsetWidth; dud.classList.add('is-shake');
              paintStatus({ spins_left: res.spins_left, balance: res.balance, owned: owned.size, total: items.length });
              try { localStorage.setItem('crama:bal', String(res.balance)); const n = document.getElementById('hd-worm-n'); if (n) n.textContent = Number(res.balance).toLocaleString('ko-KR'); } catch (e) {}
              spinning = false;
              return;
            }
            if (res.jackpot) {
              msg('🎉 컬렉션 완성! 잭팟 +30밀웜이 지급됐어요. 당신은 진정한 수집가!');
              $('gc-confetti').classList.add('is-on');
            } else {
              const it = res.item;
              owned.add(it.id);
              $('gc-item-img').src = it.asset_url;
              $('gc-item-img').alt = it.name;
              $('gc-item-name').textContent = it.name;
              $('gc-item-slot').textContent = SLOT_KO[it.slot] || it.slot;
              $('gc-item-rare').hidden = it.rarity !== 'rare';
              const card = $('gc-card');
              card.classList.toggle('is-rare', it.rarity === 'rare');
              $('gc-result').hidden = false;
              card.classList.remove('is-flip'); void card.offsetWidth; card.classList.add('is-flip');
              if (it.rarity === 'rare') $('gc-confetti').classList.add('is-on');
              paintGrid();
            }
            paintStatus({ spins_left: res.spins_left, balance: res.balance, owned: owned.size, total: items.length });
            // 헤더 밀웜 배지 즉시 갱신
            try { localStorage.setItem('crama:bal', String(res.balance)); const n = document.getElementById('hd-worm-n'); if (n) n.textContent = Number(res.balance).toLocaleString('ko-KR'); } catch (e) {}
            spinning = false;
          }, 750);
        }, 900);
      });
      $('gc-again').addEventListener('click', () => { $('gc-result').hidden = true; $('gc-spin').click(); });
      $('gc-dud-again').addEventListener('click', () => { $('gc-dud').hidden = true; $('gc-spin').click(); });

      load();
    })();
  </script>

  <style is:global>
    .gc { max-width: 40rem; text-align: center; }
    .gc .page-hero { text-align: left; }
    .gc-faq { text-align: left; }
    .gc-y { display: inline-flex; vertical-align: -4px; color: var(--accent); filter: drop-shadow(0 2px 8px rgba(245, 158, 11, 0.5)); }
    .gc-spin svg, .gc-cross a svg, .gc-rare svg, .gc-status__worm svg, .gc-dud p svg { vertical-align: -2px; }
    .gc-status__worm svg { color: var(--accent); margin-left: 2px; }
    .gc-dud__emoji { display: flex; justify-content: center; color: var(--muted); margin-bottom: 0.2rem; }
    .gc-status { display: flex; justify-content: center; gap: 1.1rem; flex-wrap: wrap; margin: 0.6rem 0 1rem; font-size: 0.82rem; color: var(--muted); }
    .gc-status[hidden] { display: none; }
    .gc-status b { color: var(--ink); font-variant-numeric: tabular-nums; }
    #gc-spins { color: var(--accent); letter-spacing: 2px; }

    /* 캡슐 머신 */
    .gc-machine { position: relative; width: 210px; margin: 0.6rem auto 0; }
    .gc-machine.is-shaking { animation: gcShake 0.18s linear infinite; }
    @keyframes gcShake { 0% { transform: translateX(-2px) rotate(-0.6deg); } 50% { transform: translateX(2px) rotate(0.6deg); } 100% { transform: translateX(-2px) rotate(-0.6deg); } }
    .gc-dome { position: relative; width: 190px; height: 150px; margin: 0 auto; border-radius: 95px 95px 14px 14px; background: linear-gradient(160deg, rgba(255,255,255,0.65), rgba(255,255,255,0.15)), var(--paper-2); border: 3px solid var(--line); border-bottom: 0; overflow: hidden; }
    .gc-cap { position: absolute; left: var(--x); top: var(--y); width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(180deg, var(--c) 50%, #fff 50%); border: 2px solid rgba(0, 0, 0, 0.08); animation: gcBob 1.6s ease-in-out var(--d) infinite alternate; }
    @keyframes gcBob { to { transform: translateY(-6px) rotate(12deg); } }
    .gc-body { position: relative; width: 210px; height: 92px; margin: 0 auto; background: var(--accent); border-radius: 12px 12px 18px 18px; box-shadow: 0 8px 20px rgba(20, 24, 50, 0.2); }
    .gc-slot { position: absolute; left: 24px; bottom: 18px; width: 58px; height: 30px; border-radius: 8px; background: rgba(0, 0, 0, 0.35); border: 2px solid rgba(255, 255, 255, 0.25); }
    .gc-knob { position: absolute; right: 30px; top: 50%; transform: translateY(-50%); width: 42px; height: 42px; border-radius: 50%; background: #fff; border: 5px solid rgba(0, 0, 0, 0.18); }
    .gc-knob::after { content: ''; position: absolute; left: 50%; top: 50%; width: 6px; height: 26px; background: rgba(0, 0, 0, 0.3); border-radius: 3px; transform: translate(-50%, -50%); }
    .gc-knob.is-turn { animation: gcTurn 0.9s ease; }
    @keyframes gcTurn { to { transform: translateY(-50%) rotate(360deg); } }
    .gc-drop { position: absolute; left: 34px; bottom: -6px; width: 30px; height: 30px; border-radius: 50%; background: linear-gradient(180deg, #f9a8d4 50%, #fff 50%); border: 2px solid rgba(0, 0, 0, 0.1); }
    .gc-drop[hidden] { display: none; }
    .gc-drop.is-fall { animation: gcFall 0.7s cubic-bezier(0.3, 0, 0.6, 1.4); }
    @keyframes gcFall { 0% { transform: translateY(-46px) scale(0.6); opacity: 0; } 45% { opacity: 1; } 70% { transform: translateY(6px) scale(1); } 85% { transform: translateY(-6px); } 100% { transform: translateY(0); } }

    .gc-spin { margin: 1.1rem auto 0; font: inherit; font-size: 1.02rem; font-weight: 800; color: #fff; background: linear-gradient(120deg, #f59e0b, #ef4444); border: 0; border-radius: 999px; padding: 0.85rem 2rem; cursor: pointer; box-shadow: 0 6px 18px rgba(239, 68, 68, 0.35); transition: transform 0.12s, opacity 0.15s; }
    .gc-spin:hover:not(:disabled) { transform: translateY(-1px); }
    .gc-spin:disabled { opacity: 0.55; cursor: default; box-shadow: none; }
    .gc-msg { font-size: 0.84rem; color: var(--ink-soft); margin: 0.7rem auto 0; max-width: 26rem; }
    .gc-msg[hidden] { display: none; }

    /* 결과 카드 */
    .gc-dud { margin: 1.2rem auto 0; padding: 1.2rem 1rem; max-width: 260px; border: 2px dashed var(--line); border-radius: 18px; background: var(--paper-2); }
    .gc-dud[hidden] { display: none; }
    .gc-dud.is-shake { animation: gcDudShake 0.4s ease; }
    @keyframes gcDudShake { 0%, 100% { transform: rotate(0); } 25% { transform: rotate(-3deg); } 75% { transform: rotate(3deg); } }
    .gc-dud__emoji { font-size: 2rem; display: block; margin-bottom: 0.2rem; }
    .gc-dud b { font-size: 0.95rem; }
    .gc-dud p { font-size: 0.8rem; color: var(--ink-soft); margin: 0.4rem 0 0.8rem; }
    .gc-dud button { font: inherit; font-size: 0.84rem; font-weight: 800; color: #fff; background: var(--ink); border: 0; border-radius: 999px; padding: 0.5rem 1.1rem; cursor: pointer; }
    .gc-result { margin: 1.2rem auto 0; }
    .gc-result[hidden] { display: none; }
    .gc-card { position: relative; width: 190px; margin: 0 auto; padding: 1.1rem 1rem 1rem; border: 2px solid var(--line); border-radius: 18px; background: var(--paper); display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
    .gc-card.is-flip { animation: gcFlip 0.5s ease; }
    @keyframes gcFlip { 0% { transform: rotateY(90deg) scale(0.8); opacity: 0; } 100% { transform: rotateY(0) scale(1); opacity: 1; } }
    .gc-card.is-rare { border-color: #f59e0b; box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.18), 0 10px 30px rgba(245, 158, 11, 0.25); }
    .gc-card img { width: 96px; height: 96px; object-fit: contain; }
    .gc-card b { font-size: 1rem; }
    .gc-card span { font-size: 0.74rem; color: var(--muted); }
    .gc-rare { font-style: normal; font-size: 0.72rem; font-weight: 800; color: #b45309; }
    .gc-rare[hidden] { display: none; }
    .gc-result__acts { display: flex; gap: 0.5rem; justify-content: center; margin-top: 0.8rem; }
    .gc-result__acts a, .gc-result__acts button { font: inherit; font-size: 0.84rem; font-weight: 700; padding: 0.5rem 1rem; border-radius: 999px; border: 1px solid var(--line); background: var(--paper); color: var(--ink-soft); cursor: pointer; text-decoration: none; }
    .gc-result__acts .is-main { background: var(--accent); border-color: var(--accent); color: #fff; }

    /* 컬렉션 */
    .gc-sec { margin: 2.2rem 0 1rem; text-align: left; }
    .gc-sec h2 { font-size: 1.05rem; margin: 0 0 0.7rem; }
    .gc-sec h2 span { font-size: 0.82rem; color: var(--accent); }
    .gc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(64px, 1fr)); gap: 0.5rem; }
    .gc-cell { position: relative; aspect-ratio: 1; border: 1px solid var(--line); border-radius: 12px; background: var(--paper-2); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .gc-cell img { width: 78%; height: 78%; object-fit: contain; filter: brightness(0) opacity(0.15); }
    .gc-cell.is-owned img { filter: none; }
    .gc-cell.is-owned { background: var(--paper); }
    .gc-cell.is-rare.is-owned { border-color: #f59e0b; }
    .gc-cross { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; margin: 2rem 0 1rem; padding-top: 1.4rem; border-top: 1px solid var(--line); }
    .gc-cross a { font-size: 0.88rem; font-weight: 700; color: var(--accent); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid var(--line); border-radius: 999px; }
    .gc-cross a:hover { border-color: var(--accent); }

    /* 컨페티(플레이 페이지와 동일 키프레임 재사용) */
    .pl-confetti { position: fixed; inset: 0; pointer-events: none; z-index: 60; }
    .pl-confetti i { position: absolute; top: -10px; left: calc(var(--i) * 5.5%); width: 7px; height: 11px; opacity: 0; background: hsl(calc(var(--i) * 47), 85%, 60%); border-radius: 2px; }
    .pl-confetti.is-on i { animation: plFall 1.6s ease-in calc(var(--i) * 0.07s) forwards; }
    @keyframes plFall { 0% { opacity: 1; transform: translateY(0) rotate(0); } 100% { opacity: 0; transform: translateY(300px) rotate(540deg); } }
  </style>
</BaseLayout>
