---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdSlot from '../components/AdSlot.astro';
import { glossarySections as sections } from '../data/glossary';

---
<BaseLayout title="용어 사전" description="주식·재테크와 AI의 핵심 용어를 쉽게 풀이한 사전. 모르는 용어를 빠르게 찾고 관련 글로 이어 보세요.">
  <div class="wrap">
    <header class="page-hero">
      <span class="eyebrow">Glossary</span>
      <h1>용어 사전</h1>
      <p>주식·재테크와 AI의 핵심 용어를 쉽게 풀이했습니다. 관련 글로 더 깊이 이어 보세요.</p>
    </header>

    <nav class="glossary-jump" aria-label="용어 분류">
      {sections.map((s) => <a class="glossary-jump__link" href={`#${s.id}`}>{s.title} ({s.terms.length})</a>)}
    </nav>

    {sections.map((s) => (
      <section class="glossary-section" id={s.id}>
        <h2>{s.title}</h2>
        <div class="glossary-list">
          {s.terms.map((t) => (
            <div class="glossary-item">
              <p class="glossary-term">{t.term}</p>
              <p class="glossary-def">
                {t.def}
                {t.href && <> <a href={t.href}>→ {t.hrefLabel}</a></>}
              </p>
            </div>
          ))}
        </div>
      </section>
    ))}

    <AdSlot slot="glossary-bottom" />
  </div>
</BaseLayout>
