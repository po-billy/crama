---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import DuoIcon from '../../components/DuoIcon.astro';
import { PILLARS, GUIDE_EXTRA, CATEGORIES, type CategorySlug } from '../../consts';

const all = (await getCollection('blog')).filter((p) => !p.data.draft);
const slugs = [...new Set([...Object.values(PILLARS), ...GUIDE_EXTRA])];
const guides = slugs
  .map((slug) => all.find((p) => p.id === slug))
  .filter((p): p is (typeof all)[number] => Boolean(p));
---
<BaseLayout title="주제별 완벽 가이드" description="주식·재테크, AI, 부업까지 — 주제별로 처음부터 끝까지 단계별로 따라가는 완벽 가이드 모음.">
  <div class="wrap">
    <header class="page-hero">
      <span class="eyebrow">Guides</span>
      <h1>주제별 완벽 가이드</h1>
      <p>처음이라면 여기서 — 주제별로 기본기부터 실전까지 순서대로 따라갈 수 있게 모았습니다.</p>
    </header>

    <div class="card-grid">
      {guides.map((p) => (
        <PostCard
          href={`/blog/${p.id}/`}
          title={p.data.title}
          description={p.data.description}
          pubDate={p.data.pubDate}
          category={p.data.category as CategorySlug}
          heroImage={p.data.heroImage}
          thumb={p.data.thumb}
          audio={!!p.data.audio}
        />
      ))}
    </div>

    <section class="guide-svc">
      <h2>가이드를 읽었다면, 직접 해보세요</h2>
      <div class="guide-svc__grid">
        <a href="/benefits/" class="guide-svc__card">
          <span class="svc-ic"><DuoIcon name="benefits" /></span>
          <strong>내 혜택 찾기</strong>
          <p>나에게 해당되는 지원금·대출·공제를 3분 만에</p>
        </a>
        <a href="/checkup/" class="guide-svc__card">
          <span class="svc-ic"><DuoIcon name="checkup" /></span>
          <strong>재무 건강 체크업</strong>
          <p>내 저축률·비상금·부채 상태를 5분 만에 진단</p>
        </a>
        <a href="/policy-calendar/" class="guide-svc__card">
          <span class="svc-ic"><DuoIcon name="calendar" /></span>
          <strong>정책 캘린더</strong>
          <p>놓치면 손해인 세금·지원금 마감일을 내 캘린더에</p>
        </a>
      </div>
    </section>
  </div>

  <style>
    .guide-svc { margin: 3rem 0 1rem; }
    .guide-svc h2 { font-family: var(--font-serif); font-size: 1.2rem; margin: 0 0 1rem; }
    .guide-svc__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
    .guide-svc__card {
      display: flex; flex-direction: column; gap: 0.3rem; padding: 1.2rem;
      border: 1px solid var(--line); border-radius: 12px; background: var(--paper);
      text-decoration: none; color: var(--ink); transition: border-color 0.12s, transform 0.12s;
    }
    .guide-svc__card:hover { border-color: var(--accent); transform: translateY(-2px); color: var(--ink); }
    .guide-svc__icon { font-size: 1.4rem; }
    .guide-svc__card strong { font-size: 0.92rem; }
    .guide-svc__card p { font-size: 0.78rem; color: var(--muted); margin: 0; line-height: 1.4; }
    @media (max-width: 640px) { .guide-svc__grid { grid-template-columns: 1fr; } }
  </style>
</BaseLayout>
