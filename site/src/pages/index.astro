---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE, CATEGORIES, EDITOR_PICKS } from '../consts';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const toCard = (p: (typeof posts)[number]) => ({
  href: `/blog/${p.id}/`,
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate,
  category: p.data.category,
  heroImage: p.data.heroImage,
});

// 에디터 큐레이션 랭킹(없으면 최신으로 채움)
const picksFromList = EDITOR_PICKS
  .map((slug) => posts.find((p) => p.id === slug))
  .filter((p): p is (typeof posts)[number] => Boolean(p));
const picks = [...picksFromList, ...posts.filter((p) => !picksFromList.includes(p))].slice(0, 6);
const ranking = picks;

const homeTools = [
  { href: '/tools/compound-calculator/', label: '복리 계산기', desc: '목돈 불어나는 속도' },
  { href: '/tools/average-price-calculator/', label: '주식 평단가 계산기', desc: '추가 매수 후 평단' },
  { href: '/tools/loan-calculator/', label: '대출 이자 계산기', desc: '월 상환액·총 이자' },
  { href: '/tools/goal-calculator/', label: '목표금액 계산기', desc: '매달 얼마 모을까' },
  { href: '/tools/pension-tax-calculator/', label: '연금 세액공제', desc: '예상 환급액' },
  { href: '/tools/rule-of-72-calculator/', label: '72의 법칙', desc: '2배 되는 기간' },
];

const latest = posts.slice(0, 6);
const byCategory = (slug: 'money' | 'ai' | 'income') =>
  posts.filter((p) => p.data.category === slug).slice(0, 3);
---
<BaseLayout title={SITE.title} description={SITE.description}>
  <div class="wrap">
    <header class="home-masthead">
      <h1>주식·재테크와 AI 트렌드, <em>깊이 있게.</em></h1>
    </header>

    <section class="home-hero">
      <aside class="tool-panel">
        <div class="side-head"><h2>바로 쓰는 계산기</h2><a href="/tools/">전체 →</a></div>
        <ul class="tool-panel__list">
          {homeTools.map((t) => (
            <li>
              <a class="tp-row" href={t.href}>
                <span class="tp-row__label">{t.label}</span>
                <span class="tp-row__desc">{t.desc}</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
      <div class="home-hero__side">
        <div class="side-head"><h2>주목할 아티클</h2></div>
        <ol class="ranked-list">
          {ranking.map((p, i) => (
            <li>
              <a class="ranked" href={`/blog/${p.id}/`}>
                <span class="ranked__num">{i + 1}</span>
                {p.data.heroImage && (
                  <div class="ranked__thumb"><img src={p.data.heroImage} alt="" loading="lazy" /></div>
                )}
                <div class="ranked__body">
                  <h3 class="ranked__title">{p.data.title}</h3>
                  <div class="ranked__meta">{CATEGORIES[p.data.category].name} · <FormattedDate date={p.data.pubDate} /></div>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section>
      <div class="section-head">
        <h2>최신 글</h2>
        <a href="/category/ai/">전체 보기</a>
      </div>
      <div class="card-grid">
        {latest.map((p) => <PostCard {...toCard(p)} />)}
      </div>
    </section>

    <AdSlot slot="home-mid" />

    {(['money', 'ai', 'income'] as const).map((slug) => (
      <section>
        <div class="section-head">
          <h2>{CATEGORIES[slug].name}</h2>
          <a href={`/category/${slug}/`}>{CATEGORIES[slug].tagline} →</a>
        </div>
        <div class="card-grid">
          {byCategory(slug).map((p) => <PostCard {...toCard(p)} />)}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
