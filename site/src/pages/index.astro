---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE, CATEGORIES, EDITOR_PICKS } from '../consts';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const toCard = (p: (typeof posts)[number]) => ({
  href: `/blog/${p.id}/`,
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate,
  category: p.data.category,
  heroImage: p.data.heroImage,
});

// 에디터 큐레이션 랭킹(없으면 최신으로 채움)
const picksFromList = EDITOR_PICKS
  .map((slug) => posts.find((p) => p.id === slug))
  .filter((p): p is (typeof posts)[number] => Boolean(p));
const picks = [...picksFromList, ...posts.filter((p) => !picksFromList.includes(p))].slice(0, 6);
const ranking = picks;

// 머니 로드맵 — 부의 축적 5단계(클릭 시 다음 할 일 + 관련 글/도구 안내)
const stages = [
  {
    name: '빚 정리',
    desc: '고금리 빚이 있으면 어떤 투자보다 먼저 줄이는 게 이득입니다.',
    todo: '대출 구조를 파악하고 상환 계획 세우기',
    links: [
      { label: '대출 기초 정리', href: '/blog/loan-basics-guide/' },
      { label: '신용점수 올리는 법', href: '/blog/credit-score-guide/' },
    ],
  },
  {
    name: '비상금 만들기',
    desc: '위기에 흔들리지 않도록 생활 안전망부터 확보합니다.',
    todo: '3~6개월 생활비를 파킹통장에 모으기',
    links: [
      { label: '비상금 가이드', href: '/blog/emergency-fund-guide/' },
      { label: '예·적금·파킹통장 비교', href: '/blog/savings-account-comparison/' },
    ],
  },
  {
    name: '종잣돈 모으기',
    desc: '투자에 굴릴 씨앗을 모으는 단계입니다.',
    todo: '선저축·자동이체로 목표액 모으기',
    links: [
      { label: '종잣돈 모으는 법', href: '/blog/seed-money-guide/' },
      { label: '목표금액 계산기', href: '/tools/goal-calculator/' },
    ],
  },
  {
    name: '투자 시작',
    desc: '분산과 장기 원칙으로 첫 투자를 시작합니다.',
    todo: '증권사 고르고 분산 포트폴리오 짜기',
    links: [
      { label: '증권사 고르는 법', href: '/blog/how-to-choose-brokerage/' },
      { label: '포트폴리오 기초', href: '/blog/investment-portfolio-basics/' },
    ],
  },
  {
    name: '자산 불리기',
    desc: '복리와 추가 수입으로 자산 증식을 가속합니다.',
    todo: '복리로 굴리고 부수입 더하기',
    links: [
      { label: '복리의 힘', href: '/blog/compound-interest-power/' },
      { label: '부업·지원금', href: '/category/income/' },
    ],
  },
];

const latest = posts.slice(0, 6);
const byCategory = (slug: 'money' | 'ai' | 'income') =>
  posts.filter((p) => p.data.category === slug).slice(0, 3);
---
<BaseLayout title={SITE.title} description={SITE.description}>
  <div class="wrap">
    <header class="home-masthead">
      <h1>주식·재테크와 AI 트렌드, <em>깊이 있게.</em></h1>
    </header>

    <section class="home-hero">
      <aside class="roadmap">
        <div class="side-head"><h2>머니 로드맵</h2><span class="roadmap__hint">나는 지금 어디?</span></div>
        <div class="roadmap__steps" role="tablist" aria-label="부의 축적 단계">
          {stages.map((s, i) => (
            <button class="roadmap__step" type="button" role="tab" data-step={i} aria-selected={i === 0 ? 'true' : 'false'}>
              <span class="roadmap__step-num">{i + 1}</span>{s.name}
            </button>
          ))}
        </div>
        <div class="roadmap__detail">
          {stages.map((s, i) => (
            <div class="roadmap__panel" data-panel={i} hidden={i !== 0}>
              <h3>{i + 1}. {s.name}</h3>
              <p>{s.desc}</p>
              <p class="roadmap__todo"><strong>다음 할 일</strong> · {s.todo}</p>
              <div class="roadmap__links">
                {s.links.map((l) => <a href={l.href}>{l.label} →</a>)}
              </div>
            </div>
          ))}
        </div>
      </aside>
      <div class="home-hero__side">
        <div class="side-head"><h2>주목할 아티클</h2></div>
        <ol class="ranked-list">
          {ranking.map((p, i) => (
            <li>
              <a class="ranked" href={`/blog/${p.id}/`}>
                <span class="ranked__num">{i + 1}</span>
                {p.data.heroImage && (
                  <div class="ranked__thumb"><img src={p.data.heroImage} alt="" loading="lazy" /></div>
                )}
                <div class="ranked__body">
                  <h3 class="ranked__title">{p.data.title}</h3>
                  <div class="ranked__meta">{CATEGORIES[p.data.category].name} · <FormattedDate date={p.data.pubDate} /></div>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <script is:inline>
      (() => {
        const steps = Array.from(document.querySelectorAll('.roadmap__step'));
        const panels = Array.from(document.querySelectorAll('.roadmap__panel'));
        steps.forEach((btn) => {
          btn.addEventListener('click', () => {
            const i = btn.dataset.step;
            steps.forEach((s) => s.setAttribute('aria-selected', s === btn ? 'true' : 'false'));
            panels.forEach((p) => { p.hidden = p.dataset.panel !== i; });
          });
        });
      })();
    </script>

    <section>
      <div class="section-head">
        <h2>최신 글</h2>
        <a href="/category/ai/">전체 보기</a>
      </div>
      <div class="card-grid">
        {latest.map((p) => <PostCard {...toCard(p)} />)}
      </div>
    </section>

    <AdSlot slot="home-mid" />

    {(['money', 'ai', 'income'] as const).map((slug) => (
      <section>
        <div class="section-head">
          <h2>{CATEGORIES[slug].name}</h2>
          <a href={`/category/${slug}/`}>{CATEGORIES[slug].tagline} →</a>
        </div>
        <div class="card-grid">
          {byCategory(slug).map((p) => <PostCard {...toCard(p)} />)}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
