---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE, CATEGORIES, EDITOR_PICKS } from '../consts';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const toCard = (p: (typeof posts)[number]) => ({
  href: `/blog/${p.id}/`,
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate,
  category: p.data.category,
  heroImage: p.data.heroImage,
});

// 에디터 큐레이션 랭킹(없으면 최신으로 채움)
const picksFromList = EDITOR_PICKS
  .map((slug) => posts.find((p) => p.id === slug))
  .filter((p): p is (typeof posts)[number] => Boolean(p));
const picks = [...picksFromList, ...posts.filter((p) => !picksFromList.includes(p))].slice(0, 6);
const ranking = picks;

// 좌측 콘텐츠 로테이터 — 가이드/진단/도구/사전이 롤링(슬라이드는 추가만 하면 됨)
const slides = [
  { badge: '가이드', title: '주식 투자 완벽 가이드', desc: '기본기·계좌·종목·운용까지, 처음이라면 여기서 시작하세요.', href: '/blog/stock-investing-complete-guide/', cta: '가이드 보기' },
  { badge: '진단', title: '투자 성향 진단', desc: '5가지 질문으로 내 성향과 그에 맞는 투자법을 찾아보세요.', href: '/quiz/investor-type/', cta: '진단 시작' },
  { badge: '도구', title: '바로 쓰는 금융 계산기', desc: '복리·평단가·대출 등 7종, 입력하면 즉시 계산.', href: '/tools/', cta: '계산기 열기' },
  { badge: '사전', title: '금융·AI 용어 사전', desc: '모르는 용어를 빠르게 찾고 관련 글로 이동.', href: '/glossary/', cta: '용어 보기' },
];

const latest = posts.slice(0, 6);
const byCategory = (slug: 'money' | 'ai' | 'income') =>
  posts.filter((p) => p.data.category === slug).slice(0, 3);
const catCount = (slug: 'money' | 'ai' | 'income') =>
  posts.filter((p) => p.data.category === slug).length;
---
<BaseLayout title={SITE.title} description={SITE.description}>
  <div class="wrap">
    <header class="home-masthead">
      <h1>주식·재테크와 AI 트렌드, <em>깊이 있게.</em></h1>
    </header>

    <section class="home-hero">
      <div class="home-hero__main">
      <aside class="rotator" aria-label="추천 콘텐츠">
        <div class="rotator__viewport">
          {slides.map((s, i) => (
            <a class={i === 0 ? 'rslide is-active' : 'rslide'} href={s.href} data-slide={i}>
              <span class="rslide__badge">{s.badge}</span>
              <h2 class="rslide__title">{s.title}</h2>
              <p class="rslide__desc">{s.desc}</p>
              <span class="rslide__cta">{s.cta} →</span>
            </a>
          ))}
        </div>
        <div class="rotator__dots">
          {slides.map((_, i) => (
            <button class="rotator__dot" type="button" data-dot={i} aria-label={`${i + 1}번 콘텐츠`} aria-current={i === 0 ? 'true' : 'false'}></button>
          ))}
        </div>
      </aside>

      <section class="home-cats" aria-label="카테고리">
        <div class="side-head"><h2>카테고리</h2><a href="/glossary/">용어사전 →</a></div>
        <ul class="home-cats__list">
          {(['money', 'ai', 'income'] as const).map((slug) => (
            <li>
              <a class="home-cat" href={`/category/${slug}/`}>
                <span class="home-cat__info">
                  <span class="home-cat__name">{CATEGORIES[slug].name}</span>
                  <span class="home-cat__tag">{CATEGORIES[slug].tagline}</span>
                </span>
                <span class="home-cat__count">{catCount(slug)}편</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
      </div>

      <div class="home-hero__side">
        <div class="side-head"><h2>주목할 아티클</h2></div>
        <ol class="ranked-list">
          {ranking.map((p, i) => (
            <li>
              <a class="ranked" href={`/blog/${p.id}/`}>
                <span class="ranked__num">{i + 1}</span>
                {p.data.heroImage && (
                  <div class="ranked__thumb"><img src={p.data.heroImage} alt="" loading="lazy" /></div>
                )}
                <div class="ranked__body">
                  <h3 class="ranked__title">{p.data.title}</h3>
                  <div class="ranked__meta">{CATEGORIES[p.data.category].name} · <FormattedDate date={p.data.pubDate} /></div>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <script is:inline>
      (() => {
        const root = document.querySelector('.rotator');
        if (!root) return;
        const slides = Array.from(root.querySelectorAll('.rslide'));
        const dots = Array.from(root.querySelectorAll('.rotator__dot'));
        let cur = 0, timer;
        const show = (n) => {
          cur = (n + slides.length) % slides.length;
          slides.forEach((s, i) => s.classList.toggle('is-active', i === cur));
          dots.forEach((d, i) => d.setAttribute('aria-current', i === cur ? 'true' : 'false'));
        };
        const start = () => { timer = setInterval(() => show(cur + 1), 5000); };
        const stop = () => clearInterval(timer);
        dots.forEach((d, i) => d.addEventListener('click', () => { show(i); stop(); start(); }));
        root.addEventListener('mouseenter', stop);
        root.addEventListener('mouseleave', start);
        start();
      })();
    </script>

    <section>
      <div class="section-head">
        <h2>최신 글</h2>
        <a href="/category/ai/">전체 보기</a>
      </div>
      <div class="card-grid">
        {latest.map((p) => <PostCard {...toCard(p)} />)}
      </div>
    </section>

    <AdSlot slot="home-mid" />

    {(['money', 'ai', 'income'] as const).map((slug) => (
      <section>
        <div class="section-head">
          <h2>{CATEGORIES[slug].name}</h2>
          <a href={`/category/${slug}/`}>{CATEGORIES[slug].tagline} →</a>
        </div>
        <div class="card-grid">
          {byCategory(slug).map((p) => <PostCard {...toCard(p)} />)}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
