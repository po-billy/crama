          { m: 12, items: [{ t: 'IRP·연금저축 납입', d: '세액공제 한도(900만원) 채우기', href: '/policy-calendar/' }, { t: 'ISA 납입 마감', d: '비과세 한도 확인', href: '/policy-calendar/' }, { t: '종합부동산세 납부', d: '12/15 마감', href: '/policy-calendar/' }] },
        ];
