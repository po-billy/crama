<script is:inline>
  // ── 소셜 프루프 토스트 ──
  (() => {
    var MSGS = [
      '방금 28세 직장인이 혜택 9건을 찾았어요',
      '25세 대학생이 장학금·지원금 5건을 발견했어요',
      '32세 프리랜서가 재무 체크업에서 B+ 등급을 받았어요',
      '방금 누군가 연 480만원의 숨은 혜택을 찾았어요',
      '26세 사회초년생이 도약계좌+월세지원을 동시에 찾았어요',
      '30세 신혼부부가 혜택 11건, 연 720만원을 발견했어요',
      '방금 누군가 재무 건강 등급 A를 달성했어요',
      '29세 직장인이 연금저축 세액공제 148만원을 확인했어요',
    ];
    var el = document.getElementById('social-proof');
    var text = document.getElementById('sp-text');
    if (!el || !text) return;
    var idx = 0, shown = 0;
    function show() {
      if (shown >= 3) return; // 세션당 최대 3회
      text.textContent = MSGS[idx % MSGS.length];
      el.hidden = false;
      el.classList.add('is-visible');
      idx++;
      shown++;
      setTimeout(function () {
        el.classList.remove('is-visible');
        setTimeout(function () { el.hidden = true; }, 400);
      }, 4000);
    }
    // 첫 표시: 8초 후, 이후 25초 간격
    setTimeout(function () { show(); setInterval(show, 25000); }, 8000);
  })();
</script>

<script is:inline>
  // ── 첫 방문 웰컴 바텀시트 (닫으면 3일 뒤 재노출, 목표 선택 시 영구 숨김) ──
  (() => {
    var WELCOMED = 'crama:welcomed';       // 목표 선택 등 확실한 관여 → 영구 숨김
    var SNOOZE = 'crama:welcome:snooze';   // 닫기/둘러보기 → 3일간 숨김(타임스탬프)
    var THREE_DAYS = 3 * 24 * 60 * 60 * 1000;
    try {
      if (localStorage.getItem(WELCOMED)) return;
      var snoozed = localStorage.getItem(SNOOZE);
      if (snoozed && (Date.now() - parseInt(snoozed, 10)) < THREE_DAYS) return;
    } catch (e) { return; }
    var sheet = document.getElementById('welcome-sheet');
    if (!sheet) return;
    // 5초 후 표시
    setTimeout(function () {
      sheet.style.display = '';
      // 다음 프레임에서 is-visible 추가해야 트랜지션 동작
      requestAnimationFrame(function () {
        requestAnimationFrame(function () { sheet.classList.add('is-visible'); });
      });
    }, 5000);
    // snooze=true → 3일간만 숨김 / false → 영구
    function close(snooze) {
      sheet.classList.remove('is-visible');
      setTimeout(function () { sheet.style.display = 'none'; }, 350);
      try { localStorage.setItem(snooze ? SNOOZE : WELCOMED, snooze ? String(Date.now()) : '1'); } catch (e) {}
    }
    // 닫기·둘러보기·배경 클릭 → 3일 스누즈(강제 이동/스크롤 없음)
    document.getElementById('welcome-close').addEventListener('click', function () { close(true); });
    document.getElementById('welcome-skip').addEventListener('click', function () { close(true); });
    sheet.addEventListener('click', function (e) { if (e.target === sheet) close(true); });
    // 골 선택 시: 영구 숨김 + 링크는 그대로 이동
    sheet.querySelectorAll('.welcome-goal').forEach(function (a) {
      a.addEventListener('click', function () { try { localStorage.setItem(WELCOMED, '1'); } catch (e) {} });
    });
  })();
</script>

<script>
  // 가이드 섹션 모바일 자동 슬라이드(보일 때만, 사용자 조작 시 일시정지, 모션 최소화 시 끔)
  const grid = document.querySelector('[data-guides]');
  const mq = window.matchMedia('(max-width: 720px)');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (grid && grid.children.length > 1) {
    let timer: ReturnType<typeof setInterval> | null = null;
    let paused = false, visible = false;
    let resumeT: ReturnType<typeof setTimeout> | null = null;
    const cards = () => Array.from(grid.children) as HTMLElement[];
    const centerOf = (card: HTMLElement) =>
      card.offsetLeft - ((grid as HTMLElement).clientWidth - card.clientWidth) / 2;
    function currentIndex() {
      const c = cards(); const sl = grid!.scrollLeft;
      let best = 0, bd = Infinity;
      c.forEach((card, i) => { const d = Math.abs(centerOf(card) - sl); if (d < bd) { bd = d; best = i; } });
      return best;
    }
    function go(i: number) {
      const c = cards(); const card = c[(i + c.length) % c.length];
      grid!.scrollTo({ left: centerOf(card), behavior: 'smooth' });
    }
    function step() { if (!paused && visible) go(currentIndex() + 1); }
    function start() { if (!timer && mq.matches && !reduce.matches) timer = setInterval(step, 3800); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    (['touchstart', 'pointerdown', 'wheel', 'keydown'] as const).forEach((ev) =>
      grid.addEventListener(ev, () => {
        paused = true;
        if (resumeT) clearTimeout(resumeT);
        resumeT = setTimeout(() => { paused = false; }, 6000);
      }, { passive: true }));
    new IntersectionObserver((es) => { visible = es[0].isIntersecting; }, { threshold: 0.3 }).observe(grid);
    mq.addEventListener?.('change', () => { stop(); start(); });
    start();
  }
</script>
