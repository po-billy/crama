          const dots = document.querySelectorAll('#rankc-dots span');
          if (!track || !dots.length || track.__bound) return;
          track.__bound = true;
          let raf;
          track.addEventListener('scroll', () => {
            cancelAnimationFrame(raf);
            raf = requestAnimationFrame(() => {
              const center = track.scrollLeft + track.clientWidth / 2;
              const cards = track.children; let best = 0, bd = Infinity;
              for (let i = 0; i < cards.length; i++) {
                const c = cards[i], cc = c.offsetLeft + c.offsetWidth / 2, d = Math.abs(cc - center);
                if (d < bd) { bd = d; best = i; }
              }
              dots.forEach((dt, i) => dt.classList.toggle('is-on', i === best));
            });
          }, { passive: true });
        }
        if (!window.__rankcBound) { window.__rankcBound = true; document.addEventListener('astro:page-load', __rankcInit); }
