---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE, CATEGORIES, EDITOR_PICKS, PILLARS, GUIDE_EXTRA } from '../consts';
import AudioPicks from '../components/AudioPicks.astro';
import Curations from '../components/Curations.astro';
import DuoIcon from '../components/DuoIcon.astro';
import ratesData from '../data/rates.json';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const toCard = (p: (typeof posts)[number]) => ({
  href: `/blog/${p.id}/`,
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate,
  category: p.data.category,
  heroImage: p.data.heroImage,
  thumb: p.data.thumb,
  audio: !!p.data.audio,
  format: p.data.format,
  readingTime: Math.max(1, Math.round((p.body?.length ?? 0) / 500)),
});

// 허브(필러) + 입문 가이드 — 별도 섹션으로 분리, 랭킹/최신에서는 제외
const pillarSlugs = Object.values(PILLARS);
// 가이드 섹션 노출 목록(필러 + 입문 가이드) — 목록 페이지와 공유(consts)
const guideSlugs = [...new Set([...pillarSlugs, ...GUIDE_EXTRA])];
const guidePosts = guideSlugs
  .map((slug) => posts.find((p) => p.id === slug))
  .filter((p): p is (typeof posts)[number] => Boolean(p))
  .map((p) => ({ title: p.data.title, href: `/blog/${p.id}/`, img: p.data.heroImage, cat: CATEGORIES[p.data.category].name }));

// 에디터 큐레이션 랭킹(없으면 최신으로 채움) — 허브는 제외
const picksFromList = EDITOR_PICKS
  .map((slug) => posts.find((p) => p.id === slug))
  .filter((p): p is (typeof posts)[number] => Boolean(p));
const picks = [
  ...picksFromList,
  ...posts.filter((p) => !picksFromList.includes(p) && !guideSlugs.includes(p.id)),
].slice(0, 8);
const ranking = picks;

// 좌측 콘텐츠 로테이터 — 가이드/진단/도구/사전이 롤링(슬라이드는 추가만 하면 됨)
const slides = [
  { title: '정보가 아니라<br />이야기를 읽다', desc: '돈과 AI를 둘러싼 관점과 장면, 머니 칼럼', href: '/column/', cta: '자세히 보기', panel: '#ffdac1', ink: '#2a201b', img: '/img/generated/rotator-column-hero.webp', imgMobile: '/img/generated/rotator-column-hero-m.webp' },
  { title: '복잡한 금융 계산,<br />입력하면 끝', desc: '복리·대출·세금·환율·노후까지 23종 계산기', href: '/tools/', cta: '자세히 보기', panel: '#ffffff', ink: '#1b1b22', img: '/img/generated/rotator-tools-hero.webp', imgMobile: '/img/generated/rotator-tools-hero-m.webp' },
  { title: '모르는 용어,<br />3초 만에 찾기', desc: '금융·AI 용어 사전, 관련 글로 바로 이동', href: '/glossary/', cta: '자세히 보기', panel: '#17151f', ink: '#ffffff', img: '/img/generated/rotator-glossary-hero.webp', imgMobile: '/img/generated/rotator-glossary-hero-m.webp' },
  { title: '주식, 처음이라면<br />여기서 시작', desc: '기본기·계좌·종목·운용까지 완벽 가이드', href: '/blog/stock-investing-complete-guide/', cta: '자세히 보기', panel: '#ffffff', ink: '#1b1b22', img: '/img/generated/rotator-guide-hero.webp', imgMobile: '/img/generated/rotator-guide-hero-m.webp' },
  { title: '내 돈 성향은<br />어떤 캐릭터일까', desc: '10가지 질문으로 보는 머니 캐릭터 테스트', href: '/quiz/money-character/', cta: '자세히 보기', panel: '#17151f', ink: '#ffffff', img: '/img/generated/rotator-quiz-hero.webp', imgMobile: '/img/generated/rotator-quiz-hero-m.webp' },
];

// 배너 하단 원형 퀵메뉴 — 둘러보기(서비스·계정·구독·콘텐츠·테스트). 코어 서비스는 상단 home-cta로 승격
const circles = [
  { label: '청년 정책', href: '/youth/', name: 'youth', badge: 'NEW' },
  { label: '복지 서비스', href: '/welfare/', name: 'welfare', badge: 'NEW' },
  { label: '내 관심', href: '/saved-picks/', name: 'saved' },
  { label: '브리핑', href: '/briefing/', name: 'brief' },
  { label: '크라미', href: '/me/', name: 'start' },
  { label: '오늘의 쇼츠', href: '/shorts/', name: 'shorts' },
  { label: '머니 캐릭터', href: '/quiz/money-character/', name: 'quiz' },
  { label: '빼꼼 투표', href: '/vote/', name: 'vote', badge: 'HOT' },
  { label: '투자 성향 진단', href: '/quiz/investor-type/', name: 'diagnose' },
  { label: '칼럼', href: '/column/', name: 'column' },
  { label: '가이드', href: '/guides/', name: 'guide' },
  { label: '계산기', href: '/tools/', name: 'calc' },
  { label: '용어집', href: '/glossary/', name: 'glossary' },
];

const latest = posts.filter((p) => !guideSlugs.includes(p.id)).slice(0, 8);
const byCategory = (slug: 'money' | 'ai' | 'income') =>
  posts.filter((p) => p.data.category === slug).slice(0, 4);

// 홈 섹션 제목 — 구어체·풍부하게(카테고리명은 consts 그대로, 홈에서만 다른 카피)
const catHome = {
  money: { title: '내 돈, 어떻게 굴릴까?', dek: '주식부터 절세까지 — 모르면 잃고, 알면 불어나는 돈 이야기' },
  ai: { title: 'AI, 먼저 보고 가요', dek: '남들이 따라올 때쯤 당신은 이미 쓰고 있다' },
  income: { title: '월급 밖에서 버는 법', dek: '부업·지원금·환급금 — 안 챙기면 남 주는 내 돈' },
} as const;

// 작은 썸네일(160px) 경로 — 랭킹/리스트의 48~90px 썸네일에 풀사이즈 hero 대신 사용(이미지 용량 절감)
const thumb = (h?: string) => (h && /-hero\.webp$/.test(h) ? h.replace(/-hero\.webp$/, '-hero-thumb.webp') : h);

// 오늘의 최고금리(12개월 최고우대) — 데일리 재방문 훅. rates.json은 크론이 매일 갱신
function bestRate(list: any[]) {
  let best: { rate: number; bank: string } | null = null;
  for (const p of list || []) for (const o of p.options || [])
    if (o.trm === 12 && o.rate2 != null && (!best || o.rate2 > best.rate)) best = { rate: o.rate2, bank: p.bank };
  return best;
}
const bestDep = bestRate((ratesData as any).deposits);
const bestSav = bestRate((ratesData as any).savings);
---
<BaseLayout spa title={SITE.title} description={SITE.description} image="/og-home.png">
  <div class="wrap wrap--home">

    {/* 마감 임박 혜택 알림 배너 — 빌드 시점 기준 30일 이내 마감 */}
    {(() => {
      const DEADLINES = [
        { date: '2026-07-03', title: '청년도약계좌 신청 마감', href: '/benefits/' },
        { date: '2026-07-25', title: '부가가치세 확정신고 마감', href: '/policy-calendar/' },
        { date: '2026-07-31', title: '재산세(주택 1기) 납부 마감', href: '/policy-calendar/' },
        { date: '2026-08-01', title: '청년 월세 지원 하반기 접수', href: '/policy-calendar/' },
        { date: '2026-08-31', title: '주민세 납부 마감', href: '/policy-calendar/' },
        { date: '2026-09-15', title: '국가장학금 2학기 신청 마감', href: '/policy-calendar/' },
        { date: '2026-09-30', title: '재산세(주택 2기) 납부 마감', href: '/policy-calendar/' },
        { date: '2026-12-15', title: '종합부동산세 납부 마감', href: '/policy-calendar/' },
        { date: '2026-12-31', title: 'IRP·연금저축 납입 마감', href: '/policy-calendar/' },
        { date: '2026-12-31', title: 'ISA 계좌 납입 마감', href: '/policy-calendar/' },
      ];
      const now = new Date();
      const soon = DEADLINES
        .map(d => ({ ...d, dday: Math.ceil((new Date(d.date).getTime() - now.getTime()) / 86400000) }))
        .filter(d => d.dday > 0 && d.dday <= 30)
        .sort((a, b) => a.dday - b.dday);
      const item = soon[0];
      return item ? (
        <a href={item.href} class="deadline-banner" id="home-gen-deadline">
          <span class="deadline-banner__dday">D-{item.dday}</span>
          <span class="deadline-banner__title">{item.title}</span>
          <span class="deadline-banner__cta">확인하기 →</span>
        </a>
      ) : null;
    })()}

    <a id="home-saved-dday" class="deadline-banner" href="/saved-picks/" hidden></a>
    <script is:inline>
      (() => {
        var el = document.getElementById('home-saved-dday');
        var S = window.CramaSaved;
        if (!el || !S) return;
        var esc = function (s) { return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); };
        function dday(ds) { if (!ds || !/^\d{4}-\d{2}-\d{2}$/.test(ds)) return null; var pt = ds.split('-'); var dl = new Date(+pt[0], +pt[1] - 1, +pt[2]); var n = new Date(); var today = new Date(n.getFullYear(), n.getMonth(), n.getDate()); return Math.round((dl - today) / 86400000); }
        function render() {
          var gen = document.getElementById('home-gen-deadline');
          var items = S.list().map(function (x) { return { x: x, d: dday(x.deadline) }; }).filter(function (o) { return o.d !== null && o.d >= 0 && o.d <= 30; }).sort(function (a, b) { return a.d - b.d; });
          if (!items.length) { el.hidden = true; return; }
          var top = items[0]; var nm = top.x.name.length > 16 ? top.x.name.slice(0, 16) + '…' : top.x.name;
          if (gen) gen.style.display = 'none';
          el.hidden = false;
          el.innerHTML = '<span class="deadline-banner__dday">' + (top.d === 0 ? 'D-Day' : 'D-' + top.d) + '</span>' +
            '<span class="deadline-banner__title">내 관심 · ' + esc(nm) + ' 마감' + (items.length > 1 ? ' 외 ' + (items.length - 1) + '건' : '') + '</span>' +
            '<span class="deadline-banner__cta">내 관심함 →</span>';
        }
        render();
        document.addEventListener('astro:page-load', render);
      })();
    </script>

    <header class="home-masthead">
      <h1>돈과 AI, <em>먼저 읽는 사람들.</em></h1>
    </header>

    <div class="home-top">
    <section class="home-banner">
      <section class="rotator rotator--banner" aria-label="추천 콘텐츠">
        <div class="rotator__viewport">
          {slides.map((s, i) => (
            <a class={i === 0 ? 'rslide is-active' : 'rslide'} href={s.href} data-slide={i} style={`--panel:${s.panel ?? '#1b1b22'}; --rtext:${s.ink ?? '#fff'}`}>
              <picture>
                <source media="(min-width: 1024px)" srcset={s.img} />
                <img class="rslide__bg" src={s.imgMobile ?? s.img} alt={s.title || ''} width="1200" height="675" style="aspect-ratio:16/9;object-fit:cover;" loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : 'auto'} />
              </picture>
              <h2 class="rslide__title" set:html={s.title}></h2>
              <p class="rslide__desc">{s.desc}</p>
              <span class="rslide__cta">{s.cta} →</span>
            </a>
          ))}
          <div class="rotator__counter"><span id="rot-cur">1</span> / {slides.length}</div>
        </div>
        <div class="rotator__dots">
          {slides.map((_, i) => (
            <button class="rotator__dot" type="button" data-dot={i} aria-label={`${i + 1}번 콘텐츠`} aria-current={i === 0 ? 'true' : 'false'}></button>
          ))}
        </div>
      </section>
    </section>
    <div class="home-cta">
      <a class="cta-card cta-card--main" href="/benefits/">
        <DuoIcon name="benefits" class="cta-card__ic" />
        <span class="cta-card__badge cta-card__badge--new">NEW</span>
        <b>내 혜택 찾기</b>
        <span class="cta-card__sub">조건만 입력하면, 내가 받을 수 있는 지원금·복지를 한 번에 찾아드려요. 무료예요.</span>
        <span class="cta-card__cta">3분 만에 확인하기 →</span>
      </a>
      <a class="cta-card" href="/checkup/">
        <DuoIcon name="checkup" class="cta-card__ic" />
        <span class="cta-card__badge cta-card__badge--new">NEW</span>
        <b>재무 체크업</b>
        <span class="cta-card__sub">3분 진단으로 내 돈 상태 점검</span>
      </a>
      <a class="cta-card" href="/policy-calendar/">
        <DuoIcon name="calendar" class="cta-card__ic" />
        <b>정책 캘린더</b>
        <span class="cta-card__sub">놓치면 손해인 신청·마감일</span>
      </a>
    </div>
    </div>

    <nav class="home-circles" aria-label="바로가기">
      {circles.map((c) => (
        <a class="hcircle" href={c.href}>
          <span class="hcircle__img">
            <DuoIcon name={c.name} class="hcircle__svg" />
            {c.badge && <span class="hcircle__badge">{c.badge}</span>}
          </span>
          <span class="hcircle__label">{c.label}</span>
        </a>
      ))}
    </nav>

    <!-- 첫 방문 3문답 온보딩 — 완료/기존 프로필 보유 시 숨김(localStorage) -->
    <section class="home-onb" id="home-onb" hidden aria-label="맞춤 정책 찾기">
      <button type="button" class="home-onb__x" id="onb-x" aria-label="닫기">×</button>
      <div class="home-onb__step" data-step="1">
        <p class="home-onb__q"><b>10초 맞춤 진단</b> · 나이대가 어떻게 되세요?</p>
        <div class="home-onb__chips">
          <button type="button" class="home-onb__chip" data-age="19">10대</button>
          <button type="button" class="home-onb__chip" data-age="22">20대 초반</button>
          <button type="button" class="home-onb__chip" data-age="27">20대 후반</button>
          <button type="button" class="home-onb__chip" data-age="32">30대 초반</button>
          <button type="button" class="home-onb__chip" data-age="37">30대 후반</button>
          <button type="button" class="home-onb__chip" data-age="45">40대+</button>
        </div>
      </div>
      <div class="home-onb__step" data-step="2" hidden>
        <p class="home-onb__q">어느 지역에 사세요?</p>
        <div class="home-onb__chips" id="onb-regions"></div>
      </div>
      <div class="home-onb__step" data-step="3" hidden>
        <p class="home-onb__q">지금 상황은요?</p>
        <div class="home-onb__chips">
          <button type="button" class="home-onb__chip" data-sit="직장인">직장인</button>
          <button type="button" class="home-onb__chip" data-sit="구직·취준">구직·취준</button>
          <button type="button" class="home-onb__chip" data-sit="학생">학생</button>
          <button type="button" class="home-onb__chip" data-sit="자영업·프리랜서">자영업·프리랜서</button>
        </div>
      </div>
      <div class="home-onb__result" data-step="4" hidden>
        <p class="home-onb__done" id="onb-headline"></p>
        <div class="home-onb__acts" id="onb-acts"></div>
      </div>
    </section>
    <script is:inline>
      (() => {
        var KEY = 'crama:onboard-v1';
        var sec = document.getElementById('home-onb');
        if (!sec) return;
        var done = false, prof = false, myProf = {};
        try { done = !!localStorage.getItem(KEY); prof = !!localStorage.getItem('crama:benefits:profile'); myProf = JSON.parse(localStorage.getItem('crama:profile') || '{}') || {}; } catch (e) {}
        if (done || prof || (myProf.age && myProf.region)) return; // 완료·매칭 프로필·내 정보 보유 → 미노출
        sec.hidden = false;

        var REGIONS = { '서울': '서울특별시', '경기': '경기도', '인천': '인천광역시', '부산': '부산광역시', '대구': '대구광역시', '광주': '광주광역시', '대전': '대전광역시', '울산': '울산광역시', '세종': '세종특별자치시', '강원': '강원특별자치도', '충북': '충청북도', '충남': '충청남도', '전북': '전북특별자치도', '전남': '전라남도', '경북': '경상북도', '경남': '경상남도', '제주': '제주특별자치도' };
        var rBox = document.getElementById('onb-regions');
        Object.keys(REGIONS).forEach(function (k) {
          var b = document.createElement('button');
          b.type = 'button'; b.className = 'home-onb__chip'; b.textContent = k; b.dataset.region = REGIONS[k];
          rBox.appendChild(b);
        });

        var ans = { age: 0, region: '', sit: '' };
        function show(n) { sec.querySelectorAll('[data-step]').forEach(function (s) { s.hidden = s.dataset.step !== String(n); }); }

        // 슬림 데이터 프리페치(첫 응답 시점)
        var dataP = null;
        function loadData() {
          if (!dataP) dataP = Promise.all([
            fetch('/data/youth-slim.json').then(function (r) { return r.json(); }).catch(function () { return { policies: [] }; }),
            fetch('/data/welfare-local-slim.json').then(function (r) { return r.json(); }).catch(function () { return { services: [] }; }),
          ]);
          return dataP;
        }

        sec.addEventListener('click', function (e) {
          var c = e.target.closest('.home-onb__chip');
          if (!c) return;
          if (c.dataset.age) { ans.age = Number(c.dataset.age); loadData(); show(2); }
          else if (c.dataset.region) { ans.region = c.dataset.region; show(3); }
          else if (c.dataset.sit) { ans.sit = c.dataset.sit; finish(); }
        });
        document.getElementById('onb-x').addEventListener('click', function () {
          try { localStorage.setItem(KEY, 'dismissed'); } catch (e) {}
          sec.hidden = true;
        });

        async function finish() {
          show(4);
          var head = document.getElementById('onb-headline');
          head.textContent = '찾는 중…';
          var d = await loadData();
          var youth = (d[0].policies || []).filter(function (p) {
            var mn = parseInt(p.minAge, 10), mx = parseInt(p.maxAge, 10);
            if (!p.ageLimit || isNaN(mn) || isNaN(mx)) return true;
            return ans.age >= mn && ans.age <= mx;
          }).length;
          var local = (d[1].services || []).filter(function (s) { return s.region === ans.region; }).length;
          var rShort = ans.region.slice(0, 2);
          head.innerHTML = ans.sit + ' 기준, 지금 <b>' + (ans.age <= 45 && youth ? '청년 정책 ' + youth + '건' : '') +
            (ans.age <= 45 && youth && local ? ' + ' : '') + (local ? rShort + ' 복지 ' + local + '건' : '') + '</b>이 기다리고 있어요.';
          var acts = document.getElementById('onb-acts');
          var html = '';
          if (ans.age <= 45 && youth) html += '<a href="/youth/">청년 정책 보기 →</a>';
          if (local) html += '<a href="/welfare/?region=' + encodeURIComponent(ans.region) + '">' + rShort + ' 복지 보기 →</a>';
          html += '<a class="is-main" href="/benefits/">3분 정밀 매칭 받기 →</a>';
          acts.innerHTML = html;
