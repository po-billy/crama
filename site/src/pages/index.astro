---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE, CATEGORIES, EDITOR_PICKS, PILLARS, GUIDE_EXTRA } from '../consts';
import AudioPicks from '../components/AudioPicks.astro';
import Curations from '../components/Curations.astro';
import InstallApp from '../components/InstallApp.astro';
import DuoIcon from '../components/DuoIcon.astro';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const toCard = (p: (typeof posts)[number]) => ({
  href: `/blog/${p.id}/`,
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate,
  category: p.data.category,
  heroImage: p.data.heroImage,
  thumb: p.data.thumb,
  audio: !!p.data.audio,
  format: p.data.format,
});

// 허브(필러) + 입문 가이드 — 별도 섹션으로 분리, 랭킹/최신에서는 제외
const pillarSlugs = Object.values(PILLARS);
// 가이드 섹션 노출 목록(필러 + 입문 가이드) — 목록 페이지와 공유(consts)
const guideSlugs = [...new Set([...pillarSlugs, ...GUIDE_EXTRA])];
const guidePosts = guideSlugs
  .map((slug) => posts.find((p) => p.id === slug))
  .filter((p): p is (typeof posts)[number] => Boolean(p))
  .map((p) => ({ title: p.data.title, href: `/blog/${p.id}/`, img: p.data.heroImage, cat: CATEGORIES[p.data.category].name }));

// 에디터 큐레이션 랭킹(없으면 최신으로 채움) — 허브는 제외
const picksFromList = EDITOR_PICKS
  .map((slug) => posts.find((p) => p.id === slug))
  .filter((p): p is (typeof posts)[number] => Boolean(p));
const picks = [
  ...picksFromList,
  ...posts.filter((p) => !picksFromList.includes(p) && !guideSlugs.includes(p.id)),
].slice(0, 8);
const ranking = picks;

// 좌측 콘텐츠 로테이터 — 가이드/진단/도구/사전이 롤링(슬라이드는 추가만 하면 됨)
const slides = [
  { title: '정보가 아니라<br />이야기를 읽다', desc: '돈과 AI를 둘러싼 관점과 장면, 머니 칼럼', href: '/column/', cta: '자세히 보기', panel: '#36302a', img: '/img/generated/rotator-column-hero.webp', imgMobile: '/img/generated/rotator-column-hero-m.webp' },
  { title: '복잡한 금융 계산,<br />입력하면 끝', desc: '복리·대출·세금·환율·노후까지 23종 계산기', href: '/tools/', cta: '자세히 보기', panel: '#1e2a3a', img: '/img/generated/rotator-tools-hero.webp', imgMobile: '/img/generated/rotator-tools-hero-m.webp' },
  { title: '모르는 용어,<br />3초 만에 찾기', desc: '금융·AI 용어 사전, 관련 글로 바로 이동', href: '/glossary/', cta: '자세히 보기', panel: '#2a2440', img: '/img/generated/rotator-glossary-hero.webp', imgMobile: '/img/generated/rotator-glossary-hero-m.webp' },
  { title: '주식, 처음이라면<br />여기서 시작', desc: '기본기·계좌·종목·운용까지 완벽 가이드', href: '/blog/stock-investing-complete-guide/', cta: '자세히 보기', panel: '#102a36', img: '/img/generated/rotator-guide-hero.webp', imgMobile: '/img/generated/rotator-guide-hero-m.webp' },
  { title: '내 돈 성향은<br />어떤 캐릭터일까', desc: '10가지 질문으로 보는 머니 캐릭터 테스트', href: '/quiz/money-character/', cta: '자세히 보기', panel: '#2d1f3d', img: '/img/generated/rotator-quiz-hero.webp', imgMobile: '/img/generated/rotator-quiz-hero-m.webp' },
];

// 배너 하단 원형 퀵메뉴 — 콘텐츠 + 테스트 바로가기
const circles = [
  { label: '머니 캐릭터 테스트', href: '/quiz/money-character/', name: 'quiz', badge: 'NEW' },
  { label: '투자 성향 진단', href: '/quiz/investor-type/', name: 'diagnose' },
  { label: '칼럼', href: '/column/', name: 'column' },
  { label: '완벽 가이드', href: '/guides/', name: 'guide' },
  { label: '계산기', href: '/tools/', name: 'calc' },
  { label: '용어집', href: '/glossary/', name: 'glossary' },
  { label: '주식·재테크', href: '/category/money/', name: 'money' },
  { label: 'AI 트렌드', href: '/category/ai/', name: 'ai' },
  { label: '부업·지원금', href: '/category/income/', name: 'income' },
];

const latest = posts.filter((p) => !guideSlugs.includes(p.id)).slice(0, 8);
const byCategory = (slug: 'money' | 'ai' | 'income') =>
  posts.filter((p) => p.data.category === slug).slice(0, 4);

// 작은 썸네일(160px) 경로 — 랭킹/리스트의 48~90px 썸네일에 풀사이즈 hero 대신 사용(이미지 용량 절감)
const thumb = (h?: string) => (h && /-hero\.webp$/.test(h) ? h.replace(/-hero\.webp$/, '-hero-thumb.webp') : h);
---
<BaseLayout spa title={SITE.title} description={SITE.description} image="/og-home.png">
  <div class="wrap wrap--home">
    <InstallApp />
    <header class="home-masthead">
      <h1>주식·재테크와 AI 트렌드, <em>깊이 있게.</em></h1>
    </header>

    <div class="home-top">
    <section class="home-banner">
      <section class="rotator rotator--banner" aria-label="추천 콘텐츠">
        <div class="rotator__viewport">
          {slides.map((s, i) => (
            <a class={i === 0 ? 'rslide is-active' : 'rslide'} href={s.href} data-slide={i} style={`--panel:${s.panel ?? '#1b1b22'}`}>
              <picture>
                <source media="(min-width: 1024px)" srcset={s.img} />
                <img class="rslide__bg" src={s.imgMobile ?? s.img} alt="" loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : 'auto'} />
              </picture>
              <h2 class="rslide__title" set:html={s.title}></h2>
              <p class="rslide__desc">{s.desc}</p>
              <span class="rslide__cta">{s.cta} →</span>
            </a>
          ))}
          <div class="rotator__counter"><span id="rot-cur">1</span> / {slides.length}</div>
        </div>
        <div class="rotator__dots">
          {slides.map((_, i) => (
            <button class="rotator__dot" type="button" data-dot={i} aria-label={`${i + 1}번 콘텐츠`} aria-current={i === 0 ? 'true' : 'false'}></button>
          ))}
        </div>
      </section>
    </section>
    <div class="home-cta">
      <a class="cta-card cta-card--main" href="/me/">
        <DuoIcon name="start" class="cta-card__ic" />
        <span class="cta-card__badge">많이 찾는</span>
        <b>크라미 시작하기</b>
        <span class="cta-card__sub">읽을수록 밀웜 적립 · 크라미 꾸미기</span>
      </a>
      <a class="cta-card cta-card--quiz" href="/quiz/money-character/">
        <DuoIcon name="quiz" class="cta-card__ic" />
        <span class="cta-card__badge cta-card__badge--new">NEW</span>
        <b>머니 캐릭터 테스트</b>
      </a>
      <a class="cta-card cta-card--shorts" href="/shorts/">
        <DuoIcon name="shorts" class="cta-card__ic" />
        <b>오늘의 쇼츠 보기</b>
      </a>
    </div>
    </div>

    <nav class="home-circles" aria-label="바로가기">
      {circles.map((c) => (
        <a class="hcircle" href={c.href}>
          <span class="hcircle__img">
            <DuoIcon name={c.name} class="hcircle__svg" />
            {c.badge && <span class="hcircle__badge">{c.badge}</span>}
          </span>
          <span class="hcircle__label">{c.label}</span>
        </a>
      ))}
    </nav>

    <section class="home-rank">
      <div class="section-head"><h2>주목할 아티클</h2><a href="/category/money/">재테크 글 전체 보기</a></div>
      <ol class="ranked-list">
        {ranking.map((p, i) => (
          <li>
            <a class="ranked" href={`/blog/${p.id}/`}>
              <span class="ranked__num">{i + 1}</span>
              {p.data.heroImage && (
                <div class="ranked__thumb"><img src={thumb(p.data.heroImage)} alt="" loading="lazy" width="60" height="60" /></div>
              )}
              <div class="ranked__body">
                <h3 class="ranked__title">{p.data.title}</h3>
                <div class="ranked__meta">{CATEGORIES[p.data.category].name} · <FormattedDate date={p.data.pubDate} /></div>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </section>

    <!-- 모바일 전용 — 주목할 아티클 스와이프 카드(상단 dot 인디케이터) -->
    <section class="rankc" aria-label="주목할 아티클">
      <div class="rankc__panel">
        <div class="rankc__head">
          <span class="rankc__label">시간 없을 땐, 이것만 📌</span>
          <a class="rankc__audio" href="/shorts/" aria-label="쇼츠로 보기">
            <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14v-2a8 8 0 0 1 16 0v2"/><rect x="3" y="13" width="4" height="7" rx="1.4"/><rect x="17" y="13" width="4" height="7" rx="1.4"/></svg>
          </a>
        </div>
        <div class="rankc__dots" id="rankc-dots" aria-hidden="true">
          {ranking.map((_, i) => <span class={i === 0 ? 'is-on' : ''}></span>)}
        </div>
        <div class="rankc__track" id="rankc-track">
          {ranking.map((p) => (
            <a class="rankc__slide" href={`/blog/${p.id}/`}>
              {p.data.heroImage
                ? <img class="rankc__img" src={p.data.heroImage} alt="" loading="lazy" />
                : <span class="rankc__img rankc__img--ph" aria-hidden="true"></span>}
              <h3 class="rankc__t">{p.data.title}</h3>
              <p class="rankc__d">{p.data.description}</p>
              <span class="rankc__cta">이어서 읽어보기</span>
            </a>
          ))}
        </div>
      </div>
      <script is:inline>
        function __rankcInit() {
          const track = document.getElementById('rankc-track');
          const dots = document.querySelectorAll('#rankc-dots span');
          if (!track || !dots.length || track.__bound) return;
          track.__bound = true;
          let raf;
          track.addEventListener('scroll', () => {
            cancelAnimationFrame(raf);
            raf = requestAnimationFrame(() => {
              const center = track.scrollLeft + track.clientWidth / 2;
              const cards = track.children; let best = 0, bd = Infinity;
              for (let i = 0; i < cards.length; i++) {
                const c = cards[i], cc = c.offsetLeft + c.offsetWidth / 2, d = Math.abs(cc - center);
                if (d < bd) { bd = d; best = i; }
              }
              dots.forEach((dt, i) => dt.classList.toggle('is-on', i === best));
            });
          }, { passive: true });
        }
        if (!window.__rankcBound) { window.__rankcBound = true; document.addEventListener('astro:page-load', __rankcInit); }
        if (document.readyState !== 'loading') __rankcInit(); else document.addEventListener('DOMContentLoaded', __rankcInit, { once: true });
      </script>
    </section>

    <AudioPicks />

    <Curations />

    <script is:inline>
      function __rotInit() {
        if (window.__rotStop) { window.__rotStop(); window.__rotStop = null; }
        const root = document.querySelector('.rotator');
        if (!root) return;
        const slides = Array.from(root.querySelectorAll('.rslide'));
        const dots = Array.from(root.querySelectorAll('.rotator__dot'));
        let cur = 0, timer, fadeTimer;
        const show = (n) => {
          const next = (n + slides.length) % slides.length;
          if (next === cur) return;
          const inEl = slides[next], outEl = slides[cur];
          clearTimeout(fadeTimer);
          // 들어오는 슬라이드를 위에 올려 페이드인, 나가는 슬라이드는 덮일 때까지 불투명 유지
          inEl.style.zIndex = '3';
          outEl.style.zIndex = '2';
          inEl.classList.add('is-active');
          fadeTimer = setTimeout(() => {
            slides.forEach((s, i) => {
              if (i !== next) s.classList.remove('is-active');
              s.style.zIndex = '';
            });
          }, 720);
          dots.forEach((d, i) => d.setAttribute('aria-current', i === next ? 'true' : 'false'));
          const counter = document.getElementById('rot-cur');
          if (counter) counter.textContent = String(next + 1);
          cur = next;
        };
        const start = () => { clearInterval(timer); timer = setInterval(() => show(cur + 1), 5000); };
        const stop = () => clearInterval(timer);
        dots.forEach((d, i) => d.addEventListener('click', () => { show(i); stop(); start(); }));
        root.addEventListener('mouseenter', stop);
        root.addEventListener('mouseleave', start);

        // PC 마우스 드래그 + 모바일 터치 스와이프 통합 (Pointer Events)
        const vp = root.querySelector('.rotator__viewport') || root;
        let px = 0, py = 0, dragging = false, justDragged = false;
        vp.addEventListener('pointerdown', (e) => {
          if (e.button > 0) return; // 좌클릭/터치만
          px = e.clientX; py = e.clientY; dragging = true; stop();
        });
        const endDrag = (e) => {
          if (!dragging) return; dragging = false;
          const dx = e.clientX - px, dy = e.clientY - py;
          if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy) * 1.3) {
            show(cur + (dx < 0 ? 1 : -1));
            justDragged = true; setTimeout(() => { justDragged = false; }, 350);
          }
          start();
        };
        window.addEventListener('pointerup', endDrag);
        window.addEventListener('pointercancel', () => { if (dragging) { dragging = false; start(); } });
        // 드래그 직후 발생하는 링크 클릭은 무시(원치 않는 페이지 이동 방지)
        slides.forEach((s) => s.addEventListener('click', (e) => { if (justDragged) { e.preventDefault(); e.stopPropagation(); } }));

        window.__rotStop = stop;
        start();
      }
      if (!window.__rotBound) { window.__rotBound = true; document.addEventListener('astro:page-load', __rotInit); }
      if (document.readyState !== 'loading') __rotInit(); else document.addEventListener('DOMContentLoaded', __rotInit, { once: true });
    </script>

    {guidePosts.length > 0 && (
      <section class="guides">
        <div class="section-head">
          <h2>주제별 완벽 가이드</h2>
          <a class="guides__hint" href="/guides/">전체 보기 →</a>
        </div>
        <div class="guides__viewport">
          <button class="guides__arrow guides__arrow--prev" type="button" data-guides-prev aria-label="이전 가이드">‹</button>
          <div class="guides__grid" data-guides>
            {guidePosts.map((g) => (
              <a class="guide-card" href={g.href}>
                {g.img && <img class="guide-card__bg" src={g.img} alt="" loading="lazy" />}
                <span class="guide-card__badge">{g.cat} 가이드</span>
                <h3 class="guide-card__title">{g.title}</h3>
                <span class="guide-card__cta">단계별로 시작하기 →</span>
              </a>
            ))}
          </div>
          <button class="guides__arrow guides__arrow--next" type="button" data-guides-next aria-label="다음 가이드">›</button>
        </div>
        <script is:inline>
          function __guidesInit() {
            if (window.__guidesStop) { window.__guidesStop(); window.__guidesStop = null; }
            const grid = document.querySelector('[data-guides]');
            if (!grid) return;
            const prev = document.querySelector('[data-guides-prev]');
            const next = document.querySelector('[data-guides-next]');
            const stepW = () => {
              const card = grid.querySelector('.guide-card');
              return card ? card.getBoundingClientRect().width + 20 : 320;
            };
            const atEnd = () => grid.scrollLeft + grid.clientWidth >= grid.scrollWidth - 8;
            prev && prev.addEventListener('click', () => grid.scrollBy({ left: -stepW(), behavior: 'smooth' }));
            next && next.addEventListener('click', () => grid.scrollBy({ left: stepW(), behavior: 'smooth' }));
            let timer;
            const start = () => { clearInterval(timer); timer = setInterval(() => {
              if (atEnd()) grid.scrollTo({ left: 0, behavior: 'smooth' });
              else grid.scrollBy({ left: stepW(), behavior: 'smooth' });
            }, 4500); };
            const stop = () => clearInterval(timer);
            grid.addEventListener('mouseenter', stop);
            grid.addEventListener('mouseleave', start);
            grid.addEventListener('pointerdown', stop);
            window.__guidesStop = stop;
            start();
          }
          if (!window.__guidesBound) { window.__guidesBound = true; document.addEventListener('astro:page-load', __guidesInit); }
          if (document.readyState !== 'loading') __guidesInit(); else document.addEventListener('DOMContentLoaded', __guidesInit, { once: true });
        </script>
      </section>
    )}

    <section>
      <div class="section-head">
        <h2>최신 글</h2>
        <a href="/category/ai/">최신 글 전체 보기</a>
      </div>
      <div class="card-grid">
        {latest.map((p) => <PostCard {...toCard(p)} />)}
      </div>
    </section>

    <AdSlot slot="home-mid" />

    {(['money', 'ai', 'income'] as const).map((slug) => (
      <section>
        <div class="section-head">
          <h2>{CATEGORIES[slug].name}</h2>
          <a href={`/category/${slug}/`}>{CATEGORIES[slug].tagline} →</a>
        </div>
        <div class="card-grid">
          {byCategory(slug).map((p) => <PostCard {...toCard(p)} />)}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<script>
  // 가이드 섹션 모바일 자동 슬라이드(보일 때만, 사용자 조작 시 일시정지, 모션 최소화 시 끔)
  const grid = document.querySelector('[data-guides]');
  const mq = window.matchMedia('(max-width: 720px)');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (grid && grid.children.length > 1) {
    let timer: ReturnType<typeof setInterval> | null = null;
    let paused = false, visible = false;
    let resumeT: ReturnType<typeof setTimeout> | null = null;
    const cards = () => Array.from(grid.children) as HTMLElement[];
    const centerOf = (card: HTMLElement) =>
      card.offsetLeft - ((grid as HTMLElement).clientWidth - card.clientWidth) / 2;
    function currentIndex() {
      const c = cards(); const sl = grid!.scrollLeft;
      let best = 0, bd = Infinity;
      c.forEach((card, i) => { const d = Math.abs(centerOf(card) - sl); if (d < bd) { bd = d; best = i; } });
      return best;
    }
    function go(i: number) {
      const c = cards(); const card = c[(i + c.length) % c.length];
      grid!.scrollTo({ left: centerOf(card), behavior: 'smooth' });
    }
    function step() { if (!paused && visible) go(currentIndex() + 1); }
    function start() { if (!timer && mq.matches && !reduce.matches) timer = setInterval(step, 3800); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    (['touchstart', 'pointerdown', 'wheel', 'keydown'] as const).forEach((ev) =>
      grid.addEventListener(ev, () => {
        paused = true;
        if (resumeT) clearTimeout(resumeT);
        resumeT = setTimeout(() => { paused = false; }, 6000);
      }, { passive: true }));
    new IntersectionObserver((es) => { visible = es[0].isIntersecting; }, { threshold: 0.3 }).observe(grid);
    mq.addEventListener?.('change', () => { stop(); start(); });
    start();
  }
</script>
