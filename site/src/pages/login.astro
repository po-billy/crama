---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/app.css';
---

<BaseLayout title="로그인 — Crama" description="크라마 로그인 / 회원가입">
  <div class="app">
    <h1>크라마 시작하기</h1>
    <p class="app__sub">먼저 읽는 사람들 — 로그인하고 밀웜을 모아 옷장을 꾸며보세요.</p>

    <div id="provider-view" class="stack">
      <button class="btn btn--kakao" id="kakao">카카오로 로그인</button>
      <button class="btn btn--google" id="google">Google로 로그인</button>
      <button class="btn btn--line" id="to-email">이메일로 로그인</button>
    </div>

    <form id="email-view" class="stack" style="display:none" autocomplete="on">
      <input class="field" type="email" id="email" placeholder="이메일" autocomplete="email" />
      <input class="field" type="password" id="password" placeholder="비밀번호 (6자 이상)" autocomplete="current-password" />
      <button class="btn btn--primary" id="submit" type="submit"><span id="submit-label">로그인</span></button>
      <div class="row-between">
        <button class="muted-link" type="button" id="back">← 다른 방법</button>
        <button class="muted-link" type="button" id="toggle-mode">회원가입하기</button>
      </div>
    </form>

    <p class="app__sub" id="cfg-warn" style="display:none; margin-top:1.5rem">환경설정(.env) 후 사용할 수 있어요.</p>
  </div>
  <div class="toast" id="toast"></div>
</BaseLayout>

<script>
  import { getUser, signInEmail, signUpEmail, signInOAuth, isSupabaseConfigured } from '../lib/api';

  const $ = (id: string) => document.getElementById(id)!;
  const toast = (m: string) => {
    const t = $('toast');
    t.textContent = m;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2200);
  };

  if (!isSupabaseConfigured) $('cfg-warn').style.display = 'block';

  // 이미 로그인 → 계정으로
  getUser().then((u) => {
    if (u) location.replace('/me/');
  });

  let signup = false;

  $('to-email').onclick = () => {
    $('provider-view').style.display = 'none';
    $('email-view').style.display = 'grid';
  };
  $('back').onclick = () => {
    $('email-view').style.display = 'none';
    $('provider-view').style.display = 'grid';
  };
  $('toggle-mode').onclick = () => {
    signup = !signup;
    $('submit-label').textContent = signup ? '회원가입' : '로그인';
    ($('toggle-mode') as HTMLElement).textContent = signup ? '로그인하기' : '회원가입하기';
  };

  $('kakao').onclick = async () => {
    const { error } = await signInOAuth('kakao');
    if (error) toast(error);
  };
  $('google').onclick = async () => {
    const { error } = await signInOAuth('google');
    if (error) toast(error);
  };

  $('email-view').addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = ($('email') as HTMLInputElement).value.trim();
    const pw = ($('password') as HTMLInputElement).value;
    if (!email || pw.length < 6) return toast('이메일과 6자 이상 비밀번호를 입력해 주세요.');
    const btn = $('submit') as HTMLButtonElement;
    btn.disabled = true;
    const res = signup ? await signUpEmail(email, pw) : await signInEmail(email, pw);
    btn.disabled = false;
    if (res.error) return toast(res.error);
    if (signup && 'needsConfirm' in res && res.needsConfirm) return toast('확인 메일을 보냈어요. 인증 후 로그인해 주세요.');
    location.replace('/me/');
  });
</script>
