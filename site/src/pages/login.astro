---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/app.css';
---

<BaseLayout title="로그인 — Crama" description="크라마 로그인 / 회원가입">
  <div class="app login">
    <div class="login__hero">
      <img class="login__mascot" src="/img/generated/meerkat-baby-wave.webp" alt="크라미" />
      <h1>크라미 시작하기</h1>
      <p class="app__sub">먼저 읽는 사람들 — 로그인하고 글 읽을 때마다 <strong>밀웜</strong>을 모아 나만의 <strong>크라미</strong>를 꾸며보세요.</p>
    </div>

    <!-- 친구 초대로 들어온 경우 -->
    <div class="ref-banner" id="ref-banner" hidden>
      <span>친구 초대 코드 <b id="ref-code"></b></span>
      <span class="ref-banner__bonus">가입 시 둘 다 +20밀웜</span>
    </div>

    <div id="provider-view" class="stack">
      <button class="btn btn--google" id="google">Google로 계속하기</button>
      <button class="btn btn--line" id="to-email">이메일로 계속하기</button>
    </div>

    <form id="email-view" class="stack" style="display:none" autocomplete="on">
      <input class="field" type="email" id="email" placeholder="이메일" autocomplete="email" />
      <input class="field" type="password" id="password" placeholder="비밀번호 (6자 이상)" autocomplete="current-password" />
      <button class="btn btn--primary" id="submit" type="submit"><span id="submit-label">로그인</span></button>
      <div class="row-between">
        <button class="muted-link" type="button" id="back">← 다른 방법</button>
        <button class="muted-link" type="button" id="toggle-mode">회원가입하기</button>
      </div>
    </form>

    <!-- 추천 코드 직접 입력 -->
    <div style="text-align:center;margin-top:1.2rem">
      <button class="muted-link" id="ref-toggle">추천 코드가 있나요?</button>
    </div>
    <div class="ref-input-row" id="ref-input-row" hidden>
      <input class="field" id="ref-input" placeholder="추천 코드 (예: BE1990)" maxlength="12" style="margin:0;text-transform:uppercase" />
      <button class="btn btn--line" id="ref-apply" style="width:auto;padding-inline:1.1rem">적용</button>
    </div>

    <p class="login__trust">Google 계정 또는 이메일로 안전하게 로그인해요.<br />비밀번호는 우리가 저장하지 않고, 인증은 Supabase가 처리합니다.</p>
    <p class="app__sub" id="cfg-warn" style="display:none;text-align:center">환경설정(.env) 후 사용할 수 있어요.</p>
  </div>
  <div class="toast" id="toast"></div>
</BaseLayout>

<script>
  import { getUser, signInEmail, signUpEmail, signInOAuth, isSupabaseConfigured } from '../lib/api';

  const $ = (id: string) => document.getElementById(id)!;
  const toast = (m: string) => { const t = $('toast'); t.textContent = m; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 2200); };

  if (!isSupabaseConfigured) $('cfg-warn').style.display = 'block';
  getUser().then((u) => { if (u) location.replace('/me/'); });

  // 레퍼럴: localStorage(BaseHead가 ?ref= 저장) 또는 직접 입력
  function showRef(code: string) {
    if (!code) return;
    $('ref-code').textContent = code;
    $('ref-banner').hidden = false;
  }
  showRef((localStorage.getItem('crama:ref') || '').toUpperCase());

  $('ref-toggle').onclick = () => { const r = $('ref-input-row'); r.hidden = !r.hidden; if (!r.hidden) ($('ref-input') as HTMLInputElement).focus(); };
  $('ref-apply').onclick = () => {
    const code = ($('ref-input') as HTMLInputElement).value.trim().toUpperCase();
    if (!code) return;
    localStorage.setItem('crama:ref', code);
    showRef(code);
    $('ref-input-row').hidden = true;
    toast('추천 코드 적용됨 — 가입하면 보상받아요');
  };

  let signup = false;
  $('to-email').onclick = () => { $('provider-view').style.display = 'none'; $('email-view').style.display = 'grid'; };
  $('back').onclick = () => { $('email-view').style.display = 'none'; $('provider-view').style.display = 'grid'; };
  $('toggle-mode').onclick = () => {
    signup = !signup;
    $('submit-label').textContent = signup ? '회원가입' : '로그인';
    ($('toggle-mode') as HTMLElement).textContent = signup ? '로그인하기' : '회원가입하기';
  };

  $('google').onclick = async () => { const { error } = await signInOAuth('google'); if (error) toast(error); };

  $('email-view').addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = ($('email') as HTMLInputElement).value.trim();
    const pw = ($('password') as HTMLInputElement).value;
    if (!email || pw.length < 6) return toast('이메일과 6자 이상 비밀번호를 입력해 주세요.');
    const btn = $('submit') as HTMLButtonElement;
    btn.disabled = true;
    const res = signup ? await signUpEmail(email, pw) : await signInEmail(email, pw);
    btn.disabled = false;
    if (res.error) return toast(res.error);
    if (signup && 'needsConfirm' in res && res.needsConfirm) return toast('확인 메일을 보냈어요. 인증 후 로그인해 주세요.');
    location.replace('/me/');
  });
</script>
