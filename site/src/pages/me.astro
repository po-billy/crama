---
import BaseLayout from '../layouts/BaseLayout.astro';
import WormIcon from '../components/WormIcon.astro';
import DuoIcon from '../components/DuoIcon.astro';
import '../styles/app.css';
---

<BaseLayout title="마이 — Crama" description="내 프로필 · 밀웜 · 크라미">
  <!-- 비로그인 → 즉시 로그인 페이지(깜빡임 방지) -->
  <!-- OAuth 콜백은 #access_token=... 해시로 도착 → Supabase가 파싱할 때까지 대기 -->
  <script is:inline>
    (() => {
      try {
        var hasToken = Object.keys(localStorage).some(function(k) { return k.includes('-auth-token'); });
        var isOAuthCallback = location.hash && (location.hash.includes('access_token') || location.hash.includes('refresh_token'));
        if (!hasToken && !isOAuthCallback) { location.replace('/login/'); return; }
      } catch (e) {}
    })();
  </script>
  <div class="app" id="me-app" style="opacity:0;transition:opacity .15s;">
    <!-- 연속 출석 → 캘린더 -->
    <a class="streak-bar" href="/calendar/">
      <span><b id="streak">0</b>일 연속 출석 중</span>
      <span class="go">캘린더로 보기 ›</span>
    </a>

    <!-- 마스코트 | 프로필 (가로) -->
    <div class="me-top">
      <div class="dress" id="dress">
        <div class="char">
          <img class="base base-body" src="/img/generated/meerkat-body.webp" alt="크라미" />
          <img class="base base-head" src="/img/generated/meerkat-head.webp" alt="" />
        </div>
      </div>
      <div class="me-profile">
        <div class="nick-row" id="nick-row"><b id="nick">회원</b><button class="nick-edit" id="nick-edit">변경</button></div>
        <span class="em" id="email"></span>
        <span class="worm-badge"><WormIcon size={16} /> <span id="bal">0</span> 마리</span>
      </div>
    </div>

    <!-- 크라미 꾸미기 -->
    <a class="btn btn--primary" href="/wardrobe/" style="margin-bottom:.6rem">크라미 꾸미기</a>
    <div class="me-actions">
      <a class="btn btn--line" href="/calendar/">출석 캘린더</a>
      <a class="btn btn--line" href="/saved/">내 스크랩</a>
    </div>

    <!-- 내 기록: 들은 시간 -->
    <div class="me-stat">
      <span class="me-stat__ic" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14v-2a8 8 0 0 1 16 0v2"/><rect x="3" y="13" width="4" height="7" rx="1.4"/><rect x="17" y="13" width="4" height="7" rx="1.4"/></svg>
      </span>
      <div class="me-stat__body">
        <span class="me-stat__label">지금까지 들은 시간</span>
        <b class="me-stat__val" id="listen-time">—</b>
      </div>
    </div>

    <!-- 업적 배지 -->
    <div class="me-badge-head">
      <h2>업적</h2>
      <span class="me-badge-count" id="badge-count"></span>
      <button class="badge-share" id="badge-share" type="button">자랑하기</button>
    </div>
    <div class="badge-grid" id="badge-grid"></div>
    <button class="badge-toggle" id="badge-toggle">모든 업적 보기</button>

    <!-- 내 서비스 -->
    <h2 style="margin:0 0 0.8rem; font-size:1.2rem">내 서비스</h2>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;margin-bottom:1.5rem;">
      <a href="/benefits/" style="display:flex;flex-direction:column;align-items:center;gap:.3rem;padding:.8rem .4rem;border:1px solid var(--line,#e7e7ef);border-radius:10px;text-decoration:none;color:var(--ink,#1b1b22);font-size:.8rem;font-weight:600;transition:border-color .12s;">
        <DuoIcon name="benefits" class="svc-ico" />내 혜택
      </a>
      <a href="/checkup/" style="display:flex;flex-direction:column;align-items:center;gap:.3rem;padding:.8rem .4rem;border:1px solid var(--line,#e7e7ef);border-radius:10px;text-decoration:none;color:var(--ink,#1b1b22);font-size:.8rem;font-weight:600;transition:border-color .12s;">
        <DuoIcon name="checkup" class="svc-ico" />재무 체크업
      </a>
      <a href="/policy-calendar/" style="display:flex;flex-direction:column;align-items:center;gap:.3rem;padding:.8rem .4rem;border:1px solid var(--line,#e7e7ef);border-radius:10px;text-decoration:none;color:var(--ink,#1b1b22);font-size:.8rem;font-weight:600;transition:border-color .12s;">
        <DuoIcon name="calendar" class="svc-ico" />정책 캘린더
      </a>
    </div>

    <!-- 밀웜 모으기 -->
    <h2 style="margin:0 0 0.8rem; font-size:1.2rem">밀웜 모으기</h2>
    <div class="panel" id="earn-list">
      <div class="skel skel-row"></div><div class="skel skel-row"></div>
      <div class="skel skel-row"></div><div class="skel skel-row"></div>
      <div class="skel skel-row"></div>
    </div>

    <!-- 친구 초대 -->
    <div class="invite" style="margin-top:2rem">
      <h3>친구 초대하고 밀웜 받기</h3>
      <p class="app__sub" style="margin:0">초대 링크로 친구가 가입하면 <b>둘 다 +20밀웜</b></p>
      <div class="invite__row">
        <div class="invite__code" id="invite-link">…</div>
        <button class="btn btn--primary invite__copy" id="invite-copy" style="width:auto;padding-inline:1.2rem">복사</button>
      </div>
    </div>

    <!-- 로그아웃 (맨 아래) -->
    <button class="btn btn--line me-logout-btn" id="logout">로그아웃</button>
  </div>
  <div class="toast" id="toast"></div>

  <!-- 리워드 광고 자리표시자 (AdMob 연동 전 임시) -->
  <div class="admodal" id="admodal" hidden>
    <div class="admodal__panel">
      <div class="admodal__media" id="ad-media"></div>
      <div class="admodal__bar">
        <span id="ad-count" class="app__sub" style="margin:0"></span>
        <button class="btn btn--primary" id="ad-claim" disabled style="width:auto;padding-inline:1.4rem">보상 받기</button>
      </div>
    </div>
  </div>

  <!-- 새 업적 해금 모달(확 보이는 알림) -->
  <div class="badge-modal" id="badge-modal" hidden>
    <div class="badge-modal__panel">
      <span class="badge-modal__eyebrow">NEW · 업적 달성</span>
      <div class="badge-modal__medals" id="badge-modal-medals"></div>
      <p class="badge-modal__names" id="badge-modal-names"></p>
      <div class="badge-modal__actions">
        <button class="btn btn--line" id="badge-modal-share" type="button">자랑하기</button>
        <button class="btn btn--primary" id="badge-modal-ok" type="button">좋아요!</button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { getUser, getProfile, wormBalance, earnWorms, earnCountsToday, stamps, signOut, wardrobeData, updateNickname, claimReferral, claimStreakMilestone, checkBadges, type EarnAction, type WardrobeSlot } from '../lib/api';

  const $ = (id: string) => document.getElementById(id)!;
  const toast = (m: string) => { const t = $('toast'); t.textContent = m; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 2200); };
  const wormSvg = () => '<svg width="15" height="15" viewBox="0 0 24 24"><circle cx="5" cy="16.5" r="3.6" fill="var(--accent)" opacity=".92"/><circle cx="9" cy="14.5" r="4" fill="var(--accent)"/><circle cx="13" cy="12" r="4.1" fill="var(--accent)"/><circle cx="16.6" cy="9.6" r="3.7" fill="var(--accent)"/><circle cx="19.5" cy="7.6" r="3.1" fill="var(--accent)"/><circle cx="20.6" cy="6.7" r=".85" fill="#1a1a1a"/></svg>';
  // 들은 시간 — 시·분·초(초 단위 정밀 집계 반영)
  function fmtHMS(sec: number): string {
    sec = Math.max(0, Math.floor(sec));
    const h = Math.floor(sec / 3600), m = Math.floor((sec % 3600) / 60), s = sec % 60;
    const p: string[] = [];
    if (h) p.push(h + '시간');
    if (h || m) p.push(m + '분');
    p.push(s + '초');
    return p.join(' ');
  }

  // ── 업적 배지(메달리온) ──
  type Rank = 'bronze' | 'silver' | 'gold' | 'platinum' | 'diamond';
  type Badge = { id: string; cat: 'listen' | 'streak' | 'reads' | 'worms'; label: string; sub: string; rank: Rank };
  const BADGES: Badge[] = [
    { id: 'listen_5m', cat: 'listen', label: '첫 청취', sub: '5분', rank: 'bronze' },
    { id: 'listen_15m', cat: 'listen', label: '귀동냥', sub: '15분', rank: 'bronze' },
    { id: 'listen_30m', cat: 'listen', label: '워밍업', sub: '30분', rank: 'bronze' },
    { id: 'listen_1h', cat: 'listen', label: '애청자', sub: '1시간', rank: 'silver' },
    { id: 'listen_5h', cat: 'listen', label: '단골 청취', sub: '5시간', rank: 'silver' },
    { id: 'listen_20h', cat: 'listen', label: '귀가 즐거워', sub: '20시간', rank: 'gold' },
    { id: 'listen_100h', cat: 'listen', label: '청취 마스터', sub: '100시간', rank: 'gold' },
    { id: 'listen_300h', cat: 'listen', label: '청취 레전드', sub: '300시간', rank: 'platinum' },
    { id: 'listen_1000h', cat: 'listen', label: '천 시간의 귀', sub: '1000시간', rank: 'diamond' },
    { id: 'streak_1', cat: 'streak', label: '첫 출석', sub: '1일', rank: 'bronze' },
    { id: 'streak_3', cat: 'streak', label: '삼일째', sub: '3일', rank: 'bronze' },
    { id: 'streak_7', cat: 'streak', label: '일주일 개근', sub: '7일', rank: 'bronze' },
    { id: 'streak_14', cat: 'streak', label: '이주일 개근', sub: '14일', rank: 'silver' },
    { id: 'streak_30', cat: 'streak', label: '한 달 개근', sub: '30일', rank: 'silver' },
    { id: 'streak_60', cat: 'streak', label: '두 달 개근', sub: '60일', rank: 'gold' },
    { id: 'streak_100', cat: 'streak', label: '백일의 약속', sub: '100일', rank: 'gold' },
    { id: 'streak_200', cat: 'streak', label: '이백일 개근', sub: '200일', rank: 'platinum' },
    { id: 'streak_365', cat: 'streak', label: '일 년 개근', sub: '365일', rank: 'diamond' },
    { id: 'read_1', cat: 'reads', label: '첫 글', sub: '1편', rank: 'bronze' },
    { id: 'read_3', cat: 'reads', label: '세 편 완독', sub: '3편', rank: 'bronze' },
    { id: 'read_10', cat: 'reads', label: '독서가', sub: '10편', rank: 'bronze' },
    { id: 'read_30', cat: 'reads', label: '탐독가', sub: '30편', rank: 'silver' },
    { id: 'read_50', cat: 'reads', label: '수집가', sub: '50편', rank: 'silver' },
    { id: 'read_100', cat: 'reads', label: '백 편 완독', sub: '100편', rank: 'gold' },
    { id: 'read_200', cat: 'reads', label: '정보 마스터', sub: '200편', rank: 'gold' },
    { id: 'read_500', cat: 'reads', label: '지식 사냥꾼', sub: '500편', rank: 'platinum' },
    { id: 'read_1000', cat: 'reads', label: '천 편의 독서', sub: '1000편', rank: 'diamond' },
    { id: 'worm_10', cat: 'worms', label: '밀웜 줍기', sub: '10마리', rank: 'bronze' },
    { id: 'worm_50', cat: 'worms', label: '밀웜 모으기', sub: '50마리', rank: 'bronze' },
    { id: 'worm_100', cat: 'worms', label: '밀웜 한 줌', sub: '100마리', rank: 'silver' },
    { id: 'worm_300', cat: 'worms', label: '밀웜 창고', sub: '300마리', rank: 'silver' },
    { id: 'worm_1000', cat: 'worms', label: '밀웜 부자', sub: '1000마리', rank: 'gold' },
    { id: 'worm_3000', cat: 'worms', label: '밀웜 재벌', sub: '3000마리', rank: 'platinum' },
    { id: 'worm_10000', cat: 'worms', label: '밀웜 큰손', sub: '10000마리', rank: 'diamond' },
  ];
  const CAT: Record<string, { bg: string; g: string; emoji: string; accent: string; name: string }> = {
    listen: { bg: 'linear-gradient(145deg,#26b9b6,#0e8a88)', g: 'head', emoji: '🎧', accent: '#13a3a0', name: '청취' },
    streak: { bg: 'linear-gradient(145deg,#ff8f43,#f1640f)', g: 'flame', emoji: '🔥', accent: '#f1640f', name: '출석' },
    reads: { bg: 'linear-gradient(145deg,#41c771,#16a34a)', g: 'book', emoji: '📖', accent: '#1aa34a', name: '독서' },
    worms: { bg: 'linear-gradient(145deg,#ffc54d,#f59e0b)', g: 'star', emoji: '⭐', accent: '#f59e0b', name: '밀웜' },
  };
  const RANK_KO: Record<Rank, string> = { bronze: '브론즈', silver: '실버', gold: '골드', platinum: '플래티넘', diamond: '다이아' };
  const GLYPH: Record<string, string> = {
    head: '<path d="M4 13v-1a8 8 0 0 1 16 0v1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><rect x="3" y="12.5" width="4.4" height="7.5" rx="2" fill="currentColor"/><rect x="16.6" y="12.5" width="4.4" height="7.5" rx="2" fill="currentColor"/>',
    flame: '<path d="M12 2c2.2 3.6 5.4 5 5.4 9.1A5.4 5.4 0 0 1 6.6 11C6.6 8.6 8 7.2 9 5.5c.5 1.3 1.5 1.9 2.3 1.2C12.1 6 12 4 12 2z" fill="currentColor"/>',
    book: '<path d="M12 6.4C9.8 5.1 6.8 4.8 4 5.3v12.3c2.8-.5 5.8-.2 8 1.1 2.2-1.3 5.2-1.6 8-1.1V5.3c-2.8-.5-5.8-.2-8 1.1z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M12 6.4V18.8" fill="none" stroke="currentColor" stroke-width="1.7"/>',
    star: '<path d="M12 2.6l2.7 5.5 6 .9-4.4 4.2 1 6-5.3-2.8-5.3 2.8 1-6L3.3 9l6-.9z" fill="currentColor"/>',
  };
  const CAT_ORDER = ['listen', 'streak', 'reads', 'worms'] as const;
  let badgeEarned = new Set<string>();
  let badgeFresh = new Set<string>();
  let badgeShowAll = false;
  function badgeCard(b: Badge): string {
    const c = CAT[b.cat]; const on = badgeEarned.has(b.id);
    return `<div class="badge ${on ? '' : 'is-locked'} ${badgeFresh.has(b.id) ? 'is-new' : ''}" data-rank="${b.rank}">
      <div class="badge__medal" style="--bg:${c.bg}"><svg viewBox="0 0 24 24" aria-hidden="true">${GLYPH[c.g]}</svg></div>
      <span class="badge__label">${b.label}</span><span class="badge__sub">${b.sub}</span>
      <span class="badge__rank">${RANK_KO[b.rank]}</span>
    </div>`;
  }
  function renderBadges(earned?: Set<string>, fresh?: Set<string>) {
    if (earned) badgeEarned = earned;
    if (fresh) badgeFresh = fresh;
    const grid = $('badge-grid'); if (!grid) return;
    // 기본: 카테고리별 '대표' 1개(획득한 것 중 최고 단계, 없으면 다음 목표=최저 잠금). 전체보기: 모든 단계
    const list = badgeShowAll
      ? BADGES
      : CAT_ORDER.map((cat) => {
          const tiers = BADGES.filter((b) => b.cat === cat); // 오름차순
          const got = tiers.filter((b) => badgeEarned.has(b.id));
          return got.length ? got[got.length - 1] : tiers[0];
        });
    grid.innerHTML = list.map(badgeCard).join('');
    const cnt = $('badge-count'); if (cnt) cnt.textContent = `${badgeEarned.size} / ${BADGES.length}`;
  }
  const badgeToggle = document.getElementById('badge-toggle');
  badgeToggle?.addEventListener('click', () => {
    badgeShowAll = !badgeShowAll;
    badgeToggle.textContent = badgeShowAll ? '접기' : '모든 업적 보기';
    renderBadges();
  });
  let lastUnlocked: Badge[] = [];
  function showBadgeUnlock(ids: string[]) {
    const byId = new Map(BADGES.map((b) => [b.id, b]));
    const items = ids.map((id) => byId.get(id)).filter(Boolean) as Badge[];
    if (!items.length) return;
    lastUnlocked = items;
    $('badge-modal-medals').innerHTML = items.map((b) => {
      const c = CAT[b.cat];
      return `<div class="badge-modal__medal" data-rank="${b.rank}" style="--bg:${c.bg}"><svg viewBox="0 0 24 24" aria-hidden="true">${GLYPH[c.g]}</svg></div>`;
    }).join('');
    $('badge-modal-names').textContent = items.map((b) => `${b.label} · ${RANK_KO[b.rank]}`).join(' · ');
    $('badge-modal').hidden = false;
  }
  const closeBadgeModal = () => { $('badge-modal').hidden = true; };
  $('badge-modal-ok')?.addEventListener('click', closeBadgeModal);
  $('badge-modal')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeBadgeModal(); });

  // ── 업적 자랑하기(소셜 공유) — 캔버스 카드 이미지 + Web Share(카톡·인스타 등 공유시트), 미지원 시 클립보드 ──
  async function makeShareCard(o: { emoji: string; title: string; sub: string; accent: string }): Promise<Blob | null> {
    const W = 1080, H = 1080, cv = document.createElement('canvas'); cv.width = W; cv.height = H;
    const x = cv.getContext('2d'); if (!x) return null;
    const bg = x.createLinearGradient(0, 0, W, H); bg.addColorStop(0, '#1c1633'); bg.addColorStop(1, '#0e0b1c');
    x.fillStyle = bg; x.fillRect(0, 0, W, H);
    x.save(); const rg = x.createRadialGradient(W / 2, 430, 30, W / 2, 430, 380);
    rg.addColorStop(0, o.accent); rg.addColorStop(1, 'rgba(0,0,0,0)'); x.globalAlpha = .45; x.fillStyle = rg;
    x.beginPath(); x.arc(W / 2, 430, 380, 0, Math.PI * 2); x.fill(); x.restore();
    x.beginPath(); x.arc(W / 2, 430, 175, 0, Math.PI * 2); x.fillStyle = o.accent; x.fill();
    x.lineWidth = 8; x.strokeStyle = 'rgba(255,255,255,.85)'; x.stroke();
    x.textAlign = 'center'; x.textBaseline = 'middle';
    x.font = '170px serif'; x.fillText(o.emoji, W / 2, 442);
    x.fillStyle = '#fff'; x.font = 'bold 88px sans-serif'; x.fillText(o.title, W / 2, 716);
    x.fillStyle = 'rgba(255,255,255,.72)'; x.font = '46px sans-serif'; x.fillText(o.sub, W / 2, 804);
    x.fillStyle = o.accent; x.font = 'bold 42px sans-serif'; x.fillText('크라마에서 달성 · crama.app', W / 2, 968);
    return await new Promise((res) => cv.toBlob((b) => res(b), 'image/png'));
  }
  async function shareAchievement(o: { emoji: string; title: string; sub: string; accent: string; text: string }) {
    try {
      const blob = await makeShareCard(o);
      const file = blob ? new File([blob], 'crama-badge.png', { type: 'image/png' }) : null;
      const nav = navigator as any;
      if (file && nav.canShare && nav.canShare({ files: [file] })) { await nav.share({ files: [file], title: '크라마 업적', text: o.text }); return; }
      if (nav.share) { await nav.share({ title: '크라마 업적', text: o.text, url: 'https://crama.app' }); return; }
      await navigator.clipboard.writeText(o.text + ' https://crama.app'); toast('자랑 문구를 복사했어요!');
    } catch (e) { /* 사용자 취소 등 */ }
  }
  function shareBadge(b: Badge) {
    const c = CAT[b.cat];
    shareAchievement({ emoji: c.emoji, title: b.label, sub: `${c.name} · ${b.sub} · ${RANK_KO[b.rank]}`, accent: c.accent, text: `크라마에서 '${b.label}' 업적을 달성했어요! ${c.emoji} 나도 도전 →` });
  }
  document.getElementById('badge-modal-share')?.addEventListener('click', () => { if (lastUnlocked[0]) shareBadge(lastUnlocked[0]); });
  document.getElementById('badge-share')?.addEventListener('click', () => {
    const ord: Rank[] = ['bronze', 'silver', 'gold', 'platinum', 'diamond'];
    const got = BADGES.filter((b) => badgeEarned.has(b.id)).sort((a, b) => ord.indexOf(a.rank) - ord.indexOf(b.rank));
    const top = got[got.length - 1];
    if (!top) { toast('업적을 하나 달성하면 자랑할 수 있어요!'); return; }
    shareBadge(top);
  });

  // ── 캐릭터 장착 미리보기 ──
  const IMG = (id: string) => `/img/wardrobe/${id}.webp`;
  function bgImg(id: string, css: string) { const i = document.createElement('img'); i.className = 'layer'; i.src = IMG(id); i.style.cssText = 'position:absolute;' + css; return i; }
  function partImg(id: string, cls: string) { const i = document.createElement('img'); i.className = 'layer ' + cls; i.src = IMG(id); return i; }
  async function renderMascot() {
    const w = await wardrobeData();
    const eq = w.equipped as Record<string, string>;
    const dress = $('dress');
    const char = dress.querySelector('.char') as HTMLElement;
    dress.querySelectorAll('.layer').forEach((n) => n.remove());
    char.querySelectorAll('.layer').forEach((n) => n.remove());
    dress.style.background = 'transparent';
    if (eq.wallpaper) dress.insertBefore(bgImg(eq.wallpaper, 'inset:0;width:100%;height:100%;object-fit:cover'), char);
    if (eq.floor) dress.insertBefore(bgImg(eq.floor, 'left:0;right:0;bottom:0;width:100%;height:22%;object-fit:cover'), char);
    const head = char.querySelector('.base-head');
    if (eq.outfit) char.insertBefore(partImg(eq.outfit, 'gear'), head);
    if (eq.scarf) char.insertBefore(partImg(eq.scarf, 'gear-scarf'), head);
    (['glasses', 'hat'] as WardrobeSlot[]).forEach((s) => { if (eq[s]) char.appendChild(partImg(eq[s], 'acc-' + s)); });
  }

  // ── 밀웜 적립 ──
  const ROWS: { action: EarnAction; label: string; sub: string; reward: number; tappable: boolean }[] = [
    { action: 'read', label: '글 완독하기', sub: '글을 끝까지 읽으면 자동', reward: 1, tappable: false },
    { action: 'audio', label: '오디오 브리핑 듣기', sub: '재생하면 자동', reward: 1, tappable: false },
    { action: 'attend', label: '출석 체크', sub: '매일 첫 방문', reward: 1, tappable: true },
    { action: 'quiz', label: '주간 퀴즈 풀기', sub: '이번 주 복습', reward: 3, tappable: true },
    { action: 'ad', label: '짧은 광고 보고 받기', sub: '하루 세 번', reward: 2, tappable: true },
  ];
  const MSG: Record<string, string> = { cap_reached: '오늘은 이미 다 받았어요!', not_authenticated: '로그인이 필요해요.', not_configured: '환경설정 후 사용할 수 있어요.' };
  const CAP: Record<EarnAction, number> = { read: 0, audio: 0, attend: 1, quiz: 1, ad: 3 };
  let counts: Record<string, number> = {};
  const checkSvg = () => '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.5 4.5L19 7"/></svg>';

  function renderEarn() {
    $('earn-list').innerHTML = ROWS.map((r) => {
      const used = counts[r.action] ?? 0;
      const cap = CAP[r.action];
      const done = cap > 0 && used >= cap;
      let right: string; let tappable = r.tappable;
      if (done) { right = `<span class="earn-done">${checkSvg()} 완료</span>`; tappable = false; }
      else if (r.action === 'ad') right = `<span class="worm-badge">${wormSvg()} ${r.reward}</span><span class="earn-remain" style="margin-left:.5rem">오늘 ${cap - used}번 남음</span>`;
      else right = `<span class="worm-badge">${wormSvg()} ${r.reward}</span>`;
      return `<div class="earn-row" ${tappable ? `data-tappable data-action="${r.action}"` : ''}>
        <div class="earn-row__t"><b>${r.label}</b><span>${r.sub}</span></div>
        <div style="display:flex;align-items:center;gap:.4rem">${right}${tappable ? '<span style="color:var(--muted)">›</span>' : ''}</div>
      </div>`;
    }).join('');
    $('earn-list').querySelectorAll('[data-tappable]').forEach((el) => el.addEventListener('click', () => {
      const action = (el as HTMLElement).dataset.action as EarnAction;
      if (action === 'ad') showAd(); else doEarn(action);
    }));
  }

  async function doEarn(action: EarnAction) {
    const res = await earnWorms(action);
    if (res.ok) { $('bal').textContent = String(res.balance); try { localStorage.setItem('crama:bal', String(res.balance)); } catch {} counts[action] = (counts[action] ?? 0) + 1; renderEarn(); toast('밀웜을 받았어요!'); }
    else toast(MSG[res.message] ?? res.message);
  }

  // ── 리워드 광고 (하우스 광고 3종 가중치 로테이션 + GA4 노출/클릭 성과 측정) ──
  // creative: 영상(mp4/webm)·gif·이미지 URL / link: 클릭 시 이동(새 탭) / weight: 노출 비중
  // 실제 광고주가 생기면 이 배열만 교체하면 됩니다(빈 배열이면 임시 박스).
  type Ad = { id: string; name: string; creative: string; link: string; weight: number };
  const ADS: Ad[] = [
    { id: 'membership', name: '멤버십',   creative: '/img/ads/ad-membership.svg', link: '/membership/', weight: 1 },
    { id: 'vote',       name: '빼꼼투표', creative: '/img/ads/ad-vote.svg',       link: '/vote/',       weight: 1 },
    { id: 'column',     name: '칼럼',     creative: '/img/ads/ad-column.svg',     link: '/column/',     weight: 1 },
  ];
  function pickAd(): Ad | null {
    const pool = ADS.filter((a) => a.creative);
    if (!pool.length) return null;
    const total = pool.reduce((s, a) => s + (a.weight || 1), 0);
    let r = Math.random() * total;
    for (const a of pool) { r -= (a.weight || 1); if (r <= 0) return a; }
    return pool[0];
  }
  function gaTrack(name: string, params: Record<string, any>) {
    try { (window as any).gtag?.('event', name, params); } catch (e) {}
  }
  function showAd() {
    const media = $('ad-media');
    const ad = pickAd();
    const creative = ad?.creative || '';
    const link = ad?.link || '';
    const isVid = /\.(mp4|webm|mov)(\?|$)/i.test(creative);
    const inner = creative
      ? (isVid ? `<video src="${creative}" autoplay muted playsinline loop></video>` : `<img src="${creative}" alt="${ad?.name || '광고'}">`)
      : `<span class="ad-ph">광고 영역 (URL 미설정)</span>`;
    media.innerHTML = (link && creative)
      ? `<a class="admodal__link" href="${link}" target="_blank" rel="noopener sponsored">${inner}</a>`
      : inner;
    if (ad) {
      gaTrack('ad_impression', { ad_id: ad.id, ad_name: ad.name, slot: 'reward' });
      const a = media.querySelector('a.admodal__link');
      if (a) a.addEventListener('click', () => gaTrack('ad_click', { ad_id: ad.id, ad_name: ad.name, slot: 'reward' }));
    }
    $('admodal').hidden = false;
    let n = 5;
    const claim = $('ad-claim') as HTMLButtonElement;
    claim.disabled = true;
    $('ad-count').textContent = `${n}초 후 보상 받기`;
    const t = setInterval(() => {
      n--;
      if (n <= 0) { clearInterval(t); $('ad-count').textContent = '시청 완료!'; claim.disabled = false; }
      else $('ad-count').textContent = `${n}초 후 보상 받기`;
    }, 1000);
    claim.onclick = async () => {
      if (claim.disabled) return;
      clearInterval(t);
      const v = media.querySelector('video'); if (v) (v as HTMLVideoElement).pause();
      $('admodal').hidden = true;
      await doEarn('ad');
    };
  }

  // ── 닉네임 변경 (인라인 편집, 이벤트 위임) ──
  let curNick = '회원';
  const showNick = () => { $('nick-row').innerHTML = `<b id="nick">${curNick}</b><button class="nick-edit" id="nick-edit">변경</button>`; };
  $('nick-row').addEventListener('click', async (e) => {
    const t = e.target as HTMLElement;
    if (t.id === 'nick-edit') {
      $('nick-row').innerHTML = `<input id="nick-input" class="nick-input" maxlength="20" value="${curNick.replace(/"/g, '&quot;')}"><button class="nick-edit" id="nick-save">저장</button><button class="nick-edit" id="nick-cancel" style="color:var(--muted)">취소</button>`;
      const inp = document.getElementById('nick-input') as HTMLInputElement;
      inp.focus(); inp.select();
      inp.addEventListener('keydown', (ev) => { if (ev.key === 'Enter') (document.getElementById('nick-save') as HTMLButtonElement).click(); });
    } else if (t.id === 'nick-save') {
      const inp = document.getElementById('nick-input') as HTMLInputElement;
      const res = await updateNickname(inp.value);
      if (res.error) { toast(res.error); return; }
      curNick = res.nickname!; showNick(); toast('닉네임을 변경했어요');
    } else if (t.id === 'nick-cancel') {
      showNick();
    }
  });
  $('logout').onclick = async () => { await signOut(); location.replace('/login/'); };

  (async () => {
    // 캐시값 즉시 표시(0 점프 방지) — fetch 후 갱신
    try { const cb = localStorage.getItem('crama:bal'); if (cb) $('bal').textContent = cb; const cs = localStorage.getItem('crama:streak'); if (cs) $('streak').textContent = cs; } catch {}
    const user = await getUser();
    if (!user) { location.replace('/login/'); return; }
    const app = document.getElementById('me-app');
    if (app) app.style.opacity = '1';
    await earnWorms('attend'); // 출석(서버 1일 1회 캡)

    // 보상 청구: 친구 초대(대기 코드) + 연속출석 마일스톤
    const ref = localStorage.getItem('crama:ref');
    if (ref) { const r = await claimReferral(ref); localStorage.removeItem('crama:ref'); if (r.ok) toast('초대 보상 +20밀웜!'); }
    const ms = await claimStreakMilestone();
    if (ms.bonus > 0) toast(`${ms.reached}일 연속 달성! +${ms.bonus}밀웜`);

    counts = await earnCountsToday();
    renderEarn();
    const [profile, bal, s] = await Promise.all([getProfile(), wormBalance(), stamps()]);
    curNick = (profile as any)?.nickname || user.email?.split('@')[0] || '회원';
    $('nick').textContent = curNick;
    $('email').textContent = user.email ?? '';
    $('bal').textContent = String(bal);
    $('streak').textContent = String(s.streak);
    const ls = Number((profile as any)?.listen_seconds || 0);
    $('listen-time').textContent = fmtHMS(ls);
    try { localStorage.setItem('crama:bal', String(bal)); localStorage.setItem('crama:streak', String(s.streak)); } catch {}

    // 업적 배지 — 현재 지표로 해금 판정 + 그리드 렌더(새로 따면 토스트)
    try {
      const rows = await checkBadges();
      const freshIds = rows.filter((r) => r.is_new).map((r) => r.badge_id);
      renderBadges(new Set(rows.map((r) => r.badge_id)), new Set(freshIds));
      if (freshIds.length) showBadgeUnlock(freshIds);
    } catch (e) {}

    // 친구 초대 링크
    const code = (profile as any)?.referral_code;
    if (code) {
      const link = `${location.origin}/?ref=${code}`;
      $('invite-link').textContent = link;
      $('invite-copy').onclick = async () => { try { await navigator.clipboard.writeText(link); toast('초대 링크 복사됨'); } catch { } };
    }
    await renderMascot();
  })();
</script>
