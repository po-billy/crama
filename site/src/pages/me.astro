  @keyframes mpUp { from { transform: translateY(28px); opacity: 0.5; } to { transform: translateY(0); opacity: 1; } }
  .mp-bs__handle { display: block; flex: none; width: 44px; height: 4px; border-radius: 999px; background: var(--line); margin: 0.2rem auto 0.85rem; }
