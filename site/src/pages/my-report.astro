---
import BaseLayout from '../layouts/BaseLayout.astro';
import { computeSalary, salaryAmounts } from '../lib/salary';
import { G_ICONS } from '../lib/game-icons';

// 연봉→[월실수령, 월공제(보험), 월세금] 슬림 테이블(빌드타임) — 클라이언트에서 최근접 보간
const SALARY_TABLE = salaryAmounts().map((man) => {
  const s = computeSalary(man * 10_000);
  return [man, s.monthlyNet, s.np + s.hi + s.ltc + s.ei, s.incomeTax + s.localTax];
});
const MEDIAN = [2564238, 4199292, 5359036, 6494738, 7556719, 8555952]; // 2026 기준 중위소득(월, 원)
// 근로소득 상위% 앵커(국세청 2023 귀속) — 클라이언트 로그 보간용
const RANK_ANCHORS = [[113769, 0.1], [21673, 1], [10057, 10], [7624, 20], [5482, 36], [4272, 50], [2642, 80], [2119, 90], [1200, 97]];
---
<BaseLayout
  title="내 돈 리포트 — 올해 나의 숫자 한 장 요약"
  description="내 정보(연봉·가구·차·집)로 올해의 실수령액, 세금+사회보험 총액, 중위소득 위치, 놓치고 있을 혜택까지 한 장에. 등록 30초, 리포트는 평생 자동 갱신."
>
  <div class="mr wrap">
    <header class="page-hero">
      <span class="eyebrow">My Money Report</span>
      <h1>내 돈 리포트 <span class="mr-y">2026</span></h1>
      <p>흩어진 계산기 대신, <b>올해 나의 숫자를 한 장으로.</b> 내 정보를 채울수록 정확해져요.</p>
    </header>

    <!-- 빈 상태(프로필 없음) -->
    <div class="mr-empty" id="mr-empty" hidden>
      <span class="mr-empty__emoji" set:html={G_ICONS.chartUp.replace('width="18" height="18"', 'width="40" height="40"')} />
      <b>30초만 등록하면 리포트가 완성돼요</b>
      <p>연봉 하나만 넣어도 실수령액과 세금이 나오고, 가구·차·집을 더하면 리포트가 점점 완전해집니다.</p>
      <a class="mr-empty__cta" href="/me/">내 정보 등록하러 가기 →</a>
    </div>

    <div id="mr-body" hidden>
      <!-- ① 올해 나의 숫자(카운트업) -->
      <div class="mr-hero" id="mr-hero">
        <div class="mr-hero__item" id="mr-h-net" hidden><span>월 실수령액</span><b data-role="num">0</b><em>원</em></div>
        <div class="mr-hero__item is-main" id="mr-h-tax" hidden><span>올해 세금+사회보험</span><b data-role="num">0</b><em>원</em></div>
        <div class="mr-hero__item" id="mr-h-med" hidden><span>내 가구 소득 위치</span><b data-role="num">0</b><em>% <i id="mr-med-note"></i></em></div>
      </div>

      <!-- ② 어디로 나가나 — 스택 바 -->
      <section class="mr-sec" id="mr-break" hidden>
        <h2>내 돈, 어디로 나가나</h2>
        <div class="mr-bar" id="mr-bar"></div>
        <ul class="mr-legend" id="mr-legend"></ul>
        <p class="mr-fun" id="mr-fun"></p>
      </section>

      <!-- ③ 놓치고 있을 혜택 -->
      <section class="mr-sec" id="mr-benefit" hidden>
        <h2>놓치고 있을지 모르는 것</h2>
        <a class="mr-benefit" href="/benefits/">
          <b id="mr-benefit-n">-</b>
          <span id="mr-benefit-sub">내 조건으로 열려 있는 정책·복지</span>
          <em>정밀 매칭 →</em>
        </a>
      </section>

      <!-- ④ 더 채우면 정확해져요 -->
      <section class="mr-sec" id="mr-missing" hidden>
        <h2>더 채우면 리포트가 완전해져요</h2>
        <div class="mr-missing" id="mr-missing-list"></div>
      </section>

      <!-- ④.5 AI 정밀 진단 크로스 -->
      <a class="mr-ai" href="/ai-report/">
        <span class="mr-ai__ic" set:html={G_ICONS.sparkle.replace('width="18" height="18"', 'width="26" height="26"')} />
        <span class="mr-ai__t"><b>AI 정밀 재무 진단</b><span>이 숫자들이 무슨 의미인지 — 등급·리스크·이번 주 할 일로 해석해드려요</span></span>
        <em>진단 받기 →</em>
      </a>

      <!-- ⑤ 공유 -->
      <div class="mr-share">
        <button type="button" id="mr-share-btn">리포트 카드 저장·공유</button>
        <span>연봉 숫자는 카드에서 가릴 수 있어요</span>
        <label class="mr-share__opt"><input type="checkbox" id="mr-share-hide" checked /> 실수령액 숨기기</label>
      </div>
    </div>

    <p class="mr-note">※ 간이 추정입니다(1인 공제·비과세 없음 가정, 세부담 상한 등 미반영). 값은 이 기기에서 계산되며 서버로 전송되지 않아요. 각 상세는 <a href="/salary/">실수령액</a>·<a href="/property-tax/">재산세</a>·<a href="/car-tax/">자동차세</a>·<a href="/median-income/">중위소득</a>에서 확인하세요.</p>
  </div>

  <script is:inline define:vars={{ SALARY_TABLE, MEDIAN, RANK_ANCHORS, GI: G_ICONS }}>
    (() => {
      const $ = (id) => document.getElementById(id);
      const fmt = (n) => Math.round(n).toLocaleString('ko-KR');
      const gi = (name, size) => (GI[name] || '').replace('width="18" height="18"', 'width="' + size + '" height="' + size + '"');
      // CramaProfile(BaseLayout)이 서버 프로필을 캐시로 내려줄 때까지 잠깐 대기 후 부팅 —
      // 첫 방문·타 기기에서 "프로필이 안 채워짐" 레이스 해결. 동기화가 늦게 오면 빈 화면에서 자동 재부팅.
      let booted = false;
      function boot() {
      if (booted === true) return; booted = true;
      let P = {};
      try { P = (window.CramaProfile ? window.CramaProfile.get() : JSON.parse(localStorage.getItem('crama:profile') || '{}')) || {}; } catch (e) {}
      const has = { salary: !!P.salary, hh: !!(P.household && (P.hhIncome || P.salary)), car: !!(P.car && (P.car.ev || (P.car.cc && P.car.year))), home: !!(P.home && P.home.price), basic: !!(P.age && P.region) };

      if (!has.salary && !has.hh && !has.car && !has.home) { booted = 'empty'; $('mr-empty').hidden = false; return; }
      $('mr-empty').hidden = true;
      $('mr-body').hidden = false;

      // ── 계산 ──
      function salaryRow(man) {
        let best = SALARY_TABLE[0];
        for (const r of SALARY_TABLE) if (Math.abs(r[0] - man) < Math.abs(best[0] - man)) best = r;
        return best; // [man, 월실수령, 월보험, 월세금]
      }
      let net = 0, insY = 0, taxY = 0;
      if (has.salary) {
        const r = salaryRow(P.salary);
        net = r[1]; insY = r[2] * 12; taxY = r[3] * 12;
      }
      let carTax = 0;
      if (has.car) {
        if (P.car.ev) carTax = 130000;
        else {
          const unit = P.car.cc <= 1000 ? 80 : P.car.cc <= 1600 ? 140 : 200;
          const age = 2026 - P.car.year + 1;
          const cut = Math.min(Math.max(age - 2, 0) * 5, 50) / 100;
          carTax = Math.floor((P.car.cc * unit * (1 - cut) * 1.3) / 10) * 10;
        }
      }
      let homeTax = 0;
      if (has.home) {
        const hp = P.home.price * 10000, one = P.home.oneHome !== false;
        const ratio = one ? (hp <= 3e8 ? 0.43 : hp <= 6e8 ? 0.44 : 0.45) : 0.6;
        const base = hp * ratio, sp = one && hp <= 9e8;
        let t;
        if (sp) t = base <= 6e7 ? base * 0.0005 : base <= 1.5e8 ? 30000 + (base - 6e7) * 0.001 : base <= 3e8 ? 120000 + (base - 1.5e8) * 0.002 : 420000 + (base - 3e8) * 0.0035;
        else t = base <= 6e7 ? base * 0.001 : base <= 1.5e8 ? 60000 + (base - 6e7) * 0.0015 : base <= 3e8 ? 195000 + (base - 1.5e8) * 0.0025 : 570000 + (base - 3e8) * 0.004;
        t = Math.floor(t / 10) * 10;
        homeTax = t + Math.floor((base * 0.0014) / 10) * 10 + Math.floor((t * 0.2) / 10) * 10;
      }
      let medPct = 0;
      if (has.hh) {
        const inc = (P.hhIncome || Math.round(P.salary / 12)) * 10000;
        medPct = Math.round((inc / MEDIAN[Math.min(P.household, 6) - 1]) * 100);
      }
      const totalOut = taxY + insY + carTax + homeTax;

      // ── ① 히어로 카운트업 ──
      function countUp(el, to, suffixPct) {
        const b = el.querySelector('[data-role=num]');
        const dur = 900, t0 = performance.now();
        const step = (t) => {
          const p = Math.min(1, (t - t0) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          b.textContent = fmt(to * eased);
          if (p < 1) requestAnimationFrame(step);
        };
        el.hidden = false;
        requestAnimationFrame(step);
      }
      if (has.salary) countUp($('mr-h-net'), net);
      if (totalOut > 0) countUp($('mr-h-tax'), totalOut);
      if (has.hh) {
        countUp($('mr-h-med'), medPct);
        $('mr-med-note').textContent = medPct <= 100 ? '(중위소득 이하 — 혜택 구간!)' : '(중위소득 위)';
      }

      // ── ② 스택 바 + 치킨 환산 ──
      if (totalOut > 0) {
        $('mr-break').hidden = false;
        const parts = [
          ['소득세', taxY, '#fb7185'],
          ['4대보험', insY, '#f59e0b'],
          ['재산세', homeTax, '#8b7bff'],
          ['자동차세', carTax, '#38bdf8'],
        ].filter((p) => p[1] > 0);
        const bar = $('mr-bar'), leg = $('mr-legend');
        for (const [label, v, color] of parts) {
          const i = document.createElement('i');
          i.style.background = color;
          i.style.width = (v / totalOut) * 100 + '%';
          bar.appendChild(i);
          const li = document.createElement('li');
          li.innerHTML = '<i style="background:' + color + '"></i><span>' + label + '</span><b>' + fmt(v) + '원</b>';
          leg.appendChild(li);
        }
        const daily = totalOut / 365;
        let funHtml = '하루 <b>' + fmt(daily) + '원</b>씩 나가는 셈 — 1년이면 치킨 ' + gi('drumstick', 14) + ' <b>' + fmt(totalOut / 20000) + '마리</b>, 아메리카노 ' + gi('coffee', 14) + ' <b>' + fmt(totalOut / 4500) + '잔</b>어치예요.';
        if (has.salary) {
          let pct = 99;
          const man = P.salary;
          if (man >= RANK_ANCHORS[0][0]) pct = 0.1;
          else if (man > RANK_ANCHORS[RANK_ANCHORS.length - 1][0]) {
            for (let i = 0; i < RANK_ANCHORS.length - 1; i++) {
              const [hm, hp] = RANK_ANCHORS[i], [lm, lp] = RANK_ANCHORS[i + 1];
              if (man <= hm && man >= lm) { const t = (Math.log(man) - Math.log(lm)) / (Math.log(hm) - Math.log(lm)); pct = Math.round((lp + (hp - lp) * t) * 10) / 10; break; }
            }
          }
          funHtml += '<br/>그리고 이 연봉은 근로소득자 <b>' + gi('trophy', 14) + ' 상위 ' + pct + '%</b> — 100명 중 앞에서 ' + Math.max(1, Math.round(pct)) + '번째예요.';
        }
        $('mr-fun').innerHTML = funHtml;
      }

      // ── ③ 놓친 혜택(청년+지역복지 슬림 매칭) ──
      if (has.basic) {
        Promise.all([
          fetch('/data/youth-slim.json').then((r) => r.json()).catch(() => ({ policies: [] })),
          fetch('/data/welfare-local-slim.json').then((r) => r.json()).catch(() => ({ services: [] })),
        ]).then(([y, w]) => {
          const youth = (y.policies || []).filter((p) => {
            const mn = parseInt(p.minAge, 10), mx = parseInt(p.maxAge, 10);
            if (!p.ageLimit || isNaN(mn) || isNaN(mx)) return true;
            return P.age >= mn && P.age <= mx;
          }).length;
          const local = (w.services || []).filter((s) => s.region === P.region).length;
          const total = (P.age <= 45 ? youth : 0) + local;
          if (!total) return;
          $('mr-benefit-n').textContent = fmt(total) + '건';
          $('mr-benefit-sub').textContent = (P.age <= 45 && youth ? '청년 정책 ' + youth + '건' : '') + (P.age <= 45 && youth && local ? ' + ' : '') + (local ? P.region.slice(0, 2) + ' 복지 ' + local + '건' : '') + ' — 지금 열려 있어요';
          $('mr-benefit').hidden = false;
        });
      }

      // ── ④ 미등록 넛지 ──
      const missing = [];
      if (!has.salary) missing.push([gi('coin', 14) + ' 연봉', '실수령액·소득세가 계산돼요']);
      if (!has.hh) missing.push([gi('users', 14) + ' 가구', '중위소득 위치 — 혜택 구간 판정']);
      if (!has.car) missing.push([gi('car', 14) + ' 차량', '자동차세가 리포트에 합산돼요']);
      if (!has.home) missing.push([gi('house', 14) + ' 집(공시가)', '재산세가 리포트에 합산돼요']);
      if (!has.basic) missing.push([gi('pin', 14) + ' 나이·지역', '놓친 혜택 개수가 나와요']);
      if (missing.length) {
        $('mr-missing').hidden = false;
        const host = $('mr-missing-list');
        for (const [t, d] of missing) {
          const a = document.createElement('a');
          a.href = '/me/';
          a.innerHTML = '<b>' + t + '</b><span>' + d + '</span><em>+ 추가</em>';
          host.appendChild(a);
        }
      }

      // ── ⑤ 공유 카드(1080×1350 캔버스) ──
      $('mr-share-btn').addEventListener('click', async () => {
        const hide = $('mr-share-hide').checked;
        const c = document.createElement('canvas');
        c.width = 1080; c.height = 1350;
        const x = c.getContext('2d');
        const g = x.createLinearGradient(0, 0, 0, 1350);
        g.addColorStop(0, '#5348cf'); g.addColorStop(1, '#2b2566');
        x.fillStyle = g; x.fillRect(0, 0, 1080, 1350);
        x.fillStyle = 'rgba(255,255,255,.85)';
        x.font = '700 44px Pretendard, sans-serif';
        x.fillText('나의 돈 리포트 · 2026', 80, 130);
        x.font = '800 92px Pretendard, sans-serif';
        x.fillStyle = '#fff';
        let yPos = 300;
        const row = (label, val) => {
          x.font = '600 40px Pretendard, sans-serif'; x.fillStyle = 'rgba(255,255,255,.7)';
          x.fillText(label, 80, yPos);
          x.font = '800 84px Pretendard, sans-serif'; x.fillStyle = '#fff';
          x.fillText(val, 80, yPos + 100);
          yPos += 230;
        };
        if (has.salary && !hide) row('월 실수령액', fmt(net) + '원');
        if (totalOut > 0) row('올해 세금+사회보험', fmt(totalOut) + '원');
        if (totalOut > 0) row('치킨으로 환산하면', fmt(totalOut / 20000) + '마리');
        if (has.hh) row('내 가구 소득 위치', '중위소득의 ' + medPct + '%');
        x.font = '600 40px Pretendard, sans-serif'; x.fillStyle = 'rgba(255,255,255,.75)';
        x.fillText('내 리포트 만들기 → crama.app/my-report', 80, 1270);
        try { if (window.gtag) window.gtag('event', 'report_share', { hide }); } catch (e) {}
        const blob = await new Promise((res) => c.toBlob(res, 'image/png'));
        const file = new File([blob], 'my-money-report.png', { type: 'image/png' });
        const isMobile = /Android|iPhone|iPad/i.test(navigator.userAgent);
        if (isMobile && navigator.canShare && navigator.canShare({ files: [file] })) {
          try { await navigator.share({ files: [file], title: '나의 돈 리포트' }); return; } catch (e) {}
        }
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'my-money-report.png';
        a.click();
      });
      }

      document.addEventListener('crama:profile-sync', () => {
        if (booted === 'empty') { booted = false; boot(); }
        else if (!booted) boot();
      });
      if (window.CramaProfile && window.CramaProfile.authed) setTimeout(boot, 800);
      else boot();
    })();
  </script>

  <style is:global>
    .mr { max-width: 42rem; }
    .mr-y { color: var(--accent); }
    .mr-empty { text-align: center; margin: 2rem 0; padding: 2.2rem 1.4rem; border: 1px dashed var(--accent); border-radius: 18px; background: var(--accent-soft); }
    .mr-empty[hidden] { display: none; }
    .mr-empty__emoji { display: flex; justify-content: center; color: var(--accent); margin-bottom: 0.5rem; }
    .mr-fun svg, .mr-missing b svg { vertical-align: -2px; color: var(--accent); }
    .mr-ai { display: flex; align-items: center; gap: 0.8rem; margin: 1.1rem 0; padding: 0.95rem 1.1rem; border: 1.5px solid var(--accent); border-radius: 14px; background: var(--accent-soft); text-decoration: none; color: var(--ink); }
    .mr-ai:hover { filter: brightness(1.02); }
    .mr-ai__ic { flex: none; color: var(--accent); display: grid; place-items: center; }
    .mr-ai__t { flex: 1; min-width: 0; }
    .mr-ai__t b { display: block; font-size: 0.94rem; }
    .mr-ai__t span { font-size: 0.78rem; color: var(--ink-soft); line-height: 1.45; }
    .mr-ai em { flex: none; font-style: normal; font-size: 0.8rem; font-weight: 800; color: var(--accent); }
    .mr-empty b { font-size: 1.05rem; }
    .mr-empty p { font-size: 0.88rem; color: var(--ink-soft); margin: 0.5rem auto 1rem; max-width: 26rem; line-height: 1.6; }
    .mr-empty__cta { display: inline-block; font-weight: 800; font-size: 0.95rem; color: #fff; background: var(--accent); border-radius: 999px; padding: 0.65rem 1.4rem; text-decoration: none; }
    #mr-body[hidden] { display: none; }
    .mr-hero { display: grid; grid-template-columns: 1fr 1.25fr 1fr; gap: 0.6rem; margin: 1.4rem 0; }
    @media (max-width: 560px) { .mr-hero { grid-template-columns: 1fr; } }
    .mr-hero__item { border: 1px solid var(--line); border-radius: 16px; padding: 1rem 1.1rem; background: var(--paper); display: flex; flex-direction: column; gap: 0.15rem; }
    .mr-hero__item[hidden] { display: none; }
    .mr-hero__item span { font-size: 0.76rem; color: var(--muted); font-weight: 600; }
    .mr-hero__item b { font-size: 1.5rem; font-weight: 800; font-variant-numeric: tabular-nums; line-height: 1.2; }
    .mr-hero__item em { font-style: normal; font-size: 0.78rem; color: var(--muted); }
    .mr-hero__item em i { font-style: normal; font-size: 0.7rem; }
    .mr-hero__item.is-main { background: var(--accent); border-color: var(--accent); color: #fff; }
    .mr-hero__item.is-main span, .mr-hero__item.is-main em { color: rgba(255, 255, 255, 0.85); }
    .mr-sec { margin: 1.8rem 0; }
    .mr-sec[hidden] { display: none; }
    .mr-sec h2 { font-size: 1.08rem; margin: 0 0 0.7rem; }
    .mr-bar { display: flex; height: 18px; border-radius: 999px; overflow: hidden; background: var(--paper-2); }
    .mr-bar i { display: block; height: 100%; }
    .mr-legend { list-style: none; margin: 0.7rem 0 0; padding: 0; display: grid; gap: 0.4rem; }
    .mr-legend li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.86rem; }
    .mr-legend i { width: 10px; height: 10px; border-radius: 3px; flex: none; }
    .mr-legend b { margin-left: auto; font-variant-numeric: tabular-nums; }
    .mr-fun { margin: 0.8rem 0 0; font-size: 0.9rem; color: var(--ink-soft); line-height: 1.6; padding: 0.75rem 0.95rem; border-radius: 12px; background: var(--paper-2); }
    .mr-fun b { color: var(--accent); }
