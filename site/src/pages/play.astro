---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqBox from '../components/FaqBox.astro';
import { gIcon, G_ICONS, Q_ICON_KEYS } from '../lib/game-icons';

const SU = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const AK = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
// 문항 카드는 라운드 데이터(questions jsonb) 기반 동적 렌더 — 매주 '이주의 종목'이 바뀐다
---
<BaseLayout
  title="오르까 내리까 — 주간 금융 예측 게임"
  image="/og-play.png"
  description="다음 주 금요일, 코스피·달러 환율·비트코인은 오를까 내릴까? 예측하고 맞히면 밀웜을 받는 크라마의 주간 예측 게임. 더블다운과 역배 보너스로 짜릿하게."
>
  <div class="pl wrap">
    <header class="page-hero">
      <span class="eyebrow">Weekly Prediction</span>
      <h1>오르까 내리까 <span class="pl-crystal" set:html={gIcon('crystal', 30)} /></h1>
      <p><b>다음 주 금요일</b>, 오를까 내릴까? 맞히면 밀웜 — 전부 맞히면 퍼펙트 보너스.</p>
    </header>

    <!-- 내 칭호(통산) -->
    <div class="pl-rank" id="pl-rank" hidden>
      <span class="pl-rank__badge" id="pl-rank-badge"></span>
      <div class="pl-rank__body">
        <b id="pl-rank-name">새싹 점쟁이</b>
        <span id="pl-rank-sub">통산 0문항 적중</span>
        <div class="pl-rank__bar"><i id="pl-rank-fill"></i></div>
      </div>
      <span class="pl-rank__next" id="pl-rank-next"></span>
    </div>

    <!-- 지난 라운드 결과 리빌 -->
    <section class="pl-reveal" id="pl-reveal" hidden>
      <h2>지난 라운드 결과 <span id="pl-reveal-round"></span></h2>
      <div class="pl-reveal__cards" id="pl-reveal-cards"></div>
      <div class="pl-reveal__total" id="pl-reveal-total" hidden>
        <span id="pl-reveal-msg"></span>
        <b id="pl-reveal-worms"></b>
      </div>
      <figure class="pl-reveal__ai" id="pl-reveal-ai" hidden>
        <img src="/img/generated/meerkat-head.webp" alt="크라미" width="34" height="34" loading="lazy" />
        <blockquote><b>크라미의 결산 한 마디</b><p id="pl-reveal-ai-text"></p></blockquote>
      </figure>
      <div class="pl-confetti" id="pl-confetti" aria-hidden="true">
        {Array.from({ length: 18 }).map((_, i) => <i style={`--i:${i}`}></i>)}
      </div>
    </section>

    <!-- 이번 라운드 -->
    <section class="pl-round">
      <div class="pl-round__head">
        <h2>이번 라운드 <span id="pl-round-id"></span></h2>
        <div class="pl-timer" id="pl-timer" hidden>
          <span>예측 마감까지</span>
          <b id="pl-timer-val">--:--:--</b>
        </div>
      </div>
      <p class="pl-round__desc" id="pl-round-desc">이번 주 금요일 15:30에 기준가가 정해지고, <b>다음 주 금요일 15:30</b> 가격으로 판정해요. 마감 전까지 얼마든지 마음을 바꿀 수 있어요.</p>

      <div class="pl-cards" id="pl-cards"></div>

      <button type="button" class="pl-submit" id="pl-submit" disabled>모두 골라주세요</button>
      <p class="pl-submitted" id="pl-submitted" hidden>제출 완료! <b id="pl-crowd"></b> 결과는 판정일에 이 페이지에서 짜릿하게 공개됩니다. 마감 전까지 수정 가능해요.</p>
      <button type="button" class="pl-share" id="pl-share" hidden>내 예측 자랑하기 — 친구는 반대에 걸까?</button>
    </section>

    <FaqBox items={[
      { q: '보상은 어떻게 계산되나요?', a: '문항당 적중 +3밀웜. 더블다운을 건 문항은 적중 시 +8(틀리면 그 문항 0). 전 문항 적중 시 퍼펙트 +6. 소수파(참여자 40% 미만이 고른 쪽)로 적중하면 역배 보너스 +3이 추가됩니다.' },
      { q: '이주의 종목은 뭔가요?', a: '고정 3문항(코스피·달러·비트코인) 외에 매주 바뀌는 스페셜 문항입니다. 삼성전자·엔비디아·테슬라·금값·이더리움 등이 로테이션으로 출제돼요. 특정 종목의 매수·매도 추천이 아닌 재미용 예측 게임입니다.' },
      { q: '판정 기준이 뭔가요?', a: '금요일 15:30에 기록한 기준가와 다음 주 금요일 15:30 가격(비트코인은 업비트, 코스피·환율은 종가 기준)을 비교합니다. 변동이 ±0.05% 미만이면 무승부로 전원 적중 처리하는 관대한 룰입니다.' },
      { q: '언제까지 예측할 수 있나요?', a: '매주 금요일 15:30에 마감됩니다. 마감 전까지는 몇 번이든 예측을 바꿀 수 있어요. 마감 후에는 기준가가 확정되고 다음 라운드가 열립니다.' },
      { q: '밀웜은 어디에 쓰나요?', a: '마이페이지의 크라미 옷장에서 마스코트 아이템을 살 수 있어요. 밀웜은 현금으로 바꿀 수 없는 재미용 포인트입니다.' },
    ]} />

    <div class="pl-cross">
      <a href="/ranking/"><Fragment set:html={gIcon('trophy', 14)} /> 예측 명중 랭킹</a>
      <a href="/gacha/"><Fragment set:html={gIcon('capsule', 14)} /> 딴 밀웜으로 뽑기</a>
      <a href="/briefing/">오늘의 시장 브리핑 →</a>
    </div>
  </div>

  <script is:inline define:vars={{ SU, AK, GI: G_ICONS, QK: Q_ICON_KEYS }}>
    (() => {
      const $ = (id) => document.getElementById(id);
      const fmt = (n) => Number(n).toLocaleString('ko-KR');
      const gi = (name, size) => (GI[name] || '').replace('width="18" height="18"', 'width="' + size + '" height="' + size + '"');
      const qIcon = (q, size) => (QK[q.key] ? gi(QK[q.key], size) : '<span style="font-size:' + size * 0.85 + 'px">' + (q.emoji || '❔') + '</span>');
      function tok() {
        try {
          for (let i = 0; i < localStorage.length; i++) {
            const k = localStorage.key(i);
            if (k && k.indexOf('sb-') === 0 && k.indexOf('-auth-token') !== -1) {
              const o = JSON.parse(localStorage.getItem(k));
              return (o && (o.access_token || (o.currentSession && o.currentSession.access_token))) || null;
            }
          }
        } catch (e) {}
        return null;
      }
      const T = tok();
      const H = (auth) => ({ 'Content-Type': 'application/json', apikey: AK, Authorization: 'Bearer ' + (auth && T ? T : AK) });
      const rest = (path, auth) => fetch(SU + '/rest/v1/' + path, { headers: H(auth) }).then((r) => (r.ok ? r.json() : null)).catch(() => null);
      const rpc = (fn, body, auth) => fetch(SU + '/rest/v1/rpc/' + fn, { method: 'POST', headers: H(auth), body: JSON.stringify(body || {}) }).then((r) => (r.ok ? r.json() : null)).catch(() => null);

      const state = { round: null, picks: {}, dd: null, submitted: false, qCount: 0 };
      const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

      // 문항 카드 빌더 — 라운드 questions 기반(⭐ 이주의 종목 포함)
      function buildRoundCards(questions) {
        const host = $('pl-cards');
        host.innerHTML = '';
        for (const q of questions) {
          const card = document.createElement('div');
          card.className = 'pl-card' + (q.special ? ' is-special' : '');
          card.dataset.key = q.key;
          card.innerHTML =
            (q.special ? '<span class="pl-special">' + gi('sparkle', 12) + ' 이주의 종목</span>' : '') +
            '<div class="pl-card__top"><span class="pl-card__emoji">' + qIcon(q, 26) + '</span>' +
            '<div class="pl-card__t"><b>' + esc(q.label) + '</b><span>' + esc(q.hint || '') + '</span></div>' +
            '<button type="button" class="pl-dd" data-role="dd" title="더블다운 — 맞히면 2.5배, 틀리면 0">' + gi('target', 13) + ' 더블</button></div>' +
            '<div class="pl-card__btns">' +
            '<button type="button" class="pl-btn pl-btn--up" data-dir="up"><i>▲</i> 오른다</button>' +
            '<button type="button" class="pl-btn pl-btn--down" data-dir="down"><i>▼</i> 내린다</button></div>' +
            '<div class="pl-dist" data-role="dist" hidden>' +
            '<div class="pl-dist__bar"><i class="is-up" data-role="up-bar"></i><i class="is-down" data-role="down-bar"></i></div>' +
            '<div class="pl-dist__nums"><span data-role="up-pct">-</span><span class="pl-dist__underdog" data-role="tag"></span><span data-role="down-pct">-</span></div></div>';
          card.querySelectorAll('.pl-btn').forEach((b) => b.addEventListener('click', () => {
            state.picks[q.key] = b.dataset.dir;
            b.classList.remove('is-pop'); void b.offsetWidth; b.classList.add('is-pop');
            paintPicks();
          }));
          card.querySelector('[data-role=dd]').addEventListener('click', () => {
            state.dd = state.dd === q.key ? null : q.key;
            paintPicks();
          });
          host.appendChild(card);
        }
      }
      function buildRevealCards(questions) {
        const host = $('pl-reveal-cards');
        host.innerHTML = '';
        for (const q of questions) {
          const card = document.createElement('div');
          card.className = 'pl-rcard';
          card.dataset.key = q.key;
          card.innerHTML =
            '<span class="pl-rcard__emoji">' + qIcon(q, 22) + '</span>' +
            '<b class="pl-rcard__label">' + esc(q.label) + (q.special ? ' ' + gi('sparkle', 12) : '') + '</b>' +
            '<span class="pl-rcard__change" data-role="change">…</span>' +
            '<span class="pl-rcard__mine" data-role="mine"></span>' +
            '<span class="pl-rcard__stamp" data-role="stamp" hidden></span>';
          host.appendChild(card);
        }
      }

      // ── 칭호 ──
      const RANKS = [
        { min: 0, name: '새싹 점쟁이', badge: 'sprout' },
        { min: 6, name: '동네 촉', badge: 'house' },
        { min: 15, name: '여의도 촉', badge: 'chartUp' },
        { min: 30, name: '골든 미어캣', badge: 'trophy' },
      ];
      async function loadRank() {
        if (!T) return;
        const rec = await rpc('my_prediction_record', {}, true);
        if (!rec || !rec.rounds) return;
        const hits = rec.hits || 0;
        let cur = RANKS[0], next = null;
        for (const r of RANKS) { if (hits >= r.min) cur = r; else { next = r; break; } }
        $('pl-rank-badge').innerHTML = gi(cur.badge, 26);
        $('pl-rank-name').textContent = cur.name;
        $('pl-rank-sub').textContent = '통산 ' + hits + '문항 적중 · ' + (rec.perfects || 0) + '번의 퍼펙트 · 밀웜 +' + fmt(rec.reward || 0);
        if (next) {
          const prev = cur.min;
          $('pl-rank-fill').style.width = Math.min(100, ((hits - prev) / (next.min - prev)) * 100) + '%';
          $('pl-rank-next').textContent = next.name + '까지 ' + (next.min - hits);
        } else {
          $('pl-rank-fill').style.width = '100%';
          $('pl-rank-next').textContent = '최고 칭호!';
        }
        $('pl-rank').hidden = false;
      }

      // ── 지난 라운드 리빌 ──
      async function loadReveal() {
        if (!T) return;
        const rounds = await rest('prediction_rounds?status=eq.settled&order=settles_at.desc&limit=1');
        const round = rounds && rounds[0];
        if (!round || !round.results) return;
        const mine = await rest('prediction_picks?round_id=eq.' + encodeURIComponent(round.id) + '&select=*', true);
        const my = mine && mine[0];
        if (!my || !my.score) return;
        $('pl-reveal-round').textContent = '#' + (round.id.split('-W')[1] || '') + '주차';
        buildRevealCards(round.questions || []);
        $('pl-reveal').hidden = false;
        const seenKey = 'crama:play-seen';
        const seen = localStorage.getItem(seenKey) === round.id;
        const cards = [...document.querySelectorAll('.pl-rcard')];
        const finish = () => {
          const s = my.score;
          const msgEl = $('pl-reveal-msg');
          msgEl.innerHTML = s.perfect ? gi('sparkle', 16) + ' 퍼펙트! 전 문항 적중' : s.hits.length ? s.hits.length + '문항 적중!' : '이번엔 빗나갔어요 — 다음 주에 설욕전';
          $('pl-reveal-worms').textContent = s.reward > 0 ? '+' + s.reward + ' 밀웜' : '';
          $('pl-reveal-total').hidden = false;
          if (round.commentary) { $('pl-reveal-ai-text').textContent = round.commentary; $('pl-reveal-ai').hidden = false; }
          if (s.reward > 0 && !seen) $('pl-confetti').classList.add('is-on');
          localStorage.setItem(seenKey, round.id);
        };
        cards.forEach((card, idx) => {
          const key = card.dataset.key;
          const res = round.results[key];
          const myDir = my.picks[key];
          const hit = res.dir === 'push' || res.dir === myDir;
          const fill = () => {
            const ch = card.querySelector('[data-role=change]');
            ch.textContent = (res.changePct > 0 ? '+' : '') + res.changePct + '%';
            ch.classList.add(res.changePct > 0 ? 'is-up' : res.changePct < 0 ? 'is-down' : 'is-flat');
            card.querySelector('[data-role=mine]').innerHTML = '내 예측: ' + (myDir === 'up' ? '▲ 오른다' : '▼ 내린다') + (my.score.double === key ? ' ' + gi('target', 11) : '');
            const st = card.querySelector('[data-role=stamp]');
            st.textContent = hit ? '적중!' : '빗나감';
            st.classList.add(hit ? 'is-hit' : 'is-miss');
            st.hidden = false;
            card.classList.add('is-done');
            if (idx === cards.length - 1) setTimeout(finish, seen ? 0 : 500);
          };
          if (seen) fill();
          else setTimeout(fill, 600 + idx * 900); // 순차 리빌 연출
        });
      }

      // ── 이번 라운드 ──
      function updateSubmit() {
        const btn = $('pl-submit');
        const n = state.qCount || 0;
        const done = n > 0 && Object.keys(state.picks).length === n;
        btn.disabled = !done;
        btn.innerHTML = state.submitted
          ? '예측 수정하기'
          : done ? (state.dd ? '제출 — ' + gi('target', 15) + ' 더블다운 포함' : '예측 제출하기') : (n - Object.keys(state.picks).length) + '개 더 골라주세요';
      }
      async function loadStats() {
        if (!state.round) return;
        const st = await rpc('prediction_stats', { p_round: state.round.id });
        if (!st) return;
        document.querySelectorAll('.pl-card').forEach((card) => {
          const key = card.dataset.key;
          const d = (st.dist && st.dist[key]) || {};
          const up = d.up || 0, down = d.down || 0, tot = up + down;
          if (!tot) return;
          const upPct = Math.round((up / tot) * 100);
          const box = card.querySelector('[data-role=dist]');
          box.hidden = false;
          requestAnimationFrame(() => {
            card.querySelector('[data-role=up-bar]').style.width = upPct + '%';
            card.querySelector('[data-role=down-bar]').style.width = (100 - upPct) + '%';
          });
          card.querySelector('[data-role=up-pct]').textContent = '▲ ' + upPct + '%';
          card.querySelector('[data-role=down-pct]').textContent = (100 - upPct) + '% ▼';
          const my = state.picks[key];
          const myShare = my === 'up' ? upPct : 100 - upPct;
          const tag = card.querySelector('[data-role=tag]');
          tag.innerHTML = my && myShare < 40 ? gi('flame', 11) + ' 소수파 — 적중 시 +3' : '';
        });
        if (state.submitted) $('pl-crowd').textContent = '지금까지 ' + fmt(st.total) + '명 참여 중.';
      }
      function paintPicks() {
        document.querySelectorAll('.pl-card').forEach((card) => {
          const key = card.dataset.key;
          card.querySelectorAll('.pl-btn').forEach((b) => b.classList.toggle('is-on', state.picks[key] === b.dataset.dir));
          card.querySelector('[data-role=dd]').classList.toggle('is-on', state.dd === key);
          card.classList.toggle('is-dd', state.dd === key);
        });
        updateSubmit();
      }
      async function loadRound() {
        const rounds = await rest('prediction_rounds?status=eq.open&order=locks_at.asc&limit=1');
        state.round = rounds && rounds[0];
        if (!state.round) { $('pl-round-desc').textContent = '다음 라운드를 준비 중이에요 — 내일 다시 와주세요!'; return; }
        $('pl-round-id').textContent = '#' + (state.round.id.split('-W')[1] || '') + '주차';
        state.qCount = (state.round.questions || []).length;
        buildRoundCards(state.round.questions || []);
        // 카운트다운
        const locks = new Date(state.round.locks_at);
        $('pl-timer').hidden = false;
        setInterval(() => {
          const ms = locks - new Date();
          if (ms <= 0) { $('pl-timer-val').textContent = '마감!'; return; }
          const d = Math.floor(ms / 864e5), h = Math.floor((ms % 864e5) / 36e5), m = Math.floor((ms % 36e5) / 6e4), s = Math.floor((ms % 6e4) / 1e3);
          $('pl-timer-val').textContent = (d ? d + '일 ' : '') + String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
        }, 1000);
        // 내 기존 픽
        if (T) {
          const mine = await rest('prediction_picks?round_id=eq.' + encodeURIComponent(state.round.id) + '&select=*', true);
          if (mine && mine[0]) {
            state.picks = mine[0].picks || {};
            state.dd = mine[0].double_key || null;
            state.submitted = true;
            $('pl-submitted').hidden = false;
            $('pl-share').hidden = false;
          }
        }
        paintPicks();
        loadStats();
      }

      $('pl-submit').addEventListener('click', async () => {
        if (!state.round) return;
        if (!T) {
          if (window.CramaSaved) window.CramaSaved.promptLogin();
          return;
        }
        const btn = $('pl-submit');
        btn.disabled = true;
        const res = await rpc('submit_prediction', { p_round: state.round.id, p_picks: state.picks, p_double: state.dd }, true);
        btn.disabled = false;
        if (res && res.ok) {
          state.submitted = true;
          $('pl-submitted').hidden = false;
          $('pl-share').hidden = false;
          try { if (window.gtag) window.gtag('event', 'prediction_submit', { round: state.round.id, dd: state.dd || 'none' }); } catch (e) {}
          loadStats();
          updateSubmit();
          $('pl-submitted').scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else if (res && res.error === 'locked') {
          btn.textContent = '이번 라운드는 마감됐어요';
        }
      });

      // 예측 자랑 카드(1080×1350) — 내 픽 + '너는 어디에 걸래?' CTA → 공유/저장
      $('pl-share').addEventListener('click', async () => {
        if (!state.round) return;
        const c = document.createElement('canvas');
        c.width = 1080; c.height = 1350;
        const x = c.getContext('2d');
        const bg = x.createLinearGradient(0, 0, 0, 1350);
        bg.addColorStop(0, '#4c46c8'); bg.addColorStop(1, '#241f52');
        x.fillStyle = bg; x.fillRect(0, 0, 1080, 1350);
        const F = "'Malgun Gothic','Apple SD Gothic Neo',sans-serif";
        x.fillStyle = '#ffd166'; x.font = '800 38px ' + F;
        x.fillText('CRAMA · 오르까 내리까', 80, 110);
        x.fillStyle = '#fff'; x.font = '900 88px ' + F;
        x.fillText('나의 이번 주 예측', 80, 230);
        x.fillStyle = 'rgba(255,255,255,.75)'; x.font = '700 40px ' + F;
        x.fillText('#' + (state.round.id.split('-W')[1] || '') + '주차 · 다음 주 금요일 판정', 80, 300);
        let y = 420;
        for (const q of state.round.questions || []) {
          const pick = state.picks[q.key];
          if (!pick) continue;
          // 행 배경
          x.fillStyle = 'rgba(255,255,255,.10)';
          x.beginPath(); x.roundRect(80, y - 62, 920, 96, 20); x.fill();
          x.fillStyle = '#fff'; x.font = '800 44px ' + F;
          x.fillText(q.label + (q.special ? ' ★' : ''), 110, y);
          const up = pick === 'up';
          x.fillStyle = up ? '#ff6b6b' : '#5aa2ff'; x.font = '900 46px ' + F;
          const t = (up ? '▲ 오른다' : '▼ 내린다') + (state.dd === q.key ? '  ×2.5' : '');
          x.fillText(t, 1000 - x.measureText(t).width - 30 + 30, y);
          y += 130;
        }
        x.fillStyle = '#fff'; x.font = '900 54px ' + F;
        x.fillText('너는 어디에 걸래?', 80, 1200);
        x.fillStyle = '#ffd166'; x.font = '800 40px ' + F;
        x.fillText('crama.app/play — 맞히면 밀웜, 전부 맞히면 퍼펙트', 80, 1265);
        try { if (window.gtag) window.gtag('event', 'predict_share', { round: state.round.id }); } catch (e) {}
        const blob = await new Promise((res2) => c.toBlob(res2, 'image/png'));
        const file = new File([blob], 'crama-prediction.png', { type: 'image/png' });
        const isMobile = /Android|iPhone|iPad/i.test(navigator.userAgent);
        if (isMobile && navigator.canShare && navigator.canShare({ files: [file] })) {
          try { await navigator.share({ files: [file], title: '오르까 내리까 — 나의 예측' }); return; } catch (e) {}
        }
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'crama-prediction.png';
        a.click();
      });

      loadRound();
      loadRank();
      loadReveal();
    })();
  </script>

