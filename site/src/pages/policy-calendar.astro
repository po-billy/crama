---
import BaseLayout from '../layouts/BaseLayout.astro';

// 2026년 주요 정책·세금·지원금 일정 — 대상·분야·지역 필터 지원
// target: 대상 (all=전체, youth=청년, worker=직장인, self=자영업·프리랜서, parent=부모, student=학생)
// field: 분야 (tax=세금, saving=저축·금융, housing=주거, job=취업·창업, family=출산·육아, invest=투자)
// ageGroup: 연령대 (all=전체, 20s, 30s, 40s, 50plus)
// region: 지역 (all=전국)
const EVENTS = [
  { month: 1, day: 15, title: '연말정산 간소화 서비스 오픈', cat: 'tax', desc: '홈택스에서 소득·세액공제 자료 확인', url: 'https://www.hometax.go.kr', target: 'worker', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 1, day: 25, title: '부가가치세 확정신고 마감', cat: 'tax', desc: '전년 2기분 부가세 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 2, day: 28, title: '연말정산 환급 시작', cat: 'tax', desc: '근로소득 연말정산 환급금 지급 시작', url: '', target: 'worker', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 3, day: 2, title: '근로·자녀장려금 반기 신청', cat: 'benefit', desc: '상반기분 장려금 신청 (~3/15)', url: 'https://www.hometax.go.kr', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 3, day: 31, title: '건강보험료 정산', cat: 'tax', desc: '전년도 소득 기준 건보료 정산·추가 납부', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 4, day: 25, title: '부가가치세 예정신고 마감', cat: 'tax', desc: '1기 부가세 예정 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 5, day: 1, title: '종합소득세 신고 시작', cat: 'tax', desc: '프리랜서·N잡러 종소세 신고 (~5/31)', url: 'https://www.hometax.go.kr', relatedSlug: 'freelancer-tax-guide', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 5, day: 1, title: '근로·자녀장려금 정기 신청', cat: 'benefit', desc: '전년 귀속 장려금 신청 (~5/31)', url: 'https://www.hometax.go.kr', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 5, day: 31, title: '종합소득세 신고 마감', cat: 'tax', desc: '기한 내 미신고 시 가산세 부과', url: 'https://www.hometax.go.kr', important: true, target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 6, day: 1, title: '재산세(건축물) 납부', cat: 'tax', desc: '건축물분 재산세 납부 (~6/30)', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 6, day: 16, title: '청년도약계좌 신규 신청', cat: 'benefit', desc: '출생연도 5부제 (~7/3)', url: 'https://www.kinfa.or.kr', relatedSlug: 'youth-leap-account-guide-2026', important: true, target: 'youth', field: 'saving', ageGroup: '20s', region: 'all' },
  { month: 7, day: 3, title: '청년도약계좌 신청 마감', cat: 'benefit', desc: '하반기 신규 가입 마감', url: 'https://www.kinfa.or.kr', important: true, target: 'youth', field: 'saving', ageGroup: '20s', region: 'all' },
  { month: 7, day: 25, title: '부가가치세 확정신고 마감', cat: 'tax', desc: '1기분 부가세 확정 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 7, day: 31, title: '재산세(주택 1기) 납부 마감', cat: 'tax', desc: '주택분 재산세 1기 납부', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 8, day: 31, title: '주민세 납부 마감', cat: 'tax', desc: '개인분 주민세 납부 (~8/31)', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 9, day: 1, title: '근로·자녀장려금 지급', cat: 'benefit', desc: '5월 신청분 장려금 지급 시작', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 9, day: 15, title: '국가장학금 2학기 신청', cat: 'benefit', desc: '2학기 국가장학금 신청 마감', url: 'https://www.kosaf.go.kr', target: 'student', field: 'saving', ageGroup: '20s', region: 'all' },
  { month: 9, day: 30, title: '재산세(주택 2기) 납부 마감', cat: 'tax', desc: '주택분 재산세 2기 납부', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 10, day: 25, title: '부가가치세 예정신고 마감', cat: 'tax', desc: '2기 부가세 예정 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 11, day: 15, title: '종합부동산세 고지', cat: 'tax', desc: '종부세 고지서 발송·납부 (~12/15)', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 11, day: 30, title: '건강보험 피부양자 요건 점검', cat: 'tax', desc: '연소득 2천만원 초과 시 지역가입 전환', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 12, day: 1, title: 'IRP·연금저축 납입 마감 임박', cat: 'invest', desc: '세액공제 한도(900만원) 채우기 (~12/31)', url: '', relatedSlug: 'irp-pension-tax-deduction', important: true, target: 'worker', field: 'invest', ageGroup: 'all', region: 'all' },
  { month: 12, day: 15, title: '종합부동산세 납부 마감', cat: 'tax', desc: '기한 내 미납부 시 가산세', url: '', important: true, target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 12, day: 31, title: 'ISA 계좌 납입 마감', cat: 'invest', desc: '올해 비과세 한도를 채우려면 연내 납입', url: '', relatedSlug: 'isa-account-guide-2026', target: 'all', field: 'invest', ageGroup: 'all', region: 'all' },
  { month: 12, day: 31, title: '연말정산 준비 완료', cat: 'tax', desc: '기부금·의료비·교육비 영수증 챙기기', url: '', target: 'worker', field: 'tax', ageGroup: 'all', region: 'all' },
];

// 필터 옵션
const TARGETS = { all: '전체', youth: '청년', worker: '직장인', self: '자영업·프리랜서', parent: '부모', student: '학생' };
const FIELDS = { all: '전체', tax: '세금', saving: '저축·금융', housing: '주거', job: '취업·창업', family: '출산·육아', invest: '투자' };
const AGE_GROUPS = { all: '전체', '20s': '20대', '30s': '30대', '40s': '40대', '50plus': '50대 이상' };
const eventsJson = JSON.stringify(EVENTS);

const CATS: Record<string, { name: string; color: string; icon: string }> = {
  tax: { name: '세금', color: '#ef4444', icon: '📋' },
  benefit: { name: '지원금', color: '#22c55e', icon: '💰' },
  invest: { name: '투자·절세', color: '#6c5ce7', icon: '📈' },
};

const MONTHS = ['1월', '2월', '3월', '4월', '5월', '6월', '7월', '8월', '9월', '10월', '11월', '12월'];
const now = new Date();
const currentMonth = now.getMonth() + 1;
---
<BaseLayout title="정책 캘린더 2026 — 놓치면 손해인 일정 한눈에" description="지원금 신청, 세금 납부, 투자 절세 마감일을 월별로 정리. 2026년 핵심 정책 일정을 한 곳에서.">
  <div class="wrap">
    <header class="page-hero" style="text-align:center;">
      <span class="eyebrow">서비스</span>
      <h1>정책 캘린더 2026</h1>
      <p>놓치면 손해인 일정, 한 곳에서 챙기세요</p>
    </header>

    <div class="pc">
      <!-- 검색 + 필터 패널 -->
      <div class="pc-search-bar">
        <input type="search" class="pc-search" id="pc-search" placeholder="정책명으로 검색" aria-label="정책 검색" />
      </div>

      <div class="pc-filter-panel">
        <div class="pc-filter-row">
          <span class="pc-filter-label">대상별</span>
          <div class="pc-filter-chips" data-filter="target">
            {Object.entries(TARGETS).map(([k, v]) => (
              <button type="button" class={`pc-chip ${k === 'all' ? 'is-on' : ''}`} data-val={k}>{v}</button>
            ))}
          </div>
        </div>
        <div class="pc-filter-row">
          <span class="pc-filter-label">분야별</span>
          <div class="pc-filter-chips" data-filter="field">
            {Object.entries(FIELDS).map(([k, v]) => (
              <button type="button" class={`pc-chip ${k === 'all' ? 'is-on' : ''}`} data-val={k}>{v}</button>
            ))}
          </div>
        </div>
        <div class="pc-filter-row">
          <span class="pc-filter-label">연령별</span>
          <div class="pc-filter-chips" data-filter="ageGroup">
            {Object.entries(AGE_GROUPS).map(([k, v]) => (
              <button type="button" class={`pc-chip ${k === 'all' ? 'is-on' : ''}`} data-val={k}>{v}</button>
            ))}
          </div>
        </div>
      </div>

      <!-- 결과 수 + 도구 -->
      <div class="pc-toolbar">
        <span class="pc-result-count" id="pc-count"></span>
        <div style="display:flex;gap:.4rem;align-items:center;">
          <a href="/policy-calendar.ics" class="pc-subscribe" download>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            캘린더 구독
          </a>
          <div class="pc-views" role="group" aria-label="보기 방식">
            <button class="pc-view is-on" type="button" data-view="timeline" title="타임라인">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
            </button>
            <button class="pc-view" type="button" data-view="grid" title="캘린더">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- 레거시 카테고리 필터 제거 — 새 필터 패널로 대체 -->
      <div class="pc-filters" style="display:none;">
        {Object.entries(CATS).map(([k, v]) => (
          <button class="pc-filter" data-cat={k}>{v.icon} {v.name}</button>
        ))}
      </div>

      <!-- 월별 타임라인 -->
      <div class="pc-timeline">
        {MONTHS.map((label, i) => {
          const m = i + 1;
          const monthEvents = EVENTS.filter(e => e.month === m);
          if (monthEvents.length === 0) return null;
          const isPast = m < currentMonth;
          const isCurrent = m === currentMonth;
          return (
            <section class={`pc-month ${isCurrent ? 'is-current' : ''} ${isPast ? 'is-past' : ''}`} id={`month-${m}`} data-month={m}>
              <h2 class="pc-month__title">
                <span class="pc-month__num">{m}</span>
                <span class="pc-month__label">{label}</span>
                {isCurrent && <span class="pc-month__badge">이번 달</span>}
              </h2>
              <div class="pc-events">
                {monthEvents.map(ev => {
                  const cat = CATS[ev.cat];
                  const eventDate = new Date(2026, ev.month - 1, ev.day);
                  const dday = Math.ceil((eventDate.getTime() - now.getTime()) / 86400000);
                  const ddayLabel = dday > 0 ? `D-${dday}` : dday === 0 ? 'D-Day' : '';
                  const globalIdx = EVENTS.indexOf(ev);
                  return (
                    <div class={`pc-event ${ev.important ? 'is-important' : ''}`} data-cat={ev.cat} data-idx={globalIdx}>
                      <div class="pc-event__date">
                        <span class="pc-event__day">{ev.day}</span>
                      </div>
                      <div class="pc-event__body">
                        <div class="pc-event__head">
                          <span class="pc-event__cat" style={`--ecolor:${cat.color}`}>{cat.icon} {cat.name}</span>
                          {dday > 0 && dday <= 30 && <span class="pc-event__dday pc-event__dday--soon">{ddayLabel}</span>}
                          {dday > 30 && dday <= 90 && <span class="pc-event__dday">{ddayLabel}</span>}
                        </div>
                        <h3 class="pc-event__title">{ev.title}</h3>
                        <p class="pc-event__desc">{ev.desc}</p>
                        <div class="pc-event__links">
                          {ev.url && <a href={ev.url} target="_blank" rel="noopener" class="pc-event__link">신청/확인 →</a>}
                          {ev.relatedSlug && <a href={`/blog/${ev.relatedSlug}/`} class="pc-event__link pc-event__link--guide">가이드 읽기</a>}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </section>
          );
        })}
      </div>

      <!-- 캘린더 그리드 뷰 -->
      <div class="pc-grid-view" id="pc-grid" hidden>
        <div class="pc-grid-nav">
          <button type="button" id="pc-prev" class="pc-grid-nav__btn" aria-label="이전 달">‹</button>
          <span class="pc-grid-nav__month" id="pc-month-label"></span>
          <button type="button" id="pc-next" class="pc-grid-nav__btn" aria-label="다음 달">›</button>
        </div>
        <div class="pc-grid-header">
          <span>일</span><span>월</span><span>화</span><span>수</span><span>목</span><span>금</span><span>토</span>
        </div>
        <div class="pc-grid-body" id="pc-grid-body"></div>
        <div class="pc-grid-events" id="pc-grid-events"></div>
      </div>

      <!-- 서비스 크로스 연결 -->
      <div class="pc-cross">
        <a href="/benefits/" class="pc-cross__card">
          <span class="pc-cross__icon">💰</span>
          <div>
            <strong>내 혜택 찾기</strong>
            <p>나에게 해당되는 지원금을 찾아보세요</p>
          </div>
          <span class="pc-cross__arrow">→</span>
        </a>
        <a href="/checkup/" class="pc-cross__card">
          <span class="pc-cross__icon">🩺</span>
          <div>
            <strong>재무 건강 체크업</strong>
            <p>내 돈 관리 상태를 진단받아 보세요</p>
          </div>
          <span class="pc-cross__arrow">→</span>
        </a>
      </div>

      <div class="pc-note">
        <p>※ 일정은 2026년 기준이며, 정부 발표에 따라 변경될 수 있습니다. 정확한 일정은 각 기관 공식 사이트에서 확인하세요.</p>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ eventsJson }}>
    (() => {
      var ALL_EVENTS = JSON.parse(eventsJson);
      var activeFilters = { target: 'all', field: 'all', ageGroup: 'all' };
      var searchQuery = '';

      // 필터 칩 이벤트
      document.querySelectorAll('.pc-filter-chips').forEach(function (group) {
        group.addEventListener('click', function (ev) {
          var btn = ev.target.closest('.pc-chip'); if (!btn) return;
          var filterKey = group.dataset.filter;
          activeFilters[filterKey] = btn.dataset.val;
          group.querySelectorAll('.pc-chip').forEach(function (c) { c.classList.toggle('is-on', c.dataset.val === btn.dataset.val); });
          applyFilters();
        });
      });

      // 검색
      var searchInput = document.getElementById('pc-search');
      var searchTimer;
      searchInput.addEventListener('input', function () {
        clearTimeout(searchTimer);
        searchTimer = setTimeout(function () {
          searchQuery = searchInput.value.trim().toLowerCase();
          applyFilters();
        }, 150);
      });

      function applyFilters() {
        var count = 0;
        document.querySelectorAll('.pc-event').forEach(function (el) {
          var idx = parseInt(el.dataset.idx);
          var ev = ALL_EVENTS[idx];
          if (!ev) { el.hidden = true; return; }
          var show = true;
          if (activeFilters.target !== 'all' && ev.target !== activeFilters.target && ev.target !== 'all') show = false;
          if (activeFilters.field !== 'all' && ev.field !== activeFilters.field && ev.field !== 'all') show = false;
          if (activeFilters.ageGroup !== 'all' && ev.ageGroup !== activeFilters.ageGroup && ev.ageGroup !== 'all') show = false;
          if (searchQuery && ev.title.toLowerCase().indexOf(searchQuery) === -1 && ev.desc.toLowerCase().indexOf(searchQuery) === -1) show = false;
          el.hidden = !show;
          if (show) count++;
        });
        // 이벤트 없는 월 숨기기
        document.querySelectorAll('.pc-month').forEach(function (m) {
          var visible = m.querySelectorAll('.pc-event:not([hidden])');
          m.hidden = visible.length === 0;
        });
        var countEl = document.getElementById('pc-count');
        if (countEl) countEl.textContent = count + '건 표시 중';
      }
      applyFilters(); // 초기 카운트

      // 이번 달로 스크롤
      var cur = document.querySelector('.pc-month.is-current');
      if (cur) setTimeout(function () { cur.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 300);

      // ── 뷰 토글 ──
      var viewBtns = document.querySelectorAll('.pc-view');
      var timeline = document.querySelector('.pc-timeline');
      var gridView = document.getElementById('pc-grid');
      viewBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var view = btn.dataset.view;
          viewBtns.forEach(function (b) { b.classList.toggle('is-on', b.dataset.view === view); });
          timeline.hidden = view !== 'timeline';
          gridView.hidden = view !== 'grid';
          if (view === 'grid') renderCalGrid(gridMonth);
        });
      });

      // ── 캘린더 그리드 ──
      var EVENTS_DATA = [
        { m:1,d:15,t:'연말정산 간소화 오픈',c:'tax' },{ m:1,d:25,t:'부가세 확정신고 마감',c:'tax' },
        { m:2,d:28,t:'연말정산 환급 시작',c:'tax' },{ m:3,d:2,t:'장려금 반기 신청',c:'benefit' },
        { m:3,d:31,t:'건보료 정산',c:'tax' },{ m:4,d:25,t:'부가세 예정신고 마감',c:'tax' },
        { m:5,d:1,t:'종소세 신고 시작',c:'tax' },{ m:5,d:1,t:'장려금 정기 신청',c:'benefit' },
        { m:5,d:31,t:'종소세 신고 마감',c:'tax' },{ m:6,d:1,t:'재산세 납부',c:'tax' },
        { m:6,d:16,t:'청년도약계좌 신청',c:'benefit' },{ m:7,d:3,t:'도약계좌 마감',c:'benefit' },
        { m:7,d:25,t:'부가세 확정신고',c:'tax' },{ m:7,d:31,t:'재산세 1기 마감',c:'tax' },
        { m:8,d:31,t:'주민세 마감',c:'tax' },{ m:9,d:1,t:'장려금 지급',c:'benefit' },
        { m:9,d:15,t:'국가장학금 2학기',c:'benefit' },{ m:9,d:30,t:'재산세 2기 마감',c:'tax' },
        { m:10,d:25,t:'부가세 예정신고',c:'tax' },{ m:11,d:15,t:'종부세 고지',c:'tax' },
        { m:12,d:1,t:'IRP 납입 임박',c:'invest' },{ m:12,d:15,t:'종부세 납부 마감',c:'tax' },
        { m:12,d:31,t:'ISA 납입 마감',c:'invest' },{ m:12,d:31,t:'연말정산 준비',c:'tax' },
      ];
      var catColors = { tax:'#ef4444', benefit:'#22c55e', invest:'#6c5ce7' };
      var gridMonth = new Date().getMonth(); // 0-based
      var MONTHS_KR = ['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];

      function renderCalGrid(monthIdx) {
        var label = document.getElementById('pc-month-label');
        label.textContent = '2026년 ' + MONTHS_KR[monthIdx];

        var body = document.getElementById('pc-grid-body');
        var first = new Date(2026, monthIdx, 1);
        var startDay = first.getDay(); // 일=0
        var daysInMonth = new Date(2026, monthIdx + 1, 0).getDate();
        var today = new Date();
        var todayDay = (today.getFullYear() === 2026 && today.getMonth() === monthIdx) ? today.getDate() : -1;

        var monthEvents = EVENTS_DATA.filter(function (e) { return e.m === monthIdx + 1; });
        var eventDays = {};
        monthEvents.forEach(function (e) { if (!eventDays[e.d]) eventDays[e.d] = []; eventDays[e.d].push(e); });

        var html = '';
        // 빈 셀
        for (var i = 0; i < startDay; i++) html += '<div class="pc-cell pc-cell--empty"></div>';
        // 날짜 셀 — 이벤트 제목을 셀 안에 직접 표시
        for (var d = 1; d <= daysInMonth; d++) {
          var isToday = d === todayDay;
          var hasEvent = eventDays[d];
          html += '<div class="pc-cell' + (isToday ? ' is-today' : '') + (hasEvent ? ' has-event' : '') + '" data-day="' + d + '">';
          html += '<span class="pc-cell__num">' + d + '</span>';
          if (hasEvent) {
            hasEvent.forEach(function (e) {
              html += '<span class="pc-cell__tag" style="background:' + (catColors[e.c] || '#888') + '">' + e.t + '</span>';
            });
          }
          html += '</div>';
        }
        body.innerHTML = html;

        // 이벤트가 있는 날짜 아래에 상세 목록도 자동 표시
        var evWrap = document.getElementById('pc-grid-events');
        var allEvts = monthEvents.sort(function (a, b) { return a.d - b.d; });
        if (allEvts.length > 0) {
          evWrap.innerHTML = '<p style="font-size:.82rem;font-weight:600;color:var(--muted);margin:0 0 .5rem;">' + MONTHS_KR[monthIdx] + ' 일정 ' + allEvts.length + '건</p>' +
            allEvts.map(function (e) {
              return '<div class="pc-grid-ev" style="border-left:3px solid ' + (catColors[e.c] || '#888') + '"><span class="pc-grid-ev__day">' + e.d + '일</span><strong>' + e.t + '</strong></div>';
            }).join('');
        } else {
          evWrap.innerHTML = '<p style="text-align:center;color:var(--muted);font-size:.9rem;padding:1rem;">이 달에는 주요 일정이 없어요</p>';
        }

        // 날짜 클릭 → 해당 날짜 이벤트 하이라이트
        body.querySelectorAll('.pc-cell[data-day]').forEach(function (cell) {
          cell.addEventListener('click', function () {
            var day = parseInt(cell.dataset.day);
            var evts = eventDays[day];
            body.querySelectorAll('.pc-cell').forEach(function (c) { c.classList.remove('is-sel'); });
            cell.classList.add('is-sel');
            if (evts) {
              evWrap.innerHTML = evts.map(function (e) {
                return '<div class="pc-grid-ev pc-grid-ev--sel" style="border-left:3px solid ' + (catColors[e.c] || '#888') + '"><span class="pc-grid-ev__day">' + e.d + '일</span><strong>' + e.t + '</strong></div>';
              }).join('');
            }
          });
        });
      }

      document.getElementById('pc-prev').addEventListener('click', function () { gridMonth = Math.max(0, gridMonth - 1); renderCalGrid(gridMonth); });
      document.getElementById('pc-next').addEventListener('click', function () { gridMonth = Math.min(11, gridMonth + 1); renderCalGrid(gridMonth); });
    })();
  </script>

  <style>
    .pc { max-width: 44rem; margin: 0 auto; }

    /* 필터 */
    .pc-filters { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 2rem; justify-content: center; }
    .pc-filter {
      padding: 0.45rem 1rem; border: 1px solid var(--line); border-radius: 20px;
      background: var(--paper); font: inherit; font-size: 0.85rem; font-weight: 500;
      color: var(--ink-soft); cursor: pointer; transition: all 0.12s;
    }
    .pc-filter:hover { border-color: var(--accent); }
    .pc-filter.is-on { background: var(--ink); color: var(--paper); border-color: var(--ink); }

    /* 타임라인 */
    .pc-timeline { position: relative; }

    .pc-month { margin-bottom: 2.5rem; }
    .pc-month.is-past { opacity: 0.5; }
    .pc-month.is-past:hover { opacity: 0.85; }
    .pc-month.is-current { opacity: 1; }

    .pc-month__title {
      display: flex; align-items: center; gap: 0.6rem;
      padding-bottom: 0.6rem; border-bottom: 2px solid var(--ink);
      margin-bottom: 1rem;
    }
    .pc-month.is-current .pc-month__title { border-bottom-color: var(--accent); }
    .pc-month__num { font-family: var(--font-serif); font-size: 1.8rem; font-weight: 700; color: var(--ink); line-height: 1; }
    .pc-month__label { font-size: 1rem; font-weight: 600; color: var(--ink-soft); }
    .pc-month__badge {
      font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.6rem;
      background: var(--accent); color: #fff; border-radius: 12px;
    }

    /* 이벤트 카드 */
    .pc-events { display: flex; flex-direction: column; gap: 0.8rem; }
    .pc-event {
      display: flex; gap: 1rem; padding: 1rem 1.2rem;
      border: 1px solid var(--line); border-radius: 12px;
      background: var(--paper); transition: box-shadow 0.12s;
    }
    .pc-event:hover { box-shadow: 0 2px 12px rgba(0,0,0,.05); }
    .pc-event.is-important { border-left: 3px solid var(--accent); }

    .pc-event__date { flex: none; width: 2.5rem; text-align: center; padding-top: 0.2rem; }
    .pc-event__day { font-family: var(--font-serif); font-size: 1.3rem; font-weight: 700; color: var(--ink); }

    .pc-event__body { flex: 1; min-width: 0; }
    .pc-event__head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.3rem; }
    .pc-event__cat { font-size: 0.75rem; font-weight: 600; color: var(--ecolor, var(--muted)); }
    .pc-event__dday { font-size: 0.72rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 6px; background: var(--paper-2); color: var(--ink-soft); }
    .pc-event__dday--soon { background: #fee2e2; color: #dc2626; }

    .pc-event__title { font-size: 1rem; font-weight: 700; margin: 0 0 0.3rem; line-height: 1.35; }
    .pc-event__desc { font-size: 0.85rem; color: var(--ink-soft); margin: 0 0 0.5rem; line-height: 1.5; }

    .pc-event__links { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .pc-event__link {
      font-size: 0.82rem; font-weight: 600; color: var(--accent);
      text-decoration: none; padding: 0.3rem 0.7rem;
      border: 1px solid var(--accent); border-radius: 6px; transition: all 0.12s;
    }
    .pc-event__link:hover { background: var(--accent); color: #fff; }
    .pc-event__link--guide { border-color: var(--line); color: var(--ink-soft); }
    .pc-event__link--guide:hover { background: var(--paper-2); color: var(--ink); border-color: var(--ink-soft); }

    .pc-note { margin-top: 2rem; padding: 1rem; background: var(--paper-2); border-radius: 10px; font-size: 0.8rem; color: var(--muted); }
    .pc-note p { margin: 0; }

    /* 검색 + 필터 패널 */
    .pc-search-bar { margin-bottom: .8rem; }
    .pc-search {
      width: 100%; padding: .7rem 1rem; font: inherit; font-size: .95rem;
      border: 2px solid var(--line); border-radius: 10px; background: var(--paper);
      color: var(--ink); transition: border-color .15s;
    }
    .pc-search:focus { outline: none; border-color: var(--accent); }
    .pc-search::placeholder { color: var(--muted); }

    .pc-filter-panel { margin-bottom: 1rem; }
    .pc-filter-row { display: flex; align-items: flex-start; gap: .5rem; margin-bottom: .5rem; }
    .pc-filter-label { font-size: .75rem; font-weight: 700; color: var(--muted); min-width: 3rem; padding-top: .35rem; flex: none; }
    .pc-filter-chips { display: flex; flex-wrap: wrap; gap: .3rem; }
    .pc-chip {
      padding: .3rem .7rem; border: 1px solid var(--line); border-radius: 16px;
      background: var(--paper); font: inherit; font-size: .78rem; font-weight: 500;
      color: var(--ink-soft); cursor: pointer; transition: all .12s; white-space: nowrap;
    }
    .pc-chip:hover { border-color: var(--accent); }
    .pc-chip.is-on { background: var(--ink); color: var(--paper); border-color: var(--ink); }

    .pc-result-count { font-size: .82rem; font-weight: 600; color: var(--muted); }

    /* 툴바 */
    .pc-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
    .pc-subscribe {
      display: inline-flex; align-items: center; gap: .4rem;
      padding: .5rem 1rem; border: 1px solid var(--accent); border-radius: 8px;
      font-size: .85rem; font-weight: 600; color: var(--accent); text-decoration: none;
      transition: all .12s;
    }
    .pc-subscribe:hover { background: var(--accent); color: #fff; }
    .pc-subscribe:hover svg { stroke: #fff; }
    .pc-views { display: flex; gap: .3rem; }
    .pc-view {
      padding: .45rem .6rem; border: 1px solid var(--line); border-radius: 6px;
      background: var(--paper); cursor: pointer; color: var(--muted); transition: all .12s;
    }
    .pc-view:hover { border-color: var(--accent); }
    .pc-view.is-on { background: var(--ink); color: var(--paper); border-color: var(--ink); }

    /* 캘린더 그리드 */
    .pc-grid-nav { display: flex; justify-content: center; align-items: center; gap: 1.5rem; margin-bottom: 1rem; }
    .pc-grid-nav__month { font-family: var(--font-serif); font-size: 1.2rem; font-weight: 700; min-width: 8rem; text-align: center; }
    .pc-grid-nav__btn { font-size: 1.5rem; background: none; border: 1px solid var(--line); border-radius: 50%; width: 2rem; height: 2rem; cursor: pointer; color: var(--ink); display: grid; place-items: center; transition: border-color .12s; }
    .pc-grid-nav__btn:hover { border-color: var(--accent); color: var(--accent); }

    .pc-grid-header { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; font-size: .75rem; font-weight: 600; color: var(--muted); padding-bottom: .4rem; border-bottom: 1px solid var(--line); margin-bottom: .3rem; }
    .pc-grid-header span:first-child { color: #ef4444; }
    .pc-grid-header span:last-child { color: #3b82f6; }

    .pc-grid-body { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: 8px; overflow: hidden; }
    .pc-cell {
      min-height: 4.5rem; display: flex; flex-direction: column; align-items: stretch;
      gap: 2px; padding: 3px; background: var(--paper); cursor: pointer; transition: background .1s;
    }
    .pc-cell:hover { background: var(--paper-2); }
    .pc-cell--empty { background: var(--paper-2); cursor: default; min-height: 2rem; }
    .pc-cell.is-today { background: var(--accent-soft); }
    .pc-cell.is-today .pc-cell__num { color: var(--accent); font-weight: 800; }
    .pc-cell.is-sel { background: var(--accent-soft); }
    .pc-cell__num { font-size: .75rem; font-weight: 500; color: var(--ink-soft); padding: 1px 3px; }
    .pc-cell__tag {
      font-size: .58rem; font-weight: 600; color: #fff; padding: 1px 3px;
      border-radius: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      line-height: 1.4;
    }
    .pc-cell.has-event { font-weight: 700; }

    .pc-grid-events { margin-top: 1rem; }
    .pc-grid-ev {
      display: flex; align-items: center; gap: .6rem;
      padding: .7rem .9rem; margin-bottom: .4rem; background: var(--paper-2); border-radius: 8px; font-size: .88rem;
    }
    .pc-grid-ev--sel { background: var(--accent-soft); }
    .pc-grid-ev__day { font-size: .75rem; font-weight: 700; color: var(--muted); min-width: 2rem; }

    @media (max-width: 480px) {
      .pc-cell { min-height: 3rem; padding: 1px; }
      .pc-cell__tag { font-size: .48rem; padding: 0 2px; line-height: 1.3; }
      .pc-cell__num { font-size: .65rem; }
      .pc-grid-nav__btn { width: 2.5rem; height: 2.5rem; font-size: 1.3rem; }
    }
    @media (max-width: 360px) {
      .pc-cell__tag { display: none; } /* 극소형 화면: 태그 숨기고 dot만 */
      .pc-cell.has-event::after { content: ''; display: block; width: 5px; height: 5px; border-radius: 50%; background: var(--accent); margin: 1px auto 0; }
    }

    .pc-cross { display: flex; flex-direction: column; gap: 0.6rem; margin: 2rem 0 1.5rem; }
    .pc-cross__card {
      display: flex; align-items: center; gap: 0.8rem; padding: 1rem 1.2rem;
      border: 1px solid var(--line); border-radius: 12px; background: var(--paper);
      text-decoration: none; color: var(--ink); transition: border-color 0.12s, box-shadow 0.12s;
    }
    .pc-cross__card:hover { border-color: var(--accent); box-shadow: 0 2px 8px rgba(0,0,0,.05); }
    .pc-cross__icon { font-size: 1.5rem; flex: none; }
    .pc-cross__card div { flex: 1; }
    .pc-cross__card strong { font-size: 0.95rem; display: block; }
    .pc-cross__card p { font-size: 0.82rem; color: var(--muted); margin: 0.2rem 0 0; }
    .pc-cross__arrow { font-size: 1.2rem; color: var(--accent); flex: none; font-weight: 700; }

    @media (max-width: 640px) {
      .pc { padding: 0; }
      .pc-event__date { width: 2rem; }
      .pc-event__day { font-size: 1.1rem; }
      .pc-event { padding: 0.8rem; gap: 0.7rem; }
      .pc-event__title { font-size: 0.92rem; }
      .pc-event__links { gap: 0.4rem; }
      .pc-event__link { padding: 0.25rem 0.6rem; font-size: 0.78rem; }
      .pc-toolbar { flex-wrap: wrap; gap: 0.5rem; }
      .pc-subscribe { font-size: 0.78rem; padding: 0.4rem 0.7rem; }
      .pc-filter-row { flex-direction: column; gap: 0.3rem; }
      .pc-filter-label { min-width: auto; padding-top: 0; }
      .pc-search { font-size: 0.9rem; padding: 0.6rem 0.8rem; }
      .pc-cross__card { padding: 0.8rem; }
      .pc-month__num { font-size: 1.4rem; }
    }
  </style>
</BaseLayout>
