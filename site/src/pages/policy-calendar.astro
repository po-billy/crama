---
import BaseLayout from '../layouts/BaseLayout.astro';
import DuoIcon from '../components/DuoIcon.astro';
import policyEvents from '../data/policy-events.json';

const BASE_EVENTS = [
  { month: 1, day: 15, title: '연말정산 간소화 서비스 오픈', cat: 'tax', desc: '홈택스에서 소득·세액공제 자료 확인', url: 'https://www.hometax.go.kr', target: 'worker', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 1, day: 25, title: '부가가치세 확정신고 마감', cat: 'tax', desc: '전년 2기분 부가세 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 2, day: 3, title: '청년 전세자금 대출 상반기 접수', cat: 'benefit', desc: '만 19~34세 무주택자, 보증금 3억 이하 전세 대출', url: 'https://nhuf.molit.go.kr', target: 'youth', field: 'housing', ageGroup: '20s', region: 'all' },
  { month: 2, day: 28, title: '연말정산 환급 시작', cat: 'tax', desc: '근로소득 연말정산 환급금 지급 시작', url: '', target: 'worker', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 3, day: 2, title: '근로·자녀장려금 반기 신청', cat: 'benefit', desc: '상반기분 장려금 신청 (~3/15)', url: 'https://www.hometax.go.kr', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 3, day: 3, title: '국민취업지원제도 상반기 신청', cat: 'benefit', desc: '구직촉진수당 월 50만원 + 취업지원 서비스', url: 'https://www.kua.go.kr', target: 'youth', field: 'job', ageGroup: '20s', region: 'all' },
  { month: 3, day: 31, title: '건강보험료 정산', cat: 'tax', desc: '전년도 소득 기준 건보료 정산·추가 납부', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 4, day: 1, title: '신혼부부 특별공급 상반기 접수', cat: 'benefit', desc: '혼인 7년 이내 무주택 세대 대상 특별공급', url: 'https://www.applyhome.co.kr', target: 'parent', field: 'housing', ageGroup: '30s', region: 'all' },
  { month: 4, day: 25, title: '부가가치세 예정신고 마감', cat: 'tax', desc: '1기 부가세 예정 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 5, day: 1, title: '종합소득세 신고 시작', cat: 'tax', desc: '프리랜서·N잡러 종소세 신고 (~5/31)', url: 'https://www.hometax.go.kr', relatedSlug: 'side-hustle-tax-guide', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 5, day: 1, title: '근로·자녀장려금 정기 신청', cat: 'benefit', desc: '전년 귀속 장려금 신청 (~5/31)', url: 'https://www.hometax.go.kr', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 5, day: 31, title: '종합소득세 신고 마감', cat: 'tax', desc: '기한 내 미신고 시 가산세 부과', url: 'https://www.hometax.go.kr', important: true, target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 6, day: 1, title: '재산세(건축물) 납부', cat: 'tax', desc: '건축물분 재산세 납부 (~6/30)', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 6, day: 16, title: '청년도약계좌 신규 신청', cat: 'benefit', desc: '출생연도 5부제 (~7/3)', url: 'https://www.kinfa.or.kr', relatedSlug: 'youth-leap-vs-future-savings', important: true, target: 'youth', field: 'saving', ageGroup: '20s', region: 'all' },
  { month: 7, day: 1, title: '부모급여 하반기 지급 시작', cat: 'benefit', desc: '만 0세 월 100만원, 만 1세 월 50만원 지급', url: 'https://www.bokjiro.go.kr', target: 'parent', field: 'family', ageGroup: '30s', region: 'all' },
  { month: 7, day: 3, title: '청년도약계좌 신청 마감', cat: 'benefit', desc: '하반기 신규 가입 마감', url: 'https://www.kinfa.or.kr', important: true, target: 'youth', field: 'saving', ageGroup: '20s', region: 'all' },
  { month: 7, day: 25, title: '부가가치세 확정신고 마감', cat: 'tax', desc: '1기분 부가세 확정 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 7, day: 31, title: '재산세(주택 1기) 납부 마감', cat: 'tax', desc: '주택분 재산세 1기 납부', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 8, day: 1, title: '청년 월세 지원 하반기 접수', cat: 'benefit', desc: '만 19~34세, 월세 20만원(최대 12개월) 지원', url: 'https://www.myhome.go.kr', important: true, target: 'youth', field: 'housing', ageGroup: '20s', region: 'all' },
  { month: 8, day: 31, title: '주민세 납부 마감', cat: 'tax', desc: '개인분 주민세 납부 (~8/31)', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 9, day: 1, title: '근로·자녀장려금 지급', cat: 'benefit', desc: '5월 신청분 장려금 지급 시작', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 9, day: 1, title: '국민내일배움카드 하반기 신청', cat: 'benefit', desc: '직업훈련비 최대 500만원 지원', url: 'https://www.hrd.go.kr', target: 'all', field: 'job', ageGroup: 'all', region: 'all' },
  { month: 9, day: 15, title: '국가장학금 2학기 신청', cat: 'benefit', desc: '2학기 국가장학금 신청 마감', url: 'https://www.kosaf.go.kr', target: 'student', field: 'saving', ageGroup: '20s', region: 'all' },
  { month: 9, day: 30, title: '재산세(주택 2기) 납부 마감', cat: 'tax', desc: '주택분 재산세 2기 납부', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 10, day: 1, title: '청년창업지원패키지 하반기 접수', cat: 'benefit', desc: '만 39세 이하 예비·초기 창업자 최대 1억 지원', url: 'https://www.k-startup.go.kr', target: 'youth', field: 'job', ageGroup: '30s', region: 'all' },
  { month: 10, day: 25, title: '부가가치세 예정신고 마감', cat: 'tax', desc: '2기 부가세 예정 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 11, day: 1, title: '주거안정 월세 대출 연중 접수', cat: 'benefit', desc: '연소득 5천만원 이하, 보증금 1억 이하 월세 대출', url: 'https://nhuf.molit.go.kr', target: 'worker', field: 'housing', ageGroup: 'all', region: 'all' },
  { month: 11, day: 15, title: '종합부동산세 고지', cat: 'tax', desc: '종부세 고지서 발송·납부 (~12/15)', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 11, day: 30, title: '건강보험 피부양자 요건 점검', cat: 'tax', desc: '연소득 2천만원 초과 시 지역가입 전환', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 12, day: 1, title: 'IRP·연금저축 납입 마감 임박', cat: 'invest', desc: '세액공제 한도(900만원) 채우기 (~12/31)', url: '', relatedSlug: 'pension-irp-tax-guide', important: true, target: 'worker', field: 'invest', ageGroup: 'all', region: 'all' },
  { month: 12, day: 15, title: '종합부동산세 납부 마감', cat: 'tax', desc: '기한 내 미납부 시 가산세', url: '', important: true, target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 12, day: 31, title: 'ISA 계좌 납입 마감', cat: 'invest', desc: '올해 비과세 한도를 채우려면 연내 납입', url: '', relatedSlug: 'isa-account-guide-2026', target: 'all', field: 'invest', ageGroup: 'all', region: 'all' },
  { month: 12, day: 31, title: '연말정산 준비 완료', cat: 'tax', desc: '기부금·의료비·교육비 영수증 챙기기', url: '', target: 'worker', field: 'tax', ageGroup: 'all', region: 'all' },
];

// 하드코딩(세금·고정 지원금 등 밸런스 base) + 청약홈 자동수집(sync-policies.js) 하이브리드
const EVENTS = [...BASE_EVENTS, ...policyEvents];

const CATS: Record<string, { name: string; color: string; icon: string }> = {
  tax: { name: '세금', color: '#ef4444', icon: '📋' },
  benefit: { name: '지원금', color: '#22c55e', icon: '💰' },
  invest: { name: '투자·절세', color: '#6c5ce7', icon: '📈' },
  housing: { name: '주거', color: '#3b82f6', icon: '🏠' },
  job: { name: '취업·창업', color: '#f59e0b', icon: '💼' },
  family: { name: '출산·육아', color: '#ec4899', icon: '👶' },
};
const TARGETS: Record<string, string> = { all: '전체', youth: '청년', worker: '직장인', self: '자영업', parent: '부모', student: '학생' };
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentDay = now.getDate();
const eventsJson = JSON.stringify(EVENTS);

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '정책 캘린더란 무엇인가요?', acceptedAnswer: { '@type': 'Answer', text: '크라마 정책 캘린더는 2026년 주요 세금 납부, 지원금 신청, 투자 절세 마감일을 한눈에 보여주는 무료 서비스입니다. 내 캘린더에 연동하면 마감일을 놓치지 않을 수 있습니다.' } },
    { '@type': 'Question', name: '캘린더를 내 휴대폰에 연동할 수 있나요?', acceptedAnswer: { '@type': 'Answer', text: '네. ICS 파일을 다운로드하면 Google Calendar, Apple Calendar, Outlook 등에 바로 연동됩니다. 필터를 적용하면 내게 맞는 일정만 선택적으로 연동할 수도 있습니다.' } },
    { '@type': 'Question', name: '어떤 일정이 포함되어 있나요?', acceptedAnswer: { '@type': 'Answer', text: '세금(연말정산, 부가세, 재산세 등), 지원금(청년도약계좌, 장려금, 월세 지원 등), 투자·절세(IRP, ISA 등), 주거, 취업·창업, 출산·육아 분야의 33건 일정이 포함되어 있습니다.' } },
  ],
};
---
<BaseLayout title="정책 캘린더 2026 — 놓치면 손해인 일정 한눈에" description="지원금 신청, 세금 납부, 투자 절세 마감일을 월별로 정리. 2026년 핵심 정책 일정을 한 곳에서." jsonLd={faqLd} footer="slim">
  <div class="pc-page">
    <!-- ━━ 히어로 ━━ -->
    <header class="pc-hero">
      <span class="pc-hero__badge">서비스</span>
      <h1 class="pc-hero__title">놓치면 손해인 일정,<br/><em>한 곳에서</em> 챙기세요</h1>
      <p class="pc-hero__lead">세금 납부부터 지원금 신청까지<br/>2026년 핵심 정책 일정을 내 캘린더에 연동하세요.</p>
      <div class="pc-hero__stats">
        <div class="pc-hero__stat"><span class="pc-hero__stat-num">{EVENTS.length}</span><span class="pc-hero__stat-label">일정 수록</span></div>
        <div class="pc-hero__stat"><span class="pc-hero__stat-num">6</span><span class="pc-hero__stat-label">분야 커버</span></div>
        <div class="pc-hero__stat"><span class="pc-hero__stat-num">0원</span><span class="pc-hero__stat-label">완전 무료</span></div>
      </div>
      <button type="button" id="pc-ics-btn" class="pc-hero__ics">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        내 맞춤 캘린더 설정하기
      </button>
      <p class="pc-hero__note">Google Calendar, Apple Calendar 등에 바로 연동됩니다.</p>
    </header>

    <!-- ━━ 고정 필터 바 → 바텀시트 모달 ━━ -->
    <button type="button" class="pc-fbar" id="pc-filter-open">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
      <span class="pc-fbar__summary" id="pc-filter-summary">전체 일정 보기</span>
      <span class="pc-fbar__edit">조건<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></span>
    </button>

    <!-- ━━ 달력 + 이 달 목록 (PC: 좌우 2단, 모바일: 세로) ━━ -->
    <div class="pc-board">
    <!-- ━━ 달력 ━━ -->
    <section class="pc-cal">
      <div class="pc-cal__nav">
        <button type="button" id="pc-prev" class="pc-cal__arrow" aria-label="이전 달">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <h2 class="pc-cal__month" id="pc-month-label"></h2>
        <button type="button" id="pc-next" class="pc-cal__arrow" aria-label="다음 달">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        </button>
        <button type="button" id="pc-today-btn" class="pc-cal__today">오늘</button>
      </div>
      <div class="pc-cal__header">
        <span class="pc-cal__dow pc-cal__dow--sun">일</span><span class="pc-cal__dow">월</span><span class="pc-cal__dow">화</span><span class="pc-cal__dow">수</span><span class="pc-cal__dow">목</span><span class="pc-cal__dow">금</span><span class="pc-cal__dow pc-cal__dow--sat">토</span>
      </div>
      <div class="pc-cal__grid" id="pc-grid"></div>
      <div class="pc-pop" id="pc-pop" hidden></div>
    </section>

    <!-- ━━ 선택한 날짜 일정 (별도 섹션) ━━ -->
    <section class="pc-day" id="pc-day" hidden>
      <div class="pc-day__head">
        <h3 class="pc-day__title" id="pc-day-title"></h3>
        <button type="button" class="pc-day__close" id="pc-day-close">
          월 전체 보기
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="pc-day-list"></div>
    </section>

    <!-- ━━ 이 달 전체 일정 (별도 섹션) ━━ -->
    <section class="pc-month" id="pc-month">
      <div class="pc-month__handle" aria-hidden="true"></div>
      <div class="pc-month__head">
        <button type="button" class="pc-month__nav" id="pc-m-prev" aria-label="이전 달">‹</button>
        <h2 class="pc-section-title" id="pc-month-title">이번 달 일정</h2>
        <button type="button" class="pc-month__nav" id="pc-m-next" aria-label="다음 달">›</button>
        <button type="button" class="pc-month__close" id="pc-list-close" aria-label="목록 닫기">✕</button>
        <button type="button" class="pc-month__refilter" id="pc-list-refilter">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
          조건 재설정
        </button>
        <button type="button" id="pc-ics-filtered" class="pc-month__ics">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          이 조건으로 캘린더 연동 <span id="pc-ics-count">0</span>건
        </button>
      </div>
      <div id="pc-month-list"></div>
      <div class="pc-empty" id="pc-month-empty" hidden><p>이 달에는 조건에 맞는 일정이 없어요</p></div>
    </section>
    </div>

    <!-- 모바일: 이 달 목록 바텀시트 트리거 + 배경 -->
    <button type="button" class="pc-list-open" id="pc-list-open">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg>
      이 달 일정 <b id="pc-list-count">0</b>건 전체 보기
      <span class="pc-list-open__arr" aria-hidden="true">›</span>
    </button>
    <div class="pc-listsheet-backdrop" id="pc-listsheet-backdrop"></div>

    <!-- ━━ 필터 바텀시트 모달 ━━ -->
    <div class="pc-sheet" id="pc-sheet" hidden>
      <div class="pc-sheet__backdrop" id="pc-sheet-backdrop"></div>
      <div class="pc-sheet__panel" role="dialog" aria-modal="true" aria-label="일정 필터">
        <div class="pc-sheet__handle"></div>
        <div class="pc-sheet__head">
          <h3>내게 맞는 일정만</h3>
          <button type="button" class="pc-sheet__x" id="pc-sheet-close" aria-label="닫기">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="pc-frow">
          <span class="pc-frow__label">대상</span>
          <div class="pc-fchips" data-filter="target">
            {Object.entries(TARGETS).map(([k, v]) => (
              <button type="button" class={`pc-fchip ${k === 'all' ? 'is-on' : ''}`} data-val={k}>{v}</button>
            ))}
          </div>
        </div>
        <div class="pc-frow">
          <span class="pc-frow__label">분야</span>
          <div class="pc-fchips" data-filter="field">
            {Object.entries({ all: '전체', tax: '세금', saving: '저축·금융', housing: '주거', job: '취업', family: '육아', invest: '투자' }).map(([k, v]) => (
              <button type="button" class={`pc-fchip ${k === 'all' ? 'is-on' : ''}`} data-val={k}>{v}</button>
            ))}
          </div>
        </div>
        <button type="button" class="pc-sheet__apply" id="pc-sheet-apply">적용하기</button>
      </div>
    </div>

    <!-- ━━ 크로스 서비스 ━━ -->
    <p class="svc-next-label">이제 뭘 할까요? <span>내 돈, 더 챙기러 가기</span></p>
    <div class="pc-cross">
      <a href="/benefits/" class="pc-cross__card">
        <span class="svc-ic"><DuoIcon name="benefits" /></span>
        <div><strong>내 혜택 찾기</strong><p>나에게 해당되는 지원금을 찾아보세요</p></div>
        <span class="pc-cross__arrow">→</span>
      </a>
      <a href="/checkup/" class="pc-cross__card">
        <span class="svc-ic"><DuoIcon name="checkup" /></span>
        <div><strong>재무 건강 체크업</strong><p>내 돈 관리 상태를 진단받아 보세요</p></div>
        <span class="pc-cross__arrow">→</span>
      </a>
    </div>
    <div class="pc-note"><p>※ 일정은 2026년 기준이며, 정부 발표에 따라 변경될 수 있습니다.</p></div>
  </div>

  <script is:inline define:vars={{ eventsJson }}>
    (() => {
      var ALL = JSON.parse(eventsJson);
      var catMeta = { tax:{name:'세금',color:'#ef4444',icon:'📋'}, benefit:{name:'지원금',color:'#22c55e',icon:'💰'}, invest:{name:'투자·절세',color:'#6c5ce7',icon:'📈'}, housing:{name:'주거',color:'#3b82f6',icon:'🏠'}, job:{name:'취업·창업',color:'#f59e0b',icon:'💼'}, family:{name:'출산·육아',color:'#ec4899',icon:'👶'} };
      var TARGET_LABEL = { all:'전체', youth:'청년', worker:'직장인', self:'자영업', parent:'부모', student:'학생' };
      var FIELD_LABEL = { all:'전체', tax:'세금', saving:'저축·금융', housing:'주거', job:'취업', family:'육아', invest:'투자' };
      var filters = { target: [], field: [] }; // 다중 선택 — 빈 배열 = 전체(청년+부모 동시 선택 등)
      var gridMonth = new Date().getMonth();
      var selDay = null;
      var MK = ['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
      function $(id) { return document.getElementById(id); }

      // 연동 선택 상태 — 각 일정에 안정 키(_k), deselected=제외된 키(기본 비어있음=전체 선택)
      ALL.forEach(function (e, i) { e._k = e.id || ('ev' + i); });
      var deselected = {};
      function selectedEvents() { return filtered().filter(function (e) { return !deselected[e._k]; }); }
      function updateIcsCount() { var el = $('pc-ics-count'); if (el) el.textContent = selectedEvents().length; }

      function filtered() {
        return ALL.filter(function (e) {
          // 다중 선택: 선택 없으면 전체. 'all' 대상/분야 일정은 항상 노출. 선택된 것 중 하나라도 맞으면 통과(OR)
          if (filters.target.length && e.target !== 'all' && filters.target.indexOf(e.target) === -1) return false;
          if (filters.field.length && e.field !== 'all' && filters.field.indexOf(e.field) === -1) return false;
          return true;
        });
      }

      // 공통 일정 카드 렌더 (날짜별 섹션 · 이 달 목록 공용)
      function evCard(e) {
        var c = catMeta[e.cat] || catMeta.tax;
        var now = new Date();
        var dd = Math.ceil((new Date(2026, e.month - 1, e.day) - now) / 86400000);
        var ddHtml = dd === 0 ? '<span class="pc-ev__dday is-soon">D-Day</span>'
          : (dd > 0 && dd <= 30) ? '<span class="pc-ev__dday is-soon">D-' + dd + '</span>'
          : dd > 0 ? '<span class="pc-ev__dday">D-' + dd + '</span>' : '';
        var _ex = deselected[e._k] ? ' is-excluded' : '';
        return '<div class="pc-ev' + (e.important ? ' is-imp' : '') + _ex + '" data-day="' + e.day + '" data-key="' + e._k + '">' +
          '<label class="pc-ev__check" title="캘린더 연동에 포함"><input type="checkbox"' + (deselected[e._k] ? '' : ' checked') + ' aria-label="연동 포함"></label>' +
          '<div class="pc-ev__main">' +
          '<div class="pc-ev__head"><span class="pc-ev__date">' + e.month + '/' + e.day + '</span>' +
          '<span class="pc-ev__cat" style="color:' + c.color + '">' + c.icon + ' ' + c.name + '</span>' + ddHtml + '</div>' +
          '<h3 class="pc-ev__title">' + e.title + '</h3>' +
          '<p class="pc-ev__desc">' + e.desc + '</p>' +
          '<div class="pc-ev__actions">' +
          (e.url ? '<a href="' + e.url + '" target="_blank" rel="noopener" class="pc-ev__btn">신청/확인 →</a>' : '') +
          (e.relatedSlug ? '<a href="/blog/' + e.relatedSlug + '/" class="pc-ev__btn pc-ev__btn--ghost">가이드 읽기</a>' : '') +
          '</div></div></div>';
      }

      // ── 달력 그리드 ──
      function renderGrid() {
        $('pc-month-label').textContent = '2026년 ' + MK[gridMonth];
        var grid = $('pc-grid');
        var startDay = new Date(2026, gridMonth, 1).getDay();
        var days = new Date(2026, gridMonth + 1, 0).getDate();
        var today = new Date();
        var todayD = (today.getFullYear() === 2026 && today.getMonth() === gridMonth) ? today.getDate() : -1;
        var evts = filtered().filter(function (e) { return e.month === gridMonth + 1; });
        var byDay = {};
        evts.forEach(function (e) { if (!byDay[e.day]) byDay[e.day] = []; byDay[e.day].push(e); });

        var h = '';
        for (var i = 0; i < startDay; i++) h += '<div class="pc-cell pc-cell--empty"></div>';
        for (var d = 1; d <= days; d++) {
          var has = byDay[d];
          h += '<div class="pc-cell' + (d === todayD ? ' is-today' : '') + (d === selDay ? ' is-sel' : '') + (has ? ' has-ev' : '') + '" data-d="' + d + '" role="button" tabindex="0">';
          h += '<span class="pc-cell__num">' + d + '</span>';
          if (has) {
            // 모바일: 색 점
            var dots = {};
            has.forEach(function (e) { dots[(catMeta[e.cat] || {}).color || '#888'] = true; });
            h += '<span class="pc-cell__dots">';
            Object.keys(dots).slice(0, 3).forEach(function (c) { h += '<span style="background:' + c + '"></span>'; });
            h += '</span>';
            // 데스크톱: 일정 제목 칩(최대 3 + 더보기)
            h += '<span class="pc-cell__evs">';
            has.slice(0, 3).forEach(function (e) {
              var c = (catMeta[e.cat] || {}).color || '#888';
              h += '<span class="pc-chip" data-key="' + e._k + '" style="--c:' + c + '">' + e.title + '</span>';
            });
            if (has.length > 3) h += '<span class="pc-chip pc-chip--more" data-more="' + d + '">+' + (has.length - 3) + '개 더보기</span>';
            h += '</span>';
          }
          h += '</div>';
        }
        grid.innerHTML = h;
        grid.querySelectorAll('.pc-cell[data-d]').forEach(function (btn) {
          btn.addEventListener('click', function (ev) {
            if (ev.target.closest('.pc-chip')) return; // 칩은 팝오버가 처리
            selectDay(parseInt(btn.dataset.d));
          });
        });
        bindChips();
        requestAnimationFrame(matchBoardHeight);
      }

      function isDesktop() { return window.matchMedia('(min-width: 769px)').matches; }

      // ── 일정 칩 팝오버: hover 미리보기 · 클릭 고정 · 상세 이동 ──
      var popHideTimer = null, popPinned = false, popKey = null;
      function evByKey(k) { for (var i = 0; i < ALL.length; i++) if (ALL[i]._k === k) return ALL[i]; return null; }
      function popHtml(e) {
        var c = catMeta[e.cat] || catMeta.tax;
        var dd = Math.ceil((new Date(2026, e.month - 1, e.day) - new Date()) / 86400000);
        var ddTxt = dd === 0 ? 'D-Day' : dd > 0 ? 'D-' + dd : '지남';
        return '<div class="pc-pop__bar" style="background:' + c.color + '"></div>' +
          '<div class="pc-pop__body">' +
          '<div class="pc-pop__meta"><b style="color:' + c.color + '">' + c.icon + ' ' + c.name + '</b>' +
          '<span>' + e.month + '/' + e.day + ' · ' + ddTxt + '</span></div>' +
          '<h4>' + e.title + '</h4><p>' + e.desc + '</p>' +
          '<div class="pc-pop__acts">' +
          (e.url ? '<a href="' + e.url + '" target="_blank" rel="noopener">신청·상세 보기 →</a>' : '') +
          (e.relatedSlug ? '<a href="/blog/' + e.relatedSlug + '/" class="is-ghost">가이드 읽기</a>' : '') +
          '<button type="button" data-popday="' + e.day + '">이 날 전체</button>' +
          '</div></div>';
      }
      function showPop(chip, key, pin) {
        var e = evByKey(key); if (!e) return;
        clearTimeout(popHideTimer);
        var pop = $('pc-pop');
        if (popKey !== key) { pop.innerHTML = popHtml(e); popKey = key; }
        popPinned = popPinned || !!pin;
        var cal = document.querySelector('.pc-cal');
        var cr = cal.getBoundingClientRect(), br = chip.getBoundingClientRect();
        pop.hidden = false;
        var W = pop.offsetWidth || 280, H = pop.offsetHeight || 160;
        var left = br.left - cr.left;
        if (left + W > cal.clientWidth - 8) left = cal.clientWidth - W - 8;
        var top = br.bottom - cr.top + 6;
        if (br.bottom + H + 20 > window.innerHeight && br.top - H - 6 > cr.top) top = br.top - cr.top - H - 6;
        pop.style.left = Math.max(4, left) + 'px';
        pop.style.top = top + 'px';
        pop.classList.toggle('is-pinned', popPinned);
        var db = pop.querySelector('[data-popday]');
        if (db && !db._bound) { db._bound = 1; db.addEventListener('click', function () { hidePop(true); selectDay(parseInt(db.dataset.popday)); }); }
      }
      function hidePop(force) {
        if (popPinned && !force) return;
        popPinned = false; popKey = null;
        var pop = $('pc-pop'); pop.hidden = true; pop.classList.remove('is-pinned');
      }
      function scheduleHide() { if (popPinned) return; clearTimeout(popHideTimer); popHideTimer = setTimeout(function () { hidePop(); }, 180); }
      function bindChips() {
        document.querySelectorAll('.pc-chip[data-key]').forEach(function (chip) {
          chip.addEventListener('mouseenter', function () { if (isDesktop() && !popPinned) showPop(chip, chip.dataset.key); });
          chip.addEventListener('mouseleave', scheduleHide);
          chip.addEventListener('click', function (ev) {
            ev.stopPropagation();
            if (popPinned && popKey === chip.dataset.key) { hidePop(true); return; }
            popPinned = false; showPop(chip, chip.dataset.key, true);
          });
        });
        document.querySelectorAll('.pc-chip--more').forEach(function (chip) {
          chip.addEventListener('click', function (ev) { ev.stopPropagation(); hidePop(true); selectDay(parseInt(chip.dataset.more)); });
        });
      }
      (function initPop() {
        var pop = $('pc-pop');
        pop.addEventListener('mouseenter', function () { clearTimeout(popHideTimer); });
        pop.addEventListener('mouseleave', scheduleHide);
        document.addEventListener('click', function (ev) {
          if (popPinned && !ev.target.closest('.pc-pop') && !ev.target.closest('.pc-chip')) hidePop(true);
        });
        document.addEventListener('keydown', function (ev) { if (ev.key === 'Escape') hidePop(true); });
      })();

      // PC: 목록 컬럼 높이를 달력에 맞추고 내부 스크롤(앱형 2-pane)
      function matchBoardHeight() {
        var month = $('pc-month'), cal = document.querySelector('.pc-cal');
        if (!month || !cal) return;
        month.style.height = isDesktop() ? cal.offsetHeight + 'px' : '';
      }

      // 데스크톱: 달력 옆 '이 달 목록'에서 같은 날짜 카드에 SELECTED 표시 + 스크롤(별도 섹션 없이)
      function highlightMonthDay(d) {
        var target = null;
        $('pc-month-list').querySelectorAll('.pc-ev').forEach(function (el) {
          var on = parseInt(el.dataset.day, 10) === d;
          el.classList.toggle('is-daysel', on);
          if (on && !target) target = el;
        });
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      // ── 선택한 날짜 ──
      function selectDay(d) {
        selDay = d;
        document.querySelectorAll('.pc-cell').forEach(function (b) { b.classList.toggle('is-sel', parseInt(b.dataset.d) === d); });
        $('pc-day').hidden = true;
        // 데스크톱: 옆 인라인 목록 하이라이트 / 모바일: 목록 바텀시트 열고 그 날 하이라이트
        if (isDesktop()) {
          highlightMonthDay(d);
        } else {
          openListSheet();
          setTimeout(function () { highlightMonthDay(d); }, 90);
        }
      }
      function closeDay() {
        selDay = null;
        document.querySelectorAll('.pc-cell').forEach(function (b) { b.classList.remove('is-sel'); });
        $('pc-day').hidden = true;
        $('pc-month-list').querySelectorAll('.pc-ev.is-daysel').forEach(function (el) { el.classList.remove('is-daysel'); });
      }

      // ── 이 달 전체 일정 ──
      function renderMonthList() {
        var m = gridMonth + 1;
        var evts = filtered().filter(function (e) { return e.month === m; }).sort(function (a, b) { return a.day - b.day; });
        $('pc-month-title').textContent = MK[gridMonth] + ' 전체 일정' + (evts.length ? ' (' + evts.length + '건)' : '');
        var lc = $('pc-list-count'); if (lc) lc.textContent = evts.length;
        $('pc-month-list').innerHTML = evts.map(evCard).join('');
        $('pc-month-empty').hidden = evts.length > 0;
        // 목록 카드 클릭 → 달력에서 그 날짜 선택(데스크톱 인라인 / 모바일 시트 유지)
        $('pc-month-list').querySelectorAll('.pc-ev').forEach(function (el) {
          el.addEventListener('click', function (ev) {
            if (ev.target.closest('a')) return; // 신청/확인·가이드 링크는 그대로
            // 카드 전영역 클릭 → 연동 포함/제외 토글 (체크박스/라벨은 네이티브 토글)
            var cb = el.querySelector('.pc-ev__check input');
            if (cb && !ev.target.closest('.pc-ev__check')) { cb.checked = !cb.checked; cb.dispatchEvent(new Event('change', { bubbles: true })); }
            // 해당 날짜 포커싱(달력·목록 하이라이트)은 유지
            var day = parseInt(el.dataset.day, 10);
            selDay = day;
            document.querySelectorAll('.pc-cell').forEach(function (b) { b.classList.toggle('is-sel', parseInt(b.dataset.d) === day); });
            highlightMonthDay(day);
          });
        });
        // 필터/월 변경으로 목록을 다시 그렸을 때 선택 상태 유지
        if (selDay != null) highlightMonthDay(selDay);
        updateIcsCount();
      }

      function refresh() { renderGrid(); renderMonthList(); }

      // ── 필터 바텀시트 ──
      function openSheet() { $('pc-sheet').hidden = false; document.body.style.overflow = 'hidden'; }
      function closeSheet() { $('pc-sheet').hidden = true; document.body.style.overflow = ''; }
      $('pc-filter-open').addEventListener('click', openSheet);
      $('pc-sheet-close').addEventListener('click', closeSheet);
      $('pc-sheet-backdrop').addEventListener('click', closeSheet);
      $('pc-sheet-apply').addEventListener('click', function () { closeSheet(); if (!isDesktop()) openListSheet(); });

      function updateFilterUI() {
        var labels = filters.target.map(function (k) { return TARGET_LABEL[k]; })
          .concat(filters.field.map(function (k) { return FIELD_LABEL[k]; }));
        $('pc-filter-summary').textContent = labels.length === 0 ? '전체 일정 보기' : labels.join(' · ') + ' 일정';
        $('pc-filter-open').classList.toggle('is-active', labels.length > 0);
        // 연동 버튼은 항상 노출(조건 없으면 전체 연동) — 플로우의 END 액션
      }

      // 각 그룹의 칩 is-on 상태를 filters 배열에 맞춰 갱신('전체'는 아무것도 안 골랐을 때만 켜짐)
      function syncChips(group) {
        var key = group.dataset.filter, arr = filters[key];
        group.querySelectorAll('.pc-fchip').forEach(function (c) {
          c.classList.toggle('is-on', c.dataset.val === 'all' ? arr.length === 0 : arr.indexOf(c.dataset.val) >= 0);
        });
      }
      document.querySelectorAll('.pc-fchips').forEach(function (group) {
        group.addEventListener('click', function (ev) {
          var btn = ev.target.closest('.pc-fchip'); if (!btn) return;
          var key = group.dataset.filter, val = btn.dataset.val, arr = filters[key];
          if (val === 'all') { filters[key] = []; } // '전체' = 조건 해제
          else { var i = arr.indexOf(val); if (i >= 0) arr.splice(i, 1); else arr.push(val); } // 토글(다중 선택)
          syncChips(group);
          updateFilterUI();
          refresh();
        });
      });

      // ── 네비게이션 ──
      $('pc-prev').addEventListener('click', function () { gridMonth = Math.max(0, gridMonth - 1); closeDay(); renderGrid(); renderMonthList(); });
      $('pc-next').addEventListener('click', function () { gridMonth = Math.min(11, gridMonth + 1); closeDay(); renderGrid(); renderMonthList(); });
      $('pc-today-btn').addEventListener('click', function () { gridMonth = new Date().getMonth(); closeDay(); renderGrid(); renderMonthList(); });
      $('pc-day-close').addEventListener('click', closeDay);

      // ── .ics 다운로드 (필터 반영) ──
      function downloadICS(events) {
        function pad(n) { return String(n).padStart(2, '0'); }
        function icsDate(m, d) { return '2026' + pad(m) + pad(d); }
        var lines = ['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Crama//Policy Calendar//KO','CALSCALE:GREGORIAN','METHOD:PUBLISH','X-WR-CALNAME:크라마 정책 캘린더 2026','X-WR-TIMEZONE:Asia/Seoul'];
        var stamp = new Date().toISOString().replace(/[-:]/g,'').replace(/\.\d+/,'');
        events.forEach(function (ev, i) {
          var dtStart = icsDate(ev.month, ev.day);
          var next = new Date(2026, ev.month - 1, ev.day + 1);
          var dtEnd = '2026' + pad(next.getMonth() + 1) + pad(next.getDate());
          lines.push('BEGIN:VEVENT','UID:crama-pc-' + ev.month + '-' + ev.day + '-' + i + '@crama.app','DTSTAMP:' + stamp,'DTSTART;VALUE=DATE:' + dtStart,'DTEND;VALUE=DATE:' + dtEnd,'SUMMARY:' + ev.title,'DESCRIPTION:' + ev.desc + '\\n\\nhttps://crama.app/policy-calendar/','URL:https://crama.app/policy-calendar/','BEGIN:VALARM','TRIGGER:-P1D','ACTION:DISPLAY','DESCRIPTION:내일: ' + ev.title,'END:VALARM','END:VEVENT');
        });
        lines.push('END:VCALENDAR');
        var blob = new Blob([lines.join('\r\n')], { type: 'text/calendar;charset=utf-8' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'crama-policy-2026.ics';
        a.click();
        URL.revokeObjectURL(a.href);
      }

      document.getElementById('pc-ics-btn').addEventListener('click', function () {
        var fbar = document.querySelector('.pc-fbar');
        if (fbar) fbar.scrollIntoView({ behavior: 'smooth', block: 'start' }); // 조건바를 헤더 밑 상단으로
        openSheet();
      });
      document.getElementById('pc-ics-filtered').addEventListener('click', function () { downloadICS(selectedEvents()); });

      renderGrid();
      renderMonthList();
      updateFilterUI();

      // ── 모바일: 이 달 목록 바텀시트(좌우 월 이동) ──
      function openListSheet() {
        if (isDesktop()) return;
        $('pc-month').classList.add('is-open');
        $('pc-listsheet-backdrop').classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }
      function closeListSheet() {
        $('pc-month').classList.remove('is-open');
        $('pc-listsheet-backdrop').classList.remove('is-open');
        document.body.style.overflow = '';
      }
      function sheetMonth(delta) {
        gridMonth = Math.min(11, Math.max(0, gridMonth + delta));
        selDay = null;
        document.querySelectorAll('.pc-cell').forEach(function (b) { b.classList.remove('is-sel'); });
        $('pc-day').hidden = true;
        renderGrid(); renderMonthList();
        var l = $('pc-month-list'); if (l) l.scrollTop = 0;
      }
      $('pc-list-open').addEventListener('click', function () { openListSheet(); });
      $('pc-list-close').addEventListener('click', closeListSheet);
      $('pc-list-refilter').addEventListener('click', function () { closeListSheet(); openSheet(); });
      $('pc-listsheet-backdrop').addEventListener('click', closeListSheet);
      $('pc-m-prev').addEventListener('click', function () { sheetMonth(-1); });
      $('pc-m-next').addEventListener('click', function () { sheetMonth(1); });
      // 시트 좌우 스와이프로 월 이동
      (function () {
        var sheet = $('pc-month'); if (!sheet) return;
        var x0 = null, y0 = null;
