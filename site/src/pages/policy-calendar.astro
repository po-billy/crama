---
import BaseLayout from '../layouts/BaseLayout.astro';

const EVENTS = [
  { month: 1, day: 15, title: '연말정산 간소화 서비스 오픈', cat: 'tax', desc: '홈택스에서 소득·세액공제 자료 확인', url: 'https://www.hometax.go.kr', target: 'worker', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 1, day: 25, title: '부가가치세 확정신고 마감', cat: 'tax', desc: '전년 2기분 부가세 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 2, day: 3, title: '청년 전세자금 대출 상반기 접수', cat: 'benefit', desc: '만 19~34세 무주택자, 보증금 3억 이하 전세 대출', url: 'https://nhuf.molit.go.kr', target: 'youth', field: 'housing', ageGroup: '20s', region: 'all' },
  { month: 2, day: 28, title: '연말정산 환급 시작', cat: 'tax', desc: '근로소득 연말정산 환급금 지급 시작', url: '', target: 'worker', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 3, day: 2, title: '근로·자녀장려금 반기 신청', cat: 'benefit', desc: '상반기분 장려금 신청 (~3/15)', url: 'https://www.hometax.go.kr', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 3, day: 3, title: '국민취업지원제도 상반기 신청', cat: 'benefit', desc: '구직촉진수당 월 50만원 + 취업지원 서비스', url: 'https://www.kua.go.kr', target: 'youth', field: 'job', ageGroup: '20s', region: 'all' },
  { month: 3, day: 31, title: '건강보험료 정산', cat: 'tax', desc: '전년도 소득 기준 건보료 정산·추가 납부', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 4, day: 1, title: '신혼부부 특별공급 상반기 접수', cat: 'benefit', desc: '혼인 7년 이내 무주택 세대 대상 특별공급', url: 'https://www.applyhome.co.kr', target: 'parent', field: 'housing', ageGroup: '30s', region: 'all' },
  { month: 4, day: 25, title: '부가가치세 예정신고 마감', cat: 'tax', desc: '1기 부가세 예정 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 5, day: 1, title: '종합소득세 신고 시작', cat: 'tax', desc: '프리랜서·N잡러 종소세 신고 (~5/31)', url: 'https://www.hometax.go.kr', relatedSlug: 'side-hustle-tax-guide', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 5, day: 1, title: '근로·자녀장려금 정기 신청', cat: 'benefit', desc: '전년 귀속 장려금 신청 (~5/31)', url: 'https://www.hometax.go.kr', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 5, day: 31, title: '종합소득세 신고 마감', cat: 'tax', desc: '기한 내 미신고 시 가산세 부과', url: 'https://www.hometax.go.kr', important: true, target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 6, day: 1, title: '재산세(건축물) 납부', cat: 'tax', desc: '건축물분 재산세 납부 (~6/30)', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 6, day: 16, title: '청년도약계좌 신규 신청', cat: 'benefit', desc: '출생연도 5부제 (~7/3)', url: 'https://www.kinfa.or.kr', relatedSlug: 'youth-leap-vs-future-savings', important: true, target: 'youth', field: 'saving', ageGroup: '20s', region: 'all' },
  { month: 7, day: 1, title: '부모급여 하반기 지급 시작', cat: 'benefit', desc: '만 0세 월 100만원, 만 1세 월 50만원 지급', url: 'https://www.bokjiro.go.kr', target: 'parent', field: 'family', ageGroup: '30s', region: 'all' },
  { month: 7, day: 3, title: '청년도약계좌 신청 마감', cat: 'benefit', desc: '하반기 신규 가입 마감', url: 'https://www.kinfa.or.kr', important: true, target: 'youth', field: 'saving', ageGroup: '20s', region: 'all' },
  { month: 7, day: 25, title: '부가가치세 확정신고 마감', cat: 'tax', desc: '1기분 부가세 확정 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 7, day: 31, title: '재산세(주택 1기) 납부 마감', cat: 'tax', desc: '주택분 재산세 1기 납부', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 8, day: 1, title: '청년 월세 지원 하반기 접수', cat: 'benefit', desc: '만 19~34세, 월세 20만원(최대 12개월) 지원', url: 'https://www.myhome.go.kr', important: true, target: 'youth', field: 'housing', ageGroup: '20s', region: 'all' },
  { month: 8, day: 31, title: '주민세 납부 마감', cat: 'tax', desc: '개인분 주민세 납부 (~8/31)', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 9, day: 1, title: '근로·자녀장려금 지급', cat: 'benefit', desc: '5월 신청분 장려금 지급 시작', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 9, day: 1, title: '국민내일배움카드 하반기 신청', cat: 'benefit', desc: '직업훈련비 최대 500만원 지원', url: 'https://www.hrd.go.kr', target: 'all', field: 'job', ageGroup: 'all', region: 'all' },
  { month: 9, day: 15, title: '국가장학금 2학기 신청', cat: 'benefit', desc: '2학기 국가장학금 신청 마감', url: 'https://www.kosaf.go.kr', target: 'student', field: 'saving', ageGroup: '20s', region: 'all' },
  { month: 9, day: 30, title: '재산세(주택 2기) 납부 마감', cat: 'tax', desc: '주택분 재산세 2기 납부', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 10, day: 1, title: '청년창업지원패키지 하반기 접수', cat: 'benefit', desc: '만 39세 이하 예비·초기 창업자 최대 1억 지원', url: 'https://www.k-startup.go.kr', target: 'youth', field: 'job', ageGroup: '30s', region: 'all' },
  { month: 10, day: 25, title: '부가가치세 예정신고 마감', cat: 'tax', desc: '2기 부가세 예정 신고·납부', url: 'https://www.hometax.go.kr', target: 'self', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 11, day: 1, title: '주거안정 월세 대출 연중 접수', cat: 'benefit', desc: '연소득 5천만원 이하, 보증금 1억 이하 월세 대출', url: 'https://nhuf.molit.go.kr', target: 'worker', field: 'housing', ageGroup: 'all', region: 'all' },
  { month: 11, day: 15, title: '종합부동산세 고지', cat: 'tax', desc: '종부세 고지서 발송·납부 (~12/15)', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 11, day: 30, title: '건강보험 피부양자 요건 점검', cat: 'tax', desc: '연소득 2천만원 초과 시 지역가입 전환', url: '', target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 12, day: 1, title: 'IRP·연금저축 납입 마감 임박', cat: 'invest', desc: '세액공제 한도(900만원) 채우기 (~12/31)', url: '', relatedSlug: 'pension-irp-tax-guide', important: true, target: 'worker', field: 'invest', ageGroup: 'all', region: 'all' },
  { month: 12, day: 15, title: '종합부동산세 납부 마감', cat: 'tax', desc: '기한 내 미납부 시 가산세', url: '', important: true, target: 'all', field: 'tax', ageGroup: 'all', region: 'all' },
  { month: 12, day: 31, title: 'ISA 계좌 납입 마감', cat: 'invest', desc: '올해 비과세 한도를 채우려면 연내 납입', url: '', relatedSlug: 'isa-account-guide-2026', target: 'all', field: 'invest', ageGroup: 'all', region: 'all' },
  { month: 12, day: 31, title: '연말정산 준비 완료', cat: 'tax', desc: '기부금·의료비·교육비 영수증 챙기기', url: '', target: 'worker', field: 'tax', ageGroup: 'all', region: 'all' },
];

const CATS: Record<string, { name: string; color: string; icon: string }> = {
  tax: { name: '세금', color: '#ef4444', icon: '📋' },
  benefit: { name: '지원금', color: '#22c55e', icon: '💰' },
  invest: { name: '투자·절세', color: '#6c5ce7', icon: '📈' },
  housing: { name: '주거', color: '#3b82f6', icon: '🏠' },
  job: { name: '취업·창업', color: '#f59e0b', icon: '💼' },
  family: { name: '출산·육아', color: '#ec4899', icon: '👶' },
};
const TARGETS: Record<string, string> = { all: '전체', youth: '청년', worker: '직장인', self: '자영업', parent: '부모', student: '학생' };
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentDay = now.getDate();
const eventsJson = JSON.stringify(EVENTS);

// 다가오는 일정 (30일 이내)
const upcoming = EVENTS
  .map(ev => ({ ...ev, date: new Date(2026, ev.month - 1, ev.day), dday: Math.ceil((new Date(2026, ev.month - 1, ev.day).getTime() - now.getTime()) / 86400000) }))
  .filter(ev => ev.dday >= 0 && ev.dday <= 30)
  .sort((a, b) => a.dday - b.dday)
  .slice(0, 4);
---
<BaseLayout title="정책 캘린더 2026 — 놓치면 손해인 일정 한눈에" description="지원금 신청, 세금 납부, 투자 절세 마감일을 월별로 정리. 2026년 핵심 정책 일정을 한 곳에서.">
  <div class="pc-page">
    <!-- ━━ 히어로 ━━ -->
    <header class="pc-hero">
      <span class="pc-hero__badge">서비스</span>
      <h1 class="pc-hero__title">놓치면 손해인 일정,<br/><em>한 곳에서</em> 챙기세요</h1>
      <p class="pc-hero__lead">세금 납부부터 지원금 신청까지<br/>2026년 핵심 정책 일정을 내 캘린더에 연동하세요.</p>
      <div class="pc-hero__stats">
        <div class="pc-hero__stat"><span class="pc-hero__stat-num">{EVENTS.length}</span><span class="pc-hero__stat-label">일정 수록</span></div>
        <div class="pc-hero__stat"><span class="pc-hero__stat-num">6</span><span class="pc-hero__stat-label">분야 커버</span></div>
        <div class="pc-hero__stat"><span class="pc-hero__stat-num">0원</span><span class="pc-hero__stat-label">완전 무료</span></div>
      </div>
      <button type="button" id="pc-ics-btn" class="pc-hero__ics">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        내 캘린더에 연동하기
      </button>
      <p class="pc-hero__note">Google Calendar, Apple Calendar 등에 바로 연동됩니다.</p>
    </header>

    <!-- ━━ 다가오는 일정 카드 ━━ -->
    {upcoming.length > 0 && (
      <section class="pc-upcoming">
        <h2 class="pc-section-title">다가오는 일정</h2>
        <div class="pc-upcoming__grid">
          {upcoming.map(ev => {
            const cat = CATS[ev.cat];
            return (
              <div class={`pc-ucard ${ev.dday <= 7 ? 'is-urgent' : ''}`}>
                <div class="pc-ucard__dday">{ev.dday === 0 ? 'D-Day' : `D-${ev.dday}`}</div>
                <div class="pc-ucard__body">
                  <span class="pc-ucard__cat" style={`color:${cat.color}`}>{cat.icon} {cat.name}</span>
                  <h3>{ev.title}</h3>
                  <p>{ev.month}/{ev.day} · {ev.desc}</p>
                </div>
                {ev.url && <a href={ev.url} target="_blank" rel="noopener" class="pc-ucard__link">확인 →</a>}
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- ━━ 캘린더 + 일정 목록 (2단 레이아웃) ━━ -->
    <div class="pc-main">
      <!-- 좌: 캘린더 그리드 -->
      <section class="pc-cal">
        <div class="pc-cal__nav">
          <button type="button" id="pc-prev" class="pc-cal__arrow" aria-label="이전 달">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <h2 class="pc-cal__month" id="pc-month-label"></h2>
          <button type="button" id="pc-next" class="pc-cal__arrow" aria-label="다음 달">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
          <button type="button" id="pc-today-btn" class="pc-cal__today">오늘</button>
        </div>
        <div class="pc-cal__header">
          <span class="pc-cal__dow pc-cal__dow--sun">일</span><span class="pc-cal__dow">월</span><span class="pc-cal__dow">화</span><span class="pc-cal__dow">수</span><span class="pc-cal__dow">목</span><span class="pc-cal__dow">금</span><span class="pc-cal__dow pc-cal__dow--sat">토</span>
        </div>
        <div class="pc-cal__grid" id="pc-grid"></div>
      </section>

      <!-- 우: 선택된 날짜의 일정 목록 -->
      <section class="pc-detail" id="pc-detail">
        <div class="pc-detail__empty" id="pc-detail-empty">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.2" opacity=".4"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          <p>날짜를 선택하면<br/>해당 일정이 여기에 표시됩니다</p>
        </div>
        <div id="pc-detail-content"></div>
      </section>
    </div>

    <!-- ━━ 필터 (접이식) ━━ -->
    <details class="pc-filter-wrap">
      <summary class="pc-filter-toggle">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
        필터로 내게 맞는 일정만 보기
        <span class="pc-filter-count" id="pc-filter-count"></span>
      </summary>
      <div class="pc-filters" id="pc-filters">
        <div class="pc-frow">
          <span class="pc-frow__label">대상</span>
          <div class="pc-fchips" data-filter="target">
            {Object.entries(TARGETS).map(([k, v]) => (
              <button type="button" class={`pc-fchip ${k === 'all' ? 'is-on' : ''}`} data-val={k}>{v}</button>
            ))}
          </div>
        </div>
        <div class="pc-frow">
          <span class="pc-frow__label">분야</span>
          <div class="pc-fchips" data-filter="field">
            {Object.entries({ all: '전체', tax: '세금', saving: '저축·금융', housing: '주거', job: '취업', family: '육아', invest: '투자' }).map(([k, v]) => (
              <button type="button" class={`pc-fchip ${k === 'all' ? 'is-on' : ''}`} data-val={k}>{v}</button>
            ))}
          </div>
        </div>
      </div>
    </details>

    <!-- 필터 적용 시 캘린더 연동 CTA -->
    <div class="pc-ics-filter" id="pc-ics-filter" hidden>
      <button type="button" id="pc-ics-filtered" class="pc-ics-filter__btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        이 조건의 일정만 내 캘린더에 연동
      </button>
    </div>

    <!-- ━━ 월별 타임라인 (전체 보기) ━━ -->
    <section class="pc-timeline" id="pc-timeline">
      <h2 class="pc-section-title">전체 일정</h2>
      <div id="pc-timeline-list"></div>
      <div class="pc-empty" id="pc-empty" hidden>
        <p>선택한 조건에 맞는 일정이 없어요</p>
      </div>
    </section>

    <!-- ━━ 크로스 서비스 ━━ -->
    <div class="pc-cross">
      <a href="/benefits/" class="pc-cross__card">
        <span class="pc-cross__icon">💰</span>
        <div><strong>내 혜택 찾기</strong><p>나에게 해당되는 지원금을 찾아보세요</p></div>
        <span class="pc-cross__arrow">→</span>
      </a>
      <a href="/checkup/" class="pc-cross__card">
        <span class="pc-cross__icon">🩺</span>
        <div><strong>재무 건강 체크업</strong><p>내 돈 관리 상태를 진단받아 보세요</p></div>
        <span class="pc-cross__arrow">→</span>
      </a>
    </div>
    <div class="pc-note"><p>※ 일정은 2026년 기준이며, 정부 발표에 따라 변경될 수 있습니다.</p></div>
  </div>

  <script is:inline define:vars={{ eventsJson }}>
    (() => {
      var ALL = JSON.parse(eventsJson);
      var catMeta = { tax:{name:'세금',color:'#ef4444',icon:'📋'}, benefit:{name:'지원금',color:'#22c55e',icon:'💰'}, invest:{name:'투자·절세',color:'#6c5ce7',icon:'📈'}, housing:{name:'주거',color:'#3b82f6',icon:'🏠'}, job:{name:'취업·창업',color:'#f59e0b',icon:'💼'}, family:{name:'출산·육아',color:'#ec4899',icon:'👶'} };
      var filters = { target: 'all', field: 'all' };
      var gridMonth = new Date().getMonth();
      var selDay = null;
      var MK = ['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];

      function filtered() {
        return ALL.filter(function (e) {
          if (filters.target !== 'all' && e.target !== filters.target && e.target !== 'all') return false;
          if (filters.field !== 'all' && e.field !== filters.field && e.field !== 'all') return false;
          return true;
        });
      }

      // ── 캘린더 그리드 ──
      function renderGrid() {
        var label = document.getElementById('pc-month-label');
        label.textContent = '2026년 ' + MK[gridMonth];
        var grid = document.getElementById('pc-grid');
        var first = new Date(2026, gridMonth, 1);
        var startDay = first.getDay();
        var days = new Date(2026, gridMonth + 1, 0).getDate();
        var today = new Date();
        var todayD = (today.getFullYear() === 2026 && today.getMonth() === gridMonth) ? today.getDate() : -1;

        var evts = filtered().filter(function (e) { return e.month === gridMonth + 1; });
        var byDay = {};
        evts.forEach(function (e) { if (!byDay[e.day]) byDay[e.day] = []; byDay[e.day].push(e); });

        var h = '';
        for (var i = 0; i < startDay; i++) h += '<div class="pc-day pc-day--empty"></div>';
        for (var d = 1; d <= days; d++) {
          var isT = d === todayD;
          var isS = d === selDay;
          var has = byDay[d];
          h += '<button type="button" class="pc-day' + (isT ? ' is-today' : '') + (isS ? ' is-sel' : '') + (has ? ' has-ev' : '') + '" data-d="' + d + '">';
          h += '<span class="pc-day__num">' + d + '</span>';
          if (has) {
            var dots = {};
            has.forEach(function (e) { dots[catMeta[e.cat]?.color || '#888'] = true; });
            h += '<span class="pc-day__dots">';
            Object.keys(dots).forEach(function (c) { h += '<span style="background:' + c + '"></span>'; });
            h += '</span>';
          }
          h += '</button>';
        }
        grid.innerHTML = h;

        // 날짜 클릭
        grid.querySelectorAll('.pc-day[data-d]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            selDay = parseInt(btn.dataset.d);
            grid.querySelectorAll('.pc-day').forEach(function (b) { b.classList.remove('is-sel'); });
            btn.classList.add('is-sel');
            showDetail(gridMonth + 1, selDay);
          });
        });

        // 이번 달이면 오늘 자동 선택
        if (todayD > 0 && selDay === null) {
          selDay = todayD;
          var todayBtn = grid.querySelector('[data-d="' + todayD + '"]');
          if (todayBtn) { todayBtn.classList.add('is-sel'); showDetail(gridMonth + 1, todayD); }
        }
      }

      function showDetail(m, d) {
        var evts = filtered().filter(function (e) { return e.month === m && e.day === d; });
        var empty = document.getElementById('pc-detail-empty');
        var content = document.getElementById('pc-detail-content');
        if (evts.length === 0) {
          empty.hidden = false;
          content.innerHTML = '<p class="pc-detail__no">' + m + '/' + d + ' — 이 날에는 일정이 없어요</p>';
          return;
        }
        empty.hidden = true;
        var now = new Date();
        content.innerHTML = '<p class="pc-detail__date">' + m + '월 ' + d + '일 · ' + evts.length + '건</p>' +
          evts.map(function (e) {
            var c = catMeta[e.cat] || catMeta.tax;
            var dd = Math.ceil((new Date(2026, e.month - 1, e.day) - now) / 86400000);
            var ddHtml = dd > 0 && dd <= 30 ? '<span class="pc-ev__dday is-soon">D-' + dd + '</span>' : dd > 0 ? '<span class="pc-ev__dday">D-' + dd + '</span>' : dd === 0 ? '<span class="pc-ev__dday is-soon">D-Day</span>' : '';
            return '<div class="pc-ev' + (e.important ? ' is-imp' : '') + '">' +
              '<div class="pc-ev__head"><span class="pc-ev__cat" style="color:' + c.color + '">' + c.icon + ' ' + c.name + '</span>' + ddHtml + '</div>' +
              '<h3 class="pc-ev__title">' + e.title + '</h3>' +
              '<p class="pc-ev__desc">' + e.desc + '</p>' +
              '<div class="pc-ev__actions">' +
              (e.url ? '<a href="' + e.url + '" target="_blank" rel="noopener" class="pc-ev__btn">신청/확인 →</a>' : '') +
              (e.relatedSlug ? '<a href="/blog/' + e.relatedSlug + '/" class="pc-ev__btn pc-ev__btn--ghost">가이드 읽기</a>' : '') +
              '</div></div>';
          }).join('');
      }

      // ── 타임라인 ──
      function renderTimeline() {
        var list = document.getElementById('pc-timeline-list');
        var now = new Date();
        var cm = now.getMonth() + 1;
        var evts = filtered();
        var byMonth = {};
        evts.forEach(function (e) { if (!byMonth[e.month]) byMonth[e.month] = []; byMonth[e.month].push(e); });

        var h = '';
        for (var m = 1; m <= 12; m++) {
          if (!byMonth[m]) continue;
          var isPast = m < cm;
          h += '<div class="pc-tl-month' + (isPast ? ' is-past' : '') + (m === cm ? ' is-now' : '') + '">';
          h += '<div class="pc-tl-month__head"><span class="pc-tl-month__num">' + m + '</span><span>' + MK[m - 1] + '</span>' + (m === cm ? '<span class="pc-tl-month__badge">이번 달</span>' : '') + '</div>';
          byMonth[m].forEach(function (e) {
            var c = catMeta[e.cat] || catMeta.tax;
            var dd = Math.ceil((new Date(2026, e.month - 1, e.day) - now) / 86400000);
            var ddHtml = dd >= 0 && dd <= 30 ? '<span class="pc-ev__dday is-soon">D-' + (dd === 0 ? 'Day' : dd) + '</span>' : '';
            h += '<div class="pc-tl-ev' + (e.important ? ' is-imp' : '') + '">' +
              '<span class="pc-tl-ev__day">' + e.day + '</span>' +
              '<div class="pc-tl-ev__body">' +
              '<div class="pc-tl-ev__row"><span style="color:' + c.color + ';font-size:.75rem;font-weight:600">' + c.icon + ' ' + c.name + '</span>' + ddHtml + '</div>' +
              '<strong>' + e.title + '</strong>' +
              '<span class="pc-tl-ev__desc">' + e.desc + '</span>' +
              '</div>' +
              (e.url ? '<a href="' + e.url + '" target="_blank" rel="noopener" class="pc-tl-ev__link">확인 →</a>' : '') +
              '</div>';
          });
          h += '</div>';
        }
        list.innerHTML = h;
        document.getElementById('pc-empty').hidden = evts.length > 0;

        // 이번 달로 스크롤
        var cur = list.querySelector('.pc-tl-month.is-now');
        if (cur) setTimeout(function () { cur.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 200);
      }

      // ── 필터 ──
      document.querySelectorAll('.pc-fchips').forEach(function (group) {
        group.addEventListener('click', function (ev) {
          var btn = ev.target.closest('.pc-fchip'); if (!btn) return;
          filters[group.dataset.filter] = btn.dataset.val;
          group.querySelectorAll('.pc-fchip').forEach(function (c) { c.classList.toggle('is-on', c.dataset.val === btn.dataset.val); });
          renderGrid(); renderTimeline();
          if (selDay) showDetail(gridMonth + 1, selDay);
          var cnt = document.getElementById('pc-filter-count');
          var active = (filters.target !== 'all' ? 1 : 0) + (filters.field !== 'all' ? 1 : 0);
          cnt.textContent = active > 0 ? active + '개 적용 중' : '';
          document.getElementById('pc-ics-filter').hidden = active === 0;
        });
      });

      // ── 네비게이션 ──
      document.getElementById('pc-prev').addEventListener('click', function () { gridMonth = Math.max(0, gridMonth - 1); selDay = null; renderGrid(); });
      document.getElementById('pc-next').addEventListener('click', function () { gridMonth = Math.min(11, gridMonth + 1); selDay = null; renderGrid(); });
      document.getElementById('pc-today-btn').addEventListener('click', function () { gridMonth = new Date().getMonth(); selDay = null; renderGrid(); });

      // ── .ics 다운로드 (필터 반영) ──
      function downloadICS(events) {
        function pad(n) { return String(n).padStart(2, '0'); }
        function icsDate(m, d) { return '2026' + pad(m) + pad(d); }
        var lines = ['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Crama//Policy Calendar//KO','CALSCALE:GREGORIAN','METHOD:PUBLISH','X-WR-CALNAME:크라마 정책 캘린더 2026','X-WR-TIMEZONE:Asia/Seoul'];
        var stamp = new Date().toISOString().replace(/[-:]/g,'').replace(/\.\d+/,'');
        events.forEach(function (ev, i) {
          var dtStart = icsDate(ev.month, ev.day);
          var next = new Date(2026, ev.month - 1, ev.day + 1);
          var dtEnd = '2026' + pad(next.getMonth() + 1) + pad(next.getDate());
          lines.push('BEGIN:VEVENT','UID:crama-pc-' + ev.month + '-' + ev.day + '-' + i + '@crama.app','DTSTAMP:' + stamp,'DTSTART;VALUE=DATE:' + dtStart,'DTEND;VALUE=DATE:' + dtEnd,'SUMMARY:' + ev.title,'DESCRIPTION:' + ev.desc + '\\n\\nhttps://crama.app/policy-calendar/','URL:https://crama.app/policy-calendar/','BEGIN:VALARM','TRIGGER:-P1D','ACTION:DISPLAY','DESCRIPTION:내일: ' + ev.title,'END:VALARM','END:VEVENT');
        });
        lines.push('END:VCALENDAR');
        var blob = new Blob([lines.join('\r\n')], { type: 'text/calendar;charset=utf-8' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'crama-policy-2026.ics';
        a.click();
        URL.revokeObjectURL(a.href);
      }

      document.getElementById('pc-ics-btn').addEventListener('click', function () { downloadICS(ALL); });
      document.getElementById('pc-ics-filtered').addEventListener('click', function () { downloadICS(filtered()); });

      renderGrid();
      renderTimeline();
    })();
  </script>

  <style is:global>
    .pc-page { max-width: 56rem; margin: 0 auto; padding: 0 1rem 3rem; }

    /* ── 히어로 ── */
    .pc-hero { text-align: center; padding: 3rem 0 2rem; }
    .pc-hero__badge {
      display: inline-block; padding: 0.3rem 0.8rem; background: var(--accent-soft);
      color: var(--accent); font-size: 0.78rem; font-weight: 700; border-radius: 20px;
      letter-spacing: 0.05em; margin-bottom: 1.2rem;
    }
    .pc-hero__title {
      font-family: var(--font-serif); font-size: clamp(1.8rem, 5vw, 2.6rem);
      line-height: 1.3; letter-spacing: -0.02em; margin: 0 0 1.2rem;
    }
    .pc-hero__title em { font-style: normal; color: var(--accent); }
    .pc-hero__lead { color: var(--muted); font-size: 1.05rem; line-height: 1.7; margin: 0 0 2rem; }
    .pc-hero__stats {
      display: flex; justify-content: center; gap: 2rem; margin: 0 0 2rem;
      padding: 1.2rem; background: var(--paper-2); border-radius: 12px;
    }
    .pc-hero__stat { text-align: center; }
    .pc-hero__stat-num { display: block; font-size: 1.4rem; font-weight: 800; color: var(--ink); }
    .pc-hero__stat-label { font-size: 0.78rem; color: var(--muted); }
    .pc-hero__ics {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
      width: 100%; max-width: 20rem; padding: 1rem; background: var(--ink); color: var(--paper);
      border-radius: 12px; font: inherit; font-size: 1.05rem; font-weight: 700;
      border: none; cursor: pointer; transition: all 0.15s;
    }
    .pc-hero__ics:hover { filter: brightness(1.15); transform: translateY(-1px); }
    .pc-hero__note { font-size: 0.75rem; color: var(--muted); margin-top: 1rem; opacity: 0.7; }

    .pc-section-title { font-size: 1rem; font-weight: 700; margin: 0 0 0.8rem; color: var(--ink); }

    /* ── 다가오는 일정 ── */
    .pc-upcoming { margin-bottom: 2rem; }
    .pc-upcoming__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr)); gap: 0.7rem; }
    .pc-ucard {
      display: flex; flex-direction: column; gap: 0.4rem;
      padding: 1rem; border: 1px solid var(--line); border-radius: 12px;
      background: var(--paper); transition: border-color 0.12s;
    }
    .pc-ucard:hover { border-color: var(--accent); }
    .pc-ucard.is-urgent { border-color: #fca5a5; }
    .pc-ucard__dday {
      display: inline-block; font-size: 0.72rem; font-weight: 800; padding: 0.15rem 0.5rem;
      background: var(--paper-2); color: var(--ink-soft); border-radius: 6px; width: fit-content;
    }
    .pc-ucard.is-urgent .pc-ucard__dday { background: #fee2e2; color: #dc2626; }
    .pc-ucard__cat { font-size: 0.72rem; font-weight: 600; }
    .pc-ucard__body h3 { font-size: 0.9rem; font-weight: 700; margin: 0.2rem 0; line-height: 1.35; }
    .pc-ucard__body p { font-size: 0.78rem; color: var(--muted); margin: 0; }
    .pc-ucard__link { font-size: 0.8rem; font-weight: 600; color: var(--accent); text-decoration: none; margin-top: auto; }

    /* ── 캘린더 + 상세 2단 ── */
    .pc-main { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; align-items: start; }

    /* 캘린더 */
    .pc-cal { background: var(--paper); border: 1px solid var(--line); border-radius: 16px; padding: 1.2rem; }
    .pc-cal__nav { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; }
    .pc-cal__month { flex: 1; text-align: center; font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700; margin: 0; }
    .pc-cal__arrow { background: none; border: 1px solid var(--line); border-radius: 8px; width: 2.2rem; height: 2.2rem; cursor: pointer; color: var(--ink); display: grid; place-items: center; transition: border-color 0.12s; }
    .pc-cal__arrow:hover { border-color: var(--accent); color: var(--accent); }
    .pc-cal__today { margin-left: auto; background: none; border: 1px solid var(--line); border-radius: 6px; padding: 0.3rem 0.7rem; font: inherit; font-size: 0.78rem; font-weight: 600; color: var(--accent); cursor: pointer; transition: all 0.12s; }
    .pc-cal__today:hover { background: var(--accent-soft); }

    .pc-cal__header { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; font-size: 0.72rem; font-weight: 600; color: var(--muted); padding-bottom: 0.4rem; }
    .pc-cal__dow--sun { color: #ef4444; }
    .pc-cal__dow--sat { color: #3b82f6; }

    .pc-cal__grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
    .pc-day {
      aspect-ratio: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 2px; background: none; border: none; border-radius: 10px; cursor: pointer;
      font: inherit; color: var(--ink); transition: background 0.1s; position: relative;
      padding: 2px;
    }
    .pc-day:hover { background: var(--paper-2); }
    .pc-day--empty { cursor: default; }
    .pc-day.is-today .pc-day__num { background: var(--accent); color: #fff; border-radius: 50%; width: 1.6rem; height: 1.6rem; display: grid; place-items: center; font-weight: 800; }
    .pc-day.is-sel { background: var(--accent-soft); border-radius: 10px; }
    .pc-day__num { font-size: 0.82rem; font-weight: 500; line-height: 1; }
    .pc-day__dots { display: flex; gap: 2px; }
    .pc-day__dots span { width: 5px; height: 5px; border-radius: 50%; }

    /* 상세 패널 */
    .pc-detail { background: var(--paper); border: 1px solid var(--line); border-radius: 16px; padding: 1.2rem; min-height: 20rem; }
    .pc-detail__empty { text-align: center; padding: 3rem 1rem; color: var(--muted); }
    .pc-detail__empty p { font-size: 0.88rem; margin: 0.8rem 0 0; line-height: 1.5; }
    .pc-detail__date { font-size: 0.85rem; font-weight: 700; color: var(--accent); margin: 0 0 0.8rem; }
    .pc-detail__no { font-size: 0.88rem; color: var(--muted); text-align: center; padding: 2rem 0; }

    .pc-ev { padding: 1rem; border: 1px solid var(--line); border-radius: 10px; margin-bottom: 0.6rem; }
    .pc-ev.is-imp { border-color: var(--accent); }
    .pc-ev__head { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.3rem; }
    .pc-ev__cat { font-size: 0.75rem; font-weight: 600; }
    .pc-ev__dday { font-size: 0.68rem; font-weight: 700; padding: 0.12rem 0.4rem; border-radius: 4px; background: var(--paper-2); color: var(--ink-soft); }
    .pc-ev__dday.is-soon { background: #fee2e2; color: #dc2626; }
    .pc-ev__title { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.2rem; line-height: 1.35; }
    .pc-ev__desc { font-size: 0.82rem; color: var(--muted); margin: 0 0 0.5rem; line-height: 1.4; }
    .pc-ev__actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .pc-ev__btn { font-size: 0.78rem; font-weight: 600; color: #fff; background: var(--accent); padding: 0.3rem 0.7rem; border-radius: 6px; text-decoration: none; transition: filter 0.12s; }
    .pc-ev__btn:hover { filter: brightness(1.1); color: #fff; }
    .pc-ev__btn--ghost { background: transparent; color: var(--ink-soft); border: 1px solid var(--line); }
    .pc-ev__btn--ghost:hover { background: var(--paper-2); color: var(--ink); }

    /* ── 필터 ── */
    .pc-filter-wrap { margin-bottom: 1.5rem; border: 1px solid var(--line); border-radius: 12px; }
    .pc-filter-toggle {
      display: flex; align-items: center; gap: 0.5rem; padding: 0.8rem 1rem;
      font: inherit; font-size: 0.88rem; font-weight: 600; color: var(--ink-soft);
      cursor: pointer; list-style: none;
    }
    .pc-filter-toggle::-webkit-details-marker { display: none; }
    .pc-filter-toggle svg { flex: none; color: var(--muted); }
    .pc-filter-count { font-size: 0.75rem; color: var(--accent); font-weight: 700; margin-left: auto; }
    .pc-filters { padding: 0 1rem 1rem; }
    .pc-frow { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
    .pc-frow__label { font-size: 0.75rem; font-weight: 700; color: var(--muted); min-width: 2.5rem; flex: none; }
    .pc-fchips { display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .pc-fchip {
      padding: 0.3rem 0.65rem; border: 1px solid var(--line); border-radius: 14px;
      background: var(--paper); font: inherit; font-size: 0.78rem; font-weight: 500;
      color: var(--ink-soft); cursor: pointer; transition: all 0.12s; white-space: nowrap;
      touch-action: manipulation;
    }
    .pc-fchip:hover { border-color: var(--accent); }
    .pc-fchip.is-on { background: var(--ink); color: var(--paper); border-color: var(--ink); }

    /* 필터 연동 CTA */
    .pc-ics-filter { margin-bottom: 1.2rem; text-align: center; }
    .pc-ics-filter__btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.65rem 1.2rem; background: var(--accent); color: #fff;
      border: none; border-radius: 10px; font: inherit; font-size: 0.85rem; font-weight: 700;
      cursor: pointer; transition: filter 0.15s;
    }
    .pc-ics-filter__btn:hover { filter: brightness(1.1); }

    /* ── 타임라인 ── */
    .pc-timeline { margin-bottom: 2rem; }
    .pc-tl-month { margin-bottom: 1.5rem; }
    .pc-tl-month.is-past { opacity: 0.45; }
    .pc-tl-month.is-past:hover { opacity: 0.8; }
    .pc-tl-month__head { display: flex; align-items: center; gap: 0.5rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--ink); margin-bottom: 0.6rem; }
    .pc-tl-month.is-now .pc-tl-month__head { border-bottom-color: var(--accent); }
    .pc-tl-month__num { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 700; line-height: 1; }
    .pc-tl-month__badge { font-size: 0.68rem; font-weight: 700; padding: 0.15rem 0.5rem; background: var(--accent); color: #fff; border-radius: 10px; }

    .pc-tl-ev {
      display: flex; align-items: flex-start; gap: 0.7rem; padding: 0.7rem 0.8rem;
      border-radius: 10px; margin-bottom: 0.3rem; transition: background 0.1s;
    }
    .pc-tl-ev:hover { background: var(--paper-2); }
    .pc-tl-ev.is-imp { background: var(--accent-soft); }
    .pc-tl-ev__day { font-family: var(--font-serif); font-size: 1.1rem; font-weight: 700; color: var(--ink); min-width: 2rem; text-align: center; padding-top: 0.1rem; }
    .pc-tl-ev__body { flex: 1; min-width: 0; }
    .pc-tl-ev__row { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.15rem; }
    .pc-tl-ev__body strong { font-size: 0.9rem; display: block; line-height: 1.35; }
    .pc-tl-ev__desc { font-size: 0.78rem; color: var(--muted); }
    .pc-tl-ev__link { flex: none; font-size: 0.78rem; font-weight: 600; color: var(--accent); text-decoration: none; white-space: nowrap; align-self: center; }

    .pc-empty { text-align: center; padding: 2rem; color: var(--muted); font-size: 0.9rem; }

    /* ── 크로스 ── */
    .pc-cross { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; margin: 1.5rem 0; }
    .pc-cross__card {
      display: flex; align-items: center; gap: 0.7rem; padding: 1rem;
      border: 1px solid var(--line); border-radius: 12px; background: var(--paper);
      text-decoration: none; color: var(--ink); transition: border-color 0.12s;
    }
    .pc-cross__card:hover { border-color: var(--accent); }
    .pc-cross__icon { font-size: 1.2rem; flex: none; }
    .pc-cross__card div { flex: 1; }
    .pc-cross__card strong { font-size: 0.9rem; display: block; }
    .pc-cross__card p { font-size: 0.78rem; color: var(--muted); margin: 0.15rem 0 0; }
    .pc-cross__arrow { font-size: 1rem; color: var(--accent); font-weight: 700; }
    .pc-note { padding: 0.8rem; background: var(--paper-2); border-radius: 8px; font-size: 0.78rem; color: var(--muted); }
    .pc-note p { margin: 0; }

    /* ── 반응형 ── */
    @media (max-width: 768px) {
      .pc-main { grid-template-columns: 1fr; }
      .pc-detail { min-height: auto; }
      .pc-cross { grid-template-columns: 1fr; }
      .pc-upcoming__grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .pc-page { padding: 0 0.5rem 2rem; }
      .pc-hero h1 { font-size: 1.4rem; }
      .pc-upcoming__grid { grid-template-columns: 1fr; }
      .pc-ucard { padding: 0.8rem; }
      .pc-cal { padding: 0.8rem; border-radius: 12px; }
      .pc-day__num { font-size: 0.75rem; }
      .pc-frow { flex-direction: column; align-items: flex-start; gap: 0.2rem; }
    }
  </style>
</BaseLayout>
