---
import BaseLayout from '../layouts/BaseLayout.astro';

// 2026년 주택 재산세(지방세법) — 1주택 공정시장가액비율 43~45%(구간별)·특례세율(공시 9억 이하, 2026년까지), 일반 60%·표준세율
const fmt = (n: number) => Math.round(n).toLocaleString('ko-KR');
function calcTax(price: number, one: boolean, urban: boolean) {
  const ratio = one ? (price <= 300_000_000 ? 0.43 : price <= 600_000_000 ? 0.44 : 0.45) : 0.6;
  const base = price * ratio;
  const special = one && price <= 900_000_000;
  let tax: number;
  if (special) {
    tax = base <= 60_000_000 ? base * 0.0005
      : base <= 150_000_000 ? 30_000 + (base - 60_000_000) * 0.001
      : base <= 300_000_000 ? 120_000 + (base - 150_000_000) * 0.002
      : 420_000 + (base - 300_000_000) * 0.0035;
  } else {
    tax = base <= 60_000_000 ? base * 0.001
      : base <= 150_000_000 ? 60_000 + (base - 60_000_000) * 0.0015
      : base <= 300_000_000 ? 195_000 + (base - 150_000_000) * 0.0025
      : 570_000 + (base - 300_000_000) * 0.004;
  }
  tax = Math.floor(tax / 10) * 10;
  const urbanTax = urban ? Math.floor((base * 0.0014) / 10) * 10 : 0;
  const edu = Math.floor((tax * 0.2) / 10) * 10;
  return { tax, urbanTax, edu, total: tax + urbanTax + edu, special };
}
const SAMPLE = [10000, 20000, 30000, 40000, 50000, 60000, 70000, 80000, 90000, 100000, 120000, 150000, 200000];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: 'https://crama.app/' },
    { '@type': 'ListItem', position: 2, name: '금융 계산기', item: 'https://crama.app/tools/' },
    { '@type': 'ListItem', position: 3, name: '재산세 계산기' },
  ],
};
---
<BaseLayout
  title="재산세 계산기 2026 — 우리 집 7월·9월에 얼마 내나?"
  description="공시가격만 넣으면 2026년 주택 재산세를 바로 계산합니다. 1주택 특례세율·공정시장가액비율 43~45%, 도시지역분·지방교육세까지 포함한 7월·9월 납부액 확인."
  jsonLd={jsonLd}
>
  <div class="wrap pt">
    <header class="page-hero">
      <span class="eyebrow">Property Tax</span>
      <h1>재산세 계산기 <span class="pt-y">2026</span></h1>
      <p><b>공시가격</b>만 넣으세요. 7월(16~31일)·9월(16~30일)에 나눠 내는 우리 집 재산세가 바로 나옵니다.</p>
      <p class="pt-basis">1주택 특례세율(공시 9억 이하)·공정시장가액비율 43~45% 반영 · 공시가격은 <a href="https://www.realtyprice.kr" target="_blank" rel="noopener">부동산 공시가격 알리미</a>에서 조회</p>
    </header>

    <div class="pt-form">
      <label>주택 공시가격
        <div class="pt-in"><input id="pt-price" type="number" inputmode="numeric" placeholder="예: 45000" min="1000" max="1000000" step="500" /><span>만원</span></div>
      </label>
      <div class="pt-checks">
        <label class="pt-check"><input id="pt-one" type="checkbox" checked /> 1세대 1주택</label>
        <label class="pt-check"><input id="pt-urban" type="checkbox" checked /> 도시지역(대부분 해당)</label>
      </div>
      <button type="button" id="pt-go">계산하기</button>
    </div>

    <div class="pt-result" id="pt-result" hidden>
      <div class="pt-hero">
        <div class="pt-hero__main"><span>연간 재산세 합계</span><b id="pt-total">-</b><em id="pt-note">-</em></div>
        <div><span>7월 납부</span><b id="pt-july">-</b><em>7/16 ~ 7/31</em></div>
        <div><span>9월 납부</span><b id="pt-sep">-</b><em>9/16 ~ 9/30</em></div>
      </div>
      <ul class="pt-break" id="pt-break"></ul>
      <p class="pt-explain" id="pt-explain"></p>
      <button type="button" class="pt-reg" id="pt-reg" hidden>우리 집을 내 정보로 저장 → 다음부터 자동 계산</button>
    </div>

    <section class="pt-sec">
      <h2>공시가격별 재산세 (도시지역분·교육세 포함)</h2>
      <div class="pt-scroll">
        <table class="pt-table">
          <thead><tr><th>공시가격</th><th>1세대 1주택</th><th>다주택·일반</th></tr></thead>
          <tbody>
            {SAMPLE.map((man) => {
              const p = man * 10_000;
              const one = calcTax(p, true, true);
              const multi = calcTax(p, false, true);
              return (
                <tr>
                  <th>{man >= 10000 ? `${man / 10000}억` : `${fmt(man)}만`}원</th>
                  <td class="pt-hl">{fmt(one.total)}원</td>
                  <td>{fmt(multi.total)}원</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <p class="pt-note">※ 세부담 상한(전년 대비 105~130%)과 지역자원시설세는 반영되지 않은 간이 계산입니다. 실제 고지서와 다를 수 있으며, 정확한 금액은 <a href="https://www.wetax.go.kr" target="_blank" rel="noopener">위택스</a>에서 확인하세요. 1주택 특례세율은 2026년 납세의무분까지 적용됩니다.</p>
    </section>

    <section class="pt-sec">
      <h2>재산세, 이렇게 계산돼요</h2>
      <ul class="pt-list">
        <li><b>과세표준</b> = 공시가격 × 공정시장가액비율(1주택 43~45% 구간별, 다주택 60%)</li>
        <li><b>세율</b> = 4단계 누진(0.1~0.4%). 공시 9억 이하 1주택은 구간별 0.05%p 낮은 특례세율(0.05~0.35%)</li>
        <li><b>도시지역분</b>(과세표준×0.14%)과 <b>지방교육세</b>(재산세×20%)가 함께 고지됩니다</li>
        <li><b>납부</b>: 7월·9월에 절반씩. 본세 20만원 이하면 7월에 한 번에 냅니다</li>
      </ul>
    </section>

    <section class="pt-sec">
      <h2>납부일 놓치지 않게 알림 받기</h2>
      <ul class="pt-alerts">
        <li data-id="proptax-july-2026" data-name="재산세 7월분 납부" data-deadline="2026-07-31">
          <div><b>7월분 납부 마감</b><span>7/16 ~ 7/31 · 늦으면 3% 가산 · 위택스</span></div>
          <button type="button" class="pt-alert-save" aria-pressed="false"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> 알림</button>
        </li>
        <li data-id="proptax-sep-2026" data-name="재산세 9월분 납부" data-deadline="2026-09-30">
          <div><b>9월분 납부 마감</b><span>9/16 ~ 9/30 · 본세 20만원 초과 시 2회차</span></div>
          <button type="button" class="pt-alert-save" aria-pressed="false"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> 알림</button>
        </li>
      </ul>
      <p class="pt-note">알림을 켜두면 마감 3일 전·1일 전에 푸시로 알려드려요(로그인 필요).</p>
    </section>

    <div class="pt-cross">
      <a href="/car-tax/">자동차세 계산 →</a>
      <a href="/salary/">연봉 실수령액 →</a>
      <a href="/benefits/">내 지원금 찾기 →</a>
    </div>
  </div>

  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const fmt = (n) => Math.round(n).toLocaleString('ko-KR');
      function calcTax(price, one, urban) {
        const ratio = one ? (price <= 3e8 ? 0.43 : price <= 6e8 ? 0.44 : 0.45) : 0.6;
        const base = price * ratio;
        const special = one && price <= 9e8;
        let tax;
        if (special) {
          tax = base <= 6e7 ? base * 0.0005 : base <= 1.5e8 ? 30000 + (base - 6e7) * 0.001 : base <= 3e8 ? 120000 + (base - 1.5e8) * 0.002 : 420000 + (base - 3e8) * 0.0035;
        } else {
          tax = base <= 6e7 ? base * 0.001 : base <= 1.5e8 ? 60000 + (base - 6e7) * 0.0015 : base <= 3e8 ? 195000 + (base - 1.5e8) * 0.0025 : 570000 + (base - 3e8) * 0.004;
        }
        tax = Math.floor(tax / 10) * 10;
        const urbanTax = urban ? Math.floor((base * 0.0014) / 10) * 10 : 0;
        const edu = Math.floor((tax * 0.2) / 10) * 10;
        return { tax, urbanTax, edu, total: tax + urbanTax + edu, special, ratio };
      }
      function calc() {
        const man = Number($('pt-price').value);
        if (!man) return;
        const price = man * 10000;
        const one = $('pt-one').checked, urban = $('pt-urban').checked;
        const r = calcTax(price, one, urban);
        $('pt-total').textContent = fmt(r.total) + '원';
        const julyAll = r.tax <= 200000; // 본세 20만 이하 → 7월 일괄
        $('pt-july').textContent = fmt(julyAll ? r.total : r.total / 2) + '원';
        $('pt-sep').textContent = julyAll ? '없음' : fmt(r.total / 2) + '원';
        $('pt-note').textContent = r.special ? '1주택 특례세율 적용' : one ? '1주택(9억 초과) — 표준세율' : '다주택·일반 세율';
        const box = $('pt-break');
        box.innerHTML = '';
        [['재산세 본세', r.tax], ['도시지역분 (0.14%)', r.urbanTax], ['지방교육세 (20%)', r.edu]].forEach(function (row) {
          const li = document.createElement('li');
          li.innerHTML = '<span>' + row[0] + '</span><b>' + fmt(row[1]) + '원</b>';
          box.appendChild(li);
        });
        $('pt-explain').textContent = '과세표준 ' + fmt(price * r.ratio) + '원(공시가격 × ' + Math.round(r.ratio * 100) + '%) 기준이에요.' + (julyAll ? ' 본세가 20만원 이하라 7월에 한 번에 냅니다.' : '');
        $('pt-result').hidden = false;
      }
      $('pt-go').addEventListener('click', calc);
      $('pt-price').addEventListener('keydown', (e) => { if (e.key === 'Enter') calc(); });

      // 프로필 사이클: 등록된 집이면 자동 프리필+계산, 계산 후 '내 정보로 저장'
      const P = window.CramaProfile;
      if (P) {
        const d = P.get();
        if (d.home && d.home.price) {
          $('pt-price').value = d.home.price;
          $('pt-one').checked = d.home.oneHome !== false;
          calc();
        }
        const btn = $('pt-reg');
        const sync = () => { const dd = P.get(); btn.hidden = false; btn.textContent = (dd.home && dd.home.price) ? '우리 집 정보 업데이트' : '우리 집을 내 정보로 저장 → 다음부터 자동 계산'; };
        $('pt-go').addEventListener('click', sync);
        if (d.home && d.home.price) sync();
        btn.addEventListener('click', () => {
          const man = Number($('pt-price').value);
          if (!man) return;
          if (P.set({ home: { price: man, oneHome: $('pt-one').checked } })) { btn.textContent = '저장됐어요 — /me에서 관리'; setTimeout(sync, 2500); }
        });
      }

      // 납부 마감 D-day 알림(하트 저장 → D-3·D-1 푸시)
      const S = window.CramaSaved;
      document.querySelectorAll('.pt-alerts li').forEach((li) => {
        const hbtn = li.querySelector('.pt-alert-save');
        if (!S) { hbtn.hidden = true; return; }
        const hsync = (on) => { hbtn.classList.toggle('is-on', on); hbtn.setAttribute('aria-pressed', on ? 'true' : 'false'); };
        hsync(S.has('dday', li.dataset.id));
        hbtn.addEventListener('click', () => hsync(S.toggle({ type: 'dday', id: li.dataset.id, name: li.dataset.name, url: '/property-tax/', sub: '재산세', deadline: li.dataset.deadline })));
      });
    })();
  </script>

  <style is:global>
    .pt { max-width: 42rem; }
    .pt-y { color: var(--accent); }
    .page-hero .pt-basis { font-size: 0.82rem; color: var(--muted); margin-top: 0.5rem; }
    .pt-basis a { color: var(--accent); }
    .pt-form { display: grid; gap: 0.8rem; margin: 1.4rem 0 1rem; padding: 1.1rem 1.2rem; border: 1px solid var(--line); border-radius: 14px; background: var(--paper-2); }
    .pt-form > label { font-size: 0.84rem; font-weight: 700; color: var(--ink-soft); display: flex; flex-direction: column; gap: 0.35rem; }
    .pt-in { display: flex; align-items: center; gap: 0.4rem; }
    .pt-in input { flex: 1; min-width: 0; font: inherit; font-size: 1rem; padding: 0.6rem 0.8rem; border: 1px solid var(--line); border-radius: 10px; background: var(--paper); color: var(--ink); }
    .pt-in input:focus { outline: none; border-color: var(--accent); }
    .pt-in span { color: var(--muted); font-size: 0.85rem; }
    .pt-checks { display: flex; gap: 1.2rem; flex-wrap: wrap; }
    .pt-check { display: flex; align-items: center; gap: 0.4rem; font-size: 0.86rem; font-weight: 700; color: var(--ink-soft); }
    .pt-form button { font: inherit; font-weight: 800; font-size: 1rem; padding: 0.8rem; border: 0; border-radius: 12px; background: var(--accent); color: #fff; cursor: pointer; }
    .pt-result[hidden] { display: none; }
    .pt-hero { display: grid; grid-template-columns: 1.3fr 1fr 1fr; gap: 0.6rem; margin-bottom: 0.7rem; }
    .pt-hero > div { border: 1px solid var(--line); border-radius: 14px; padding: 0.95rem 1rem; background: var(--paper); display: flex; flex-direction: column; gap: 0.15rem; }
    .pt-hero span { font-size: 0.76rem; color: var(--muted); font-weight: 600; }
    .pt-hero b { font-size: 1.1rem; }
    .pt-hero em { font-style: normal; font-size: 0.72rem; color: var(--muted); }
    .pt-hero__main { background: var(--accent) !important; border-color: var(--accent) !important; color: #fff; }
    .pt-hero__main span, .pt-hero__main em { color: rgba(255, 255, 255, 0.85); }
    .pt-hero__main b { font-size: 1.3rem; }
    @media (max-width: 560px) { .pt-hero { grid-template-columns: 1fr; } }
    .pt-break { list-style: none; margin: 0 0 0.5rem; padding: 0.3rem 1rem; border: 1px solid var(--line); border-radius: 12px; background: var(--paper); }
    .pt-break li { display: flex; justify-content: space-between; gap: 0.8rem; padding: 0.5rem 0; font-size: 0.88rem; border-bottom: 1px dashed var(--line); }
    .pt-break li:last-child { border-bottom: 0; }
    .pt-break b { font-variant-numeric: tabular-nums; }
    .pt-explain { font-size: 0.82rem; color: var(--muted); margin: 0.4rem 0 0; }
    .pt-reg { display: block; margin-top: 0.7rem; font: inherit; font-size: 0.85rem; font-weight: 700; color: var(--accent); background: var(--accent-soft); border: 1px dashed var(--accent); border-radius: 10px; padding: 0.6rem 1rem; cursor: pointer; width: 100%; }
    .pt-reg[hidden] { display: none; }
    .pt-sec { margin: 1.8rem 0; }
    .pt-sec h2 { font-size: 1.1rem; margin: 0 0 0.7rem; }
    .pt-scroll { overflow-x: auto; }
    .pt-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; white-space: nowrap; }
    .pt-table thead th { font-size: 0.75rem; color: var(--muted); text-align: right; padding: 0.45rem 0.7rem; border-bottom: 2px solid var(--line); }
    .pt-table thead th:first-child { text-align: left; }
    .pt-table tbody th { text-align: left; padding: 0.52rem 0.7rem; border-bottom: 1px solid var(--line); }
    .pt-table tbody td { padding: 0.52rem 0.7rem; border-bottom: 1px solid var(--line); text-align: right; font-variant-numeric: tabular-nums; }
    .pt-hl { font-weight: 800; color: var(--accent); }
    .pt-list { margin: 0; padding-left: 1.1rem; display: grid; gap: 0.55rem; font-size: 0.92rem; line-height: 1.6; color: var(--ink-soft); }
    .pt-note { font-size: 0.78rem; color: var(--muted); margin: 0.7rem 0 0; line-height: 1.5; }
    .pt-note a { color: var(--accent); }
    .pt-alerts { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.5rem; }
    .pt-alerts li { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; padding: 0.75rem 0.9rem; border: 1px solid var(--line); border-radius: 12px; }
    .pt-alerts b { font-size: 0.92rem; display: block; }
    .pt-alerts span { font-size: 0.76rem; color: var(--muted); }
    .pt-alert-save { flex: none; display: inline-flex; align-items: center; gap: 0.3rem; font: inherit; font-size: 0.8rem; font-weight: 700; padding: 0.45rem 0.8rem; border: 1px solid var(--line); border-radius: 999px; background: var(--paper); color: var(--ink-soft); cursor: pointer; }
    .pt-alert-save:hover { border-color: #e11d48; color: #e11d48; }
    .pt-alert-save.is-on { color: #e11d48; border-color: #e11d48; }
    .pt-cross { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; margin: 2rem 0 1rem; padding-top: 1.4rem; border-top: 1px solid var(--line); }
    .pt-cross a { font-size: 0.88rem; font-weight: 700; color: var(--accent); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid var(--line); border-radius: 999px; }
    .pt-cross a:hover { border-color: var(--accent); }
  </style>
</BaseLayout>
