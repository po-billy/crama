---
import BaseLayout from '../../layouts/BaseLayout.astro';

// 단계형 성향 테스트 — 각 선택지가 캐릭터(key)에 점수를 더하고, 최다 득점 캐릭터가 결과.
const questions = [
  {
    text: '월급날, 가장 먼저 드는 생각은?',
    options: [
      { label: '일단 일부는 딴 통장으로 옮겨 둬야지', tags: ['turtle', 'squirrel'] },
      { label: '이번 달엔 뭘 좀 사 볼까', tags: ['cicada'] },
      { label: '어디에 투자하면 좋을지부터 본다', tags: ['hawk', 'fox'] },
      { label: '본업 말고 들어올 돈이 또 없나', tags: ['ant'] },
    ],
  },
  {
    text: '여윳돈 100만 원이 생긴다면?',
    options: [
      { label: '안전하게 예금·파킹통장에', tags: ['turtle'] },
      { label: '매달 나눠서 꾸준히 적립', tags: ['squirrel'] },
      { label: '오를 것 같은 곳에 과감히', tags: ['hawk'] },
      { label: '갖고 싶던 걸 나에게 선물', tags: ['cicada'] },
    ],
  },
  {
    text: '투자한 게 20% 떨어졌다. 내 반응은?',
    options: [
      { label: '불안해서 일단 판다', tags: ['turtle'] },
      { label: '계획대로 그냥 더 사 모은다', tags: ['squirrel'] },
      { label: '기회다! 비중을 늘린다', tags: ['hawk'] },
      { label: '왜 떨어졌는지 자료부터 뒤진다', tags: ['fox'] },
    ],
  },
  {
    text: '돈 정보, 주로 어떻게 얻나?',
    options: [
      { label: '검증된 기본부터 차근차근', tags: ['turtle', 'squirrel'] },
      { label: '뉴스·지표·리포트를 직접 분석', tags: ['fox'] },
      { label: '화제되는 종목·트렌드를 빠르게', tags: ['hawk'] },
      { label: '돈 버는 부업·수익화 사례 위주', tags: ['ant'] },
    ],
  },
  {
    text: '나에게 "잘 쓴 돈"이란?',
    options: [
      { label: '미래의 불안을 줄여 주는 돈', tags: ['turtle'] },
      { label: '시간이 지나 더 불어날 돈', tags: ['squirrel', 'hawk'] },
      { label: '지금의 나를 행복하게 하는 돈', tags: ['cicada'] },
      { label: '더 많이 벌 기회를 만드는 돈', tags: ['ant', 'fox'] },
    ],
  },
  {
    text: '5년 뒤, 바라는 내 모습은?',
    options: [
      { label: '흔들리지 않는 단단한 통장', tags: ['turtle'] },
      { label: '꾸준히 굴러 커진 눈덩이', tags: ['squirrel'] },
      { label: '과감한 베팅이 통한 한 방', tags: ['hawk'] },
      { label: '여러 갈래로 들어오는 수입', tags: ['ant'] },
