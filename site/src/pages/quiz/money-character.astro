];

const results = {
  turtle: {
    emoji: '🐢',
    name: '든든한 거북이',
    quote: '“천천히, 그러나 확실히.”',
    desc: '무엇보다 원금과 안정을 중시하는 신중파입니다. 불안을 줄이는 토대를 먼저 다지는 게 잘 맞아요. 비상금과 안전자산으로 바닥을 단단히 깔아 두면, 그 위에서 마음 편히 한 걸음씩 나아갈 수 있습니다.',
    links: [
      { label: '세탁기가 멈춘 날, 비상금이 나를 구했다', href: '/blog/emergency-fund-story/' },
      { label: '비상금 만들기 가이드', href: '/blog/emergency-fund-guide/' },
      { label: '예·적금·파킹통장 비교', href: '/blog/savings-account-comparison/' },
      { label: '통장 하나로 살다가, 넷으로 쪼갰다', href: '/blog/account-splitting-story/' },
    ],
  },
  squirrel: {
    emoji: '🐿️',
    name: '꾸준한 다람쥐',
    quote: '“매달 조금씩, 도토리를 모으듯.”',
    desc: '타이밍을 좇기보다 습관으로 쌓아 가는 적립형입니다. 시간과 복리가 가장 큰 무기예요. 매달 같은 금액을 빠짐없이 넣는 단순함이, 길게 보면 가장 강력한 전략이 됩니다.',
    links: [
      { label: '지우의 1년 적립식 투자 이야기', href: '/blog/first-year-investing-story/' },
      { label: '복리의 힘', href: '/blog/compound-interest-power/' },
      { label: 'S&P500 ETF 가이드', href: '/blog/money-sp500-etf-guide/' },
      { label: '첫 월급으로 무엇을 하셨나요', href: '/blog/first-salary-story/' },
    ],
  },
  hawk: {
    emoji: '🦅',
    name: '모험가 매',
    quote: '“위험 너머의 수익을 노린다.”',
    desc: '높은 수익을 위해 변동성을 감수하는 적극파입니다. 추진력이 강점이지만, 분산과 심리 관리가 받쳐 줘야 오래갑니다. 남의 수익에 휘둘리지 않는 기준만 갖추면 더 단단해져요.',
    links: [
      { label: '친구가 두 배를 벌었다는 그날 밤', href: '/blog/chasing-returns-fomo/' },
      { label: '투자 심리 다스리기', href: '/blog/investor-psychology-guide/' },
      { label: '가치투자 vs 성장투자', href: '/blog/value-vs-growth-investing/' },
      { label: '미국주식 입문', href: '/blog/us-stock-investment-beginners-guide/' },
    ],
  },
  fox: {
    emoji: '🦊',
    name: '똑똑한 여우',
    quote: '“남보다 한발 먼저 안다.”',
    desc: '직접 분석하고 전략을 세우는 정보파입니다. 분산과 자산배분을 설계하는 데 강점이 있어요. 금리·환율 같은 큰 흐름까지 읽어 두면, 흔들리는 시장에서도 길을 잃지 않습니다.',
    links: [
      { label: '투자 포트폴리오 기초', href: '/blog/investment-portfolio-basics/' },
      { label: 'ETF vs 펀드', href: '/blog/money-etf-vs-fund/' },
      { label: '금리·환율의 영향', href: '/blog/interest-rate-exchange-basics/' },
      { label: '주식 투자 완벽 가이드', href: '/blog/stock-investing-complete-guide/' },
    ],
  },
  cicada: {
    emoji: '🎍',
    name: '즐기는 베짱이',
    quote: '“지금의 행복도 중요해.”',
    desc: '현재의 만족을 소중히 여기는 균형파입니다. 누리는 것도 삶의 일부죠. 다만 "먼저 떼고 남은 걸 쓰는" 순서 하나만 들이면, 행복과 저축을 둘 다 잡을 수 있습니다.',
    links: [
      { label: '월급은 올랐는데, 왜 통장은 그대로일까', href: '/blog/lifestyle-inflation-trap/' },
      { label: '아침 커피를 끊으면 부자가 된다는 거짓말', href: '/blog/latte-factor-myth/' },
      { label: '통장 하나로 살다가, 넷으로 쪼갰다', href: '/blog/account-splitting-story/' },
      { label: '첫 월급으로 무엇을 하셨나요', href: '/blog/first-salary-story/' },
    ],
  },
  ant: {
    emoji: '🐜',
    name: '부지런한 개미',
    quote: '“버는 길을 여러 갈래로.”',
    desc: '버는 힘을 키우는 데 관심이 많은 실행파입니다. 수입원을 늘리는 감각이 강점이에요. 한탕보다 오래가는 두 번째 수입을 설계하면, 월급 밖에서도 단단한 토대가 생깁니다.',
    links: [
      { label: '처음 벌어 본 만 원의 무게', href: '/blog/first-side-income-story/' },
      { label: '퇴근 후의 나를 갈아 넣었다, 그리고 멈췄다', href: '/blog/side-hustle-burnout-story/' },
      { label: '직장인 부업 시작하기', href: '/blog/side-hustle-for-office-workers/' },
      { label: 'AI로 부업 시작하기', href: '/blog/ai-side-hustle-guide/' },
    ],
  },
