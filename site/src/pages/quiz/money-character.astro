const resultKeys = Object.keys(results);
---
<BaseLayout title="나의 머니 캐릭터 테스트" description="6가지 질문으로 나의 돈 성향을 캐릭터로 진단하고, 나에게 맞는 재테크 글을 추천받아 보세요. (재미·정보 제공용 간이 테스트)">
  <div class="wrap mc">
    <!-- 시작 화면 -->
    <section class="mc-intro" id="mc-intro">
      <span class="eyebrow">머니 캐릭터 테스트</span>
      <h1>나와 비슷한<br />돈 캐릭터를 찾아볼까요?</h1>
      <p class="mc-intro__lead">6가지 질문이면 충분해요. 내 돈 성향을 캐릭터로 알려주고, 딱 맞는 글까지 추천해 드려요.</p>
      <div class="mc-intro__emojis" aria-hidden="true">🐢 🐿️ 🦅 🦊 🐜</div>
      <button class="mc-btn mc-btn--lg" type="button" id="mc-start">지금 시작하기</button>
      <p class="mc-note">재미·정보 제공용 간이 테스트입니다.</p>
    </section>

    <!-- 질문 화면 -->
    <section class="mc-quiz" id="mc-quiz" hidden>
      <div class="mc-top">
        <button class="mc-back" type="button" id="mc-back" aria-label="이전 질문">‹</button>
        <div class="mc-progress"><span class="mc-progress__bar" id="mc-bar"></span></div>
      </div>
      <p class="mc-step" id="mc-step"></p>
      <h2 class="mc-question" id="mc-question"></h2>
      <div class="mc-options" id="mc-options"></div>
    </section>

    <!-- 결과 화면 -->
    <section class="mc-result" id="mc-result" hidden>
      <div class="mc-card" id="mc-card">
        <span class="mc-card__eyebrow">내 머니 캐릭터는</span>
        <div class="mc-card__emoji" id="mc-emoji"></div>
        <h2 class="mc-card__name" id="mc-name"></h2>
        <p class="mc-card__quote" id="mc-quote"></p>
        <p class="mc-card__desc" id="mc-desc"></p>
      </div>
      <p class="mc-rec-title"><strong>이런 글을 추천해요</strong></p>
      <ul class="mc-rec" id="mc-rec"></ul>
      <div class="mc-actions">
        <button class="mc-btn" type="button" id="mc-share">결과 공유하기</button>
        <button class="mc-btn mc-btn--ghost" type="button" id="mc-again">다시 테스트하기</button>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ questions, results, resultKeys }}>
    (() => {
      const $ = (id) => document.getElementById(id);
      const intro = $('mc-intro'), quiz = $('mc-quiz'), result = $('mc-result');
      let step = 0;
      const picks = new Array(questions.length).fill(null); // 각 문항에서 고른 tags

      const show = (el) => { el.hidden = false; };
      const hide = (el) => { el.hidden = true; };

      function renderStep() {
        const q = questions[step];
        $('mc-bar').style.width = ((step) / questions.length * 100) + '%';
        $('mc-step').textContent = (step + 1) + ' / ' + questions.length;
        $('mc-question').textContent = q.text;
        $('mc-back').style.visibility = step === 0 ? 'hidden' : 'visible';
        const wrap = $('mc-options');
        wrap.innerHTML = '';
        q.options.forEach((o, i) => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'mc-opt' + (picks[step] === i ? ' is-sel' : '');
          b.textContent = o.label;
          b.addEventListener('click', () => {
            picks[step] = i;
            if (step < questions.length - 1) { step++; renderStep(); }
            else finish();
          });
          wrap.appendChild(b);
        });
      }

      function finish() {
        $('mc-bar').style.width = '100%';
        const tally = {};
        resultKeys.forEach((k) => tally[k] = 0);
        picks.forEach((pi, qi) => {
          if (pi == null) return;
          questions[qi].options[pi].tags.forEach((t) => { tally[t] = (tally[t] || 0) + 1; });
        });
        // 최다 득점(동점이면 resultKeys 순서가 빠른 쪽)
        let best = resultKeys[0];
        resultKeys.forEach((k) => { if (tally[k] > tally[best]) best = k; });
        renderResult(best);
        if (history.replaceState) history.replaceState(null, '', '#' + best);
        else location.hash = best;
      }

      function renderResult(key) {
        const r = results[key];
        if (!r) return;
        $('mc-emoji').textContent = r.emoji;
        $('mc-name').textContent = r.name;
        $('mc-quote').textContent = r.quote;
        $('mc-desc').textContent = r.desc;
        $('mc-rec').innerHTML = r.links
          .map((l) => '<li><a href="' + l.href + '">' + l.label + ' →</a></li>').join('');
        hide(intro); hide(quiz); show(result);
        result.dataset.key = key;
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      function startQuiz() {
        step = 0; picks.fill(null);
        hide(intro); hide(result); show(quiz);
        renderStep();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      $('mc-start').addEventListener('click', startQuiz);
      $('mc-again').addEventListener('click', () => {
        if (history.replaceState) history.replaceState(null, '', location.pathname);
        startQuiz();
      });
      $('mc-back').addEventListener('click', () => { if (step > 0) { step--; renderStep(); } });
      $('mc-share').addEventListener('click', async () => {
        const key = result.dataset.key;
        const url = location.origin + location.pathname + '#' + key;
        const text = '나의 머니 캐릭터는 "' + results[key].name + '"! 당신의 돈 캐릭터는?';
        try {
          if (navigator.share) { await navigator.share({ title: '나의 머니 캐릭터 테스트', text, url }); }
          else { await navigator.clipboard.writeText(url); alert('결과 링크를 복사했어요!\n' + url); }
        } catch (_) { /* 사용자가 취소 */ }
      });

      // 공유 링크로 들어오면(#key) 결과를 바로 보여준다
      const h = (location.hash || '').replace('#', '');
      if (results[h]) renderResult(h);
    })();
  </script>

  <style>
    .mc { max-width: 34rem; }
    .mc-btn {
      font: inherit; font-weight: 700; cursor: pointer; border: none; border-radius: 999px;
      background: var(--ink); color: var(--paper); padding: 0.85rem 1.7rem; transition: filter .15s ease;
    }
    .mc-btn:hover { filter: brightness(1.15); }
    .mc-btn--lg { width: 100%; padding: 1.05rem; font-size: 1.05rem; margin-top: 1.4rem; }
    .mc-btn--ghost { background: transparent; color: var(--muted); border: 1px solid var(--line); }

    /* 시작 */
    .mc-intro { text-align: center; padding: 1.5rem 0 2rem; }
    .mc-intro h1 { font-size: 1.9rem; line-height: 1.3; margin: 0.6rem 0 1rem; }
    .mc-intro__lead { color: var(--muted); line-height: 1.65; }
    .mc-intro__emojis { font-size: 2.2rem; letter-spacing: 0.3rem; margin: 1.8rem 0; }
    .mc-note { color: var(--muted); font-size: 0.8rem; margin-top: 0.9rem; opacity: 0.8; }

    /* 질문 */
    .mc-top { display: flex; align-items: center; gap: 0.8rem; margin: 0.5rem 0 1.6rem; }
    .mc-back {
      font-size: 1.5rem; line-height: 1; background: none; border: none; cursor: pointer;
      color: var(--ink); padding: 0 0.2rem; flex: none;
    }
    .mc-progress { flex: 1; height: 6px; background: var(--paper-2); border-radius: 999px; overflow: hidden; }
    .mc-progress__bar { display: block; height: 100%; width: 0; background: var(--accent); border-radius: 999px; transition: width .3s ease; }
    .mc-step { color: var(--muted); font-size: 0.85rem; font-weight: 600; margin: 0 0 0.5rem; }
    .mc-question { font-size: 1.45rem; line-height: 1.35; margin: 0 0 1.6rem; }
    .mc-options { display: flex; flex-direction: column; gap: 0.7rem; }
    .mc-opt {
      font: inherit; text-align: left; cursor: pointer; color: var(--ink);
      background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius);
      padding: 1rem 1.2rem; transition: border-color .15s ease, background .15s ease, transform .05s ease;
    }
    .mc-opt:hover { border-color: var(--accent); background: var(--paper-2); }
    .mc-opt:active { transform: scale(0.99); }
    .mc-opt.is-sel { border-color: var(--accent); background: var(--paper-2); }

    /* 결과 */
    .mc-card {
      text-align: center; border: 1px solid var(--line); border-radius: 1.2rem;
      background: linear-gradient(180deg, var(--paper-2), var(--paper));
      padding: 2.2rem 1.6rem; margin-bottom: 1.6rem;
    }
    .mc-card__eyebrow { font-family: var(--font-sans); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; color: var(--accent); text-transform: uppercase; }
    .mc-card__emoji { font-size: 4.5rem; line-height: 1; margin: 0.8rem 0 0.4rem; }
    .mc-card__name { font-size: 2rem; margin: 0.2rem 0 0.6rem; }
    .mc-card__quote { font-family: var(--font-serif); font-style: italic; font-size: 1.15rem; color: var(--ink); margin: 0 0 1rem; }
    .mc-card__desc { color: var(--ink-soft); line-height: 1.7; text-align: left; }
    .mc-rec-title { margin: 0 0 0.4rem; }
    .mc-rec { list-style: none; padding: 0; margin: 0 0 1.6rem; }
    .mc-rec li { padding: 0.55rem 0; border-bottom: 1px solid var(--line); }
    .mc-rec a { color: var(--accent); font-weight: 600; }
    .mc-actions { display: flex; gap: 0.7rem; flex-wrap: wrap; }
    .mc-actions .mc-btn { flex: 1; min-width: 9rem; }

    @media (max-width: 480px) {
      .mc-intro h1 { font-size: 1.65rem; }
      .mc-question { font-size: 1.3rem; }
      .mc-card__name { font-size: 1.7rem; }
    }
  </style>
</BaseLayout>
