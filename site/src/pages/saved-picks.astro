---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="내 관심 — 저장한 정책·복지" description="저장한 청년 정책·복지 서비스·혜택을 한곳에서 관리하세요. 로그인 없이 이 기기에 저장됩니다.">
  <div class="wrap">
    <header class="page-hero">
      <span class="eyebrow">My Picks</span>
      <h1>내 관심</h1>
      <p>저장한 청년 정책·복지 서비스·혜택을 한곳에. 계정에 저장되어 <b>어느 기기에서나</b> 볼 수 있어요.</p>
    </header>

    <div id="sp-body"><p class="sp-loading">불러오는 중…</p></div>
  </div>

  <script is:inline>
    (() => {
      const body = document.getElementById('sp-body');
      const S = window.CramaSaved;
      if (!body || !S) return;
      const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      const TYPES = [
        { key: 'youth', label: '청년 정책', href: '/youth/', color: '#06b6d4' },
        { key: 'welfare', label: '복지 서비스', href: '/welfare/', color: '#ec4899' },
        { key: 'benefit', label: '내 혜택', href: '/benefits/', color: '#10b981' },
      ];
      function dday(ds) {
        if (!ds || !/^\d{4}-\d{2}-\d{2}$/.test(ds)) return null;
        var pt = ds.split('-'); var dl = new Date(+pt[0], +pt[1] - 1, +pt[2]);
        var n = new Date(); var today = new Date(n.getFullYear(), n.getMonth(), n.getDate());
        return Math.round((dl - today) / 86400000);
      }
      function ddayBadge(it) {
        var dd = dday(it.deadline);
        if (dd === null || dd < 0) return '';
        var cls = dd <= 7 ? ' is-urgent' : (dd <= 30 ? ' is-soon' : '');
        return '<span class="sp-dday' + cls + '">' + (dd === 0 ? 'D-Day' : 'D-' + dd) + '</span>';
      }
      function render() {
        if (!S.authed) {
          body.innerHTML = '<div class="sp-login">' +
            '<h2>관심 목록은 로그인하고 쓸 수 있어요</h2>' +
            '<p>하트로 저장한 정책·복지·혜택이 계정에 안전하게 보관되고,<br>폰·PC 어디서나 이어서 볼 수 있어요. 곧 <b>마감 임박 알림</b>도 보내드려요.</p>' +
            '<button type="button" class="sp-login__btn" id="sp-login-go">무료 로그인 · 30초 →</button>' +
            '<div class="sp-empty__links"><a href="/youth/">청년 정책 둘러보기 →</a><a href="/welfare/">복지 서비스 →</a><a href="/benefits/">내 혜택 찾기 →</a></div></div>';
          const go = document.getElementById('sp-login-go');
          if (go) go.addEventListener('click', () => {
            try { localStorage.setItem('crama:login-return', '/saved-picks/'); } catch (e) {}
            location.href = '/login/';
          });
          return;
        }
        const all = S.list();
        if (!all.length) {
          body.innerHTML = '<div class="sp-empty"><p>아직 저장한 항목이 없어요.<br>청년 정책·복지 서비스에서 하트를 눌러 저장해 보세요.</p>' +
            '<div class="sp-empty__links"><a href="/youth/">청년 정책 →</a><a href="/welfare/">복지 서비스 →</a><a href="/benefits/">내 혜택 찾기 →</a></div></div>';
          return;
        }
        var urgent = all.filter(function (x) { var d = dday(x.deadline); return d !== null && d >= 0 && d <= 30; }).length;
        let html = urgent ? '<p class="sp-urgent">마감 30일 이내 <b>' + urgent + '건</b> — 서둘러 신청하세요.</p>' : '';
        TYPES.forEach((t) => {
          const items = S.list(t.key);
          if (!items.length) return;
          items.sort(function (a, b) { var da = dday(a.deadline), db = dday(b.deadline); if (da === null && db === null) return 0; if (da === null) return 1; if (db === null) return -1; return da - db; });
          html += '<section class="sp-group"><div class="sp-group__head"><h2 style="--c:' + t.color + '">' + t.label + ' <span>' + items.length + '</span></h2><a href="' + t.href + '">전체 보기 →</a></div><div class="sp-list">';
          html += items.map((it) =>
            '<div class="sp-item" data-type="' + t.key + '" data-id="' + esc(it.id) + '">' +
            '<a class="sp-item__main" href="' + esc(it.url || t.href) + '"' + (it.url ? ' target="_blank" rel="noopener"' : '') + '>' +
            (it.sub ? '<span class="sp-item__sub" style="--c:' + t.color + '">' + esc(it.sub) + '</span>' : '') +
            '<strong>' + esc(it.name) + '</strong></a>' +
            ddayBadge(it) +
            '<button type="button" class="sp-item__x" aria-label="삭제">×</button></div>'
          ).join('');
          html += '</div></section>';
        });
        body.innerHTML = html;
      }
      body.addEventListener('click', (e) => {
        const x = e.target.closest('.sp-item__x'); if (!x) return;
        const item = x.closest('.sp-item');
        S.remove(item.dataset.type, item.dataset.id);
        render();
      });
      render();
      document.addEventListener('astro:page-load', render);
      document.addEventListener('crama:saved-sync', render); // 서버 동기화 완료 시 최신 목록 반영
    })();
  </script>

  <style>
    .sp-loading { color: var(--muted); padding: 2rem 0; }
    .sp-login { text-align: center; padding: 2.2rem 1rem; border: 1px solid var(--line); border-radius: 16px; background: var(--paper-2); }
    .sp-login h2 { font-size: 1.2rem; margin: 0 0 0.6rem; }
    .sp-login p { font-size: 0.92rem; color: var(--ink-soft); line-height: 1.6; margin: 0 0 1.1rem; }
    .sp-login__btn { font: inherit; font-weight: 800; font-size: 0.95rem; padding: 0.8rem 1.6rem; border: 0; border-radius: 12px; background: var(--accent); color: #fff; cursor: pointer; margin-bottom: 1.2rem; }
    .sp-login__btn:hover { filter: brightness(1.1); }
    .sp-empty { text-align: center; color: var(--muted); padding: 2.5rem 0; }
    .sp-empty__links { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; margin-top: 1.2rem; }
    .sp-empty__links a { font-size: 0.9rem; font-weight: 700; color: var(--accent); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid var(--line); border-radius: 999px; }
    .sp-empty__links a:hover { border-color: var(--accent); }

    .sp-group { margin-bottom: 2rem; }
    .sp-group__head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 0.8rem; }
    .sp-group__head h2 { font-size: 1.15rem; margin: 0; }
    .sp-group__head h2 span { font-size: 0.85rem; font-weight: 700; color: var(--c, var(--accent)); }
    .sp-group__head a { font-size: 0.85rem; font-weight: 600; color: var(--muted); text-decoration: none; }
    .sp-group__head a:hover { color: var(--accent); }
    .sp-list { display: grid; gap: 0.6rem; }
    .sp-item { display: flex; align-items: center; gap: 0.6rem; padding: 0.9rem 1rem; border: 1px solid var(--line); border-radius: 12px; background: var(--paper); }
    .sp-item__main { flex: 1; min-width: 0; text-decoration: none; color: var(--ink); display: flex; flex-direction: column; gap: 0.15rem; }
    .sp-item__sub { font-size: 0.68rem; font-weight: 700; color: var(--c, var(--accent)); }
    .sp-item__main strong { font-size: 0.95rem; font-weight: 700; line-height: 1.35; }
    .sp-item__main:hover strong { color: var(--accent); }
    .sp-item__x { flex: none; width: 2rem; height: 2rem; border: 0; background: var(--paper-2); border-radius: 50%; color: var(--muted); font-size: 1.2rem; line-height: 1; cursor: pointer; transition: all 0.12s; }
    .sp-item__x:hover { background: #fee2e2; color: #ef4444; }
    .sp-urgent { background: color-mix(in srgb, #f43f5e 8%, var(--paper)); color: #e11d48; font-size: 0.9rem; font-weight: 600; padding: 0.7rem 1rem; border: 1px solid color-mix(in srgb, #f43f5e 20%, var(--paper)); border-radius: 10px; margin: 0 0 1.4rem; }
    .sp-dday { flex: none; font-size: 0.72rem; font-weight: 800; color: var(--muted); padding: 0.2rem 0.5rem; border-radius: 999px; background: var(--paper-2); white-space: nowrap; }
    .sp-dday.is-soon { color: #d97706; background: color-mix(in srgb, #f59e0b 15%, var(--paper)); }
    .sp-dday.is-urgent { color: #e11d48; background: color-mix(in srgb, #f43f5e 15%, var(--paper)); }
  </style>
</BaseLayout>
