---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORIES } from '../consts';
const catNames = Object.fromEntries(
  Object.values(CATEGORIES).map((c) => [c.slug, c.name]),
);
---
<BaseLayout title="검색" description="Crama의 글을 검색하세요 — 주식·재테크와 AI 트렌드.">
  <div class="wrap">
    <header class="page-hero">
      <span class="eyebrow">Search</span>
      <h1>검색</h1>
      <p>제목·설명·태그로 글을 찾습니다.</p>
    </header>

    <div class="search-box" style="position:relative;">
      <input
        type="search"
        id="q"
        class="search-input"
        placeholder="예: ETF, 배당, AI 에이전트, 프롬프트…"
        autocomplete="off"
        autofocus
      />
      <button type="button" id="search-clear" aria-label="검색어 지우기" style="display:none;position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;font-size:1.2rem;color:var(--muted,#94a3b8);cursor:pointer;padding:4px 8px;line-height:1;">&times;</button>
    </div>

    <div class="search-results" id="results" aria-live="polite"></div>
  </div>

  <script define:vars={{ catNames }}>
    const input = document.getElementById('q');
    const out = document.getElementById('results');
    let data = [];

    fetch('/search.json')
      .then((r) => r.json())
      .then((d) => {
        data = d;
        const params = new URLSearchParams(location.search);
        const q = params.get('q');
        if (q) { input.value = q; render(q); }
      });

    function esc(s) {
      return String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    }

    function render(query) {
      const q = query.trim().toLowerCase();
      if (!q) { out.innerHTML = ''; return; }
      const hits = data.filter((p) => {
        const hay = (p.title + ' ' + p.description + ' ' + (p.tags || []).join(' ')).toLowerCase();
        return q.split(/\s+/).every((t) => hay.includes(t));
      });
      if (hits.length === 0) {
        out.innerHTML = `<p class="search-empty">"${esc(query)}"에 대한 결과가 없습니다.</p>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.5rem;margin-top:1.5rem;max-width:480px;">
            <a href="/benefits/" style="display:flex;flex-direction:column;align-items:center;gap:.3rem;padding:.8rem;border:1px solid var(--line);border-radius:10px;text-decoration:none;color:var(--ink);font-size:.85rem;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><defs><linearGradient id="sb" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse"><stop stop-color="#10b981"/><stop offset="1" stop-color="#22c55e"/></linearGradient></defs><circle cx="12" cy="12" r="9" fill="url(#sb)"/><path d="M8.5 12.5l2 2 5-5" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg><strong>내 혜택 찾기</strong></a>
            <a href="/checkup/" style="display:flex;flex-direction:column;align-items:center;gap:.3rem;padding:.8rem;border:1px solid var(--line);border-radius:10px;text-decoration:none;color:var(--ink);font-size:.85rem;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><defs><linearGradient id="sc" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse"><stop stop-color="#f59e0b"/><stop offset="1" stop-color="#ef4444"/></linearGradient></defs><rect x="5" y="3" width="14" height="18" rx="3.5" fill="url(#sc)"/><path d="M9 9h6M9 12.5h4" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/></svg><strong>재무 체크업</strong></a>
            <a href="/policy-calendar/" style="display:flex;flex-direction:column;align-items:center;gap:.3rem;padding:.8rem;border:1px solid var(--line);border-radius:10px;text-decoration:none;color:var(--ink);font-size:.85rem;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><defs><linearGradient id="sd" x1="0" y1="0" x2="24" y2="24" gradientUnits="userSpaceOnUse"><stop stop-color="#3b82f6"/><stop offset="1" stop-color="#6366f1"/></linearGradient></defs><rect x="4" y="5" width="16" height="14" rx="3" fill="url(#sd)"/><path d="M8 3v3.5M16 3v3.5M4 9.5h16" stroke="url(#sd)" stroke-width="1.8" stroke-linecap="round"/><g fill="#fff"><circle cx="9" cy="13" r="1.1"/><circle cx="12" cy="13" r="1.1"/><circle cx="15" cy="13" r="1.1"/></g></svg><strong>정책 캘린더</strong></a>
          </div>`;
        return;
      }
      out.innerHTML = hits
        .map(
          (p) => `
        <a class="search-result" href="${p.url}">
          <span class="eyebrow">${esc(catNames[p.category] || p.category)}</span>
          <h3>${esc(p.title)}${p.premium ? '<span class="premium-tag">멤버십</span>' : ''}</h3>
          <p>${esc(p.description)}</p>
        </a>`,
        )
        .join('');
    }

    const clearBtn = document.getElementById('search-clear');
    function updateClear() { clearBtn.style.display = input.value ? '' : 'none'; }
    clearBtn.addEventListener('click', () => { input.value = ''; out.innerHTML = ''; updateClear(); input.focus(); });

    let t;
    input.addEventListener('input', () => {
      clearTimeout(t);
      updateClear();
      t = setTimeout(() => render(input.value), 120);
    });
  </script>
</BaseLayout>
