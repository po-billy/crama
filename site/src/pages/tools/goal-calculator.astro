---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="목표금액 달성 계산기" description="목표 금액과 기간, 수익률, 현재 보유금을 입력하면 매달 얼마를 모아야 하는지 역산해 드립니다.">
  <div class="wrap">
    <header class="page-hero">
      <span class="eyebrow">계산기</span>
      <h1>목표금액 달성 계산기</h1>
      <p>목표에 도달하려면 매달 얼마를 모아야 할까요? 역산해 보세요.</p>
    </header>

    <div class="calc">
      <div class="calc__inputs">
        <div class="calc__field"><label for="g-target">목표 금액 (원)</label><input id="g-target" type="number" inputmode="numeric" value="100000000" min="0" /></div>
        <div class="calc__field"><label for="g-current">현재 보유금 (원)</label><input id="g-current" type="number" inputmode="numeric" value="10000000" min="0" /></div>
        <div class="calc__field"><label for="g-rate">연 수익률 (%)</label><input id="g-rate" type="number" value="5" step="0.1" /></div>
        <div class="calc__field"><label for="g-years">목표 기간 (년)</label><input id="g-years" type="number" value="10" min="1" /></div>
      </div>
      <div class="calc__result">
        <div class="calc__result-label">매달 모아야 할 금액</div>
        <div class="calc__result-main" id="g-monthly">-</div>
        <div class="calc__row"><span>총 납입 원금</span><strong id="g-contributed">-</strong></div>
        <div class="calc__row"><span>예상 투자 수익</span><strong id="g-interest">-</strong></div>
      </div>
    </div>

    <p class="calc__note measure">* 매월 적립·월 복리를 가정한 단순 계산이며 세금·수수료·물가는 반영하지 않았습니다. 현재 보유금이 충분하면 '0원'으로 표시됩니다. 반대로 최종 금액을 구하려면 <a href="/tools/compound-calculator/">복리 계산기</a>를 이용하세요.</p>
  </div>

  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const fmt = (n) => Math.round(n).toLocaleString('ko-KR') + '원';
      const calc = () => {
        const FV = +$('g-target').value || 0;
        const P = +$('g-current').value || 0;
        const r = (+$('g-rate').value || 0) / 100 / 12;
        const n = (+$('g-years').value || 0) * 12;
        if (n === 0) return;
        const grown = P * Math.pow(1 + r, n);
        let pmt;
        if (r === 0) pmt = (FV - P) / n;
        else pmt = (FV - grown) / ((Math.pow(1 + r, n) - 1) / r);
        if (pmt < 0) pmt = 0;
        const contributed = P + pmt * n;
        $('g-monthly').textContent = fmt(pmt);
        $('g-contributed').textContent = fmt(contributed);
        $('g-interest').textContent = fmt(Math.max(0, FV - contributed));
      };
      ['g-target', 'g-current', 'g-rate', 'g-years'].forEach((id) => $(id).addEventListener('input', calc));
      calc();
    })();
  </script>
</BaseLayout>
