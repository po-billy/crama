---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DuoIcon from '../../components/DuoIcon.astro';
const groups = [
  {
    title: '지원금·정책',
    tools: [
      { href: '/tools/benefits-finder/', title: '지원금 자격 진단기', desc: '나이·가구원수·소득만 입력하면 청년미래적금·도약계좌·민생회복 소비쿠폰 등 받을 수 있는 지원을 한 번에 가늠합니다.' },
    ],
  },
  {
    title: '투자·수익',
    tools: [
      { href: '/tools/compound-calculator/', title: '복리 계산기', desc: '원금·월 적립·수익률·기간으로 복리로 불어나는 최종 금액을 계산합니다.' },
      { href: '/tools/average-price-calculator/', title: '주식 평단가 계산기', desc: '추가 매수(물타기) 시 새 평균 단가와 총 수량을 계산합니다.' },
      { href: '/tools/stock-return-calculator/', title: '주식 수익률 계산기', desc: '수수료·세금까지 반영한 실제 손익과 수익률을 계산합니다.' },
      { href: '/tools/dividend-calculator/', title: '배당금 계산기', desc: '투자금액과 배당수익률로 세후 연 배당금과 월평균을 계산합니다.' },
      { href: '/tools/rule-of-72-calculator/', title: '72의 법칙 계산기', desc: '수익률로 원금이 2배가 되기까지 걸리는 기간을 간단히 계산합니다.' },
      { href: '/tools/exchange-calculator/', title: '환율 계산기', desc: '환율을 입력해 외화↔원화를 양방향으로 환산합니다.' },
    ],
  },
  {
    title: '저축·목표',
    tools: [
      { href: '/tools/savings-calculator/', title: '적금·예금 계산기', desc: '매월 적립액과 금리로 만기 수령액과 이자를 계산합니다.' },
      { href: '/tools/deposit-interest-calculator/', title: '예금 이자(세후) 계산기', desc: '목돈 예금의 세전·세후 이자와 만기 수령액을 계산합니다.' },
      { href: '/tools/goal-calculator/', title: '목표금액 달성 계산기', desc: '목표 금액에 도달하려면 매달 얼마를 모아야 하는지 역산합니다.' },
      { href: '/tools/emergency-fund-calculator/', title: '비상금 목표 계산기', desc: '월 생활비와 개월수로 마련해야 할 비상금 규모를 계산합니다.' },
      { href: '/tools/inflation-calculator/', title: '물가상승률 계산기', desc: '물가를 반영해 미래에 필요한 금액과 현재 화폐의 미래 가치를 계산합니다.' },
    ],
  },
  {
    title: '대출·부동산',
    tools: [
      { href: '/tools/loan-calculator/', title: '대출 이자 계산기', desc: '대출금·금리·기간으로 월 상환액과 총 이자를 계산합니다(원리금균등).' },
      { href: '/tools/dsr-calculator/', title: 'DSR 계산기', desc: '연소득과 연간 원리금으로 총부채원리금상환비율(DSR)을 계산합니다.' },
      { href: '/tools/ltv-calculator/', title: '주담대 한도(LTV) 계산기', desc: '주택가격과 LTV 비율로 담보대출 가능 금액을 계산합니다.' },
      { href: '/tools/jeonse-wolse-calculator/', title: '전월세 전환 계산기', desc: '전환율로 보증금↔월세를 서로 환산합니다.' },
      { href: '/tools/pyeong-converter/', title: '평수 변환기', desc: '평과 제곱미터(㎡)를 서로 변환합니다.' },
    ],
  },
  {
    title: '급여·세금',
    tools: [
      { href: '/tools/severance-pay-calculator/', title: '퇴직금 계산기', desc: '월 평균임금과 재직기간으로 예상 퇴직금을 계산합니다.' },
      { href: '/tools/hourly-wage-calculator/', title: '시급·주휴수당 계산기', desc: '시급과 주 근로시간으로 주휴수당 포함 급여를 계산합니다.' },
      { href: '/tools/pension-tax-calculator/', title: '연금 세액공제 계산기', desc: '연금저축·IRP 납입액으로 예상 세액공제 환급액을 계산합니다.' },
      { href: '/tools/overseas-stock-tax-calculator/', title: '해외주식 양도세 계산기', desc: '양도차익에서 250만원 공제 후 양도소득세(22%)를 계산합니다.' },
      { href: '/tools/vat-calculator/', title: '부가가치세(VAT) 계산기', desc: '공급가액↔합계금액의 부가세 10%를 양방향으로 계산합니다.' },
    ],
  },
  {
    title: '노후·은퇴',
    tools: [
      { href: '/tools/retirement-calculator/', title: '노후자금 계산기', desc: '은퇴 후 월 생활비와 기간으로 필요한 노후 자금을 계산합니다.' },
      { href: '/tools/fire-calculator/', title: 'FIRE(4% 룰) 계산기', desc: '연 지출과 인출률로 경제적 자유에 필요한 목표 자산을 계산합니다.' },
    ],
  },
];
const total = groups.reduce((n, g) => n + g.tools.length, 0);
---
<BaseLayout title="금융 계산기" description="복리·대출·세금·환율·노후까지, 재테크에 바로 쓰는 무료 금융 계산기 모음. 직접 입력해 결과를 확인하세요.">
  <div class="wrap">
    <header class="page-hero">
      <span class="eyebrow">Tools</span>
      <h1>금융 계산기</h1>
      <p>재테크에 바로 쓰는 계산기 {total}종. 숫자를 입력하면 결과가 즉시 계산됩니다.</p>
    </header>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.8rem;margin:1.5rem 0 2.5rem;padding:1.5rem;background:var(--paper-2);border-radius:14px;">
      <a href="/benefits/" style="display:flex;align-items:center;gap:.6rem;padding:.8rem 1rem;border:1px solid var(--line);border-radius:10px;background:var(--paper);text-decoration:none;color:var(--ink);transition:border-color .12s;">
        <DuoIcon name="benefits" class="svc-ico" />
        <div><strong style="font-size:.88rem;">내 혜택 찾기</strong><br/><span style="font-size:.75rem;color:var(--muted);">지원금 자동 매칭</span></div>
      </a>
      <a href="/checkup/" style="display:flex;align-items:center;gap:.6rem;padding:.8rem 1rem;border:1px solid var(--line);border-radius:10px;background:var(--paper);text-decoration:none;color:var(--ink);transition:border-color .12s;">
        <DuoIcon name="checkup" class="svc-ico" />
        <div><strong style="font-size:.88rem;">재무 건강 체크업</strong><br/><span style="font-size:.75rem;color:var(--muted);">5분 종합 진단</span></div>
      </a>
      <a href="/policy-calendar/" style="display:flex;align-items:center;gap:.6rem;padding:.8rem 1rem;border:1px solid var(--line);border-radius:10px;background:var(--paper);text-decoration:none;color:var(--ink);transition:border-color .12s;">
        <DuoIcon name="calendar" class="svc-ico" />
        <div><strong style="font-size:.88rem;">정책 캘린더</strong><br/><span style="font-size:.75rem;color:var(--muted);">마감일 한눈에</span></div>
      </a>
    </div>

    {groups.map((g) => (
      <section class="tool-section">
        <h2 class="tool-section__title">{g.title}</h2>
        <div class="tool-grid">
          {g.tools.map((t) => (
            <a class="tool-card" href={t.href}>
              <h3>{t.title}</h3>
              <p>{t.desc}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <style>
    .tool-section { margin-top: 2.4rem; }
    .tool-section__title { font-size: 1.15rem; margin: 0 0 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--ink); }
    .tool-card h3 { font-size: 1.1rem; margin: 0 0 0.35rem; }
  </style>
</BaseLayout>
