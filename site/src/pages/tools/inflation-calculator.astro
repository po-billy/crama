---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="물가상승률(인플레이션) 계산기" description="물가상승률을 반영해 미래에 필요한 금액과 현재 화폐의 미래 가치를 계산합니다.">
  <div class="wrap">
    <header class="page-hero">
      <span class="eyebrow">계산기</span>
      <h1>물가상승률 계산기</h1>
      <p>지금의 돈이 미래에 얼마의 가치가 되는지 확인해 보세요.</p>
    </header>
    <div class="calc">
      <div class="calc__inputs">
        <div class="calc__field"><label for="in-amount">현재 금액 (만원)</label><input id="in-amount" type="number" value="1000" step="100" min="0" /></div>
        <div class="calc__field"><label for="in-rate">연 물가상승률 (%)</label><input id="in-rate" type="number" value="2.5" step="0.1" min="0" /></div>
        <div class="calc__field"><label for="in-years">기간 (년)</label><input id="in-years" type="number" value="10" step="1" min="0" /></div>
      </div>
      <div class="calc__result">
        <div class="calc__result-label">같은 구매력에 필요한 미래 금액</div>
        <div class="calc__result-main" id="in-future">-</div>
        <div class="calc__row"><span>현재 금액의 미래 실질가치</span><strong id="in-realvalue">-</strong></div>
        <div class="calc__row"><span>가치 하락분</span><strong id="in-loss">-</strong></div>
      </div>
    </div>
    <p class="calc__note measure">* 미래 필요금액 = 현재금액 × (1 + 물가상승률)^기간. 현금을 그대로 두면 구매력이 줄기 때문에, 인플레이션을 이기는 투자가 필요합니다. <a href="/blog/inflation-investing-guide/">인플레이션과 투자</a>를 참고하세요.</p>
  </div>
  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const won = (man) => Math.round(man).toLocaleString('ko-KR') + '만원';
      const calc = () => {
        const amount = +$('in-amount').value || 0;
        const rate = (+$('in-rate').value || 0) / 100;
        const years = +$('in-years').value || 0;
        const factor = Math.pow(1 + rate, years);
        $('in-future').textContent = amount > 0 ? won(amount * factor) : '-';
        $('in-realvalue').textContent = amount > 0 ? won(amount / factor) : '-';
        $('in-loss').textContent = amount > 0 ? won(amount - amount / factor) : '-';
      };
      ['in-amount', 'in-rate', 'in-years'].forEach((id) => $(id).addEventListener('input', calc));
      calc();
    })();
  </script>
</BaseLayout>
