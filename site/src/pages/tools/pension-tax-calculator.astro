---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="연금 세액공제 계산기" description="연금저축·IRP 납입액과 공제율을 입력하면 예상 세액공제 환급액을 간단히 계산해 드립니다.">
  <div class="wrap">
    <header class="page-hero">
      <span class="eyebrow">계산기</span>
      <h1>연금 세액공제 계산기</h1>
      <p>연금저축·IRP 납입으로 돌려받을 세액공제 환급액을 가늠해 보세요.</p>
    </header>

    <div class="calc">
      <div class="calc__inputs">
        <div class="calc__field"><label for="p-saving">연금저축 납입액 (원/연)</label><input id="p-saving" type="number" inputmode="numeric" value="6000000" min="0" /></div>
        <div class="calc__field"><label for="p-irp">IRP 납입액 (원/연)</label><input id="p-irp" type="number" inputmode="numeric" value="3000000" min="0" /></div>
        <div class="calc__field"><label for="p-limit">공제 한도 (원/연)</label><input id="p-limit" type="number" inputmode="numeric" value="9000000" min="0" /></div>
        <div class="calc__field">
          <label for="p-rate">공제율</label>
          <select id="p-rate" style="font:inherit;padding:0.7rem 0.9rem;border:1px solid var(--line);border-radius:var(--radius);background:var(--paper);color:var(--ink);">
            <option value="16.5">16.5% (총급여 5,500만 원 이하)</option>
            <option value="13.2">13.2% (총급여 5,500만 원 초과)</option>
          </select>
        </div>
      </div>
      <div class="calc__result">
        <div class="calc__result-label">예상 세액공제 환급액</div>
        <div class="calc__result-main" id="p-refund">-</div>
        <div class="calc__row"><span>총 납입액</span><strong id="p-total">-</strong></div>
        <div class="calc__row"><span>공제 적용 금액</span><strong id="p-applied">-</strong></div>
      </div>
    </div>

    <p class="calc__note measure">* 공제 한도·공제율은 연도와 제도 변경에 따라 달라질 수 있어, 한도를 직접 입력하도록 했습니다. 위 값은 참고용 추정치이며 실제 환급액은 개인 상황에 따라 다릅니다. 정확한 기준은 국세청 안내를 확인하세요. 개념은 <a href="/blog/pension-irp-tax-guide/">연금저축·IRP 세액공제</a>에서 다룹니다.</p>
  </div>

  <script is:inline>
    (() => {
      const $ = (id) => document.getElementById(id);
      const won = (n) => Math.round(n).toLocaleString('ko-KR') + '원';
      const calc = () => {
        const saving = +$('p-saving').value || 0;
        const irp = +$('p-irp').value || 0;
        const limit = +$('p-limit').value || 0;
        const rate = (+$('p-rate').value || 0) / 100;
        const total = saving + irp;
        const applied = Math.min(total, limit);
        const refund = applied * rate;
        $('p-refund').textContent = won(refund);
        $('p-total').textContent = won(total);
        $('p-applied').textContent = won(applied);
      };
      ['p-saving', 'p-irp', 'p-limit'].forEach((id) => $(id).addEventListener('input', calc));
      $('p-rate').addEventListener('change', calc);
      calc();
    })();
  </script>
</BaseLayout>
