---
import BaseLayout from '../layouts/BaseLayout.astro';

// 2026년 기준(이직일 2026-01-01 이후): 1일 상한 68,100원 · 하한 66,048원(최저시급 10,320×80%×8h)
const CAP = 68100, FLOOR = 66048;
const fmt = (n: number) => Math.round(n).toLocaleString('ko-KR');
// 소정급여일수(2019.10 개정): 가입기간 × 연령(50세 미만 / 50세 이상·장애인)
const DAYS = [
  { label: '1년 미만', u50: 120, o50: 120 },
  { label: '1년 ~ 3년', u50: 150, o50: 180 },
  { label: '3년 ~ 5년', u50: 180, o50: 210 },
  { label: '5년 ~ 10년', u50: 210, o50: 240 },
  { label: '10년 이상', u50: 240, o50: 270 },
];
---
<BaseLayout
  title="실업급여 계산기 2026 — 하루 얼마, 총 얼마?"
  description={`2026년 실업급여(구직급여) 계산: 1일 상한 ${fmt(CAP)}원·하한 ${fmt(FLOOR)}원. 나이·고용보험 가입기간·월급만 넣으면 일액과 총 수령액을 바로 계산합니다.`}
>
  <div class="wrap ub">
    <header class="page-hero">
      <span class="eyebrow">Unemployment</span>
      <h1>실업급여 계산기 <span class="ub-y">2026</span></h1>
      <p>퇴사 전 <b>월급·나이·고용보험 가입기간</b>만 넣으세요. 하루 얼마, 며칠, 총 얼마 받는지 바로 나옵니다.</p>
      <p class="ub-basis">2026년 1월 1일 이후 이직 기준 · 1일 상한 {fmt(CAP)}원 / 하한 {fmt(FLOOR)}원</p>
    </header>

    <div class="ub-form">
      <label>퇴사 직전 월급(세전)
        <div class="ub-in"><input id="ub-pay" type="number" inputmode="numeric" placeholder="예: 300" min="50" max="3000" /><span>만원</span></div>
      </label>
      <label>만 나이
        <div class="ub-in"><input id="ub-age" type="number" inputmode="numeric" placeholder="예: 32" min="15" max="80" /><span>세</span></div>
      </label>
      <label>고용보험 가입기간
        <select id="ub-term">
          <option value="0">1년 미만</option>
          <option value="1" selected>1년 ~ 3년</option>
          <option value="2">3년 ~ 5년</option>
          <option value="3">5년 ~ 10년</option>
          <option value="4">10년 이상</option>
        </select>
      </label>
      <button type="button" id="ub-go">계산하기</button>
    </div>

    <div class="ub-result" id="ub-result" hidden>
      <div class="ub-hero">
        <div><span>1일 구직급여</span><b id="ub-daily">-</b></div>
        <div class="ub-hero__main"><span>총 수령 예상액</span><b id="ub-total">-</b><em id="ub-days">-</em></div>
        <div><span>월 환산(30일)</span><b id="ub-monthly">-</b></div>
      </div>
      <p class="ub-note" id="ub-explain"></p>
      <button type="button" class="ub-reg" id="ub-reg" hidden>나이·연봉을 내 정보로 저장 → 다른 계산기도 자동 입력</button>
    </div>

    <section class="ub-sec">
      <h2>소정급여일수 표 (며칠 받나)</h2>
      <table class="ub-table">
        <thead><tr><th>고용보험 가입기간</th><th>50세 미만</th><th>50세 이상·장애인</th></tr></thead>
        <tbody>
          {DAYS.map((d) => (
            <tr><th>{d.label}</th><td>{d.u50}일</td><td>{d.o50}일</td></tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="ub-sec">
      <h2>계산 방식과 조건</h2>
      <ul class="ub-list">
        <li><b>1일 금액</b> = 퇴직 전 3개월 평균임금의 60% (상한 {fmt(CAP)}원, 하한 {fmt(FLOOR)}원 — 월급 약 335만원 이하면 대부분 하한 적용)</li>
        <li><b>수급 조건</b>: 이직 전 18개월 중 고용보험 180일 이상 + 비자발적 퇴사(권고사직·계약만료 등). 자발적 퇴사도 임금체불·괴롭힘 등 정당한 사유면 인정</li>
        <li><b>신청</b>: 퇴사 후 워크넷 구직등록 → 고용센터 수급자격 신청 → 실업인정(구직활동)마다 지급. 퇴직 후 12개월 지나면 남은 일수가 있어도 소멸 — 빨리 신청하세요</li>
      </ul>
      <p class="ub-note">※ 간이 계산입니다. 정확한 금액은 <a href="https://eiac.ei.go.kr/" target="_blank" rel="noopener">고용보험 모의계산</a>에서 확인하세요.</p>
    </section>

    <div class="ub-cross">
      <a href="/benefits/">실직하면 받을 수 있는 지원금 더 찾기 →</a>
      <a href="/severance/">퇴직금 계산표 →</a>
      <a href="/salary/">연봉 실수령액 →</a>
    </div>
  </div>

  <script is:inline>
    (() => {
      const CAP = 68100, FLOOR = 66048;
      const DAYS = [[120,120],[150,180],[180,210],[210,240],[240,270]];
      const $ = (id) => document.getElementById(id);
      const fmt = (n) => Math.round(n).toLocaleString('ko-KR');
      function calc() {
        const pay = Number($('ub-pay').value) * 10000;
        const age = Number($('ub-age').value);
        const t = Number($('ub-term').value);
        if (!pay || !age) return;
        const avgDaily = (pay * 3) / 91;                 // 3개월 평균임금(약식)
        const daily = Math.min(CAP, Math.max(FLOOR, avgDaily * 0.6));
        const days = DAYS[t][age >= 50 ? 1 : 0];
        $('ub-daily').textContent = fmt(daily) + '원';
        $('ub-days').textContent = days + '일 지급';
        $('ub-total').textContent = fmt(daily * days) + '원';
        $('ub-monthly').textContent = fmt(daily * 30) + '원';
        $('ub-explain').textContent = daily === FLOOR
          ? '평균임금의 60%가 하한액보다 낮아 하한액(' + fmt(FLOOR) + '원)이 적용됩니다.'
          : daily === CAP
            ? '평균임금의 60%가 상한액을 넘어 상한액(' + fmt(CAP) + '원)이 적용됩니다.'
            : '퇴직 전 3개월 평균임금의 60%가 적용됩니다.';
        $('ub-result').hidden = false;
      }
      $('ub-go').addEventListener('click', calc);
      ['ub-pay', 'ub-age'].forEach((id) => $(id).addEventListener('keydown', (e) => { if (e.key === 'Enter') calc(); }));

      // 프로필 사이클: 등록된 나이·연봉 프리필, 계산 후 '내 정보로 저장'
      const P = window.CramaProfile;
      if (P) {
        const d = P.get();
        if (d.age) $('ub-age').value = d.age;
        if (d.salary) $('ub-pay').value = Math.round(d.salary / 12);
        if (d.age && d.salary) calc();
        const btn = $('ub-reg');
        const sync = () => { const dd = P.get(); btn.hidden = false; btn.textContent = (dd.age && dd.salary) ? '내 정보 업데이트' : '나이·연봉을 내 정보로 저장 → 다른 계산기도 자동 입력'; };
        $('ub-go').addEventListener('click', sync);
        if (d.age || d.salary) sync();
        btn.addEventListener('click', () => {
          const patch = {};
          const age = Number($('ub-age').value); if (age) patch.age = age;
          const pay = Number($('ub-pay').value); if (pay) patch.salary = pay * 12;
          if (P.set(patch)) { btn.textContent = '저장됐어요 — /me에서 관리'; setTimeout(sync, 2500); }
        });
      }
    })();
  </script>

  <style>
    .ub { max-width: 42rem; }
    .ub-y { color: var(--accent); }
    .page-hero .ub-basis { font-size: 0.82rem; color: var(--muted); margin-top: 0.5rem; }
    .ub-form { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin: 1.4rem 0 1rem; padding: 1.1rem 1.2rem; border: 1px solid var(--line); border-radius: 14px; background: var(--paper-2); }
    .ub-form label { font-size: 0.84rem; font-weight: 700; color: var(--ink-soft); display: flex; flex-direction: column; gap: 0.35rem; }
    .ub-in { display: flex; align-items: center; gap: 0.4rem; }
    .ub-in input { flex: 1; min-width: 0; font: inherit; font-size: 1rem; padding: 0.6rem 0.8rem; border: 1px solid var(--line); border-radius: 10px; background: var(--paper); color: var(--ink); }
    .ub-in span { color: var(--muted); font-size: 0.85rem; font-weight: 500; }
    .ub-form select { font: inherit; font-size: 0.95rem; padding: 0.6rem 0.8rem; border: 1px solid var(--line); border-radius: 10px; background: var(--paper); color: var(--ink); }
    .ub-form input:focus, .ub-form select:focus { outline: none; border-color: var(--accent); }
    .ub-form button { grid-column: 1 / -1; font: inherit; font-weight: 800; font-size: 1rem; padding: 0.8rem; border: 0; border-radius: 12px; background: var(--accent); color: #fff; cursor: pointer; }
    @media (max-width: 560px) { .ub-form { grid-template-columns: 1fr; } }
    .ub-result[hidden] { display: none; }
    .ub-reg { display: block; margin-top: 0.7rem; font: inherit; font-size: 0.85rem; font-weight: 700; color: var(--accent); background: var(--accent-soft); border: 1px dashed var(--accent); border-radius: 10px; padding: 0.6rem 1rem; cursor: pointer; width: 100%; }
    .ub-reg[hidden] { display: none; }
    .ub-hero { display: grid; grid-template-columns: 1fr 1.3fr 1fr; gap: 0.6rem; margin-bottom: 0.6rem; }
    .ub-hero > div { border: 1px solid var(--line); border-radius: 14px; padding: 0.95rem 1rem; background: var(--paper); display: flex; flex-direction: column; gap: 0.15rem; }
    .ub-hero span { font-size: 0.76rem; color: var(--muted); font-weight: 600; }
    .ub-hero b { font-size: 1.1rem; }
    .ub-hero__main { background: var(--accent) !important; border-color: var(--accent) !important; color: #fff; }
    .ub-hero__main span { color: rgba(255,255,255,0.85); }
    .ub-hero__main b { font-size: 1.3rem; }
    .ub-hero__main em { font-style: normal; font-size: 0.78rem; opacity: 0.9; }
    @media (max-width: 560px) { .ub-hero { grid-template-columns: 1fr; } }
    .ub-sec { margin: 1.8rem 0; }
    .ub-sec h2 { font-size: 1.1rem; margin: 0 0 0.7rem; }
    .ub-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
    .ub-table thead th { font-size: 0.76rem; color: var(--muted); text-align: left; padding: 0.45rem 0.7rem; border-bottom: 2px solid var(--line); }
    .ub-table tbody th, .ub-table tbody td { padding: 0.55rem 0.7rem; border-bottom: 1px solid var(--line); text-align: left; font-variant-numeric: tabular-nums; }
    .ub-table tbody td { font-weight: 600; }
    .ub-list { margin: 0; padding-left: 1.1rem; display: grid; gap: 0.55rem; font-size: 0.92rem; line-height: 1.6; color: var(--ink-soft); }
    .ub-note { font-size: 0.8rem; color: var(--muted); margin: 0.7rem 0 0; }
    .ub-note a { color: var(--accent); }
    .ub-cross { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; margin: 2rem 0 1rem; padding-top: 1.4rem; border-top: 1px solid var(--line); }
    .ub-cross a { font-size: 0.88rem; font-weight: 700; color: var(--accent); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid var(--line); border-radius: 999px; }
    .ub-cross a:hover { border-color: var(--accent); }
  </style>
</BaseLayout>
