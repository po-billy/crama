---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/app.css';
import { fetchActivePolls } from '../lib/polls-build.js';
const polls = await fetchActivePolls();
---

<BaseLayout title="오늘의 투표 — Crama" description="지금 화제인 이슈, 배경부터 읽고 한 표">
  <div class="app">
    <header class="vhead">
      <span class="vhead__eyebrow">CRAMA VOTE</span>
      <h1>오늘의 투표</h1>
      <p class="app__sub" style="margin-top:.4rem">지금 화제인 이슈, 배경부터 읽고 한 표 던지기 — 참여하면 <strong style="color:var(--accent)">밀웜 +3</strong></p>
    </header>

    {polls.length === 0 ? (
      <p class="app__sub">진행 중인 투표가 없어요. 매일 새 투표가 올라와요 👀</p>
    ) : (
      <div class="vlist">
        {polls.map((p: any, i: number) => (
          <a class="vcard" href={`/vote/${p.id}/`}>
            <span class="vcard__no">{String(i + 1).padStart(2, '0')}</span>
            <div class="vcard__main">
              <span class="vcard__emoji">{p.emoji || '🗳️'}</span>
              <h2 class="vcard__q">{p.question}</h2>
              {p.teaser && <p class="vcard__teaser">{p.teaser}</p>}
              <span class="vcard__go">배경 읽고 투표하기 →</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
