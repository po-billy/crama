---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/app.css';
import { fetchActivePolls } from '../lib/polls-build.js';
const polls = await fetchActivePolls();
const featured = polls[0];
const past = polls.slice(1);
---

<BaseLayout title="빼꼼 투표 — Crama" description="요즘 뜨거운 그 이슈, 크라미와 함께 한 표로 의견을 모아요">
  <div class="votewrap">
    <header class="vphead">
      <h1>빼꼼 투표</h1>
      <p>요즘 뜨거운 그 이슈, 크라미와 함께 한 표로 의견을 모아요. 참여하면 <strong>밀웜 +3</strong> 🐛</p>
    </header>

    {!featured ? (
      <p class="app__sub">진행 중인 투표가 없어요. 매일 새 투표가 올라와요 👀</p>
    ) : (
      <>
        <a class="vfeat" href={`/vote/${featured.id}/`}>
          <div class="vfeat__top">
            <span class="vbadge vbadge--live"><i></i> 투표 진행 중</span>
            <div class="vfeat__act">
              <span class="vfeat__count" data-count-live={featured.id}>참여 집계 중…</span>
              <span class="vfeat__btn">배경 읽고 투표하기</span>
            </div>
          </div>
          <h2 class="vfeat__q">{featured.emoji ? featured.emoji + ' ' : ''}{featured.question}</h2>
          <div class="vfeat__line"></div>
          <p class="vfeat__excerpt" data-excerpt={featured.id}>{featured.teaser}</p>
        </a>

        {past.length > 0 && (
          <section class="vpast">
            <h2 class="vpast__h">지난 투표</h2>
            <div class="vgrid">
              {past.map((p: any) => (
                <a class="vpcard" href={`/vote/${p.id}/`}>
                  <div class="vpcard__cover">
                    {p.image ? <img src={p.image} alt="" loading="lazy" /> : <span class="vpcard__coveremoji">{p.emoji || '🗳️'}</span>}
                  </div>
                  <h3 class="vpcard__q">{p.emoji ? p.emoji + ' ' : ''}{p.question}</h3>
                  {p.teaser && <p class="vpcard__teaser">{p.teaser}</p>}
                  <span class="vpcard__count" data-count={p.id}></span>
                </a>
              ))}
            </div>
          </section>
        )}
      </>
    )}
  </div>
</BaseLayout>

<script>
  import { getPollResults, getOpinions } from '../lib/api';
  const esc = (s: string) => s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!));

  // 진행 중 카드 참여수 — 'N명 참여 중'
  document.querySelectorAll('[data-count-live]').forEach(async (el) => {
    const id = Number(el.getAttribute('data-count-live'));
    try {
      const r = await getPollResults(id);
      const t = (r && (r as any).total) || 0;
      el.textContent = t > 0 ? `${t.toLocaleString()}명 참여 중` : '아직 참여 전';
    } catch (e) {}
  });

  // 지난 투표 참여수 — 'N명 참여했어요'
  document.querySelectorAll('[data-count]').forEach(async (el) => {
    const id = Number(el.getAttribute('data-count'));
    try {
      const r = await getPollResults(id);
      const t = (r && (r as any).total) || 0;
      el.textContent = t > 0 ? `${t.toLocaleString()}명 참여했어요` : '참여를 기다려요';
    } catch (e) {}
  });

  // 진행 중 카드의 의견 한 줄(있으면 teaser 대체)
  (async () => {
    const ex = document.querySelector('[data-excerpt]');
    if (!ex) return;
    const id = Number(ex.getAttribute('data-excerpt'));
    try {
      const ops = await getOpinions(id);
      if (ops && ops.length) {
        const o = ops[0];
        ex.innerHTML = `${esc(o.text)} <span class="vfeat__by">by ${esc(o.nickname || '크라미')}</span>`;
      }
    } catch (e) {}
  })();
</script>
