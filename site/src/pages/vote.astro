---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/app.css';
import { fetchActivePolls } from '../lib/polls-build.js';
const polls = await fetchActivePolls();
const featured = polls[0];
const past = polls.slice(1);
---

<BaseLayout title="오늘의 투표 — Crama" description="지금 화제인 이슈, 배경부터 읽고 한 표">
  <div class="app">
    <header class="vhead">
      <span class="vhead__eyebrow">오늘의 여론 🦫</span>
      <h1>빼꼼 투표</h1>
      <p class="app__sub" style="margin-top:.4rem">지금 화제인 이슈에 한 표 — 표를 많이 받은 쪽 크라미가 구멍에서 <strong style="color:var(--accent)">빼꼼!</strong> 참여하면 <strong style="color:var(--accent)">밀웜 +3</strong></p>
    </header>

    {!featured ? (
      <p class="app__sub">진행 중인 투표가 없어요. 매일 새 투표가 올라와요 👀</p>
    ) : (
      <>
        <a class="vfeat" href={`/vote/${featured.id}/`}>
          <div class="vfeat__bar">
            <span class="vbadge vbadge--live"><i></i> 투표 진행 중</span>
            <span class="vfeat__count" data-count={featured.id}></span>
          </div>
          <h2 class="vfeat__q">{featured.question} <span class="vfeat__emoji">{featured.emoji || '🗳️'}</span></h2>
          {featured.teaser && <p class="vfeat__teaser">{featured.teaser}</p>}
          <span class="vfeat__cta">배경 읽고 투표하기 →</span>
        </a>

        {past.length > 0 && (
          <section class="vpast">
            <h2 class="vpast__h">지난 투표</h2>
            <div class="vgrid">
              {past.map((p: any) => (
                <a class="vpcard" href={`/vote/${p.id}/`}>
                  <div class="vpcard__bar">
                    <span class="vpcard__count" data-count={p.id}></span>
                  </div>
                  <h3 class="vpcard__q">{p.question} <span class="vpcard__emoji">{p.emoji || '🗳️'}</span></h3>
                  {p.teaser && <p class="vpcard__teaser">{p.teaser}</p>}
                  <span class="vpcard__go">결과 보기 →</span>
                </a>
              ))}
            </div>
          </section>
        )}
      </>
    )}
  </div>
</BaseLayout>

<script>
  // 참여 수 라이브 채우기(있을 때만) — 진행중/지난 구분감 강화
  import { getPollResults } from '../lib/api';
  document.querySelectorAll('[data-count]').forEach(async (el) => {
    const id = Number(el.getAttribute('data-count'));
    try {
      const r = await getPollResults(id);
      const t = (r && (r as any).total) || 0;
      if (t > 0) el.textContent = `${t.toLocaleString()}명 참여`;
    } catch (e) {}
  });
</script>
