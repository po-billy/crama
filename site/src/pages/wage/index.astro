---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { wageAmounts } from './[hourly].astro';

const MIN_WAGE = 10320;
const list = wageAmounts();
const fmt = (n: number) => Math.round(n).toLocaleString('ko-KR');
---
<BaseLayout
  title="시급 → 월급 환산표 2026 — 주휴수당 포함"
  description={`2026 최저시급 ${fmt(MIN_WAGE)}원부터 시급 25,000원까지, 주휴수당 포함 월급·연봉 환산을 한 표로. 주 40시간·월 209시간 기준.`}
>
  <div class="wrap wgx">
    <header class="page-hero">
      <span class="eyebrow">Wage</span>
      <h1>시급 → 월급 환산표 <span class="wgx-y">2026</span></h1>
      <p><b>2026 최저시급 {fmt(MIN_WAGE)}원</b> 기준, 주휴수당 포함 월급과 연봉 환산을 확인하세요. (주 40시간 · 월 209시간)</p>
    </header>

    <table class="wgx-table">
      <thead><tr><th>시급</th><th>월급 (주휴 포함)</th><th>연봉 환산</th><th></th></tr></thead>
      <tbody>
        {list.map((w) => (
          <tr class={w === MIN_WAGE ? 'is-min' : ''}>
            <th><a href={`/wage/${w}/`}>{fmt(w)}원{w === MIN_WAGE ? ' (최저)' : ''}</a></th>
            <td>{fmt(w * 209)}원</td>
            <td>{fmt(w * 209 * 12)}원</td>
            <td><a href={`/wage/${w}/`}>상세 →</a></td>
          </tr>
        ))}
      </tbody>
    </table>

    <div class="wgx-cross">
      <a href="/tools/hourly-wage-calculator/">내 근무시간으로 계산 →</a>
      <a href="/salary/">연봉 실수령액 표 →</a>
      <a href="/benefits/">받을 수 있는 지원금 →</a>
    </div>
  </div>

  <style>
    .wgx { max-width: 40rem; }
    .wgx-y { color: var(--accent); }
    .wgx-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; margin-top: 1.2rem; }
    .wgx-table thead th { font-size: 0.78rem; color: var(--muted); text-align: left; padding: 0.5rem 0.7rem; border-bottom: 2px solid var(--line); }
    .wgx-table tbody th, .wgx-table tbody td { padding: 0.55rem 0.7rem; border-bottom: 1px solid var(--line); text-align: left; font-variant-numeric: tabular-nums; }
    .wgx-table tbody th a { color: var(--ink); font-weight: 700; text-decoration: none; }
    .wgx-table tbody th a:hover { color: var(--accent); }
    .wgx-table td:last-child a { font-size: 0.8rem; color: var(--muted); text-decoration: none; }
    .is-min th, .is-min td { background: var(--accent-soft); }
    .is-min th a { color: var(--accent); }
    .wgx-cross { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; margin: 2rem 0 1rem; padding-top: 1.4rem; border-top: 1px solid var(--line); }
    .wgx-cross a { font-size: 0.88rem; font-weight: 700; color: var(--accent); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid var(--line); border-radius: 999px; }
    .wgx-cross a:hover { border-color: var(--accent); }
  </style>
</BaseLayout>
