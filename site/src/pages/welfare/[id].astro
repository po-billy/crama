---
import BaseLayout from '../../layouts/BaseLayout.astro';
import welfare from '../../data/welfare-services.json';

export async function getStaticPaths() {
  return (welfare.services || []).map((s: any) => ({ params: { id: s.id }, props: { s } }));
}

const { s } = Astro.props;
const generatedAt: string = welfare.generatedAt || '';
const all = (welfare.services || []) as any[];
const themes = (welfare.themes || []) as string[];

const PALETTE = ['#3b82f6', '#10b981', '#f59e0b', '#6366f1', '#14b8a6', '#8b5cf6', '#ec4899', '#f97316', '#22c55e', '#ef4444', '#06b6d4', '#64748b', '#f43f5e', '#a855f7'];
const color = PALETTE[Math.max(0, themes.indexOf(s.theme)) % PALETTE.length] || '#6c5ce7';

// 관련 복지 — 같은 관심주제에서 6개
const related = all.filter((x) => x.theme === s.theme && x.id !== s.id).slice(0, 6);

const pageTitle = `${s.name} — 복지 서비스`;
const pageDesc = (s.summary || `${s.theme} 분야 복지 서비스. 지원 대상·내용·신청 방법을 확인하세요.`).slice(0, 150);

// 상세조회 증분 보강(rich) — 있으면 섹션으로, 없으면 개요만
const rich = s.rich || {};
const sections = [
  { title: '어떤 지원인가요?', body: rich.outline || s.detail || s.summary },
  { title: '지원 대상', body: rich.target },
  { title: '선정 기준', body: rich.criteria },
  { title: '지원 내용', body: rich.benefit },
].filter((x) => x.body && x.body.length > 2);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'GovernmentService',
      name: s.name,
      description: pageDesc,
      serviceType: s.theme || '복지',
      provider: { '@type': 'GovernmentOrganization', name: s.ministry || '대한민국 정부' },
      url: `https://crama.app/welfare/${s.id}/`,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '홈', item: 'https://crama.app/' },
        { '@type': 'ListItem', position: 2, name: '복지 서비스', item: 'https://crama.app/welfare/' },
        { '@type': 'ListItem', position: 3, name: s.name },
      ],
    },
  ],
};
---
<BaseLayout title={pageTitle} description={pageDesc} jsonLd={jsonLd}>
  <div class="wrap wfd">
    <nav class="wfd-crumb" aria-label="브레드크럼">
      <a href="/">홈</a><span>›</span><a href="/welfare/">복지 서비스</a><span>›</span><b>{s.theme || '복지'}</b>
    </nav>

    <header class="wfd-head">
      <div class="wfd-head__meta">
        <span class="wfd-theme" style={`--c:${color}`}>{s.theme || '복지'}</span>
        {s.online && <span class="wfd-online">온라인 신청 가능</span>}
        {s.cycle && <span class="wfd-chip">지원주기 {s.cycle}</span>}
        {s.ptype && <span class="wfd-chip">{s.ptype}</span>}
      </div>
      <h1>{s.name}</h1>
      <div class="wfd-actions">
        {s.url
          ? <a class="wfd-apply" href={s.url} target="_blank" rel="noopener">복지로에서 자세히·신청 →</a>
          : <a class="wfd-apply" href="https://www.bokjiro.go.kr/" target="_blank" rel="noopener">복지로에서 확인하기 →</a>}
        <button type="button" class="wfd-save" id="wfd-save" aria-pressed="false" data-id={s.id} data-name={s.name} data-theme={s.theme || '복지'}>
          <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span id="wfd-save-label">관심 저장</span>
        </button>
      </div>
    </header>

    <div class="wfd-body">
      {sections.map((x) => (
        <section class="wfd-sec">
          <h2>{x.title}</h2>
          <p>{x.body}</p>
        </section>
      ))}

      <section class="wfd-sec">
        <h2>기관·문의</h2>
        <dl class="wfd-org">
          {s.ministry && <><dt>소관 부처</dt><dd>{s.ministry}</dd></>}
          {s.cycle && <><dt>지원 주기</dt><dd>{s.cycle}</dd></>}
          {s.ptype && <><dt>제공 유형</dt><dd>{s.ptype}</dd></>}
          {s.tel && <><dt>문의</dt><dd><a href={`tel:${s.tel.replace(/[^0-9-]/g, '')}`}>{s.tel}</a></dd></>}
          <><dt>신청</dt><dd>{s.online ? '온라인(복지로) 신청 가능' : '방문·기관별 신청(복지로에서 확인)'}</dd></>
        </dl>
      </section>

      <p class="wfd-fresh">기준일 {generatedAt} · 출처 <a href="https://www.bokjiro.go.kr/" target="_blank" rel="noopener">복지로·보건복지부</a> · 내용은 변경될 수 있으니 신청 전 꼭 확인하세요.</p>
    </div>

    {related.length > 0 && (
      <section class="wfd-rel">
        <h2>{s.theme || '복지'} 분야, 이런 지원도 있어요</h2>
        <div class="wfd-rel__grid">
          {related.map((r) => (
            <a class="wfd-rel__card" href={`/welfare/${r.id}/`}>
              <span class="wfd-rel__theme" style={`--c:${color}`}>{r.ministry || r.theme}</span>
              <strong>{r.name}</strong>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="wfd-cross">
      <a href="/welfare/">복지 서비스 5,000+ 전체 보기 →</a>
      <a href="/benefits/">내 혜택 찾기 →</a>
      <a href="/saved-picks/">내 관심함 →</a>
    </div>
  </div>

  <script is:inline>
    (() => {
      const btn = document.getElementById('wfd-save');
      const S = window.CramaSaved;
      if (!btn || !S) return;
      const label = document.getElementById('wfd-save-label');
      const rec = { type: 'welfare', id: btn.dataset.id, name: btn.dataset.name, url: location.pathname, sub: btn.dataset.theme };
      const sync = (on) => { btn.classList.toggle('is-on', on); btn.setAttribute('aria-pressed', on ? 'true' : 'false'); label.textContent = on ? '저장됨' : '관심 저장'; };
      sync(S.has('welfare', rec.id));
      btn.addEventListener('click', () => sync(S.toggle(rec)));
    })();
  </script>

  <style>
    .wfd { max-width: 46rem; }
    .wfd-crumb { display: flex; align-items: center; gap: 0.45rem; font-size: 0.8rem; color: var(--muted); margin: 0.4rem 0 1.2rem; flex-wrap: wrap; }
    .wfd-crumb a { color: var(--muted); text-decoration: none; }
    .wfd-crumb a:hover { color: var(--accent); }
    .wfd-crumb b { color: var(--ink-soft); font-weight: 600; }

    .wfd-head__meta { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-bottom: 0.7rem; }
    .wfd-theme { font-size: 0.75rem; font-weight: 800; color: var(--c, var(--accent)); background: color-mix(in srgb, var(--c, var(--accent)) 12%, var(--paper)); padding: 0.25rem 0.65rem; border-radius: 999px; }
    .wfd-online { font-size: 0.75rem; font-weight: 700; color: #16a34a; background: color-mix(in srgb, #22c55e 14%, var(--paper)); padding: 0.25rem 0.65rem; border-radius: 999px; }
    .wfd-chip { font-size: 0.75rem; font-weight: 700; color: var(--ink-soft); background: var(--paper-2); padding: 0.25rem 0.65rem; border-radius: 999px; }
    .wfd-head h1 { font-family: var(--font-serif); font-size: clamp(1.45rem, 4vw, 2rem); line-height: 1.3; margin: 0 0 0.9rem; }
    .wfd-actions { display: flex; flex-wrap: wrap; gap: 0.6rem; align-items: center; margin-bottom: 1.6rem; }
    .wfd-apply { display: inline-flex; align-items: center; padding: 0.75rem 1.4rem; background: var(--accent); color: #fff; font-weight: 700; font-size: 0.95rem; text-decoration: none; border-radius: 12px; transition: filter 0.12s; }
    .wfd-apply:hover { filter: brightness(1.1); }
    .wfd-save { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.72rem 1.1rem; border: 1px solid var(--line); border-radius: 12px; background: var(--paper); font: inherit; font-size: 0.9rem; font-weight: 700; color: var(--ink-soft); cursor: pointer; transition: all 0.12s; }
    .wfd-save:hover { border-color: #e11d48; color: #e11d48; }
    .wfd-save.is-on { color: #e11d48; border-color: #e11d48; }
    .wfd-save.is-on svg { fill: #e11d48; }

    .wfd-body { border-top: 1px solid var(--line); padding-top: 1.4rem; }
    .wfd-sec { margin-bottom: 1.5rem; }
    .wfd-sec h2 { font-size: 1.08rem; margin: 0 0 0.5rem; }
    .wfd-sec p { font-size: 0.95rem; line-height: 1.7; color: var(--ink-soft); margin: 0; white-space: pre-line; }
    .wfd-org { display: grid; grid-template-columns: 6rem 1fr; gap: 0.4rem 0.8rem; margin: 0; font-size: 0.92rem; }
    .wfd-org dt { color: var(--muted); font-weight: 600; }
    .wfd-org dd { margin: 0; color: var(--ink-soft); }
    .wfd-org a { color: var(--accent); text-decoration: none; }
    .wfd-fresh { font-size: 0.8rem; color: var(--muted); border-top: 1px dashed var(--line); padding-top: 1rem; margin: 1.6rem 0 0; }
    .wfd-fresh a { color: var(--accent); }

    .wfd-rel { margin-top: 2.4rem; }
    .wfd-rel h2 { font-size: 1.12rem; margin: 0 0 0.9rem; }
    .wfd-rel__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr)); gap: 0.7rem; }
    .wfd-rel__card { display: flex; flex-direction: column; gap: 0.3rem; padding: 0.95rem 1.05rem; border: 1px solid var(--line); border-radius: 12px; background: var(--paper); text-decoration: none; color: var(--ink); transition: transform 0.12s, border-color 0.12s; }
    .wfd-rel__card:hover { transform: translateY(-2px); border-color: var(--c, var(--accent)); }
    .wfd-rel__theme { font-size: 0.68rem; font-weight: 800; color: var(--c, var(--accent)); }
    .wfd-rel__card strong { font-size: 0.9rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    .wfd-cross { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; margin: 2.4rem 0 1rem; padding-top: 1.5rem; border-top: 1px solid var(--line); }
    .wfd-cross a { font-size: 0.88rem; font-weight: 700; color: var(--accent); text-decoration: none; padding: 0.5rem 1rem; border: 1px solid var(--line); border-radius: 999px; }
    .wfd-cross a:hover { border-color: var(--accent); }
  </style>
</BaseLayout>
