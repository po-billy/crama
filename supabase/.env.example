# Crama DB 관리/마이그레이션 전용 시크릿 (CLI·스크립트용)
# ⚠️ 절대 앱(.env)에 넣지 말 것 — 여기 값은 클라이언트에 번들되지 않음.
# 이 파일을 복사해 supabase/.env 로 만들고 값을 채우세요. (git에 안 올라감)

SUPABASE_PROJECT_REF=dqwzqirrzelzfngyrcmw

# 데이터베이스 비밀번호 (Project Settings → Database → Database password)
# supabase db push / psql 직접 연결에 사용
SUPABASE_DB_PASSWORD=

# service_role 키 (Project Settings → API) — 관리용 데이터 작업/시드에 사용
SUPABASE_SERVICE_ROLE_KEY=

# (선택) CLI 로그인 토큰 (supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=
